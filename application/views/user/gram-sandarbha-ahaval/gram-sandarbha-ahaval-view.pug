	style.
		.error {
			color:red !important;
			font-style:italic !important;
			font-weight:700 !important;
		}
		.bg-warning{
			background-color:#f0d688 !important;
		}
		body{
			
			height:100vh;
		}
		@media (min-width: 576px) {
			.modal-dialog { max-width: none; }
		}

		.modal-dialog {
			width: 98%;
			height: 92%;
			padding: 0;
		}
body
	include ../include/navs.pug
	.mt-2.mb-3.text-center
		h1.heading-1 ग्राम कर संदर्भ अहवाल

	.container
		.d-flex.justify-content-end
			a.btn.btn-success.text-light(href='/gram-sandarbha-ahaval/gram-sandarbha-ahaval-form-view')
				i.fa.fa-plus &nbsp; नवीन अहवाल भरा

		each ahaval, index in gramSandarbhaAhavalList
			.d-flex
				p #{index}
				button.btn.btn-danger(class='deleteGramAhavalBtn' data-id=ahaval.id) delete
				a.btn.btn-success(href=`/gram-sandarbha-ahaval/gram-sandarbha-ahaval-form-view?id=${ahaval.id}&isEdit=${true}`) Edit



	