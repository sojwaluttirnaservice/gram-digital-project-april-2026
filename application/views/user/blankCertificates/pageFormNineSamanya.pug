doctype html
head
  title नमुना ९ सामान्य blank print
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  meta(http-equiv='X-UA-Compatible' content='ie=edge')
  // common css
  style.
    @page { 
      size: landscape;
      margin: 5mm 5mm 5mm 5mm;
      -webkit-print-color-adjust: exact; 
    }
    .m-bottom {
      margin: 5mm 5mm 5mm 5mm !important;
    }

    .abs{
      position: absolute;
      z-index: 100;
    }
body
  .row.m-bottom.relative
    img(src="/print/1.jpg" width="100%" height="100%")

    .abs(style='z-index:100; top: 2rem; font-weight:bold; font-size: 1.8rem; color: blue; left: 48.5rem;') #{gp.gp_name}
  .row.set-p-break.m-bottom.relative
    img(src="/print/2.jpg" width="100%" height="100%")
    .abs(style='z-index:100; top: 60.3rem; font-weight:bold; font-size: 1.8rem; color: red; left: 48.5rem;') #{gp.gp_name}
