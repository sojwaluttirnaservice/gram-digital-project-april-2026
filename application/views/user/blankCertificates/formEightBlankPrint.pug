doctype html
head
    title नमुना ८ - blank print
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    script(src="/asstest/plugins/qr_code/qrious.min.js")
    style.
        @media print {
            @page{
                size: A4 landscape;
            }
            .my-print{
                position: relative;
                page-break-before: always;
            }
            table, .normal-text{
                page-break-inside: avoid;
            }
            .waterMark{
                position: absolute;
                opacity: 0.3;
                width: 100%;
                height: 100%;
            }
        }
        
        .main-heading {
            margin-left:10%
        }
        .heading-second{
            margin-left:30%
        }
        .heading-second-2{
            margin-left:30%
        }
        #table2 td {
            padding-left:1px;
            padding-right:1px;
        }
        #table3 td {
            padding-left:3px;
            padding-right:3px;
        } 
        p{
            padding-bottom:0px !important;
            margin-bottom:1px !important;
        }
        td{
            font-size:12px !important;
            border:0.5px solid;
        }
        table{
            width:100% !important;
        }
        .h5{
            font-size:15px !important;
        }
        .h6{
            font-size:14px !important;
        }
        .h7{
            font-size:11px !important;
        }
        .h8{
            font-size:10px !important;
        }
        .waterMark{
            position: absolute;
            opacity: 0.2;
            top: 50%;
            left: 50%;
            width: 500px;
            height: 500px;
            transform: translateX(-50%);
        }

        .text-red {
            color: red;
        }
