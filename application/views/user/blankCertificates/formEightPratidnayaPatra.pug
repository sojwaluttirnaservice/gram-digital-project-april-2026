doctype html
head
    title नमुना 8 प्रतिज्ञापत्र
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    style.
        @media print {
            @page{
                size: A4 portrait;
            }
            .my-print{
                position: relative;
                page-break-before: always;
            }
            table{
                page-break-inside: avoid;
            }
            .waterMark{
                position: absolute;
                opacity: 0.3;
                width: 100%;
                height: 100%;
            }
        } 

        .my-print > div{
            padding: 0 12px;
        }
        .dynamicValueColor{
            color: #CA3125;
            font-weight: bold;
            font-size: 0.97px;
        }
        .main-heading {
            font-size: 10px;
            font-weight: bold;
        }
        .heading-second{
            font-size: 15px;
            font-weight: bold;
            color: #CA3125;
        }
        .heading-second-2{
            font-size: 15px;
            font-weight: bold;
            color: #CA3125;
        }
        p{
            padding-bottom:0px !important;
            margin-bottom:1px !important;
        }
        table{
            width:100% !important;
            border-collapse: collapse !important;
        }
        .h5{
            font-size:15px !important;
        }
        .h6{
            font-size:14px !important;
        }
        .h7{
            font-size:13px !important;
        }
        .h8{
            font-size:10px !important;
        }
        .qrcode{
            width: 180px;
            height: 180px;

        }
        .qrcode img{
            width:100%;
            height:100%;
        }
        .userInfoBlock{
            border: 1px solid black;
            display: flex;
            justify-content: space-around;
            align-items: center;
            font-weight: bold;
            padding-top: 5px;
        }
        .fontBold{
            font-weight: bold;
        }
        .allUserInfoName{
            font-weight: bold;
            margin-right: 10px; 
        }
        .allUserInfoValues{
            font-weight: bold;
            margin-left: 10px;
        }
        .photoBlock {
            height: 14rem;
            border-left: 1px solid black;
            border-right: 1px solid black;
        }
        #table1{
            border-bottom: 1px solid black;
        }
        #table1 tr{
            height: 3px;
            font-size: 13px;
        }
        #table2{
        }
        #table2 tr{
            height: 6px;
            font-size: 13px;
        }
        td{
            border: 1px solid black;
        }
        th{
            border-left: 1px solid black;
            border-right: 1px solid black;
        }
        .waterMark{
            position: absolute;
            opacity: 0.3;
            top: calc(50% - 250px);
            left: calc(50% - 250px);
            width: 500px;
            height: 500px;
        }
        .my-print{
            position: relative;
            border: 1px solid black;
        }
    script(src="/asstest/plugins/qrcodejs/qrcode.min.js")
    //- script.
    //-     let _gp = !{JSON.stringify(gp)};
    //-     console.log(_gp)

body.m-0.p-0(style="width: 210mm; height: 297mm;")
    .row.my-print.m-0.p-0
        img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")
        .col-12
            div.d-flex.justify-content-between.pt-2.pb-2
                div.d-flex.flex-column.justify-content-center.align-items-center.text-align-center
                    img(src="/img/header-images/mudra-nav.jpg" width="95" height="40")
                    span.font-weight-bold नमुना-८
                div.d-flex.flex-column.align-items-center.justify-content-center
                    p.main-heading.text-center महाराष्ट्र शासन राजपत्र असाधारण भाग चार-ब मार्च ३, २०१६/फाल्गुल १३ शके १९३७ नुसार नमुना ८ नियम ३२(९)
                    p.heading-second ग्रामपंचायत कार्यालय #{gp.gp_name} प. स. #{gp.gp_taluka} जि #{gp.gp_dist} (मोजणी फॉर्म )
                    p.heading-second-2 सन. _____ ते _____ इमारतीचा / जमिनीचा भांडवली मूल्यावर आधारित कर आकारणी अर्ज नमुना 
                div.d-flex.flex-column.justify-content-center.align-items-center
                    img.float-right(src="/img/header-images/g-sevalogo-new.jpeg" width="115" height="40")
                    p.font-weight-bold.h7 पान क्र:- 
        .col-12
            //- div.userInfoBlock
