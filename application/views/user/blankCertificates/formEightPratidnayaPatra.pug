            //-         b.fontBold.dynamicValueColor 
            //-     span.fontBold.h6 आधार.क्र: 
            //-         b.fontBold.dynamicValueColor 
            table
                thead(style='border: 1px solid black;')
                    tr 
                        th(width='10%') अ.क्र 
                        th(width='15%') जुना घर क्र 
                        th(width='18%') मालमत्ता क्रमांक 
                        th(width='27%') मो.क्र 
                        th(width='30%') आधार.क्र 
            div.m-0.p-0
                table
                    tr.text-center 
                        th(width='33.33%') घराचा फोटो
                        th(width='33.33%') QR कोड 
                        th(width='33.33%') घराचा नकाशा
                    tr.photoBlock
                        td
                        td 
                        td

        .col-12
            table#table1
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName मालमत्ता धारकाचे नाव/पत्नी चे नाव : 
                    td(width="50%") 
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName भोगवटधारकाचे नाव :
                    td(width="10%")  
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName बोझा/शेरा: 
                    td(width="10%")  
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName  पूर्वेस:
                    td(width="10%") 
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%")  
                        p.text-center.allUserInfoName  पश्चिमेस:
                    td(width="10%")  
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName  उत्तरेस:
                    td(width="10%") 
                        p.allUserInfoValues.dynamicValueColor  
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName  दक्षिणेस:
                    td(width="10%") 
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="20%") 
                        p.text-center.allUserInfoName  घरकूल:
                    td(width="20%") 
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName शौच्छालय:
                    td(width="20%") 
                        p.allUserInfoValues.dynamicValueColor 

                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName माजी सैनिक:
                    td(width="20%") 
                        p.allUserInfoValues.dynamicValueColor -
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName  गट क्र./भुमापण क्र. /नगर भामपण क्र:
                    td(width="10%") 
                        p.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName लांबी(पु)(प) X रुंदी (उ)(द): 
                    td(width="10%") 
                        span.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName  एकूण जागेचे क्षेत्रफळ:
                    td(width: "10%")
                        span.allUserInfoValues.dynamicValueColor 
                tr(style="height: 30px !important;")
                    td(width="10%") 
                        p.text-center.allUserInfoName एकूण जागेची चौ.मी:
                    td(width="10%")
                        span.allUserInfoValues.dynamicValueColor 
        .col-12 
            .row
                .col-12
                    table#table2
                        tr.text-center(style="font-size: 14px;")
                            th(style="font-size: 13px;") अनु क्र
                            th(style="font-size: 13px;") इमारतीचा प्रकार (A - आर सी सी पद्धतीची इमारत / B - दगड विटांची व चुना किंवा सिमेंट वापरून उभारलेली इमारत / C - दगड किंवा विटा वापरलेली मातीची इमारत / D - झोपडी किंवा मातीचे इमारत)
                            th(style="font-size: 13px;") इमारतीचा वापर  
                            th(style="font-size: 13px;") इमारतीचे बांधकाम वर्ष 
                            th(style="font-size: 13px;") लांबी चौ फूट X रुंदी चौ फूट
                            th(style="font-size: 13px;") एकूण चौ.फूट. क्षेत्रफळ 

                        each el, i in [1,2,3,4,5,6,7]
                            tr(style="height: 35px !important;")
                                td(style="width: 5% !important;").text-center #{i+1}
                                td(style="width: 220px !important;")
                                td(style="width: 50px !important;")
                                td(style="width: 50px !important;") 
                                td(style="width: 75px !important;") 
                                td(style="width: 60px !important;") 

        .col-12
            div(style="border-left: 1px solid black; border-right: 1px solid black; border-bottom: 1px solid black; padding: 10px 15px;")
                h6.text-center.dynamicValueColor सत्यपत्र सर्वेक्षण समतीस प्रतिज्ञालेख
                p.text-justify(style="font-size: 12.5px;") &nbsp; &nbsp; &nbsp;&nbsp; मी श्री./श्रीमती. __________________ भोगवटदाराचे नाव : _____________________  राहणार ______________________ मालमत्ता क्र ____________________ खालील सही करणार प्रतिज्ञालेख लिहून देतो की,मालमत्ते बाबत पंचायतीणे गठित समितीस/ यांनी विहित केलेल्या मालमत्ता सर्वेक्षण फॉर्म मध्ये (नमुन्यामध्ये )माझ्या व्दारे दिलेली,घोषित केलेल्या माहितीप्रमाणे वरील मालमत्तेची (घरांची व खुल्याजागेची)सर्वेक्षण व्दारे (मोजणी व्दारे) घेण्यात आलेली मोजणी स्थळ मोजणी, माझ्या समक्ष घेण्यात आली व माझ्या माहितीप्रमाणे वरील नमुन्यात भरलेली संपूर्ण माहिती पूर्णतः सत्य व अचूक आहे.त्या करिता वरीलप्रमाणे नमूद केलेली मालमत्तेची मोजणी संपूर्ण खरी आहे.सदर हि माहिती खोटी व चुकीची आढळल्यास किंवा याबबातीस मी दिशाभूल केल्यास या मध्ये ग्राम पंचायतने गठीत समिती तसेच व सर्वेक्षण संस्था जबाबदार रहाणार नाही. तसेच यामध्ये काही चुकीचे आढळल्यास शासन अधिनियमात असलेल्या तरतुदीचे अधिन राहून ग्राम पंचायत पंचायत समिती दुरुस्ती करण्याबाबत अर्ज दाखल करण्याची जबाबदारी माझी राहील.वरील प्रतिज्ञालेख हा माझ्या वारसास लागू राहील.

                h6.text-start.dynamicValueColor सत्यापन
                div
                    .row 
                        .col-7 
                            p.text-justify(style="font-size: 12.5px;") &nbsp; &nbsp; &nbsp;&nbsp; मी वर नमुद केलेली सर्व माहिती खरी व सत्य असून ती खोटी व असत्य आढळल्यास मी.भा.वि.चे कलम ११९,१९३(२),२०० नुसार गुन्ह्यास पात्र राहील याची माला जविण आहे करिता मी,सत्य प्रतिज्ञेवर लिहून देत आहे. 
                        .col-5
                            p(style="font-size: 10px; color: red;") प्रतिज्ञालेख अंगठा व सही 
                            p(style="font-size: 10px;") नाव : ____________________


        .col-12
            table.table.mt-4.table-borderless(style="background-color: transperent;")
                thead
                    tr
                        td 
                            div
                                p.text-center.font-weight-bold(style="font-size: 10px;") कार्यालयीन 
                                p.text-center.font-weight-bold(style="font-size: 10px;") शिक्का
                        td 
                            div
                                p.h7.text-center.font-weight-bold सचिव/ग्रा.वि. अधिकारी
