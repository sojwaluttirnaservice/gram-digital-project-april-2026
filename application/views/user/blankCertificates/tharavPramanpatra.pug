
doctype html
head
    title ठराव प्रमाणपत्र
    meta(charset='UTF-8')
    //- meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    style.
        @media print {
            @page{
                size: A4 landscape;
                margin: 0px;
            }
        }

        .year-font {
            font-size: 1.45rem;
            font-weight: bold;
            color: red;
            position: relative;
            z-index: 1;
        }

        .year-font::before {
            content: '';
            position: absolute;
            height: 2rem;
            width: 8rem;
            background: #fff;
            z-index: -1;
        }

        .font-1{
            font-size: 1.8rem;
            font-weight: bold;
            z-index: 100;
            color: red;
        }
        .font-small{
            font-size: 0.8rem;
            font-weight: bold;
            z-index: 100;
            color: blue;
        }
        .font-small-2{
            font-size: 0.67rem;
            font-weight: 800;
            z-index: 100;
            color: blue;
        }
        .font-small-3{
            font-size: 0.67rem;
            font-weight: 700;
            z-index: 100;
            color: blue;
        }
        .bg-small{
            background: white;
            width: 90px;
        }
        .bg-small-2{
            background: white;
            width: 180px;
        }
        div {
            z-index: 100;
        }
//- body(style="width:210mm; height:297mm;")
body.position-relative(style="width:297mm; height:210mm;")

    img.position-absolute.w-100.h-100(src="/img/blank-certificates-images/tharav-pramanptra.jpg")
    //- gpNames
    .position-absolute.font-1(style='top: 8.8%; left: 45%') #{gp.gp_name}
    //- .position-absolute.font-1(style='top: 8.8%; left: 56%;') प. स. #{gp.gp_taluka}
    .position-absolute.font-1(style='top: 14.9%; left: 27%;') #{gp.gp_taluka}
    .position-absolute.font-1(style='top: 14.9%; left: 61%;') #{gp.gp_dist}


    .position-absolute.year-font(style='top: 37.6%; left: 59.7%;') #{y1}
    .position-absolute.year-font(style='top: 37.6%; left: 72.7%;') #{y2}



    //- gpNames downside
    .position-absolute.font-small(style='bottom: 9%; left: 18%') #{gp.gp_name}
    .position-absolute.font-small(style='bottom: 9%; left: 40.5%') #{gp.gp_name}
    .position-absolute.font-small(style='bottom: 9%; left: 60.7%;') #{gp.gp_taluka}
    .position-absolute.font-small(style='bottom: 9%; left: 81%;') #{gp.gp_taluka}

