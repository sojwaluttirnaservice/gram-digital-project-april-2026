                    {id:3, value: "नमुना ९ सामान्य", link:'/print/blankCertificate/formNineSamanya'}, 
                    {id:4, value: "नमुना ९ पाणी", link:'/print/blankCertificate/formNinePani'}, 

                    {id:5, value: "मागणी बिल", link:'/print/blankCertificate/magniBill'}, 
