extends ../master-layout/master-layout
block internal_css
    style.
        .modal-dialog {
            width: 98%;
            height: 92%;
            padding: 0;
        }


block custom_js
    script(src='/asstest/coustom/js/handlers/blank-certificates-manager.js')

