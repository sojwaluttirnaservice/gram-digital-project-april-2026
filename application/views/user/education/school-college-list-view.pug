extends ../include/index-page-master-layout.pug
block internal_css

    style.
        .animate-roll {
            animation: roll 2600ms linear infinite alternate;
        }
        @keyframes roll {
            0 % {
                transform: translate(0px, 0px);
            }
            100% {
                transform: translate(2000%, -10%);
            }
        }

        .my-animate-bounce {
            animation: bounce 1200ms linear infinite alternate;
        }

        @keyframes bounce {
            0 % {
                transform: translateY(0px);
                transform: translateX(0px);
            }
            100% {
                transform: translateY(20px);
            }
        }

block content

    //- .main-content-white-overlay(class='fixed top-0 left-0 w-full min-h-screen h-full bg-white bg-opacity-60 z-[10]')


    .moving-dots(class='fixed bottom-[10%] left-0 w-full max-h-screen ')
        div(class='animate-roll my-bg-blue size-10 rounded-full')

    section(class='py-6 relative')

        img.bg.my-animate-bounce(class='fixed top-[35%] left-[35%]' src='/backgrounds/education-institute/student-learning-bg-education.png')
        //- .bg-overlay(class='absolute top-0 left-0 w-full h-full max-h-screen bg-red-500 bg-opacity') ddf
        .container 

            div(class='')
                h4.general-heading(class='sticky text-center text-lgl md:text-2xl font-bold my-text-blue-dark tracking-wider w-fit mx-auto px-4 md:px-8 pb-2 border-b-2')  
                    <i class="fa-solid fa-list"></i>
                    //- span.ml-2 शिक्षण संस्था यादी
                    span.ml-2 #{t("educationPage.heading")}
                    if institute_type != -1
                        //- -let instituteTypeMarathi;
                        span.ml-2 ( #{institute_type == 1 ? `${t("educationPage.aanganwadi")}` : institute_type == 2 ? `${t("educationPage.school")}`: `${t("educationPage.college")}`} )


    section(class='relative')

        .container
            .gallery-container(class='mt-8 relative')

                if institutesList && institutesList.length > 0
                    div(class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4  gap-y-8 gap-x-10 justify-content-between')

                        each institute in institutesList
                            .gallery-card(class='flex flex-col gap-2 ')
                                div(class='relative w-full rounded-xl hover:shadow-xl border ')
                                    if institute_type == -1
                                        div(class='absolute border shadow-lg rounded-md text-gray-600 top-[10px] -left-[10px] bg-white px-3 text-sm z-[50]') #{institute.institute_type === 1 ? `${t("educationPage.aanganwadi")}` : institute.institute_type === 2 ? `${t("educationPage.school")}`: `${t("educationPage.college")}` }
                                    .image-holder(class='relative w-full rounded-xl overflow-hidden h-40 hover:shadow-lg')
                                        - let path = `/new-gp-page/main-page/files/education-institute-files/${institute.institute_image}`
                                        img(src=path class='w-full h-full transition duration-300 ease-in-out hover:scale-[1.06]' onerror="this.src='/img/fallback/no-image-found.png'")
                                    .buttons-container(class='w-full absolute bottom-0 left-0')
                                        div(class='bg-white py-1 flex items-center justify-center gap-6 bg-opacity-60')
                                            a(class='bg-emerald-500 text-white size-6 flex items-center justify-center p-1 rounded-md' href=`/education/school-college-gallery-view?id=${institute.id}&instituteName=${institute.institute_name}` target='_blank')
                                                <i class="fa-solid fa-image"></i>
                                            a(class='bg-blue-500 text-white size-6 flex items-center justify-center p-1 rounded-md' href=`/education/institute-details-view?id=${institute.id}&instituteName=${institute.institute_name}` target='_blank')
                                                <i class="fa-solid fa-info"></i>
                                div(class='relative bg-white group rounded-md hover:shadow-3xl' style='box-shadow: rgba(9, 30, 66, 0.25) 0px 4px 8px -2px, rgba(9, 30, 66, 0.08) 0px 0px 0px 1px;') 
                                    div(class='text-center font-semibold tracking-wider text-sm md:text-base px-2 py-1 w-full tracking-wider truncate ellipses') #{institute.institute_name} 
                                    div(class='absolute left-1/2 transform -translate-x-1/2 top-full mt-2 w-max px-2 py-1 bg-gray-600 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity')
                                        | #{institute.institute_name}
                                        //- Tooltip arrow
                                        div(class='absolute left-1/2 transform -translate-x-1/2 -top-2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-600')

                else 
                    div(class='mt-8 text-center text-3xl font-bold tracking-wider italic') 
                        //- | यादी उपलब्ध नाही...
                        | #{t("educationPage.noList")}
