block content



	section(class='py-6 z-[10]')
		.container 

			div(class='')
				h4.general-heading(class='sticky text-center text-xl md:text-2xl font-bold my-text-blue-dark tracking-wider w-fit mx-auto px-8 pb-2 border-b-2')  
					<i class="fa-solid fa-list"></i>
					span.ml-2 #{instituteDetails.institute_name} 
					div.text-center(class='text-gray-600 text-base') ( Staff Members )

			div(class='flex justify-end')
				a(class='text-white font-bold px-4 py-1 bg-blue-500 rounded-md flex items-center gap-2 w-fit' href='#' onclick='window.history.length > 1 ? window.history.back() : window.close()') 
					<i class="fa-solid fa-circle-chevron-left"></i>
					span Back

			.gallery-container(class='mt-8')
				if instituteStaff && instituteStaff.length > 0
					div(class='grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5  gap-y-8 gap-x-10 justify-content-between')

						each staffMember in instituteStaff
							.gallery-card(class='flex flex-col gap-2 ')
								div(class='relative w-full')
									.image-holder(class='mx-auto border overflow-hidden border-stone-300 rounded-md p-1 overflow-hidden h-[180px]  w-[150px]')
										- let path = `/new-gp-page/main-page/files/education-institute-files/${staffMember.staff_photo}`
										img(src=path class='w-full h-full transition dureation-300 ease-in-out  rounded-md hover:scale-[1.05]' alt=`${staffMember.staff_name}` onerror="this.src='/img/fallback/no-image-found.png'")

									//- .buttons-container(class='w-full absolute bottom-0 left-0')
									//- 	div(class='bg-white py-1 flex items-center justify-center gap-6 bg-opacity-60')
									//- 		a(class='bg-emerald-500 text-white size-6 flex items-center justify-center p-1 rounded-md' href=`/arogya/arogya-seva-kendra-gallery-view?id=${sevak.id}&sevakName=${sevak.arogya_seva_kendra_name}` target='_blank')
									//- 			<i class="fa-solid fa-image"></i>
									//- 		a(class='bg-blue-500 text-white size-6 flex items-center justify-center p-1 rounded-md' href=`/arogya/arogya-seva-kendra-details-view?id=${sevak.id}&sevakName=${sevak.arogya_seva_kendra_name}` target='_blank')
									//- 			<i class="fa-solid fa-info"></i>
								
								div(class='relative group rounded-md' style='box-shadow: rgba(9, 30, 66, 0.25) 0px 4px 8px -2px, rgba(9, 30, 66, 0.08) 0px 0px 0px 1px;') 
									div(class='px-2 py-1')
										div(class='text-center w-full font-medium tracking-wider truncate ellipses') #{staffMember.staff_name}
										div(class='text-center font-medium text-xs') (#{staffMember.staff_designation})
									div(class='absolute left-1/2 transform -translate-x-1/2 top-full mt-2 w-max px-2 py-1 bg-gray-600 text-white text-xs rounded opacity-0 group-hover:opacity-100 transition-opacity')
										| #{staffMember.staff_name}
										//- Tooltip arrow
										div(class='absolute left-1/2 transform -translate-x-1/2 -top-2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-gray-600')

				else 
					div(class='mt-8 text-center text-3xl font-bold tracking-wider italic') यादी उपलब्ध नाही...
