doctype html
head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
    link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")  

    //toggle
    script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
    // extras

    //mask plugin jquery    
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js") 

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src='/asstest/coustom/js/handlers/marriage.js')
    script.
        $(function() {
            $(document).on('click','#open-month-year-modal-btn', function(e){
                e.preventDefault();
                $('#monthYearModal').modal('show');
            });
        })
    style.
        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#f0d688 !important;
        }
        body{
            
            height:100vh;
        }
        @media (min-width: 576px) {
        .modal-dialog { max-width: none; }
            }
            .modal-dialog {
                width: 98%;
                height: 92%;
                padding: 0;
            }
body
    include ../include/navs.pug
    .modal#marriageModel(tabindex='-1' role='dialog')
        .modal-dialog.modal-dialog-centered(role='document' style="width:60% !important;")
            .modal-content
                .modal-header
                    h5.modal-title
                    button.close(type='button' data-dismiss='modal' aria-label='Close')
                        span(aria-hidden='true') ×
                .modal-body 
                    .row
                        .col-3
                        .col-3
                            .form-group.mb-2
                                input#printPlace.form-control(placeholder="---- ठिकाण ----")
                        .col-1
                            .form-group.mt-2.text-center
                                span.font-weight-bold आणि
                        .col-3
                            .form-group.mb-2
                                input#date31.form-control(placeholder="--- दिनांक ---")
                                input#idData.form-control(type="hidden" placeholder="--- दिनांक ---")
                        .col-12
                            .d-flex.justify-content-center(style='gap:1.2rem;')
                                button#btnPrintCertificate.btn.btn-primary(type='button' data-format='old') प्रिंट करा (Color)
                                button#btnPrintMarriageCertificate.btn.btn-primary(type='button' data-format='new') प्रिंट करा (Black & White)

    - let marathiMonths = ["जानेवारी","फेब्रुवारी","मार्च","एप्रिल","मे","जून","जुलै","ऑगस्ट","सप्टेंबर","ऑक्टोबर","नोव्हेंबर","डिसेंबर"];

    .modal.fade#monthYearModal(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog.modal-dialog-centered
            .modal-content(style='max-width: 600px').mx-auto
                .modal-header
                    div
                        h4.modal-title.fs-5#exampleModalLabel महिना वर्ष निवडा
                        p(class='text-danger' style='font-size:0.8rem;') विवाह नोंदणी रजिस्टर प्रिंट मारताना महिना व वर्ष हे विवाह नोंदणीनुसार निवडावे.
                        button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                .modal-body
                    .row.justify-content-center
                        .col-3
                            select.form-control(name='month')
                                each month, index in marathiMonths
                                    option(value=(index + 1)) #{month}

                        .col-3
                            input.form-control(type='text' name='year' placeholder='Year')


                .modal-footer
                    //- button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
                    button.btn.btn-primary(type="button" id='marriage-register-report-print-btn') Print




    .container-fluid

        div.row.justify-content-center.my-3
            div.col-12.col-xl-11
                div.card.shadow-sm(style="background: oklch(86.9% 0.022 252.894);")
                    div.card-body.d-flex.flex-column.flex-md-row.align-items-center.justify-content-between.gap-3
                        div
                            h4.mb-1
                                i.fa.fa-users.me-2
                                | विवाह नोंदणी यादी
                            p.mb-0.text-muted.small विवाह नोंदणी यादी खाली दर्शविली आहे.
                        div.d-flex(style='gap:1rem;')
                            button.btn.btn-primary.btn-sm( onclick='history.back();') Back
                            button.btn.btn-secondary.btn-sm(data-bs-toggle="modal" data-bs-target="#print-report-modal")
                                i.fa.fa-print.me-1
                                | रिपोर्ट
                            a.btn.btn-secondary.btn-sm(href=`/marriage/list?status=pending&sort=${sort}`) प्रलंबित अर्ज
                            a.btn.btn-success.btn-sm(href=`/marriage/list?status=accepted&sort=${sort}`) मान्य अर्ज
                            a.btn.btn-danger.btn-sm(href=`/marriage/list?status=rejected&sort=${sort}`) रद्द अर्ज
                            //- a.btn.btn-success.btn-sm(style='background: oklch(60% 0.118 184.704);' href=`/complaints/list?status=resolved&sort=${sort}`) पूर्त तक्रार

                            button(id='open-month-year-modal-btn' data-bs-target="#monthYearModal").float-right.btn.btn-primary.btn-sm.mr-2
                                |  विवाह नोंदणी रजिस्टर प्रिंट

                            a(href="marriage/add-new").btn.btn-primary.btn-sm
                                span.fa.fa-user-plus
                                |  नवीन नोंदणी करा 


        .row
            //- .col-12.mt-3
                h4.ml-5.text-center
                    span.fa.fa-users
                    |  विवाह नोंदणी यादी
                    a(href="marriage/add-new").float-right.btn.btn-primary.btn-sm.mr-2
                        span.fa.fa-user-plus
                        |  नवीन नोंदणी करा 

                    button(id='open-month-year-modal-btn' data-bs-target="#monthYearModal").float-right.btn.btn-primary.btn-sm.mr-2
                        |  विवाह नोंदणी रजिस्टर प्रिंट

                    button.btn.btn-primary.float-right.btn-sm.mr-2( onclick='history.back();') Back

            .col-12
                .table-responsive(style='margin-bottom: 5rem;')
                    table.table.table-bordered.text-center
                        thead
                            tr.bg-success.text-white
                                th(width="10%") अनु क्रमांक
                                th(width="10%") खंड क्रंमाक
                                th(width="25%") पती
                                th(width="25%") पत्नी
                                th(width="10%") विवाह दिनांक
                                th(width='10%') नोंदणी दिनांक 
                                th(width="10%") विवाह स्थळ
                                th(width="5%") काढा
                                th(width="5%") प्रिंट
                                th(width="5%") सुधारणी 
                        tbody#marriageList
                            if(marriageRegistrationList.length == 0)
                                tr
                                    td(colspan="15").text-center.text-danger विवाह नोंदणी यादी रिकामी आहे
                            else
                                each marriageRegistrationEntry,index in marriageRegistrationList
                                    tr
                                        td #{marriageRegistrationEntry.id}
                                        td #{marriageRegistrationEntry.marriageVolume}
                                        td #{marriageRegistrationEntry.marriageHusbandNameE}
                                        td #{marriageRegistrationEntry.marriageWifedNameE}
                                        td #{marriageRegistrationEntry.marriageDate}
                                        td #{marriageRegistrationEntry.registration_date || marriageRegistrationEntry.registration_date_two}
                                        td #{marriageRegistrationEntry.marriagePlaceE}
                                        td 
                                            span.removeMarriage.fa.fa-trash.text-danger.hand(data-id = marriageRegistrationEntry.id data-certId=marriageRegistrationEntry.id)
                                        td
                                            span.fa.fa-print.text-primary.hand.printModel(data-id = marriageRegistrationEntry.id)
                                        td
                                            span.fa.fa-edit.editMarriage.hand(data-id = marriageRegistrationEntry.id)

