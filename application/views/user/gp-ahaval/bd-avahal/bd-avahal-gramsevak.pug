                                            input.form-control.form-control(type="text" name='district_name' id='district_name' value=isEdit ? data.district_name : gp.gp_dist)
                                        .form-group.col-6
                                            label.font-weight-bold(for='village_name') शहर/गाव :
                                            input.form-control.form-control(type="text" name='village_name' id='village_name' value=isEdit ? data.village_name : gp.gp_name)
                                        .form-group.col-6
                                            label.font-weight-bold(for='registration_center_name') नोंदणी केंद्राचे नाव :
                                            input.form-control(type="text" name='registration_center_name' id='registration_center_name' value=isEdit ? data.registration_center_name : '')
                                        .form-group.col-6
                                            label.font-weight-bold(for='census_code_number') जनगणना सांकेतांक क्रमांक :
                                            input.form-control(type="text" name='census_code_number' id='census_code_number' value=isEdit ? data.census_code_number : '') 


                        .col-8
