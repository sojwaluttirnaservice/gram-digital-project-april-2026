    body#body
        include ../../include/navs.pug
        //- #bdAvahalGramsevakContainer
        if data !== undefined && !data 
            p.text-center.mt-5.fw-bold.fs-3.text-danger माहिती उपलब्ध नाही
        else 
            div
                form#BDAvahalForm
                    #formHeading 
                        h1.heading-1 मासिक अहवाल 
                            span(style='font-size:1rem !important') (नमुना क्रमांक. ११, १२ व १३)
                    .row.align-items-center.justify-content-center
                        .col-8.mt-3
                            .card
                                .card-header.bg-warning.font-weight-bold 
                                    |माहिती
                                .card-body
                                    .row
                                        .form-group.col-6
                                            label.font-weight-bold(for='bd-avahal-month') अहवाल माहे : 
                                            input.form-control(type="text" name='bd-avahal-month' id='bd-avahal-month' value='' readonly)
                                        .form-group.col-6
                                            label.font-weight-bold(for='bd-avahal-year') वर्ष : 
                                            input.form-control(type="text" name='bd-avahal-year' id='bd-avahal-year' value='' readonly)
                                        .form-group.col-6
