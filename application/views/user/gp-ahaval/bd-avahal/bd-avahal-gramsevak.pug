                                        input.number-input(type="text" name='fetal_death_count_male' id='fetal_death_count_male' value=isEdit ? data.fetal_death_count_male : '')
                                    td स्त्री
                                    td(width="8%") 
                                        input.number-input(type="text" name='fetal_death_count_female' id='fetal_death_count_female' value=isEdit ? data.fetal_death_count_female : '')
                                    td एकूण
                                    td(width="8%") 
                                        input.number-input(type="text" name='fetal_death_count_total' id='fetal_death_count_total' value=isEdit ? data.fetal_death_count_total : '')


