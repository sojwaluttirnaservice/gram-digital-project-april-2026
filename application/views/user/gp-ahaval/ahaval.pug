doctype html
head
	meta(charset='UTF-8')
	meta(name='viewport' content='width=device-width, initial-scale=1.0')
	meta(http-equiv='X-UA-Compatible' content='ie=edge')
	// common css
	link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
	link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
	link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
	link(rel='stylesheet' href='/asstest/coustom/css/main.css')
	link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
	link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')



	script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
	script(src='/asstest/plugins/popper/popper.min.js')
	script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
	script(src='/asstest/plugins/date/jquery-ui.js')
	script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
	script(src='/asstest/plugins/notify/notify.js')
	script(src='/asstest/plugins/jquery_validation/jquery.validate.min.js')
	script(src='/asstest/plugins/jquery_validation/additional-methods.js')  


	//toggle
	script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
	// extras

	// common js setups
	script(src='/asstest/coustom/js/base.converter.js')
	script(src='/asstest/coustom/js/common.js')
	script(src='/asstest/coustom/js/handlers/ahaval.js')

	style.
		body{
			
			height:100vh;
		}
		@media (min-width: 576px) {
			.modal-dialog { 
				max-width: none; 
			}
		}
		.modal-dialog {
			width: 98%;
			height: 92%;
			padding: 0;
		}

body
	include ../include/navs.pug
	.modal#karAhavalModel(tabindex='-1' role='dialog')
		.modal-dialog(role='document' style='width:60% !important;')
			.modal-content
				.modal-header
					h5.modal-title
					button.close(type='button' data-dismiss='modal' aria-label='Close')
						span(aria-hidden='true') ×
				.modal-body 
					.row
						.col-3
						.col-3
							.form-group.mb-2
								select#monthName.form-control(placeholder='')
									option(value='0') ---- महिना निवडा----
									option(value='4') एप्रिल  
									option(value='5') मे
									option(value='6') जून	
									option(value='7') जुलै
									option(value='8') ऑगस्ट  
									option(value='9') सप्टेंबर
									option(value='10') ऑक्टोबर
									option(value='11') नोव्हेंबर
									option(value='12') डिसेंबर
									option(value='1') जानेवारी
									option(value='2') फेब्रुवारी
									option(value='3') मार्च
						.col-4
							button#btnPrintAhaval.btn.btn-primary.mb-2(type='submit') प्रिंट करा
							a.btn.btn-primary.mb-2.ml-2(href='/kar-wasuli') ग्राम सेवक अहवाल
	.container-fluid
		.row
			.col-12.mt-3.text-center
				h4.heading-1 अहवाल
		.row
			- 
				let avahalButtons = [
					{value:  'कर वसुली अहवाल', id: 'karVasuliAvahal'}, 
					{value: 'ब्लिचिंग अहवाल', id: 'bleachingAvahal'}, 
					{value: 'विवाह नोंदणी अहवाल', id: 'marriageAvahal'}, 
					{value: 'जन्म मृत्यू अहवाल ', id: 'birthDeathAvahal'}, 
				]

			each el in avahalButtons
				.col-6.col-md-2
					.box.box--white-1(id=el.id style='d-flex justify-content-center bg-primary')
						.commonModalFrom
							p.box__title(class="d-flex justify-content-center align-items-center" style='gap:0.2rem')
								i.text-primary.fa.fa-stack-overflow.fa-2x
								span #{el.value}
