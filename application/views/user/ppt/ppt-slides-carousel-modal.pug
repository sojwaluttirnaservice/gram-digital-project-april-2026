//- Modal for PPT Slide Carousel — Full Screen
style.
    .yatra-one-regular {
        font-family: "Yatra One", system-ui;
        font-weight: 400;
        font-style: normal;
    }

    .dekko-regular {
        font-family: "Dekko", cursive;
        font-weight: 400;
        font-style: normal;
    }

    /* Carousel items always fill the body and have a consistent background */
    #pptSlidesCarousel .carousel-inner { height: 100%; }
    #pptSlidesCarousel .carousel-item { height: 100%; background: #111; }
    #pptSlidesCarousel .carousel-item-next,
    #pptSlidesCarousel .carousel-item-prev { height: 100%; background: #111;}
    /* Content injected by JS fills its carousel-item */
    #ppt-carousel-inner .carousel-item > div { height: 100%; }
    /* Make sure all slide images inside the modal are always fully visible */
    #ppt-carousel-inner img:not(.header-slide-img) { max-height: 100% !important; max-width: 100% !important; object-fit: contain !important; }

.modal.fade.yatra-one-regular(tabindex="-1" id="ppt-slides-carousel-modal" aria-hidden="true")
    .modal-dialog.modal-fullscreen
        .modal-content(style="background: #0d0d0d; display: flex; flex-direction: column;")

            //- ── Header ─────────────────────────────────────────────
            //- .modal-header(style="background: linear-gradient(90deg, #1a1a2e, #16213e); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 0.75rem 1.5rem; flex-shrink: 0;")
                .d-flex.align-items-center.gap-3
                    span(style="background: rgba(255,255,255,0.1); color: #fff; border-radius: 50%; width: 38px; height: 38px; display:flex; align-items:center; justify-content:center;")
                        i.fa.fa-photo
                    div
                        h5.mb-0(style="color: #fff; font-weight: 700; font-size: 1rem;")
                            span#carousel-ppt-title PPT Title
                        small(style="color: rgba(255,255,255,0.5); font-size: 0.75rem;") Slide Viewer
                
                //- Prominent close button in header
                button.btn(type="button" data-bs-dismiss="modal" aria-label="Close" style="margin-left: auto; background: rgba(255,255,255,0.12); color: #fff; border-radius: 8px; padding: 6px 16px; font-size: 0.85rem; font-weight: 600; border: 1px solid rgba(255,255,255,0.15);")
                    i.fa.fa-times.me-2
                    | Close

            //- ── Carousel Body (takes all remaining space) ────────────
            .modal-body.p-0(style="flex: 1 1 0; overflow: hidden; position: relative; background: #111;")
                #pptSlidesCarousel.carousel.carousel-fade(data-bs-interval="false" style="height: 100%; position: relative;")

                    //- Indicators (bottom dots)
                    .carousel-indicators#ppt-carousel-indicators

                    //- Slide Items
                    .carousel-inner#ppt-carousel-inner(style="height: 100%;")
                        .carousel-item.active(style="height: 100%; display: flex; align-items: center; justify-content: center;")
                            .text-center
                                .spinner-border.text-light.mb-3(role="status" style="width: 3rem; height: 3rem;")
                                p(style="color: rgba(255,255,255,0.5); font-size: 0.95rem;") Loading Slides...

                    //- Prev button — explicit z-index so it's always on top
                    button.carousel-control-prev(type="button" data-bs-target="#pptSlidesCarousel" data-bs-slide="prev" style="z-index: 20; width: 64px;")
                        span.carousel-control-prev-icon(aria-hidden="true" style="background-color: rgba(0,0,0,0.55); border-radius: 50%; width: 48px; height: 48px; background-size: 50%; backdrop-filter: blur(4px);")
                        span.visually-hidden Previous

                    //- Next button — explicit z-index so it's always on top
                    button.carousel-control-next(type="button" data-bs-target="#pptSlidesCarousel" data-bs-slide="next" style="z-index: 20; width: 64px;")
                        span.carousel-control-next-icon(aria-hidden="true" style="background-color: rgba(0,0,0,0.55); border-radius: 50%; width: 48px; height: 48px; background-size: 50%; backdrop-filter: blur(4px);")
                        span.visually-hidden Next

            //- ── Footer Controls ──────────────────────────────────────
            .modal-footer(style="background: linear-gradient(90deg, #1a1a2e, #16213e); border-top: 1px solid rgba(255,255,255,0.08); padding: 0.5rem 1rem; flex-shrink: 0; justify-content: space-between; align-items:center;")

                //- LEFT SIDE (Icon + Title like header)
                .d-flex.align-items-center.gap-3
                    span(style="background: rgba(255,255,255,0.1); color: #fff; border-radius: 50%; width: 32px; height: 32px; display:flex; align-items:center; justify-content:center;")
                        i.fa.fa-photo

                    div
                        strong(style="color:#fff; font-size:0.85rem;")
                            span#carousel-ppt-title-footer PPT Title
                        br
                        small(style="color: rgba(255,255,255,0.5); font-size: 0.7rem;") Slide Viewer

                //- CENTER (Play / Pause / Counter)
                .d-flex.align-items-center.gap-2
                    button.btn.btn-sm#play-carousel-btn(style="background: #2f80ed; color: #fff; border-radius: 6px; padding: 5px 14px; font-size: 0.8rem; border: none;")
                        i.fa.fa-play.me-1
                        | Play

                    button.btn.btn-sm#pause-carousel-btn(style="background: rgba(255,255,255,0.1); color: #fff; border-radius: 6px; padding: 5px 14px; font-size: 0.8rem; border: 1px solid rgba(255,255,255,0.15);")
                        i.fa.fa-pause.me-1
                        | Pause

                    span.fw-bold.small#ppt-slide-counter(style="color: rgba(255,255,255,0.6); font-size: 0.8rem;")

                //- RIGHT SIDE (Close Button)
                button.btn.btn-sm(type="button" data-bs-dismiss="modal" style="background: rgba(255,255,255,0.1); color: #fff; border-radius: 6px; padding: 5px 14px; font-size: 0.8rem; border: 1px solid rgba(255,255,255,0.15);")
                    i.fa.fa-times.me-1
                    | Close