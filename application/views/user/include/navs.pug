style.

    .navigation-bar{
        background-color: rgba(224, 242, 254, 0.85); /* Sky-50 with transparency */
        position: sticky;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 1000;
        padding: 0.8rem 0; /* Improved spacing */
        backdrop-filter: blur(16px);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
        //- border-bottom: 1px solid rgba(255, 255, 255, 0.6);
        border-bottom: 2px solid gray;
        
    }

    .nav-items-container{
        padding: 0; /* Clear padding as parent has vertical padding now */
    }

    .nav-items {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .gp-name {
        font-weight: 700;
        color: #1e293b; /* Slate-800 */
        font-size: 1.25rem;
        text-align: center;
        letter-spacing: -0.01em;
        background: linear-gradient(135deg, #0284c7 0%, #6714a2ff 100%); /* Sky-600 to Blue-800 */
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .buttons-container {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .buttons {
        padding: 0.6rem 1.4rem;
        border: none;
        border-radius: 8px; /* Slightly rounded corners */
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); /* Sky Blue Gradient */
        color: #fff;
        font-weight: 600;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        text-decoration: none;
        font-size: 0.95rem;
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.25);
    }

    .buttons:hover {
        color: #fff;
        background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
        transform: translateY(-2px);
        box-shadow: 0 6px 15px rgba(14, 165, 233, 0.4);
    }

    .buttons:active {
        color: #fff;
        transform: translateY(0);
        box-shadow: 0 2px 5px rgba(37, 99, 235, 0.2);
    }



