doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title #{title || "PRINT"} 

        script(src="/asstest/coustom/css/tailwind.js")
        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin="")
        link(href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Marathi:ital@0;1&family=Yatra+One&display=swap" rel="stylesheet")

        
    style.
        .tiro-devanagari-marathi-regular {
            font-family: "Tiro Devanagari Marathi", serif;
            font-weight: 400;
            font-style: normal;
        }

        @media print {
            .hide-print {
                display: none;
            }
        }

    block internal_css
    block custom_css

    block content
        

    block internal_js
    block custom_js

