    body.yatra-one-regular
        //- body
        .wrapper(class='relative')
            //- Scroll Up Button
            div#scrollUpContainer(class='hidden fixed z-[100] bottom-5 right-5')
                button#scrollUpBtn(class='w-12 h-12 z-[1000] flex items-center justify-center rounded-full bg-sky-700 border-2 border-green-400 text-white shadow-lg transition-transform transition-colors duration-300 transform hover:scale-110 hover:bg-gradient-to-br hover:from-blue-600 hover:to-green-500 hover:border-green-300' title='Scroll to top')
                    i(class='fas fa-arrow-up text-xl')

            include ./index-header.pug


            main(class='relative')

                //- dialog#myModal.modal
                    .modal-box

                        form(method="dialog")

                            h3(class='text-center text-gray-500 font-bold text-xl') गाव निवडा
                            button.btn.btn-sm.btn-circle.btn-ghost.absolute.right-2.top-2 ✕

                        .p-4(class='md:p-5')
                            .modal-body
                                table.table.table-bordered(class='w-full border-collapse border border-gray-200')
                                    thead
                                        tr
                                            each value, index in sub_village
                                                th(width="5%" class='border border-gray-300 p-2') #{index + 1}
                                                th(class='border border-gray-300 p-2')
                                                    - var url = value.gp_url + "/login";
                                                    button(data-url=url, class='redirectToLoginPageModalBtn text-blue-500 hover:text-blue-700') #{value.gp_name}

                block content


        //- script(src='/asstest/plugins/OwlCarousel2-2.3.4/OwlCarousel2-2.3.4/dist/owl.carousel.js')
        script(src='https://cdnjs.cloudflare.com/ajax/libs/ekko-lightbox/5.3.0/ekko-lightbox.min.js')

        script.
            gpCount = #{sub_count}

            const scrollContainer = document.getElementById("scrollUpContainer");
            const scrollBtn = document.getElementById('scrollUpBtn');

            // Show/hide button on scroll
            window.addEventListener("scroll", () => {
                if (window.scrollY > 150) {
                    scrollContainer.classList.remove("hidden");
                } else {
                    scrollContainer.classList.add("hidden");
                }
            });

            // Scroll smoothly to top when clicked
            scrollBtn.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });

        script(src='/gram-panchayet/js/main.js')
        block internal_js
        block external_js


