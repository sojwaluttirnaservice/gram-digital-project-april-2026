body
    include ../../include/navs.pug



    .modal.fade#monthYearModal(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog
            .modal-content(style='max-width: 600px').mx-auto
                .modal-header
                    h4.modal-title.fs-5#exampleModalLabel महिना वर्ष निवडा
                    button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                .modal-body
                    .row.justify-content-center
                        .col-3
                            input.form-control(type='text' name='month' placeholder='Month')

                        .col-3
                            input.form-control(type='text' name='year' placeholder='Year')


                .modal-footer
                    //- button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
                    button.btn.btn-primary(type="button" id='print-btn') Print

    .container-fluid
        .row
            .col-12.mt-3
                h4.ml-5.text-center
                    span.fa.fa-users
                    | &nbsp;अनुपलब्धता प्रमाणपत्र नोंदणी यादी
                    a(href="/unavailability-certificate/form").float-right.btn.btn-primary.btn-sm.mr-2
                        span.fa.fa-user-plus
                        |  नवीन अनुपलब्धता प्रमाणपत्र नोंदणी करा 

                    //- button(id='open-month-year-modal-btn' data-bs-target="#monthYearModal").float-right.btn.btn-primary.btn-sm.mr-2
                        |  अनुपलब्धता प्रमाणपत्र  प्रिंट

            .col-12
                .table-responsive(style='margin-bottom: 5rem;')
                    table.table.table-bordered.text-center
                        thead
                            tr.bg-success.text-white
                                th(width="10%") अनु क्रमांक
                                th(width="10%") नोंदणी दिनांक  
                                th(width="25%")  नाव 
                                th(width="10%") अनुपलब्ध दाखला
                                th(width="5%") सुधारणी
                                th(width="5%") काढा
                                th(width="5%") प्रिंट

                        tbody#unavailabilityCertificatesList 
                            if unavailabilityCertificates == null || unavailabilityCertificates.length == 0
                                tr 
                                    td(colspan='7' ) No data available 
                            else 
                                each _certificate, _index in unavailabilityCertificates
                                    tr 
                                        td #{_index + 1}
                                        td #{_certificate._date_of_registration}
                                        td #{_certificate.name }

                                        td #{_certificate.certificate_not_found_for ? _certificate.certificate_not_found_for.toUpperCase() : ""}
                                        td 
                                            a.btn.text-primary(href=`/unavailability-certificate/edit-form/${_certificate.id}` target="_blank")
                                                i.fa.fa-edit

                                        td 
                                            button.btn.text-danger(class='delete-unavailability-certificate-btn' data-unavailabilityCertificateId=`${_certificate.id}`)
                                                i.fa.fa-trash
                                        td 
                                            a.btn.text-primary(href=`/unavailability-certificate/print/${_certificate.id}?date=${new Date().toLocaleDateString('en-GB')}` target="_blank")
                                                i.fa.fa-print





