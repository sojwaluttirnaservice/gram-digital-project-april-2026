body
    include ../../include/navs.pug



    .modal.fade#monthYearModal(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog
            .modal-content(style='max-width: 600px').mx-auto
                .modal-header
                    h4.modal-title.fs-5#exampleModalLabel महिना वर्ष निवडा
                    button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                .modal-body
                    .row.justify-content-center
                        //- .col-3
                        //-     input.form-control(type='text' name='month' placeholder='Month')

                        .col-3
                            input.form-control(type='text' name='year' placeholder='Year')


                .modal-footer
                    //- button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Close
                    button.btn.btn-primary(type="button" id='print-death-registration-record-btn') Print

    .container-fluid
        .row
            .col-12.mt-3
                h4.ml-5.text-center
                    span.fa.fa-users
                    | &nbsp; मृत्यू नोंदणी यादी
                    a(href="/death-certificate/death-certificate-form").float-right.btn.btn-primary.btn-sm.mr-2
                        span.fa.fa-user-plus
                        |  नवीन मृत्यू प्रमाणपत्र नोंदणी करा 

                    button(id='open-month-year-modal-btn' data-bs-target="#monthYearModal").float-right.btn.btn-primary.btn-sm.mr-2
                        | मृत्यू नोंदणी रजिस्टर प्रिंट

            .col-12
                .table-responsive(style='margin-bottom: 5rem;')
                    table.table.table-bordered.text-center
                        thead
                            tr.bg-success.text-white
                                th(width="8%") अनु क्रमांक
                                th(width="12%") नोंदणी दिनांक  
                                th(width="25%") मृतकाचे  नाव 
                                th(width="12%") मृत्यू दिनांक
                                th(width="25%") ग्रामपंचायत नोंदणी मृत्यू अहवाल
                                th(width="6%") सुधारणी
                                th(width="6%") काढा
                                th(width="6%") प्रिंट

                        tbody#deathCertificatesList 
                            if deathCertificates == null || deathCertificates.length == 0
                                tr 
                                    td(colspan='7' ) No data available 
                            else 
                                each _certificate, _index in deathCertificates
                                    tr 
                                        td #{_index + 1}
                                        td #{_certificate._date_of_registration}
                                        td #{_certificate.name_of_deceased}
                                        
                                        td #{_certificate._date_of_death}
                                        td 
                                            if _certificate.gp_registration_death_report_file_name
                                                a.btn.btn-success.btn-sm(href=`/uploads/docs/certificates/death/death-registration/${_certificate.gp_registration_death_report_file_name}` target="_blank")
                                                    span बघा
                                            else 
                                                p.text-danger उपलब्ध नाही
                                
                                        td 
                                            a.btn.text-primary(href=`/death-certificate/edit-death-certificate-form/${_certificate.id}` target="_blank")
                                                i.fa.fa-edit

                                        td 
                                            button.btn.text-danger(class='delete-death-certificate-btn' data-deathCertificateId=`${_certificate.id}`)
                                                i.fa.fa-trash
                                        td 
                                            a.btn.text-primary(href=`/death-certificate/print-death-certificate/${_certificate.id}` target="_blank")
                                                i.fa.fa-print





