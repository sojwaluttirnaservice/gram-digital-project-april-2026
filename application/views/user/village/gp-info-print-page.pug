                            tbody
                                if subVillages && subVillages.length > 0
                                    each subVillage in subVillages
                                        tr
                                            td(class='border px-4 py-2') #{subVillage.gp_name || '-'}
                                            td(class='border px-4 py-2') #{subVillage.number_of_households || '-'}
                                            td(class='border px-4 py-2') #{subVillage.number_of_households_having_toilets || '-'}
                                            td(class='border px-4 py-2') #{subVillage.open_defecation_free_year || '-'}
                                            td(class='border px-4 py-2') #{subVillage.odf_plus_remarks || '-'}

                                else 
                                    tr
                                        td(class='border px-4 py-2 bg-rose-200 font-bold text-center' colspan='5') कोणतीही नोंद उपलब्ध नाही.




        //- सां|डपाणी व घनकचरा व्यवस्थापन
        section
            .container.mx-auto

                div(class='p-6')
                    h5(class='text-lg font-bold mb-4 text-blue-800') सांडपाणी व घनकचरा व्यवस्थापन
                    div(class='overflow-x-auto')
                        table(class='table-auto w-full text-sm text-left text-gray-700 border border-gray-300')
                            thead(class='bg-blue-100 text-blue-900')
                                tr
                                    th(class='border px-4 py-2') गाव
                                    th(class='border px-4 py-2') कुटुंब संख्या
                                    th(class='border px-4 py-2') जोडलेले कुटुंब
                                    th(class='border px-4 py-2') शोषखड्डे
                                    th(class='border px-4 py-2') व्यवस्थापन
                            tbody
                                if subVillages && subVillages.length > 0
                                    each subVillage in subVillages
                                        tr
                                            td(class='border px-4 py-2') #{subVillage.gp_name || '-'}
                                            td(class='border px-4 py-2') #{subVillage.number_of_households || '-'}
                                            td(class='border px-4 py-2') #{subVillage.households_connected_to_waste_management || '-'}
                                            td(class='border px-4 py-2') #{subVillage.soak_pits || '-'}
                                            td(class='border px-4 py-2') #{subVillage.waste_management || '-'}

                                else 
                                    tr
                                        td(class='border px-4 py-2 bg-rose-200 font-bold text-center' colspan='5') कोणतीही नोंद उपलब्ध नाही.

        //- आदर्श तक्ता  (Ideal Table)
        section
            .container.mx-auto
                div(class="mt-8 px-4")
                    h5(class="text-2xl font-semibold text-center text-blue-800 mb-2") ग्रामपंचायत #{gp && gp.gp_name ? gp.gp_name : '-'} ता. #{gp && gp.gp_taluka ? gp.gp_taluka : '-'}, जि. #{gp && gp.gp_dist ? gp.gp_dist : '-'}

                    h5(class="text-xl text-center font-bold text-blue-700 mb-4") "आदर्श तक्ता" 

                    - let adarshTakta = (gp && gp.ps_gram_adarsh_takta) ? JSON.parse(gp.ps_gram_adarsh_takta) : {}

                    if Object.keys(adarshTakta).length > 0
                        div(class="overflow-x-auto")
                            table(class="w-full table-auto border border-blue-300 rounded-md shadow-sm")
                                thead
                                    tr(class="bg-blue-100 text-blue-800")
                                        th(class="px-4 py-2 text-left border border-blue-300") अ. क्र.
                                        th(class="px-4 py-2 text-left border border-blue-300") विवरण
                                        th(class="px-4 py-2 text-left border border-blue-300") संख्या

                                tbody
                                    each key, taktaIndex in Object.keys(adarshTakta)
                                        tr(class="odd:bg-white even:bg-blue-50")
                                            td(class="px-4 py-2 border border-blue-200") #{taktaIndex + 1}
                                            td(class="px-4 py-2 border border-blue-200") #{key}
                                            td(class="px-4 py-2 border border-blue-200") #{adarshTakta[key] || '-'}
                    else
                        p(class="text-center text-red-600 mt-2") अद्याप आदर्श तक्त्याची माहिती उपलब्ध नाही.

        //- ग्रामपंचायत कार्यकारिणी
        section     
            .container.mx-auto 
                div(class="mt-8 px-4")
