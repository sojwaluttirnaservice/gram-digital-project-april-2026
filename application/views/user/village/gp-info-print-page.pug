                    h6(class='mt-2 text-center text-3xl text-blue-900 font-bold') पं. स. #{gp.gp_taluka}, जि. #{gp.gp_dist}

                div(class='mt-2')
                    p(class='text-center text-3xl text-blue-800') 
                        span सन 
                        input(class='border w-32 print:hidden outline-none focus:border px-2 rounded-md' placeholder='२०२३' data-dynamic-inputs data-target='from-year') 
                        span(data-reciever='from-year' class='hidden print:inline') 
                        span -
                        input(class='border ml-1 w-32 print:hidden outline-none focus:border px-2 rounded-md' placeholder='२०२३' data-dynamic-inputs data-target='to-year') 
                        span(data-reciever='to-year' class='hidden print:inline') 

                div(class='flex justify-center')
                    div(class='w-[80%] h-[25rem]')
                        img(src='/uploads/images/gp/main/'+ gp.gp_image_name onerror="this.src='/img/fallback/no-image-found.png'" class='border border-gray-400 w-full h-full rounded-md')

                div(class='mt-4 text-6xl text-pink-600 font-extrabold')
                    div(class='text-center')
                        div(class='print:hidden')
                            input(class='border outline-none focus:border px-2 rounded-md placeholder:text-pink-500' placeholder='पुरस्काराचे नाव इथे लिहा' data-dynamic-inputs data-target='award-name')
                        p.text-center(data-reciever='award-name' class='hidden print:block font-extrabold').noto-sans-devanagari-semibold आर आर आबा पाटील पुरस्कार



                        //- २०२३-२०२४ 

                div(class='mt-auto')
                    div(class='grid grid-cols-2')
                        div.text-center
                            p(class='text-pink-600 font-bold text-xl') सरपंच 
                            p(class='text-blue-800 font-bold') #{sarpanchDetails.name}

                        div.text-center
