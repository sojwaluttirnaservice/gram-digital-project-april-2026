                                    tbody
                                        //- SC
                                        tr(class='hover:bg-blue-50')
                                            td(class='border px-5 py-2') अनुसूचित जाती (SC)
                                            td(class='border px-5 py-2') #{subVillage.sc_count_male}
                                            td(class='border px-5 py-2') #{subVillage.sc_count_female}
                                            td(class='border px-5 py-2') #{subVillage.sc_count}

                                        //- ST
                                        tr(class='hover:bg-blue-50')
                                            td(class='border px-5 py-2') अनुसूचित जमाती (ST)
                                            td(class='border px-5 py-2') #{subVillage.st_count_male}
                                            td(class='border px-5 py-2') #{subVillage.st_count_female}
                                            td(class='border px-5 py-2') #{subVillage.st_count}

                                        //- NT
                                        tr(class='hover:bg-blue-50')
                                            td(class='border px-5 py-2') विमुक्त जाती/भटक्या जमाती (NT)
                                            td(class='border px-5 py-2') #{subVillage.nt_count_male}
                                            td(class='border px-5 py-2') #{subVillage.nt_count_female}
                                            td(class='border px-5 py-2') #{subVillage.nt_count}

                                        //- OBC
                                        tr(class='hover:bg-blue-50')
                                            td(class='border px-5 py-2') इतर मागासवर्गीय (OBC)
                                            td(class='border px-5 py-2') #{subVillage.obc_count_male}
                                            td(class='border px-5 py-2') #{subVillage.obc_count_female}
                                            td(class='border px-5 py-2') #{subVillage.obc_count}

                                        //- Others
                                        tr(class='hover:bg-blue-50')
                                            td(class='border px-5 py-2') इतर (Open/General)
                                            td(class='border px-5 py-2') #{subVillage.open_others_count_male}
                                            td(class='border px-5 py-2') #{subVillage.open_others_count_female}
                                            td(class='border px-5 py-2') #{subVillage.open_others_count}

                                        //- Total Row (Optional, if you want frontend total)
                                        -
                                            let totalMale = subVillage.sc_count_male + subVillage.st_count_male + subVillage.nt_count_male + subVillage.obc_count_male + subVillage.open_others_count_male;
                                            let totalFemale = subVillage.sc_count_female + subVillage.st_count_female + subVillage.nt_count_female + subVillage.obc_count_female + subVillage.open_others_count_female;
                                            let totalAll = subVillage.sc_count + subVillage.st_count + subVillage.nt_count + subVillage.obc_count + subVillage.open_others_count;
                                        tr(class='font-bold bg-blue-100 text-blue-900')
                                            td(class='border px-5 py-2') एकूण लोकसंख्या
                                            td(class='border px-5 py-2') #{totalMale}
                                            td(class='border px-5 py-2') #{totalFemale}
                                            td(class='border px-5 py-2') #{totalAll}

                else    
                    h3.text-center.text-rose-400.font-bold.text-xl कोणतीही जनसंख्या माहिती उपलब्ध नाही

                //- // Other Details Card
                div(class='p-6 space-y-2')
                    - let mainVillageFirst = (subVillages && subVillages[0]) ? subVillages[0] : {}
                    p वार्ड संख्याः #{mainVillageFirst.ward_number || '-'}, एकूण सदस्य :- #{mainVillageFirst.total_members || '-'}, जनतेतून सरपंच- #{mainVillageFirst.sarpanch_directly_elected_count || '-'}
                    p करः घरपट्टी, दिवाकर, आरोग्य कर, पाणीपट्टी
                    p घरांची संख्या :
                        if subVillages && subVillages.length > 0 

                            for sub_village, subvillageInd in subVillages
                                span #{sub_village.gp_name} - 
                                span #{sub_village.home_count || 0}
                                if subvillageInd != subVillages.length - 1
                                    span , 
                    p क्षेत्रफळ:
                        if subVillages && subVillages.length > 0
                            for sub_village, subvillageInd in subVillages
                                span #{sub_village.gp_name} - 
                                span #{sub_village.area_in_sq_hectare}
                                if subvillageInd != subVillages.length - 1
                                    span ,

                    p मतदार संघ (लोकसभा): #{mainVillageFirst.constituency_number}-#{mainVillageFirst.constituency_name}
                    p विधानसभा: #{mainVillageFirst.assembly_constituency_number}-#{mainVillageFirst.assembly_constituency_name}
                    p Website: 
                        a(class='text-blue-600 underline' href=mainVillageFirst.gp_url target='_blank') #{mainVillageFirst.gp_url}

        //- पाणीपुरवठा
        section 
            .container.mx-auto 
                div(class='p-6')
                    h5(class='text-lg font-bold mb-4 text-blue-800') पाणीपुरवठा
                    div(class='overflow-x-auto mx-auto')
                        table(class='table-auto w-full text-sm text-left text-gray-700 border border-gray-300')
                            thead(class='bg-blue-100 text-blue-900')
                                tr
                                    th(class='border px-4 py-2') टाकीचे ठिकाण
                                    th(class='border px-4 py-2') क्षमता
                                    th(class='border px-4 py-2') कर्मचारी
                                    th(class='border px-4 py-2') सामान्य दर
                                    th(class='border px-4 py-2') विशेष दर
                            tbody
                                if subVillages && subVillages.length > 0
                                    each subVillage in subVillages
                                        tr
                                            td(class='border px-4 py-2') #{subVillage.tank_location || '-'}
                                            td(class='border px-4 py-2') #{subVillage.tank_capacity || '-'}
                                            td(class='border px-4 py-2') #{subVillage.staff_in_charge || '-'}
                                            td(class='border px-4 py-2') #{subVillage.normal_rate || '-'}
                                            td(class='border px-4 py-2') #{subVillage.special_rate || '-'}


                                else 
                                    tr
                                        td(class='border px-4 py-2 bg-rose-200 font-bold text-center' colspan='5') कोणतीही नोंद उपलब्ध नाही.

        //- //- स्वच्छ भारत मिशन
        section 
            .container.mx-auto 

