                                    th(class='px-2 py-2 border border-gray-300' rowspan='3') मदतनीस

                                    //- if totalYearlyStatsLength > 0
                                    //- th(colspan=totalAgeWiseColumnsCount rowspan='1') मुलांची संख्या
                                    th(class='px-2 py-2 border border-gray-300' colspan='4') मुलांची संख्या

                                    th(class='px-2 py-2 border border-gray-300' rowspan='3') शौचालय
                                    th(class='px-2 py-2 border border-gray-300' rowspan='3') किचन शेड

                                // 2nd Header Row: Year Ranges
                                tr(class='bg-green-500 text-white')
                                    - const firstYearRange = firstCenter?.yearly_stats?.[0]?.year_range || '-'
                                    - const secondYearRange = firstCenter?.yearly_stats?.[1]?.year_range || '-'

                                    //- th(rowspan='1', colspan=firstColWidth)= firstYearRange
                                    //- th(rowspan='1', colspan=secondColWidth)= secondYearRange
                                    th(class='px-2 py-2 border border-gray-300' colspan='2')= firstYearRange
                                    th(class='px-2 py-2 border border-gray-300' colspan='2')= secondYearRange

                                // 3rd Header Row: Age Groups
                                tr(class='bg-green-400 text-white')
                                    - let firstAgeWiseCountArray = firstCenter?.yearly_stats?.[0]?.agewise_children || []
                                    - let secondAgeWiseCountArray = firstCenter?.yearly_stats?.[1]?.agewise_children || []

                                    - var minAge0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].min_age : '-'
                                    - var maxAge0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].max_age : '-'
                                    - var minAge1 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].min_age : '-'
                                    - var maxAge1 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].max_age : '-'

                                    - var minAge2 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].min_age : '-'
                                    - var maxAge2 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].max_age : '-'
                                    - var minAge3 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].min_age : '-'
                                    - var maxAge3 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].max_age : '-'

                                    th(class='px-2 py-2 border border-gray-300') #{minAge0} ते #{maxAge0}
                                    th(class='px-2 py-2 border border-gray-300') #{minAge1} ते #{maxAge1}
                                    th(class='px-2 py-2 border border-gray-300') #{minAge2} ते #{maxAge2}
                                    th(class='px-2 py-2 border border-gray-300') #{minAge3} ते #{maxAge3}

                            tbody
                                each center, centerInd in aanganwadiCenters
                                    tr(class='hover:bg-gray-100')
                                        td(class='px-2 py-2 border border-gray-300') #{centerInd + 1}
                                        td(class='px-2 py-2 border border-gray-300') #{center.village_name || '-'}

                                        // सेविका नाव (empty for now)

                                        - let sevikaNames = (center && Array.isArray(center.workers)) ? center.workers.filter(w => w.role === 'सेविका').map(w => w.name).join(', ') : '-' 
                                        td(class='px-2 py-2 border border-gray-300') 
                                            div #{sevikaNames}


                                        // मदतनीस नाव (empty for now)
                                        - let madatnisNames = (center && Array.isArray(center.workers)) ? center.workers.filter(w => w.role === 'मदतनीस').map(w => w.name).join(', ') : '-' 
                                        td(class='px-2 py-2 border border-gray-300')
                                            div #{madatnisNames}


                                        // मुलांची वयोवारी संख्या
                                        //- // First array (yearly_stats[0])
                                        - let firstAgeWiseCountArray = center?.yearly_stats?.[0]?.agewise_children || []
                                        - var firstCount0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].child_count : '-'
                                        - var secondCount0 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].child_count : '-'

                                        //- // Second array (yearly_stats[1])
                                        - let secondAgeWiseCountArray = center?.yearly_stats?.[1]?.agewise_children || []
                                        - var firstCount1 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].child_count : '-'
                                        - var secondCount2 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].child_count : '-'

                                        //- // Rendering all 4 td elements
                                        td(class='px-2 py-2 border border-gray-300') #{firstCount0}
                                        td(class='px-2 py-2 border border-gray-300') #{secondCount0}
                                        td(class='px-2 py-2 border border-gray-300') #{firstCount1}
                                        td(class='px-2 py-2 border border-gray-300') #{secondCount2}

                                        // शौचालय स्थिती
                                        td(class='px-2 py-2 border border-gray-300') #{center.has_toilet === 'AVAILABLE' ? 'होय' : 'नाही'}

                                        // किचन शेड स्थिती
                                        td(class='px-2 py-2 border border-gray-300') #{center.has_kitchen_shed === 'AVAILABLE' ? 'होय' : 'नाही'}

                else 
                    h4.text-center.font-bold.text-rose-400.text-xl कोणत्याही आंगणवाडी केंद्राची नोंद उपलब्ध नाही.

        //- //- आशा सेविका यादी
        section 
            .container.mx-auto 
                div(class='p-6 mt-6')
                    h5(class='text-lg font-bold mb-4 text-pink-800') आशा सेविका यादी

                    table(class='min-w-full table-auto border-collapse border border-pink-300')
                        thead
                            tr(class='bg-pink-100 text-pink-800')
                                th(class='border border-pink-300 px-4 py-2 text-left') अनु. क्र.
                                th(class='border border-pink-300 px-4 py-2 text-left') नाव
                                th(class='border border-pink-300 px-4 py-2 text-left') मोबाईल
                                th(class='border border-pink-300 px-4 py-2 text-left') गाव

                        tbody
                            if workers && workers.length > 11
                                each worker, index in workers
                                    tr(class='hover:bg-pink-50')
                                        td(class='border border-pink-200 px-4 py-2') #{index + 1}
                                        td(class='border border-pink-200 px-4 py-2 capitalize') #{worker.name}
                                        td(class='border border-pink-200 px-4 py-2') #{worker.mobile}
