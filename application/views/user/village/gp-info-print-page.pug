                                        td(class='border border-blue-200 px-4 py-2') #{structure.structure_length_m}
                                        td(class='border border-blue-200 px-4 py-2') #{structure.storage_capacity_cubic_m || '-'}

                            else    
                                tr
                                    td(class='border border-blue-200 px-4 py-2 bg-rose-300 text-center' colspan='4') कोणत्याही जल संधारण संरचनेची नोंद उपलब्ध नाही.




        section     
            .container.mx-auto 

                if aanganwadiCenters && aanganwadiCenters.length > 0
                    - let totalYearlyStatsLength = 0
                    - let totalAgeWiseColumnsCount = 0
                    - let ageWiseLengths = []
                    - let firstCenter = aanganwadiCenters[0]

                    // Count yearly stats and agewise columns
                    if firstCenter && Array.isArray(firstCenter.yearly_stats)
                        - totalYearlyStatsLength = firstCenter.yearly_stats.length
                        each stat in firstCenter.yearly_stats
                            if stat && Array.isArray(stat.agewise_children) && stat.agewise_children.length > 0
                                - totalAgeWiseColumnsCount += stat.agewise_children.length
                                - ageWiseLengths.push(stat.agewise_children.length)

                    - ageWiseLengths.sort((a, b) => b - a)

                    //- - let firstColWidth = ageWiseLengths[0] || 2
                    //- - let secondColWidth = ageWiseLengths[1] || 2
                    //- - let sumOfTopTwo = firstColWidth + secondColWidth
                    //- - totalAgeWiseColumnsCount = Math.max(4, sumOfTopTwo)
                    div.p-6
