                            p(class='text-blue-800 font-bold')  #{gramsevakDetails.name} 





        section
            .container.mx-auto
                div(class='gp-general-info-page-heading mt-8')
                    h4(class='general-heading sticky text-center text-xl md:text-2xl font-bold text-blue-900 tracking-wider w-fit mx-auto px-8 pb-2 border-b-2 border-blue-900')  

                        span(class='') ग्रामपंचायतीची सर्वसाधारण माहिती


        section(class='py-8 md:py-16 relative')
            .container(class='mx-auto px-4 md:px-8 max-w-6xl space-y-8')

                // Basic Info Card 
                div(class='p-6 space-y-2')
