                                                span.bg-blue-50.px-2.py-1.rounded.border.border-blue-300
                                                    | #{staff.staff_designation || 'हुद्दा नाही'}
                                            p(class="text-blue-800 text-sm")
                                                i(class="fa fa-phone mr-2 text-blue-500")
                                                | #{staff.staff_mob_no || 'नोंद नाही'}
                            else
                                p(class="text-sm text-red-600 font-medium mt-2") शिक्षकांची नोंद उपलब्ध नाही.
