                            thead
                                // 1st Header Row
                                tr(class='bg-green-600 text-white')
                                    th(class='px-2 py-2 border border-gray-300' rowspan='3') अनु क्र.
                                    th(class='px-2 py-2 border border-gray-300' rowspan='3') गावाचे नाव
