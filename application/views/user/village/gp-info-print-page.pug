                                i(class="fa fa-users mr-2 text-blue-500")
                                | शिक्षक यादी

                            - let staffMembers = institute && institute.staff_members ? institute.staff_members : []

                            if staffMembers && staffMembers.length > 0
                                div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4")
