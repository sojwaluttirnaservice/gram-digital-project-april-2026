doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title #{title}


        script(src='/asstest/coustom/css/tailwind.js')

        //- MARATHI FONT

        //- YATRA ONE
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Mukta:wght@200;300;400;500;600;700;800&family=Noto+Sans+Devanagari:wght@100..900&family=Tiro+Devanagari+Marathi:ital@0;1&family=Yatra+One&display=swap" rel="stylesheet">
        style.
            table {
                border-collapse: collapse;
            }
            td, th {
                padding: 0.2rem;
                border: 1px solid #f472b6;
            }
            @media print {

                @page {
                    size: A4 portrait;
                    //- margin: 9mm 9mm 9mm 9mm;
                    padding-block: 1rem;
                    border: 4mm ridge rgba(255, 182, 193, 0.6);
                    background-image: url('https://blog.ipleaders.in/wp-content/uploads/2021/08/Panchayat.jpg')
                }

                body::before {
                    content: "";
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100vw;
                    height: 100vh;
                    background-image: url('https://blog.ipleaders.in/wp-content/uploads/2021/08/Panchayat.jpg');
                    background-size: cover;
                    background-repeat: no-repeat;
                    background-position: center;
                    opacity: 0.1; /* Adjust visibility like a watermark */
                    z-index: -1;
                    pointer-events: none;
                }


                .hide-print {
                    display: none;
                }

                .print{
                    //- size: A4 landscape;
                    //- page-break-after: always;
                    //- break-after: page;
                    height:100lvh;
                }

                .my-print {
                    position: relative;
                    background: none !important; /* Prevent bg-white/90 or any tailwind override */
                }

                * {
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                .print-bg {
                    background-image: url('/img/background/bg-tricolor.png');
                    background-size: cover;
                    background-repeat: no-repeat;
                    background-position: top center;
                }
            }


            .tiro-devanagari-marathi-regular {
                font-family: "Tiro Devanagari Marathi", serif;
                font-weight: 400;
                font-style: normal;
            }

            .tiro-devanagari-marathi-regular-italic {
                font-family: "Tiro Devanagari Marathi", serif;
                font-weight: 400;
                font-style: italic;
            }
            .mukta-bold {
                font-family: "Mukta", sans-serif;
                font-weight: 700;
                font-style: normal;
            }
            .noto-sans-devanagari-extrabold {
                font-family: "Noto Sans Devanagari", sans-serif;
                font-optical-sizing: auto;
                font-weight: 800;
                font-style: normal;
                font-variation-settings:"wdth" 100;
            }
        script.
            document.addEventListener('DOMContentLoaded', function(){
                function printPage(){
                    window.print()
                }


                //- printPage()
                // Select all inputs with the data-dynamic-inputs attribute
                const dynamicInputs = document.querySelectorAll('[data-dynamic-inputs]');

                if (dynamicInputs) {
                    dynamicInputs.forEach((dynamicInput) => {
                        if (dynamicInput) {
                            dynamicInput.addEventListener('input', function (e) {
                                const inputValue = e.target.value;
                                const targetElementName = e.target.getAttribute('data-target');

                                // Find the receiver element with matching data-reciever attribute
                                const receiverElement = document.querySelector(`[data-reciever="${targetElementName}"]`);
                                if (receiverElement) {
                                    receiverElement.textContent = inputValue;
                                }
                            });
                        }
                    });
                }

            })
    body.tiro-devanagari-marathi-regular

        - let members = gp && gp.gp_member ? JSON.parse(gp.gp_member) : []

        - let sarpanchDetails = members && members.length > 0 ? members.find((member) => member && (member.p_name == 'सरपंच')) : null
        - let gramsevakDetails = members && members.length > 0 ? members.find((member) => member && (member.p_name == 'ग्रामसेवक' || member.p_name == 'ग्रामविकास अधिकारी' || member.p_name == 'ग्रामपंचायत अधिकारी')) : null


        div.hide-print

            div(class="fixed top-[45%] right-[2%] flex flex-col gap-2 z-50")
                button(class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded shadow-md" onclick="window.print()") Print
                //- button(class="bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2 rounded shadow-md" id="download-pdf-btn") Download

        section(class='print:break-after-page print:h-lvh')
            div.p-6(class='flex flex-col gap-2 h-full')
                div.w-full(class='')
                    div(class="w-full grid grid-cols-8 gap-2")
