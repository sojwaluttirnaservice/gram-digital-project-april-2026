                    each institute, instituteIndex in institutesWithStaff
                        div(class="bg-white shadow-md rounded-xl p-6 mb-6 border border-blue-300 hover:shadow-lg transition-shadow")
                            div(class="flex items-center gap-3 mb-4")
                                div(class="bg-blue-100 text-blue-800 text-sm font-semibold px-3 py-1 rounded-full shadow-sm")
