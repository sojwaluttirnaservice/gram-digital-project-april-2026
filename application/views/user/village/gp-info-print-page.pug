                        svg(xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor' class='w-6 h-6')
                            path(stroke-linecap='round' stroke-linejoin='round' d='M2.25 6.75v10.5a2.25 2.25 0 002.25 2.25h15a2.25 2.25 0 002.25-2.25V6.75M4.5 6.75L12 12.75l7.5-6')
                        h5(class='font-semibold text-lg') मूलभूत माहिती


                    p(class='text-sm md:text-base font-medium') Email : -
                    p(class='text-sm md:text-base font-medium') सरपंचाचे नाव : #{sarpanchDetails ? sarpanchDetails.name : '-'}


                    p(class='text-sm md:text-base font-medium') ग्रामसेवकाचे नाव : #{gramsevakDetails ? gramsevakDetails.name : '-'}
                    p(class='text-sm md:text-base font-medium') ग्रामपंचायतीचा चार्ज घेतल्याचा दिनांक : #{gp && gp.charge_taken_date ? gp.charge_taken_date : '-'}
                    p(class='text-sm md:text-base font-medium') सरपंच निवडणूक दिनांक : #{gp && gp.sarpanch_election_date ? gp.sarpanch_election_date : '-'}
                    p(class='text-sm md:text-base font-medium') मुदत संपण्याची दिनांक : #{gp && gp.term_end_date ? gp.term_end_date : '-'}
                    p(class='text-sm md:text-base font-medium') वार्षिक अहवाल दिनांक : #{gp && gp.annual_report_date ? gp.annual_report_date : '-'}
                    p(class='text-sm md:text-base font-medium') अंदाजपत्रक सन #{gp && gp.budget_year ? gp.budget_year : '-'}
                    p(class='text-sm md:text-base font-medium') हिशेच तपासणी वर्ष : #{gp && gp.audit_year ? gp.audit_year : '-'}
                    p(class='text-sm md:text-base font-medium') लोकसंख्या सन २०११ च्या जनगणनेनुसार



                //- Population Section
                if subVillages && subVillages.length > 0
                    each subVillage in subVillages
                        div(class="mb-8")
                            h4.text-xl.text-center.font-semibold.text-blue-700.mb-2 #{subVillage.gp_name} गावाची लोकसंख्या माहिती

                            div(class='overflow-x-auto rounded-xl shadow border border-blue-200 bg-white')
                                table(class='table-auto w-full text-sm text-gray-800')
                                    thead(class='bg-blue-500 text-white text-left uppercase text-sm')
                                        tr
                                            th(class='px-5 py-3 border') संवर्ग
                                            th(class='px-5 py-3 border') पुरुष
                                            th(class='px-5 py-3 border') स्त्री
