                //- - let sumOfTopTwo = firstColWidth + secondColWidth
                //- - totalAgeWiseColumnsCount = Math.max(4, sumOfTopTwo)

                h2(class='text-2xl font-bold text-center text-red-700 my-6 border-2 border-red-700 rounded-lg px-4 py-2')
                    //- | अंगणवाडी केंद्रांची यादी
                    | #{t("gpNotesPage.anganwadiCentersSection.sectionTitle")}

                .overflow-x-auto.mt-3
                    table(class='w-full border-collapse border border-gray-400 text-center')
                        thead
                            // 1st Header Row
                            tr(class='bg-green-600 text-white')
                                th(class='px-2 py-2 border border-gray-300' rowspan='3') 
                                    //- | अनु क्र.
                                    | #{t("gpNotesPage.anganwadiCentersSection.serialNo")}
                                th(class='px-2 py-2 border border-gray-300' rowspan='3') 
                                    //- | गावाचे नाव
                                    | #{t("gpNotesPage.anganwadiCentersSection.villageName")}
                                th(class='px-2 py-2 border border-gray-300' rowspan='3')
                                    //- | सेविका
                                    | #{t("gpNotesPage.anganwadiCentersSection.sevika")}
                                th(class='px-2 py-2 border border-gray-300' rowspan='3') 
                                    //- | मदतनीस
                                    | #{t("gpNotesPage.anganwadiCentersSection.assistant")}

                                //- if totalYearlyStatsLength > 0
                                //- th(colspan=totalAgeWiseColumnsCount rowspan='1') मुलांची संख्या
                                th(class='px-2 py-2 border border-gray-300' colspan='4') 
                                    //- | मुलांची संख्या
                                    | #{t("gpNotesPage.anganwadiCentersSection.numberOfChildren")}

                                th(class='px-2 py-2 border border-gray-300' rowspan='3') 
                                    //- | शौचालय
                                    | #{t("gpNotesPage.anganwadiCentersSection.toilet")}
                                th(class='px-2 py-2 border border-gray-300' rowspan='3') 
                                    //- | किचन शेड
                                    | #{t("gpNotesPage.anganwadiCentersSection.kitchenShed")}

                            // 2nd Header Row: Year Ranges
                            tr(class='bg-green-500 text-white')
                                - const firstYearRange = firstCenter?.yearly_stats?.[0]?.year_range || '-'
                                - const secondYearRange = firstCenter?.yearly_stats?.[1]?.year_range || '-'

                                //- th(rowspan='1', colspan=firstColWidth)= firstYearRange
                                //- th(rowspan='1', colspan=secondColWidth)= secondYearRange
                                th(class='px-2 py-2 border border-gray-300' colspan='2')= firstYearRange
                                th(class='px-2 py-2 border border-gray-300' colspan='2')= secondYearRange

                            // 3rd Header Row: Age Groups
                            tr(class='bg-green-400 text-white')
                                - let firstAgeWiseCountArray = firstCenter?.yearly_stats?.[0]?.agewise_children || []
                                - let secondAgeWiseCountArray = firstCenter?.yearly_stats?.[1]?.agewise_children || []

                                - var minAge0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].min_age : '-'
                                - var maxAge0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].max_age : '-'
                                - var minAge1 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].min_age : '-'
                                - var maxAge1 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].max_age : '-'

                                - var minAge2 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].min_age : '-'
                                - var maxAge2 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].max_age : '-'
                                - var minAge3 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].min_age : '-'
                                - var maxAge3 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].max_age : '-'

                                th(class='px-2 py-2 border border-gray-300') #{minAge0} ते #{maxAge0}
                                th(class='px-2 py-2 border border-gray-300') #{minAge1} ते #{maxAge1}
                                th(class='px-2 py-2 border border-gray-300') #{minAge2} ते #{maxAge2}
                                th(class='px-2 py-2 border border-gray-300') #{minAge3} ते #{maxAge3}

                        tbody
                            each center, centerInd in aanganwadiCenters
                                tr(class='hover:bg-gray-100')
                                    td(class='px-2 py-2 border border-gray-300') #{centerInd + 1}
                                    td(class='px-2 py-2 border border-gray-300') #{center.village_name || '-'}

                                    // सेविका नाव (empty for now)

                                    - let sevikaNames = (center && Array.isArray(center.workers)) ? center.workers.filter(w => w.role === 'सेविका').map(w => w.name).join(', ') : '-' 
                                    td(class='px-2 py-2 border border-gray-300') 
                                        div #{sevikaNames}


                                    // मदतनीस नाव (empty for now)
                                    - let madatnisNames = (center && Array.isArray(center.workers)) ? center.workers.filter(w => w.role === 'मदतनीस').map(w => w.name).join(', ') : '-' 
                                    td(class='px-2 py-2 border border-gray-300')
                                        div #{madatnisNames}


                                    //- // मुलांची वयोवारी संख्या
                                    //- // First array (yearly_stats[0])
                                    - let firstAgeWiseCountArray = center?.yearly_stats?.[0]?.agewise_children || []
                                    - var firstCount0 = firstAgeWiseCountArray[0] ? firstAgeWiseCountArray[0].child_count : '-'
                                    - var secondCount0 = firstAgeWiseCountArray[1] ? firstAgeWiseCountArray[1].child_count : '-'

                                    //- // Second array (yearly_stats[1])
                                    - let secondAgeWiseCountArray = center?.yearly_stats?.[1]?.agewise_children || []
                                    - var firstCount1 = secondAgeWiseCountArray[0] ? secondAgeWiseCountArray[0].child_count : '-'
                                    - var secondCount2 = secondAgeWiseCountArray[1] ? secondAgeWiseCountArray[1].child_count : '-'

                                    //- // Rendering all 4 td elements
                                    td(class='px-2 py-2 border border-gray-300') #{firstCount0}
                                    td(class='px-2 py-2 border border-gray-300') #{secondCount0}
                                    td(class='px-2 py-2 border border-gray-300') #{firstCount1}
                                    td(class='px-2 py-2 border border-gray-300') #{secondCount2}

                                    //- // शौचालय स्थिती
                                    td(class='px-2 py-2 border border-gray-300') #{center.has_toilet === 'AVAILABLE' ? 'होय' : 'नाही'}

                                    //- // किचन शेड स्थिती
                                    td(class='px-2 py-2 border border-gray-300') #{center.has_kitchen_shed === 'AVAILABLE' ? 'होय' : 'नाही'}



            //- आशा सेविका यादी (translation in pr)
            if workers && workers.length > 0
                div(class='bg-white shadow-lg rounded-xl p-6 border border-pink-200 mt-6')
                    h5(class='text-lg font-bold mb-4 text-pink-800') 
                        //- | आशा सेविका यादी
                        | #{t("gpNotesPage.ashaWorkersSection.sectionTitle")}

                    table(class='min-w-full table-auto border-collapse border border-pink-300')
                        thead
                            tr(class='bg-pink-100 text-pink-800')
                                th(class='border border-pink-300 px-4 py-2 text-left') 
                                    //- | अनु. क्र.
                                    | #{t("gpNotesPage.ashaWorkersSection.serialNo")}
                                th(class='border border-pink-300 px-4 py-2 text-left') 
                                    //- | नाव
                                    | #{t("gpNotesPage.ashaWorkersSection.name")}
                                th(class='border border-pink-300 px-4 py-2 text-left') 
                                    //- | मोबाईल
                                    | #{t("gpNotesPage.ashaWorkersSection.mobile")}
                                th(class='border border-pink-300 px-4 py-2 text-left') 
                                    //- | गाव
                                    | #{t("gpNotesPage.ashaWorkersSection.village")}

                        tbody
                            each worker, index in workers
                                tr(class='hover:bg-pink-50')
                                    td(class='border border-pink-200 px-4 py-2') #{index + 1}
                                    td(class='border border-pink-200 px-4 py-2 capitalize') #{worker.name}
                                    td(class='border border-pink-200 px-4 py-2') #{worker.mobile}
                                    td(class='border border-pink-200 px-4 py-2 capitalize') #{worker.village || '-'}






            if institutesWithStaff && institutesWithStaff.length > 0
                section(class="bg-blue-50 py-10 px-4 md:px-10 rounded-2xl shadow-inner border border-blue-200")
                    h3(class="text-2xl font-bold text-blue-800 text-center mb-8")
                        i(class="fa fa-school mr-2 text-blue-600")
                        //- | शैक्षणिक संस्था व कर्मचारी माहिती
                        | #{t("gpNotesPage.educationalInstitutesSection.sectionTitle")}

                    each institute, instituteIndex in institutesWithStaff
                        div(class="bg-white shadow-md rounded-xl p-6 mb-6 border border-blue-300 hover:shadow-lg transition-shadow")
                            div(class="flex items-center gap-3 mb-4")
                                div(class="bg-blue-100 text-blue-800 text-sm font-semibold px-3 py-1 rounded-full shadow-sm")
                                    i(class="fa fa-university mr-2")
                                    //- | संस्था 
                                    | #{t("gpNotesPage.educationalInstitutesSection.instituteLabel")} 
                                    | #{instituteIndex + 1}
                                h4(class="text-xl font-bold text-blue-900") #{institute.institute_name}

                            h6(class="text-base font-semibold text-blue-700 mb-3 mt-2 flex items-center")
                                i(class="fa fa-users mr-2 text-blue-500")
                                //- | शिक्षक यादी
                                | #{t("gpNotesPage.educationalInstitutesSection.teachersListHeading")}

                            - let staffMembers = institute && institute.staff_members ? institute.staff_members : []

                            if staffMembers && staffMembers.length > 0
                                div(class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4")
                                    each staff in staffMembers
                                        div(class="bg-blue-100 p-4 rounded-lg shadow-sm border border-blue-200 hover:bg-blue-200 transition-colors")
                                            h5(class="text-blue-900 font-semibold text-lg capitalize mb-1") 
                                                i(class="fa fa-user mr-2 text-blue-600")
                                                | #{staff.staff_name}
                                            div(class="flex items-center text-sm text-blue-700 font-medium")
                                                i(class="fa fa-id-badge mr-2 text-blue-500")
                                                span.bg-blue-50.px-2.py-1.rounded.border.border-blue-300
                                                    | #{staff.staff_designation || `${t("gpNotesPage.educationalInstitutesSection.noDesignation")}`}
                                            p(class="text-blue-800 text-sm")
                                                i(class="fa fa-phone mr-2 text-blue-500")
                                                | #{staff.staff_mob_no || `${t("gpNotesPage.educationalInstitutesSection.noMobile")}`}
                            else
                                p(class="text-sm text-red-600 font-medium mt-2") 
                                    //- span शिक्षकांची नोंद उपलब्ध नाही.
                                    span #{t("gpNotesPage.educationalInstitutesSection.noTeachersAvailable")}


block external_js
