extends ../include/index-page-master-layout.pug

block content
    section
        .container
            div(class='gp-general-info-page-heading mt-8')
                h4(class='general-heading sticky text-center text-xl md:text-2xl font-bold text-blue-900 tracking-wider w-fit mx-auto px-8 pb-2 border-b-2 border-blue-900')  
                    i(class='fa-solid fa-pen')
                    span(class='ml-2') 
                        //- | ग्रामपंचायतीची सर्वसाधारण माहिती
                        | #{t("gpNotesPage.generalInfoPageSection.pageTitle")}

                .text-end
                    a(class='px-4 py-2 rounded-md bg-blue-500 text-white font-medium tracking-wider' href='/village/gp-info-print' target='_blank') 
                        //- | प्रिंट काढा
                        | #{t("gpNotesPage.generalInfoPageSection.pageTitle")}

    section(class='py-8 md:py-16 relative')
        .container(class='mx-auto px-4 md:px-8 max-w-6xl space-y-8')

            //- Basic Info Card (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 space-y-2 border border-gray-100')
                div(class='flex items-center space-x-2 mb-4 text-blue-700')
                    svg(xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor' class='w-6 h-6')
                        path(stroke-linecap='round' stroke-linejoin='round' d='M2.25 6.75v10.5a2.25 2.25 0 002.25 2.25h15a2.25 2.25 0 002.25-2.25V6.75M4.5 6.75L12 12.75l7.5-6')
                    h5(class='font-semibold text-lg') 
                        //- | मूलभूत माहिती
                        | #{t("gpNotesPage.basicInfoSection.sectionTitle")}

                - let members = gp && gp.gp_member ? JSON.parse(gp.gp_member) : []

                p(class='text-sm md:text-base font-medium') 
                    //- span Email : -
                    span #{t("gpNotesPage.basicInfoSection.email")}
                - let sarpanchDetails = members && members.length > 0 ? members.find((member) => member && (member.p_name == 'सरपंच')) : null

                p(class='text-sm md:text-base font-medium') #{t("gpNotesPage.basicInfoSection.sarpanchName")} #{sarpanchDetails ? sarpanchDetails.name : '-'}

                - let gramsevakDetails = members && members.length > 0 ? members.find((member) => member && (member.p_name == 'ग्रामसेवक' || member.p_name == 'ग्रामविकास अधिकारी' || member.p_name == 'ग्रामपंचायत अधिकारी')) : null
                
                p(class='text-sm md:text-base font-medium') 
                    //- span ग्रामसेवकाचे नाव : 
                    span #{t("gpNotesPage.basicInfoSection.gramSevakName")}
                    span #{gramsevakDetails ? gramsevakDetails.name : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span ग्रामपंचायतीचा चार्ज घेतल्याचा दिनांक :
                    span #{t("gpNotesPage.basicInfoSection.dateOfTakingCharge")} 
                    #{gp && gp.charge_taken_date ? gp.charge_taken_date : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span सरपंच निवडणूक दिनांक : 
                    span #{t("gpNotesPage.basicInfoSection.sarpanchElectionDate")} 
                    span #{gp && gp.sarpanch_election_date ? gp.sarpanch_election_date : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span मुदत संपण्याची दिनांक : 
                    span #{t("gpNotesPage.basicInfoSection.termEndDate")} 
                    span #{gp && gp.term_end_date ? gp.term_end_date : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span वार्षिक अहवाल दिनांक : 
                    span #{t("gpNotesPage.basicInfoSection.annualReportDate")} 
                    span #{gp && gp.annual_report_date ? gp.annual_report_date : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span अंदाजपत्रक सन 
                    span #{t("gpNotesPage.basicInfoSection.budgetYear")} 
                    span #{gp && gp.budget_year ? gp.budget_year : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span हिशेच तपासणी वर्ष : 
                    span #{t("gpNotesPage.basicInfoSection.auditYear")} 
                    span #{gp && gp.audit_year ? gp.audit_year : '-'}
                p(class='text-sm md:text-base font-medium') 
                    //- span लोकसंख्या सन २०११ च्या जनगणनेनुसार
                    span #{t("gpNotesPage.basicInfoSection.population2011")} 



            //- Population Section (translation done)
            each subVillage in subVillages
                div(class="mb-8")
                    h4.text-xl.font-semibold.text-blue-700.mb-2 #{subVillage.gp_name} 
                        //- span गावाची लोकसंख्या माहिती
                        span #{t("gpNotesPage.populationSection.sectionTitle")}

                    div(class='overflow-x-auto rounded-xl shadow border border-blue-200 bg-white')
                        table(class='table-auto w-full text-sm text-gray-800')
                            thead(class='bg-blue-500 text-white text-left uppercase text-sm')
                                tr
                                    th(class='px-5 py-3 border') 
                                        //- | संवर्ग
                                        | #{t("gpNotesPage.populationSection.category")}
                                    th(class='px-5 py-3 border') 
                                        //- | पुरुष
                                        | #{t("gpNotesPage.populationSection.male")}
                                    th(class='px-5 py-3 border') 
                                        //- | स्त्री
                                        | #{t("gpNotesPage.populationSection.female")}
                                    th(class='px-5 py-3 border') 
                                        //- | एकूण
                                        | #{t("gpNotesPage.populationSection.total")}

                            tbody
                                //- SC
                                tr(class='hover:bg-blue-50')
                                    td(class='border px-5 py-2') 
                                        //- | अनुसूचित जाती (SC)
                                        | #{t("gpNotesPage.populationSection.scheduledCaste")}
                                    td(class='border px-5 py-2') #{subVillage.sc_count_male}
                                    td(class='border px-5 py-2') #{subVillage.sc_count_female}
                                    td(class='border px-5 py-2') #{subVillage.sc_count}

                                //- ST
                                tr(class='hover:bg-blue-50')
                                    td(class='border px-5 py-2') 
                                        //- | अनुसूचित जमाती (ST)
                                        | #{t("gpNotesPage.populationSection.scheduledTribe")}
                                    td(class='border px-5 py-2') #{subVillage.st_count_male}
                                    td(class='border px-5 py-2') #{subVillage.st_count_female}
                                    td(class='border px-5 py-2') #{subVillage.st_count}

                                //- NT
                                tr(class='hover:bg-blue-50')
                                    td(class='border px-5 py-2') 
                                        //- | विमुक्त जाती/भटक्या जमाती (NT)
                                        | #{t("gpNotesPage.populationSection.nomadicTribes")}
                                    td(class='border px-5 py-2') #{subVillage.nt_count_male}
                                    td(class='border px-5 py-2') #{subVillage.nt_count_female}
                                    td(class='border px-5 py-2') #{subVillage.nt_count}

                                //- OBC
                                tr(class='hover:bg-blue-50')
                                    td(class='border px-5 py-2') 
                                        //- | इतर मागासवर्गीय (OBC)
                                        | #{t("gpNotesPage.populationSection.otherBackwardClasses")}
                                    td(class='border px-5 py-2') #{subVillage.obc_count_male}
                                    td(class='border px-5 py-2') #{subVillage.obc_count_female}
                                    td(class='border px-5 py-2') #{subVillage.obc_count}

                                //- Others
                                tr(class='hover:bg-blue-50')
                                    td(class='border px-5 py-2') 
                                        //- | इतर (Open/General)
                                        | #{t("gpNotesPage.populationSection.others")}
                                    td(class='border px-5 py-2') #{subVillage.open_others_count_male}
                                    td(class='border px-5 py-2') #{subVillage.open_others_count_female}
                                    td(class='border px-5 py-2') #{subVillage.open_others_count}

                                //- Total Row (Optional, if you want frontend total)
                                -
                                    let totalMale = subVillage.sc_count_male + subVillage.st_count_male + subVillage.nt_count_male + subVillage.obc_count_male + subVillage.open_others_count_male;
                                    let totalFemale = subVillage.sc_count_female + subVillage.st_count_female + subVillage.nt_count_female + subVillage.obc_count_female + subVillage.open_others_count_female;
                                    let totalAll = subVillage.sc_count + subVillage.st_count + subVillage.nt_count + subVillage.obc_count + subVillage.open_others_count;
                                tr(class='font-bold bg-blue-100 text-blue-900')
                                    td(class='border px-5 py-2') 
                                        //- | एकूण लोकसंख्या
                                        | #{t("gpNotesPage.populationSection.totalPopulation")}
                                    td(class='border px-5 py-2') #{totalMale}
                                    td(class='border px-5 py-2') #{totalFemale}
                                    td(class='border px-5 py-2') #{totalAll}


            //- Other Details Card (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 space-y-2 border border-gray-100')
                - let mainVillageFirst = (subVillages && subVillages[0]) ? subVillages[0] : {}
                p 
                    span वार्ड संख्याः 
                    span #{t("gpNotesPage.otherDetailsSection.wardNumber")}
                    span #{mainVillageFirst.ward_number || '-'}, 
                    //- span एकूण सदस्य :- 
                    span #{t("gpNotesPage.otherDetailsSection.totalMembers")}
                    span #{mainVillageFirst.total_members || '-'}, 
                    //- span जनतेतून सरपंच- 
                    span #{t("gpNotesPage.otherDetailsSection.directlyElectedSarpanch")}
                    span #{mainVillageFirst.sarpanch_directly_elected_count || '-'}
                //- p करः घरपट्टी, दिवाकर, आरोग्य कर, पाणीपट्टी
                p #{t("gpNotesPage.otherDetailsSection.taxes")}
                //- p घरांची संख्या :
                p #{t("gpNotesPage.otherDetailsSection.numberOfHouses")}
                    if subVillages && subVillages.length > 0 

                        for sub_village, subvillageInd in subVillages
                            span #{sub_village.gp_name} - 
                            span #{sub_village.home_count || 0}
                            if subvillageInd != subVillages.length - 1
                                span , 
                //- p क्षेत्रफळ:
                p #{t("gpNotesPage.otherDetailsSection.area")} 
                    if subVillages && subVillages.length > 0
                        for sub_village, subvillageInd in subVillages
                            span #{sub_village.gp_name} - 
                            span #{sub_village.area_in_sq_hectare}
                            if subvillageInd != subVillages.length - 1
                                span ,

                p 
                    //- span मतदार संघ (लोकसभा): 
                    span #{t("gpNotesPage.otherDetailsSection.constituencyLokSabha")}  
                    span #{mainVillageFirst.constituency_number}-#{mainVillageFirst.constituency_name}
                p 
                    //- span विधानसभा: 
                    span #{t("gpNotesPage.otherDetailsSection.assembly")} 
                    span #{mainVillageFirst.assembly_constituency_number}-#{mainVillageFirst.assembly_constituency_name}
                p 
                    //- span Website: 
                    span #{t("gpNotesPage.otherDetailsSection.website")} 
                    a(class='text-blue-600 underline' href=mainVillageFirst.gp_url target='_blank') #{mainVillageFirst.gp_url}

            //- // आरोग्य (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 border border-gray-100')
                h5(class='text-lg font-bold mb-2 text-green-700') 🏥
                    //- span आरोग्य
                    span #{t("gpNotesPage.healthSection.sectionTitle")}

                if subVillages && subVillages.length > 0

                    each subVillage, subVillageInd in subVillages 

                        h6(class='font-semibold mb-1') #{subVillageInd + 1}. #{subVillage.gp_name} 
                            //- span आरोग्य उपकेंद्र
                            span #{t("gpNotesPage.healthSection.sectionTitle")}
                        ul(class='list-disc list-inside text-sm space-y-1')
                            - let healthSubCenters = subVillage && subVillage.health_sub_centers ? JSON.parse(subVillage.health_sub_centers) : []

                            if healthSubCenters && healthSubCenters.length
                                each healthSubCenter, healthSubCenterInd in healthSubCenters
                                    li.pl-4 
                                        //- | आरोग्य उपकेंद्र : 
                                        | #{t("gpNotesPage.healthSection.healthSubCenter")} : 
                                        | #{healthSubCenter.name}
                                        p.ml-4 
                                            //- | आरोग्य सेविकेचे नाव : 
                                            | #{t("gpNotesPage.healthSection.healthWorkerName")} : 
                                            | #{healthSubCenter.worker_name}, 
                                            //- | मो. क्र. 
                                            | #{t("gpNotesPage.healthSection.mobileNumber")}. 
                                            | #{healthSubCenter.worker_contact}

                                    if healthSubCenterInd < healthSubCenters.length - 1
                                        hr

                            else 
                                h6.text-left 
                                    //- span कोणतेही आरोग्य उपकेंद्राची नोंद नाही
                                    span #{t("gpNotesPage.healthSection.noRecord")}

                        if subVillageInd < subVillages.length - 1
                            hr(class='border-t-2 border-gray-400 my-4')

            //- पाणीपुरवठा (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 border border-gray-100')
                h5(class='text-lg font-bold mb-4 text-blue-800') 
                    //- | पाणीपुरवठा
                    | #{t("gpNotesPage.waterSupplySection.sectionTitle")} 
                div(class='overflow-x-auto')
                    table(class='table-auto w-full text-sm text-left text-gray-700 border border-gray-300')
                        thead(class='bg-blue-100 text-blue-900')
                            tr
                                th(class='border px-4 py-2') 
                                    //- | टाकीचे ठिकाण
                                    | #{t("gpNotesPage.waterSupplySection.tankLocation")} 
                                th(class='border px-4 py-2') 
                                    //- | क्षमता
                                    | #{t("gpNotesPage.waterSupplySection.capacity")} 
                                th(class='border px-4 py-2') 
                                    //- | कर्मचारी
                                    | #{t("gpNotesPage.waterSupplySection.staff")} 
                                th(class='border px-4 py-2') 
                                    //- | सामान्य दर
                                    | #{t("gpNotesPage.waterSupplySection.normalRate")} 
                                th(class='border px-4 py-2') 
                                    //- | विशेष दर
                                    | #{t("gpNotesPage.waterSupplySection.specialRate")} 
                        tbody
                            each subVillage in subVillages
                                tr
                                    td(class='border px-4 py-2') #{subVillage.tank_location || '-'}
                                    td(class='border px-4 py-2') #{subVillage.tank_capacity || '-'}
                                    td(class='border px-4 py-2') #{subVillage.staff_in_charge || '-'}
                                    td(class='border px-4 py-2') #{subVillage.normal_rate || '-'}
                                    td(class='border px-4 py-2') #{subVillage.special_rate || '-'}


            //- स्वच्छ भारत मिशन (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 border border-gray-100')
                h5(class='text-lg font-bold mb-4 text-blue-800') 
                    //- span स्वच्छ भारत मिशन
                    span #{t("gpNotesPage.swachhBharatMissionSection.sectionTitle")} 
                div(class='overflow-x-auto')
                    table(class='table-auto w-full text-sm text-left text-gray-700 border border-gray-300')
                        thead(class='bg-blue-100 text-blue-900')
                            tr
                                th(class='border px-4 py-2') 
                                    //- | गाव
                                    | #{t("gpNotesPage.swachhBharatMissionSection.village")} 
                                th(class='border px-4 py-2') 
                                    //- | कुटुंब संख्या
                                    | #{t("gpNotesPage.swachhBharatMissionSection.numberOfHouseholds")} 
                                th(class='border px-4 py-2') 
                                    //- | शौचालय असलेली
                                    | #{t("gpNotesPage.swachhBharatMissionSection.withToilet")} 
                                th(class='border px-4 py-2') 
                                    //- | हागणदारी मुक्ती वर्ष
                                    | #{t("gpNotesPage.swachhBharatMissionSection.openDefecationFreeYear")} 
                                th(class='border px-4 py-2') 
                                    //- | शेरा
                                    | #{t("gpNotesPage.swachhBharatMissionSection.remarks")} 
                        tbody
                            each subVillage in subVillages
                                tr
                                    td(class='border px-4 py-2') #{subVillage.gp_name || '-'}
                                    td(class='border px-4 py-2') #{subVillage.number_of_households || '-'}
                                    td(class='border px-4 py-2') #{subVillage.number_of_households_having_toilets || '-'}
                                    td(class='border px-4 py-2') #{subVillage.open_defecation_free_year || '-'}
                                    td(class='border px-4 py-2') #{subVillage.odf_plus_remarks || '-'}



            //- सांडपाणी व घनकचरा व्यवस्थापन (translation done)
            div(class='bg-white shadow-lg rounded-xl p-6 border border-gray-100')
                h5(class='text-lg font-bold mb-4 text-blue-800') 
                    //- | सांडपाणी व घनकचरा व्यवस्थापन
                    | #{t("gpNotesPage.wasteManagementSection.sectionTitle")}
                div(class='overflow-x-auto')
                    table(class='table-auto w-full text-sm text-left text-gray-700 border border-gray-300')
                        thead(class='bg-blue-100 text-blue-900')
                            tr
                                th(class='border px-4 py-2') 
                                    //- | गाव
                                    | #{t("gpNotesPage.wasteManagementSection.village")}
                                th(class='border px-4 py-2') 
                                    //- | कुटुंब संख्या
                                    | #{t("gpNotesPage.wasteManagementSection.numberOfHouseholds")}
                                th(class='border px-4 py-2') 
                                    //- | जोडलेले कुटुंब
                                    | #{t("gpNotesPage.wasteManagementSection.connectedHouseholds")}
                                th(class='border px-4 py-2') 
                                    //- | शोषखड्डे
                                    | #{t("gpNotesPage.wasteManagementSection.soakPits")}
                                th(class='border px-4 py-2') 
                                    //- | व्यवस्थापन
                                    | #{t("gpNotesPage.wasteManagementSection.management")}
                        tbody
                            each subVillage in subVillages
                                tr
                                    td(class='border px-4 py-2') #{subVillage.gp_name || '-'}
                                    td(class='border px-4 py-2') #{subVillage.number_of_households || '-'}
                                    td(class='border px-4 py-2') #{subVillage.households_connected_to_waste_management || '-'}
                                    td(class='border px-4 py-2') #{subVillage.soak_pits || '-'}
                                    td(class='border px-4 py-2') #{subVillage.waste_management || '-'}



            //- आदर्श तक्ता  (Ideal Table) (translation done)
            div(class="mt-8 px-4")
                h5(class="text-2xl font-semibold text-center text-blue-800 mb-2") 
                    //- | ग्रामपंचायत 
                    | #{t("gp.gpName")}
                    | #{gp && gp.gp_name ? gp.gp_name : '-'} 
                    //- | ता. 
                    | #{t("gp.talukaAbb")}. 
                    | #{gp && gp.gp_taluka ? gp.gp_taluka : '-'}, 
                    //- | जि. 
                    | #{t("gp.distAbb")}. 
                    | #{gp && gp.gp_dist ? gp.gp_dist : '-'}

                h5(class="text-xl text-center font-bold text-blue-700 mb-4") 
                    span "
                    //- span आदर्श तक्ता
                    span #{t("gpNotesPage.idealTableSection.sectionTitle")}
                    span " 

                - let adarshTakta = (gp && gp.ps_gram_adarsh_takta) ? JSON.parse(gp.ps_gram_adarsh_takta) : {}

                if Object.keys(adarshTakta).length > 0
                    div(class="overflow-x-auto")
                        table(class="w-full table-auto border border-blue-300 rounded-md shadow-sm")
                            thead
                                tr(class="bg-blue-100 text-blue-800")
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | अ. क्र.
                                        | #{t("gpNotesPage.idealTableSection.serialNo")} 
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | विवरण
                                        | #{t("gpNotesPage.idealTableSection.description")}
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | संख्या
                                        | #{t("gpNotesPage.idealTableSection.number")}

                            tbody
                                each key, taktaIndex in Object.keys(adarshTakta)
                                    tr(class="odd:bg-white even:bg-blue-50")
                                        td(class="px-4 py-2 border border-blue-200") #{taktaIndex + 1}
                                        td(class="px-4 py-2 border border-blue-200") #{key}
                                        td(class="px-4 py-2 border border-blue-200") #{adarshTakta[key] || '-'}
                else
                    p(class="text-center text-red-600 mt-2") 
                        //- | अद्याप आदर्श तक्त्याची माहिती उपलब्ध नाही.
                        | #{t("gpNotesPage.idealTableSection.noInfo")}



            //- ग्रामपंचायत कार्यकारिणी (GP Committee) (translation done)
            div(class="mt-8 px-4")
                h5(class="text-xl font-semibold text-center text-blue-800 mb-2") 
                    //- | ग्रामपंचायत 
                    | #{t("gp.gpName")}
                    | #{gp && gp.gp_name ? gp.gp_name : '-'} 
                    //- | ता. 
                    | #{t("gp.talukaAbb")}. 
                    | #{gp && gp.gp_taluka ? gp.gp_taluka : '-'}, 
                    //- | जि. 
                    | #{t("gp.distAbb")}. 
                    | #{gp && gp.gp_dist ? gp.gp_dist : '-'}

                h5(class="text-xl text-center font-bold text-blue-700 mb-4") 
                    span "
                    //- span ग्रामपंचायत कार्यकारिणी
                    span #{t("gpNotesPage.gpCommitteeSection.sectionTitle")}
                    span " 


                if mainGpMembers && mainGpMembers.length > 0
                    div(class="overflow-x-auto")
                        table(class="w-full table-auto border border-blue-300 rounded-md shadow-sm")
                            thead
                                tr(class="bg-blue-100 text-blue-800")
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | अ. क्र.
                                        | #{t("gpNotesPage.gpCommitteeSection.serialNo")}
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | सदस्याचे नाव
                                        | #{t("gpNotesPage.gpCommitteeSection.memberName")}
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | पद
                                        | #{t("gpNotesPage.gpCommitteeSection.position")}
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | प्रवर्ग
                                        | #{t("gpNotesPage.gpCommitteeSection.category")}
                                    th(class="px-4 py-2 text-left border border-blue-300") 
                                        //- | मो. नं.
                                        | #{t("gpNotesPage.gpCommitteeSection.mobileNumber")}

                            tbody
                                each member, index in mainGpMembers
