  style.
    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    body{
      
      height:100vh;
    }

    @media (max-width: 768px){
      tr, td, thead {
        font-size: 0.8rem;
      }
    }
    @media (min-width: 576px) {
    .modal-dialog { max-width: none; }
      }
      .modal-dialog {
        width: 98%;
        height: 92%;
        padding: 0;
      }
body
  include ../include/navs.pug
  .container-fluid
    .row.p-0.p-1.pt-3
      .col-12
        center
          a(href="/meter").float-right.btn.btn-success.btn-sm.mr-2 ग्राहक यादी
          a(href="/meter/add-new-user").float-right.btn.btn-primary.btn-sm.mr-2 नवीन ग्राहक जोडा
          h5.font-weight-bold.m-3 ग्राहक मीटर यादी
      .col-12
        div.table-responsive
          table.table.table-bordered.text-center.m-0
            thead
              tr.bg-primary.text-white
                th(width="8%") अनु क्र.
                th(width="10%") नळ क्रमांक
                th(width="10%") वाल क्रमांक
                th(width="25%") ग्राहक नाव
                th(width="8%") युनिट्स
                th(width="10%") तारखेच्या आत भरणा
                th(width="10%") तारखेच्या आत भरणा
                th(width="8%") रद्द करा

            tbody#marriageList
              if(list.length == 0)
                tr
                  td(colspan="15").text-center.text-danger ग्राहक मीटर यादी यादी रिकामी आहे
              else
                each value,index in list
                  tr.text-left
                    td(width="8%").text-center #{value.id}
                    td(width="10%").text-center #{value.mbl_nal_number}
                    td(width="10%").text-center #{value.mbl_valve_number}
                    td(width="25%") #{value.mbl_user_name}
                    td(width="8%").text-center #{value.mbl_total_unit}
                    td(width="10%").text-center #{value.mbl_deyak_date}
                    td(width="10%").text-center #{value.mbl_deyak_amt_fill_last_date}
                    td(width="8%").text-center 
                      - var href="/meter/remove-meter/"+value.id;
                      a(href=href).text-danger
                        span.fa.fa-trash
