    style.
        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#f0d688 !important;
        }
        body{
            
            height:100vh;
        }

        @media (max-width: 768px){
            td, th, thead {
                font-size: 0.8rem;
            }
        }
        @media (min-width: 576px) {
        .modal-dialog { max-width: none; }
            }
            .modal-dialog {
                width: 98%;
                height: 92%;
                padding: 0;
            }
body
    include ../include/navs.pug
    .container-fluid
        .row.p-0.p-1.pt-3
            .col-12
                center
                    a(href="/meter/tap-connection-form").float-right.btn.btn-primary.btn-sm.mr-2 नवीन ग्राहक जोडा
                    a(href="/watertax").float-right.btn.btn-primary.btn-sm.mr-2 पाणी कर भरा 
                    a(href="/meter").float-right.btn.btn-primary.btn-sm.mr-2 मीटर मेन्यूू
                    h5.font-weight-bold.m-3 नळ यादी 
            .col-12
                div.table-responsive
                    table.table.table-bordered.text-center.m-0
                        thead
                            tr.bg-primary.text-white
                                th(width="8%") अर्ज क्रमांक
                                th(width="25%") ग्राहक नाव
                                th(width="15%") मो. क्रमांक

                                th(width="15%") नळ क्रमांक
                                th(width="10%") वॉल्व्ह क्रमांक
                                //- th(width="10%") मागील विशेष पाणी कर
                                //- th(width="10%") मागील सामान्य पाणी कर
                                th(width="10%") करा
                        tbody
                            if(taplist.length == 0)
                                tr
                                    td(colspan="15").text-center.text-danger यादी रिकामी आहे
                            else
                                each entry,index in taplist
                                    tr
                                        td(width="8%") #{index+1}
                                        td(width="25%") #{entry.name}
                                        td(width="15%") #{entry.mobile}
                                        td(width="15%") #{entry.id}  
                                        td(width="10%") #{entry.valve_number}
                                        //- td(width="10%") #{entry.last_special_water_tax}
                                        //- td(width="10%") #{entry.last_general_water_tax}
                                        td(width="10%")
                                            .d-flex.align-items-center.justify-content-center
                                                - var href=`/meter/edit-tap-connection/${entry.id}`;
                                                a(href=href).text-success.d-inline-block
                                                    i.fa.fa-pencil-square.fa-2x
                                                //- - var href=`/meter/edit-tap-connection/${entry.id}`;
                                                //- a(href=href title="भरणा करा").text-danger
                                                //-     i.fa.fa-download.fa-2x
