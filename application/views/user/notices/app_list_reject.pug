  style.
    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    body{
      
      height:100vh;
    }
    @media (min-width: 576px) {
    .modal-dialog { max-width: none; }
      }
      .modal-dialog {
        width: 50%;
        height: 92%;
        padding: 0;
      }
body
    include ../include/navs.pug
    .container-fluid
        .row
          .col-12.mt-3
              h4.ml-5.text-center
                span.fa.fa-users
                | अर्ज रद्द यादी
              div.float-right.mb-2
               a(href="/application").btn.btn-primary.btn-sm नवीन अर्ज यादी 
                a(href="/application/accepted").btn.btn-success.btn-sm.ml-2 मान्य यादी
               
          .col-12
              table.table.table-bordered.text-center
                  thead
                    tr.bg-danger.text-white
                        th(width="8%") अर्ज क्रमांक
                        th(width="15%") नाव
                        th(width="13%") मो. क्रमांक
                        th(width="25%") ई-मेल
                        th(width="10%") आधार क्रमांक
                        th(width="15%") दाखले मागणी
                        th(width="8%") दिनांक
                  tbody#marriageList
                    if(list.length == 0)
                      tr
                        td(colspan="15").text-center.text-danger अर्ज रद्द नोंदणी यादी रिकामी आहे
                    else
                      each value,index in list
                        tr
                          td #{value.id}
                          td #{value.formName}
                          td #{value.formMobile}
                          td #{value.formEmail}
                          td #{value.formAadhar}
                          td 
                            small #{value.docName}
                          td 
                            span #{value.create_date}
    script.
      $(function(){
        newApplicationList = !{json_list};
        console.log(newApplicationList);
      })
