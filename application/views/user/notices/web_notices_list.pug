  style.
    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    body{
      
      height:100vh;
    }
    @media (min-width: 576px) {
    //- .modal-dialog { max-width: none; }
      }
      .modal-dialog {
        width: 50%;
        height: 92%;
        padding: 0;
      }
    @media (max-width: 768px){
      .modal-dialog {
