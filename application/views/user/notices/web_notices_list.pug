    }
body
  include ../include/navs.pug
  .modal#masterWebNotice(tabindex='-1' role='dialog')
    .modal-dialog(role='document' style='margin-inline:auto; ')
      .modal-content
        .modal-header
          h5.modal-title title
          button.close(type='button' data-dismiss='modal' aria-label='Close')
            span(aria-hidden='true') ×
        .modal-body 
          .row
            .col-12
              form
                .row
                  .form-group.col-12
                    label(for='comment') वेब नोटीस:
                    textarea#webNoticeText.form-control(rows='5' placeholder="नोटिस मजकूर इथे लिहा")
                  .form-group.col-12.text-center
                    button#saveWebNotice.btn.btn-primary.mb-2(type='submit') जतन करा


  .container-fluid
    .row
      .col-12.mt-3
        h4.ml-5.text-center
          span.fa.fa-users.mr-1
          |  ग्रामपंचायत वेब नोटीस
        div.d-inline-block.float-right.mb-2
          button#newWebNotice.btn.btn-success.btn-sm.ml-2 वेब नोटीस जोडा
      .col-12
        .table-responsive
          table.table.table-bordered.text-center
            thead
              tr.bg-warning.text-dark
                th(width="8%") अर्ज क्रमांक
                th(width="30%") नोटीस
                th(width="10%") मुख्य पानावर दर्शवा
                th(width="10%") दिनांक
                th(width="10%") अधिक करा
            tbody#noticeList
              if(list.length == 0)
                tr
                  td(colspan="15").text-center.text-danger ग्रामपंचायत सभा यादी रिकामी आहे
              else
                each notice,index in list
                  tr
                    td #{notice.id}
                    td.text-left #{notice.notice}
                    td
                      if(notice.show_type == 1)
                        a(href="/web-notice/visibility?v=0&id="+notice.id).btn.btn-outline-primary
                          i.fa.fa-eye
                      else
                        a(href="/web-notice/visibility?v=1&id="+notice.id).btn.btn-outline-secondary
                          i.fa.fa-eye-slash

                    td #{notice.date_1}
                    td 
                      a(href="/web-notice/remove?id="+notice.id).btn.btn-outline-danger
                        i.fa.fa-trash

