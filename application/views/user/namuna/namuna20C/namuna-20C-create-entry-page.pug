doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')

    // Common CSS
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // Common JS setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-20c/namuna-20c-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-20c/namuna-20c-create-entry-page-handler.js' type='module' defer)

    title नमुना २० (क) - मोजमाप वही नोंदणी

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    -
      const months = [
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
        "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
      ]

    .container
      h2.heading-1.mt-1.mb-2 नमुना २० (क) - मोजमाप वही नोंदणी

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/20/c') यादी

      form(id='namuna-20c-form').mt-1
        .form.form-1
          .row.justify-content-center.justify-content-md-between.gx-4.gy-2

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  each month, monthIndex in months
                    option(value=(monthIndex + 1)) #{month}

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="measurement") मोजमाप
                input.form-control(type="text" id="measurement" name="measurement" required placeholder="उदाहरण: क्षेत्रफळ, लांबी, रुंदी")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="work_description") कामाचे वर्णन
                input.form-control(type="text" id="work_description" name="work_description" required placeholder="कामाचे वर्णन, शक्य असल्यास वक्षेत्राचे प्राधिकारी यांचे नाव")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="subhead") कामाचे उपशीर्ष
                input.form-control(type="text" id="subhead" name="subhead" placeholder="कामाचे उपशीर्ष")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="sector_authority_name") क्षेत्राचे प्राधिकाराचे नाव
                input.form-control(type="text" id="sector_authority_name" name="sector_authority_name" placeholder="क्षेत्राचे प्राधिकाराचे नाव")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="unit") परिमाण
                input.form-control(type="text" id="unit" name="unit" required placeholder="परिमाण")

            //- --------------------------

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="height") उंची 
                input.form-control(type="number" step="0.01" id="height" name="height" required placeholder="उदा. 11")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="length") लांबी
                input.form-control(type="number" step="0.01" id="length" name="length" required placeholder="उदा. 22")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="width") रुंदी 
                input.form-control(type="number" step="0.01" id="width" name="width" required placeholder="उदा. 11")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="depth_or_elevation") खोली / उंची 
                input.form-control(type="number" step="0.01" id="depth_or_elevation" name="depth_or_elevation" required placeholder="उदा. 29")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="total") एकूण 
                input.form-control(type="number" step="0.01" id="total" name="total" required placeholder="उदा. 29")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="total_measurement") एकूण परिमाण
                input.form-control(type="number" step="0.01" id="total_measurement" name="total_measurement" required placeholder="उदा. 29")


            //- 
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="total_quantity") एकूण माप
                input.form-control(type="number" step="0.01" id="total_quantity" name="total_quantity" required placeholder="एकूण माप")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="grand_total") संपूर्ण एकूण
                input.form-control(type="text" id="grand_total" name="grand_total" required placeholder="उदा. 8000")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="rate") दर 
                input.form-control(type="text" id="rate" name="rate" required placeholder="दर")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="amount") रक्कम 
                input.form-control(type="text" id="amount" name="amount" required placeholder="रक्कम")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-20c-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
