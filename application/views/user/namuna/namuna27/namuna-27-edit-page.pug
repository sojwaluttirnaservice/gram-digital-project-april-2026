doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-27/namuna-27-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-27/namuna-27-create-entry-page-handler.js' type='module' defer)

    title नमुना २७ - लेखापरीक्षणातील आक्षेपांच्या पूर्ततेचे मासिक विवरण
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug
    - 
      const months = [
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
        "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
      ]
    .container
      h2.heading-1.mt-2.mb-1 Edit नमुना २७ - लेखापरीक्षणातील आक्षेपांच्या पूर्ततेचे मासिक विवरण

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/27') यादी

      form(id='namuna-27-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना २७ नोंदणी

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  each month, monthIndex in months
                    option(value=(monthIndex + 1) selected = ((monthIndex + 1) == namuna27Entry.month ? true: false)) #{month}

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="audit-report-year") लेखापरीक्षण अहवालाचे वर्ष
                input.form-control(type="number" id="audit-report-year" name="audit_report_year" required placeholder="वर्ष" value=namuna27Entry.audit_report_year)

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="paragraph-number") परिच्छेद क्रमांक
                input.form-control(type="text" id="paragraph-number" name="paragraph_number" required placeholder="परिच्छेद क्रमांक" value=namuna27Entry.paragraph_number)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="paragraphs-resolved-by-gp") ग्रामपंचायतीने पूर्तता केलेले परिच्छेद
                input.form-control(type="number" id="paragraphs-resolved-by-gp" name="paragraphs_resolved_by_gp" required placeholder="ग्रामपंचायतीने पूर्तता केलेले परिच्छेद" value=namuna27Entry.paragraphs_resolved_by_gp)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="objections-resolved-by-committee") पंचायत समितीने आक्षेपाद्वारे मान्य केलेली पूर्तता संख्या
                input.form-control(type="number" id="objections-resolved-by-committee" name="objections_resolved_by_committee" required placeholder="पंचायत समितीने आक्षेपाद्वारे मान्य केलेली पूर्तता" value=namuna27Entry.objections_resolved_by_committee)

            .col-11.col-md-6.col-lg-8
              .form-group
                label.form-label(for="objections-resolved-by-auditor") लेख परीक्षकांनी ज्या बाबतीत पूर्तता मान्य केली आहे त्या आक्षेपांची संख्या
                input.form-control(type="number" id="objections-resolved-by-auditor" name="objections_resolved_by_auditor" required placeholder="लेख परीक्षकान्ने मान्य केलेली पूर्तता" value=namuna27Entry.objections_resolved_by_auditor)

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="pending-objections") प्रलंबित असलेल्या आक्षेपांची संख्या
                input.form-control(type="number" id="pending-objections" name="pending_objections" required placeholder="प्रलंबित आक्षेप" value=namuna27Entry.pending_objections)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="reasons-for-non-compliance") पुर्तता न केल्याबद्दलाची कारणे
                textarea.form-control(id="reasons-for-non-compliance" name="reasons_for_non_compliance" rows="3" placeholder="पुर्तता न केल्याबद्दल कारणे") #{namuna27Entry.reasons_for_non_compliance}

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा
                textarea.form-control(id="remarks" name="remarks" rows="3" placeholder="शेरा") #{namuna27Entry.remarks}

                input(name='id' value=namuna27Entry.id hidden)

          .d-flex.gap-4.justify-content-center
            button.btn.btn-success(type='button' id="update-namuna-27-entry") Update 
            button.btn.btn-secondary(type='reset' id='reset') Reset
