doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-29/namuna-29-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-29/namuna-29-installment-create-entry-page-handler.js' type='module' defer)

    title Edit नमुना २९ Installment
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug
    - 
      const months = [
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
        "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
      ]
    .container
      h2.heading-1.mt-2.mb-1 Edit नमुना २९ Installment

      div

        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/29') कर्ज यादी
          a.btn.btn-primary(href=`/namuna/29/installment/history/${namuna29InstallmentEntry.namuna_29_loan_id}`) Installment History 


      if namuna29InstallmentEntry

        form(id='namuna-29-installment-form').mt-1
          .form.form-1
            //- h4.text-center.fw-bold नमुना १८ नोंदणी

            .row.justify-content-center.justify-content-md-between.gx-4.gy-2
              .col-11.col-md-6.col-lg-2
                .form-group
                  label.form-label(for="installment_month") महिना
                  select.form-select(id="installment_month" name="installment_month" required)
                    option(value='') --निवडा--
                    each month, monthIndex in months 
                      option(value=(monthIndex + 1) selected = (((monthIndex + 1) == namuna29InstallmentEntry.installment_month) ? true: false))=month

              .col-11.col-md-6.col-lg-2
                .form-group
                  label.form-label(for="installment_year") वर्ष
                  select.form-select(id="installment_year" name="installment_year" required)
                    option(value='') --निवडा--
                    - let currentYear = new Date().getFullYear()
                    - let startYear = currentYear - 25
                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                      option(value=year selected = ((year == namuna29InstallmentEntry.installment_year) ? true: false)) #{year}

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="installment_principal") प्रत्येक हफ्त्यातील मुद्दलीची कर्ज रक्कम
                  input.form-control(type="number" id="installment_principal" name="installment_principal" required placeholder="" value=namuna29InstallmentEntry.installment_principal)

              //- Doubtness
              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="installment_interest_amount") प्रत्येक हफ्त्यातील मुद्दलीची व्याज रक्कम
                  input.form-control(type="number" id="installment_interest_amount" name="installment_interest_amount" required placeholder="" value=namuna29InstallmentEntry.installment_interest_amount)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="disbursement_date") प्रदानाची दिनांक
                  input.form-control.datepicker(id="disbursement_date" name="disbursement_date" required placeholder="" value=namuna29InstallmentEntry._disbursement_date)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="disbursement_principal") प्रदानाची मुद्दल
                  input.form-control(type="number" id="disbursement_principal" name="disbursement_principal" required placeholder="" value=namuna29InstallmentEntry.disbursement_principal)

              //- 
              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="disbursement_interest") प्रदानाची व्याज
                  input.form-control(type="number" id="disbursement_interest" name="disbursement_interest" required placeholder="" value=namuna29InstallmentEntry.disbursement_interest)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="total_balance") एकूण शिल्लक रक्कम
                  input.form-control(type="number" id="total_balance" name="total_balance" placeholder="" value=namuna29InstallmentEntry.total_balance)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="balance_principal") शिल्लक मुद्दल
                  input.form-control(type="number" id="balance_principal" name="balance_principal" required placeholder="" value=namuna29InstallmentEntry.balance_principal)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="balance_interest") शिल्लक व्याज
                  input.form-control(type="number" id="balance_interest" name="balance_interest" required placeholder="" value=namuna29InstallmentEntry.balance_interest)

              .col-11.col-md-12.col-lg-12
                .form-group
                  label.form-label(for="remarks") शेरा
                  input.form-control(type="text" id="remarks" name="remarks" required placeholder="" value=namuna29InstallmentEntry.remarks)

                  input(name='namuna_29_loan_id_fk' value=namuna29InstallmentEntry.namuna_29_loan_id_fk hidden)

                  input(name='id' value=namuna29InstallmentEntry.id hidden)


          .d-flex.gap-4.justify-content-center
            button.btn.btn-success(type='button' id="update-namuna-29-installment-entry") Update
            button.btn.btn-secondary(type='reset' id='reset') Reset             
      else 
        h4.fw-bold.text-center संबंधित नोंद उपलब्ध नाही

