    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-29/namuna-29-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-29/namuna-29-installment-create-entry-page-handler.js' type='module' defer)


    title नमुना २९ - मुद्दल भरणा (Installment) 
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना २९ - कर्जाची नोंदवही


      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/29') कर्ज यादी
          a.btn.btn-primary(href=`/namuna/29/installment/history/${namuna29Entry.id}`) Installment History 


      form(id='namuna-29-installment-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना १८ नोंदणी
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") मुद्दल भरणा (Installment) 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="installment_month") महिना
                select.form-select(id="installment_month" name="installment_month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="installment_year") वर्ष
                select.form-select(id="installment_year" name="installment_year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="installment_principal") प्रत्येक हफ्त्यातील मुद्दलीची कर्ज रक्कम
                input.form-control(type="number" id="installment_principal" name="installment_principal" required placeholder=" ")

            //- Doubtness
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="installment_interest_amount") प्रत्येक हफ्त्यातील मुद्दलीची व्याज रक्कम
                input.form-control(type="number" id="installment_interest_amount" name="installment_interest_amount" required placeholder=" ")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="disbursement_date") प्रदानाची दिनांक
                input.form-control.datepicker(id="disbursement_date" name="disbursement_date" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="disbursement_principal") प्रदानाची मुद्दल
                input.form-control(type="number" id="disbursement_principal" name="disbursement_principal" required placeholder="")

            //- 
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="disbursement_interest") प्रदानाची व्याज
                input.form-control(type="number" id="disbursement_interest" name="disbursement_interest" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="total_balance") एकूण शिल्लक रक्कम
                input.form-control(type="number" id="total_balance" name="total_balance" placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="balance_principal") शिल्लक मुद्दल
                input.form-control(type="number" id="balance_principal" name="balance_principal" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="balance_interest") शिल्लक व्याज
                input.form-control(type="number" id="balance_interest" name="balance_interest" required placeholder="")

            .col-11.col-md-12.col-lg-12
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(type="text" id="remarks" name="remarks" required placeholder="")

                input(name='namuna_29_loan_id_fk' value=namuna29Entry.id hidden)





          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-29-installment-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
