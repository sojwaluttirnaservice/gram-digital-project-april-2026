doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title नमुना ३२ प्रिंट

        style.

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            table{
                border-collapse:  collapse;
            }

            tr, th, td{
                border: 1px solid gray;
            }

            th, td {
                padding: 0.2rem 0.4rem;
                text-align: center;
            }

            #hide-buttons{
                button{
                    position: fixed;
                    top: 48%;
                    left: 1rem;
                    background: blue;
                    padding: 0.2rem 0.4rem;
                    color: white;
                }
            }


            /* Print-specific styles */
            @media print {
                //- @page {
                //-     size:A4 portrait; /* Forces vertical orientation */
                //- }
                .my-print {
                    page-break-before: always; /* Forces new page for each entry */
                    size:A4 portrait;
                }
                body {
                    margin: 0; /* Removes default margin for printing */
                    height: 100%;
                }
                tr {
                    break-inside: avoid; /* Prevents table rows from breaking across pages */
                    page-break-inside: avoid; /* For compatibility with older browsers */
                }
                #hide-buttons {
                    display:none;
                }
            }

        link(rel='stylesheet' href='/asstest/coustom/css/namuna/namuna-1-to-33-print.css')

    body
        - const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"]
        #hide-buttons 

            button(type='button' onclick='window.print()') Print



        if namuna32Details

            each namuna32Entry in namuna32Details


                .my-print

                    div(style='width: 100%;height: 100%;padding: 2rem 4rem; display: flex; flex-direction: column; align-items: center; justify-content: space-between; gap: 2rem;')

                        each _ in [1, 2]

                            div(style='wdith: 100%;')

                                div(style='border: 1px solid black; padding: 1rem;')

                                    div
                                        div(style='display: flex; align-items: center; justify-content: space-between;')

                                            div नमुना ३२

                                            div ग्रामपंचायत कार्यालय 
                                                span #{gp.gp_name}
                                            div
                                                img(src="/new-gp-page/main-page/images/header-images/mudra-nav-2.png" style='width: 100px;')

                                        div 
                                            div.text-center(style='font-size:10px;') महा. ग्रा. पं. लेखा संहिता २०११ (नियम २४(क) (३) पहा)


                                    div(style='border:1px solid black;border-top: 6px solid black;border-bottom: 6px solid black; padding: 1rem 0.5rem;text-align: center; font-weight: bold;')
                                        | रकमेच्या परताव्यासाठीचा आदेश #{namuna32Entry.amount_refund_order} प्रमाणक क्रमांक #{namuna32Entry.certificate_number}

                                    table 
                                        thead
                                            tr 
                                                th पावती क्रमांक
                                                th दिलेल्या मूळ रक्कम दिनांक
                                                th रक्कम
                                                th परत करावयाची रक्कम

                                                th ठेविदाराचे नाव
                                                th परतावा करणाऱ्या करणाऱ्याचे नाव
                                                th ठिकाण


                                            tr 
                                                each marathiNum in ['१', '२', '३', '४', '५', '६', '७']
                                                    th #{marathiNum}
                                        tbody 

                                            tr 
                                                td #{namuna32Entry.receipt_number}
                                                td #{namuna32Entry._given_original_amount_date}
                                                td #{namuna32Entry.amount}
                                                td #{namuna32Entry.amount_to_return}

                                                td #{namuna32Entry.depositor_name}
                                                td #{namuna32Entry.refund_person_name}
                                                td #{namuna32Entry.location}




                                    div 
                                        div(style='margin-top: 2rem;')
                                            p श्री #{namuna32Entry.dddddddddddd} यांस रुपये ( /-) (अक्षरी) दिले. 
                                                | रूपये (#{namuna32Entry.dddddddddddd}) (अक्षरी) #{namuna32Entry.dddddddddddd} इतकी रक्कम 
                                                | #{namuna32Entry.dddddddddddd} या ठिकाणी दिनांक #{namuna32Entry.dddddddddddd} रोजी मिळाली 

                                        div
                                            div(style='padding-top: 5rem; width: 100%; display: flex; align-items: center; justify-content: space-evenly;')
                                                p सचिव
                                                p रक्कम स्वीकारण्याची सही
                                                P सरपंच

        else 
            h3(style='text-align:center; margin-top:3rem; font-size:2rem;') सदर महिना #{month} व वर्ष #{year} साठी नोंद उपलब्ध नाही 
