doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-19-employee/namuna-19-employee-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-19-employee/namuna-19-employee-create-entry-page-handler.js' type='module' defer)


    title Edit नमुना १९ - कामावर असलेल्या व्यक्तीचा हजेरीपट
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    h2.heading-1.mt-2.mb-1 Edit नमुना १९ - कामावर असलेल्या व्यक्तीचा हजेरीपट
    if !namuna19EmployeeEntry
      h2.text-center.fw-bold सदर नोंदणी उपलब्ध नाही

    else
      .container

        div 
          .d-flex.align-items-center.justify-content-end(style='gap: 1rem;')
            div
              a.btn.btn-primary.btn-sm(href='/namuna/19/employees')
                .d-flex.gap-2.align-items-center
                  <i class="fa fa-plus"></i>
                  | कर्मचारी यादी 
            a.btn.btn-primary.btn-sm(href='/namuna') नमुने
            button.btn.btn-secondary.btn-sm(type="button" onclick="window.history.back()") मागे जा


        form(id='namuna-19-employee-form').mt-1
          .form.form-1
            //- h4.text-center.fw-bold नमुना १९ - कर्मचारी नोंदणी
            h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना १९ कर्मचारी नोंदणी


            .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
              //- .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="month") महिना
                  select.form-select(id="month" name="month" required)
                    option(value='') --निवडा--
                    option(value="1") ०१ (जानेवारी)
                    option(value="2") ०२ (फेब्रुवारी)
                    option(value="3") ०३ (मार्च)
                    option(value="4") ०४ (एप्रिल)
                    option(value="5") ०५ (मे)
                    option(value="6") ०६ (जून)
                    option(value="7") ०७ (जुलै)
                    option(value="8") ०८ (ऑगस्ट)
                    option(value="9") ०९ (सप्टेंबर)
                    option(value="10") १० (ऑक्टोबर)
                    option(value="11") ११ (नोव्हेंबर)
                    option(value="12") १२ (डिसेंबर)

              //- .col-11.col-md-6.col-lg-2
                .form-group
                  label.form-label(for="year") वर्ष
                  select.form-select(id="year" name="year" required)
                    option(value='') --निवडा--
                    - let currentYear = new Date().getFullYear()
                    - let startYear = currentYear - 25
                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                      option(value=year) #{year}

              //- .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="date") दिनांक
                  input.form-control.datepicker(type="text" id="date" name="date" required placeholder="दिनांक")

              .col-11.col-md-6.col-lg-7
                .form-group
                  label.form-label(for="name") कर्मचाऱ्याचे नाव
                  input.form-control(type="text" id="name" name="name" required value=namuna19EmployeeEntry.name placeholder="नाव")

              .col-11.col-md-12.col-lg-3.d-none
                .form-group
                  label.form-label(for="post-id") पद
                  input.form-control(id="post-id" name="post_id" value=namuna19EmployeeEntry.post_id placeholder="पद")


              .col-11.col-md-12.col-lg-5
                .form-group
                  label.form-label(for="post-name") पदाचे नाव
                  input.form-control(id="post-name" name="post_name" value=namuna19EmployeeEntry.post_name required placeholder="पदाचे नाव")

              .col-11.col-md-12.col-lg-5
                .form-group
                  label.form-label(for="mobile") मोबाईल
                  input.form-control(id="mobile" name="mobile" required maxlength='10' value=namuna19EmployeeEntry.mobile placeholder="")

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="monthly-salary") महिन्याचे वेतन
                  input.form-control(id="monthly-salary" name="monthly_salary" value=namuna19EmployeeEntry.monthly_salary required placeholder="उदा. 24000")

              .col-11.col-md-12.col-lg-2
                .form-group
                  label.form-label(for="gender") लिंग
                  select.form-select(id="gender" name="gender" required placeholder="")
                    option(value='') -- निवडा --
                    option(value='Male' selected= (namuna19EmployeeEntry.gender == 'Male')) पुरुष
                    option(value="Female" selected = (namuna19EmployeeEntry.gender == 'Female')) स्त्री
                    option(value="Other" selected = (namuna19EmployeeEntry.gender == "Other")) इतर

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="state-share") राज्याचा हिस्सा 
                  input.form-control(type="number" id="state-share" name="state_share" value=namuna19EmployeeEntry.state_share required placeholder="")

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="pf-cutting-percentage") पीएफ कपात टक्केवारी
                  input.form-control(id="pf-cutting-percentage" type='number' name="pf_cutting_percentage"  value=namuna19EmployeeEntry.pf_cutting_percentage placeholder="")


              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="grampanchayat-share") ग्रामपंचायत हिस्सेदारी 
                  input.form-control(id="grampanchayat-share" name="grampanchayat_share" value=namuna19EmployeeEntry.grampanchayat_share  placeholder="")

              .col-11.col-md-6.col-lg-6
                .form-group
                  label.form-label(for="address") पत्ता
                  textarea.form-control( id="address" name="address" required placeholder="पत्ता") #{ namuna19EmployeeEntry.address}

              .col-11.col-md-12.col-lg-6
                .form-group
                  label.form-label(for="remarks") शेरा
                  textarea.form-control(id="remarks" name="remarks" placeholder="टीप" ) #{namuna19EmployeeEntry.remarks}
                  input(name='id' value=namuna19EmployeeEntry.id required hidden)

            .d-flex.gap-4.justify-content-center
              button.btn.btn-success(type='button' id="update-namuna-19-employee-entry") Update
              button.btn.btn-secondary(type='reset' id='reset') Reset