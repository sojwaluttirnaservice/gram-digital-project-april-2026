        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script.
            $(() => {
                // Assuming you have an API that converts the English number to Marathi
                function convertNumberToMarathi(englishNumber) {
                    // Replace this with your actual API endpoint and logic
                    return fetch(`/currency/toWords`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ data: englishNumber }),
                    })
                    .then(response => {
                        if (!response.ok) {
                            // If the response status is not OK, throw an error
                            throw new Error(`Error fetching Marathi number: ${response.statusText}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        if (data && data.words) {
                            return data.words; // Assuming the API returns a "marathiNumber" key
                        } else {
                            throw new Error('Marathi number not found in the API response.');
                        }
                    })
                    .catch(err => {
                        console.error(err);  // Log detailed error
                        return 'Error';  // You can return a fallback value or message for UI display
                    });
                }

                // Function to update the spans
                function updateMarathiNumbers() {
                    // Get all spans that contain English numbers
                    $('[data-englishNumId]').each(function() {
                        const englishNumber = $(this).attr('data-englishNumber');
                        const wordId = $(this).attr('data-englishNumId');

                        // Get the corresponding span to insert the Marathi number
                        const $marathiWordSpan = $(`[data-englishWordId='${wordId}']`);

                        // Call the API to get the Marathi equivalent of the number
                        convertNumberToMarathi(englishNumber).then(function(marathiNumber) {
                            // Insert the Marathi number into the appropriate span
                            if ($marathiWordSpan.length) {
                                $marathiWordSpan.text(marathiNumber);
                            }
                        });
                    });
                }

                // Call the update function after the page has loaded
                updateMarathiNumbers();
            });



