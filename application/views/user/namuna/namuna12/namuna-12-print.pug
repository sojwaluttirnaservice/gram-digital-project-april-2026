                    position: fixed;
                    top: 48%;
                    left: 1rem;
                    background: blue;
                    padding: 0.2rem 0.4rem;
                    color: white;
                }
            }


            /* Print-specific styles */
            @media print {
                /* Set the page to A4 portrait */
                @page {
                    size: A4 portrait;
                }

                .my-print {
                    page-break-before: always;
                    margin: 0; /* Ensure there is no margin around each print block */
                    padding: 0; /* Ensure no padding */
                    height: 100vh; /* Set height to take up the full viewport height of the page */
                    display: flex;
                    flex-direction: column; /* Allow inner elements to stack vertically */
                }

                .my-print > div {
                    flex: 1; /* Take up available space */
                    border: 1px solid black;
                    padding: 0.8rem;
                    box-sizing: border-box; /* Include padding in the height calculation */
                }

                #hide-buttons {
                    display:none;
                }
            }

