doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-19-payment/namuna-19-payment-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-19-payment/namuna-19-payment-create-entry-page-handler.js' type='module' defer)

    title नमुना १९ कामावर असलेल्या व्यक्तीचा हजेरीपट 
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना १९ कामावर असलेल्या व्यक्तीचा हजेरीपट 
        span.text-info (कर्मचारी वेतन करा) 

      div(class='d-flex align-items-center justify-content-end gap-3')
        button.btn.btn-secondary.btn-sm(type="button" onclick="window.history.back()") मागे जा
        a.btn.btn-primary.btn-sm(href='/namuna/19') नमुना १९
        a.btn.btn-primary.btn-sm(href='/namuna') नमुने

      if !employees || employees.length == 0

        h2.text-center कर्मचारी संख्या ० आहे

      else

        div.mb-4
          .row.justify-content-center

            .col-12.col-md-8.col-lg-6

              .d-flex.align-items-center(style='gap:1rem;')
                label.form-label.fw-bold(for="" style='width: 9rem;') कर्मचारी निवडा
                select.form-control(id='selected-employee')

                  option(value='') --निवडा--
                  each emp in employees 
                    option(value=emp.id data-employee=JSON.stringify(emp) ) #{emp.name}


        form(id='namuna-19-employee-form').mt-1


          .form.form-1
            //- h4.text-center.fw-bold कर्मचारी माहिती
            h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") कर्मचारी माहिती


            .row.justify-content-center.justify-content-md-between.gx-4.px-3
              .col-11.col-md-6.col-lg-6
                .form-group
                  label.form-label(for="name") कर्मचाऱ्याचे नाव
                  input.form-control(type="text" id="name" name="name" required placeholder="नाव" readonly)

              .col-11.col-md-12.col-lg-3.d-none
                .form-group
                  label.form-label(for="post-id") पद
                  input.form-control(id="post-id" name="post_id" placeholder="पद" readonly)


              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="post-name") पदाचे नाव
                  input.form-control(id="post-name" name="post_name" required placeholder="पदाचे नाव" readonly)

              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="gender") लिंग
                  select.form-control(id="gender" name="gender" required placeholder="" readonly)
                    option(value='') -- निवडा --
                    option(value="Male") पुरुष
                    option(value="Female") स्त्री
                    option(value="Other") इतर

              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="mobile") मोबाईल
                  input.form-control(id="mobile" name="mobile" required maxlength='10' placeholder="" readonly)

              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="state-share") राज्याचा हिस्सा
                  input.form-control(id="state-share" name="state_share"  required maxlength='10' placeholder="" readonly)


              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="pf-cutting-percentage") पीएफ कपात टक्केवारी
                  input.form-control(id="pf-cutting-percentage" name="pf_cutting_percentage"  required maxlength='10' placeholder="" readonly)


              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="grampanchayat-share") ग्रामपंचायत हिस्सेदारी 
                  input.form-control(id="grampanchayat-share" name="grampanchayat_share"  required maxlength='10' placeholder="" readonly)



              //- .col-11.col-md-12.col-lg-4.d-none
                .form-group
                  label.form-label(for="monthly-salary") महिन्याचे वेतन
                  input.form-control(id="monthly-salary" name="monthly_salary" required placeholder="उदा. 24000" readonly)



              .col-11.col-md-6.col-lg-6.d-none
                .form-group
                  label.form-label(for="address") पत्ता
                  textarea.form-control( id="address" name="address" required placeholder="पत्ता")

              .col-11.col-md-12.col-lg-6.d-none
                .form-group
                  label.form-label(for="remarks") शेरा
                  textarea.form-control(id="remarks" name="remarks" placeholder="टीप")

        form(id='namuna-19-payment-form').mt-1
          .form.form-1
            //- h4.text-center.fw-bold पेमेंट माहिती
            h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") नमुना १९ पेमेंट माहिती


            #payment-already-done-box
              .p-2.mb-2.text-center.text-success.fw-bold सदर महिन्यासाठी वेतन आधीच केलेले आहे


            .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="month") महिना
                  select.form-select(id="month" name="month" required)
                    option(value='') --निवडा--
                    option(value="1") ०१ (जानेवारी)
                    option(value="2") ०२ (फेब्रुवारी)
                    option(value="3") ०३ (मार्च)
                    option(value="4") ०४ (एप्रिल)
                    option(value="5") ०५ (मे)
                    option(value="6") ०६ (जून)
                    option(value="7") ०७ (जुलै)
                    option(value="8") ०८ (ऑगस्ट)
                    option(value="9") ०९ (सप्टेंबर)
                    option(value="10") १० (ऑक्टोबर)
                    option(value="11") ११ (नोव्हेंबर)
                    option(value="12") १२ (डिसेंबर)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="year") वर्ष
                  select.form-select(id="year" name="year" required)
                    option(value='') --निवडा--
                    - let currentYear = new Date().getFullYear()
                    - let startYear = currentYear - 25
                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                      option(value=year) #{year}

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="working-days") कामाचे दिवस
                  input.form-control(type="text" id="working-days" name="working_days" required  readonly)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="present-days") हजेरीचे दिवस
                  select.form-control(type="text" id="present-days" name="present_days" required readonly)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="grampanchayat-calculated-salary") ग्रामपंचायत हजेरी वेतन
                  input.form-control(id="grampanchayat-calculated-salary" name="calculated_grampanchayat_salary"  required placeholder="" value='0' readonly)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="state-calculated-salary") राज्याचे वेतन
                  input.form-control(id="state-calculated-salary" name="calculated_state_salary"  required placeholder="" value='0' readonly)

                  input.form-control(name='state_share' hidden)
                  input.form-control(name='grampanchayat_share' hidden)
                  input.form-control(name='pf_cutting_percentage' hidden)
                  input.form-control(name='employee_id_fk' hidden)

            .d-flex.gap-4.justify-content-center

              .make-payment
                .d-flex.align-items-center(style='gap: 1rem;')
                  button.btn.btn-primary(type='button' id="submit-namuna-19-payment-btn") Save Payment 
                  button.btn.btn-secondary(type='reset' id='reset') Reset
              .delete-payment
                button.btn.btn-danger(id='delete-payment-record-btn' data-paymentId='') Delete
