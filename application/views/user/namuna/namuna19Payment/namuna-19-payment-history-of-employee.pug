    title नमुना १९ कामावर असलेल्या व्यक्तीचा हजेरीपट
    //-  कर्मचारी वेतन नोंदी
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना १९ कामावर असलेल्या व्यक्तीचा हजेरीपट  
        span.text-info (कर्मचारी वेतन नोंदी)

      .container

        div 
          .d-flex.justify-content-end
            button.btn.btn-secondary.btn-sm(type="button" onclick="window.history.back()") मागे जा


        if !employee

          h3.text-center  सदर कर्मचाऱ्याची नोंद उपलब्ध नाहीये


        else


          form(id='namuna-19-employee-form').mt-1
            .form.form-1
              //- h4.text-center.fw-bold नमुना १९ - कर्मचारी नोंदणी
              h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") कर्मचारी माहिती


              .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3

                .col-11.col-md-6.col-lg-5
                  .form-group
                    label.form-label(for="name") कर्मचाऱ्याचे नाव
                    input.form-control(type="text" id="name" name="name" value=employee.name required placeholder="नाव")

                .col-11.col-md-12.col-lg-3.d-none
                  .form-group
                    label.form-label(for="post-id") पद
                    input.form-control(id="post-id" name="post_id" readonly placeholder="पद")


                .col-11.col-md-12.col-lg-4
                  .form-group
                    label.form-label(for="post-name") पदाचे नाव
                    input.form-control(id="post-name" name="post_name" required value=employee.post_name placeholder="पदाचे नाव")

                .col-11.col-md-12.col-lg-3.d-none
                  .form-group
                    label.form-label(for="mobile") मोबाईल
                    input.form-control(id="mobile" name="mobile" required maxlength='10' placeholder="")

                .col-11.col-md-12.col-lg-3
                  .form-group
                    label.form-label(for="monthly-salary") महिन्याचे वेतन
                    input.form-control(id="monthly-salary" name="monthly_salary" required value=employee.monthly_salary placeholder="उदा. 24000")


          if (!paymentRecord || paymentRecord.length == 0)

            h3.text-center सदर कर्मचाऱ्यासाठी वेतन नोंद उपलब्ध नाही

          else



            .table-responsive

              table.table.table-striped
                thead
                  tr 
                    th(colspan='6')
                      .text-center PAYMENT HISTORY
                  tr
                    th(style='width: 15%') महिना
                    th(style='width: 15%') वर्ष 
                    th(style='width: 20%') कामाचे दिवस
                    th(style='width: 20%') हजेरी दिवस
                    th(style='width: 20%') वेतन 
                    th.text-center(style='width: 10%') Action

                tbody


                  each record in paymentRecord 

                    tr
                      td #{record.month}
                      td #{record.year}
                      td #{record.working_days}
                      td #{record.present_days}
                      - let totalPay = +record.calculated_state_salary + +record.calculated_grampanchayat_salary
                      td #{isNaN(totalPay) ? totalPay : totalPay.toFixed(2)}
                      td
                        .d-flex.justify-content-center.align-items-center(style='gap: 0.5rem;')

                          button.btn.btn-danger.btn-sm(type='button' class='delete-payment-record-btn' data-paymentId=`${record.id}`)
                            i.fa.fa-trash




