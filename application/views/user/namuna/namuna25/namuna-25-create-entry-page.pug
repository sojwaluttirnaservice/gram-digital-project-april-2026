doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-25/namuna-25-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-25/namuna-25-create-entry-page-handler.js' type='module' defer)

    title नमुना २५ - गुंतवणुकीची नोंदवही
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    - 
      const months = [
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
        "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
      ]

    .container
      h2.heading-1.mt-1.mb-1 नमुना २५ - गुंतवणुकीची नोंदवही

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/25') यादी

      form(id='namuna-25-form').mt-1
        .form.form-1
          .row.justify-content-center.justify-content-md-between.gx-4.gy-2


            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  each month, monthIndex in months
                    option(value=(monthIndex + 1)) #{month}

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="investment_date") गुंतवणुकीची तारीख
                input.form-control.datepicker(type="text" id="investment_date" name="investment_date" required)

            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="investment_details") गुंतवणुकीचा तपशिल
                input.form-control(type="text" id="investment_details" name="investment_details" required placeholder="उदाहरण: बँक, NSC, बांड्स")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="reference_number") इतर क्रमांक
                input.form-control(type="text" id="reference_number" name="reference_number" placeholder="क्रमांक व तारीख")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="reference_date") इतर तारीख
                input.form-control.datepicker(type="text" id="reference_date" name="reference_date" placeholder="तारीख")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="face_value") दर्शनी मूल्य
                input.form-control(type="number" step="0.01" id="face_value" name="face_value" required placeholder="दर्शनी मूल्य")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="purchase_price") खरेदी किंमत
                input.form-control(type="number" step="0.01" id="purchase_price" name="purchase_price" required placeholder="खरेदी किंमत")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="maturity_date") परिणत होण्याची तारीख
                input.form-control.datepicker(type="text" id="maturity_date" name="maturity_date" placeholder="परिणत होण्याची तारीख")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="net_payable_amount") निव्वळ देय रक्कम
                input.form-control(type="number" step="0.01" id="net_payable_amount" name="net_payable_amount" placeholder="निव्वळ देय रक्कम")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="interest_earned_date") उपार्जित व्याजाची तारीख
                input.form-control.datepicker(type="text" id="interest_earned_date" name="interest_earned_date" placeholder="उपार्जित व्याजाची तारीख")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="transfer_promotion_date") बदलीचा पदोन्नतीचा दिनांक
                input.form-control.datepicker(type="text" id="transfer_promotion_date" name="transfer_promotion_date" placeholder="बदलीचा पदोन्नतीचा दिनांक")

            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="cashbook_deposited_amount") दैनिक रोकडवहीतील जमा रक्कम
                input.form-control(type="number" step="0.01" id="cashbook_deposited_amount" name="cashbook_deposited_amount" placeholder="दैनिक रोकडवहीतील जमा रक्कम")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="specific_details") प्रकातीचा तपशिल
                input.form-control(type="text" id="specific_details" name="specific_details" placeholder="प्रकातीचा तपशिल")


          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-25-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
