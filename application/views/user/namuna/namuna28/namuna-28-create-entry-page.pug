    title नमुना २८ - मागासवर्गीय / महिला बालकल्याण खर्च नोंदणी 
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना २८ - मागासवर्गीय / महिला बालकल्याण खर्च नोंदणी 
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/28') यादी
      form(id='namuna-28-form').mt-1
        //- .form.form-1
        div

          .row.justify-content-center.justify-content-md-center.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#a89057; padding:8px 18px; display:block; margin:10px auto;") नमुना २८: मागासवर्गीय १५% खर्च


          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="bc_15_provision") मागासवर्गीयांसाठीम केलेली तरतूद
                input.form-control(type="text" id="bc_15_provision" name="bc_15_provision" required placeholder=" ")

            //- Doubtness
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="bc_15_income") चालू महिन्यात झालेले उत्पन्न
                input.form-control(type="text" id="bc_15_income" name="bc_15_income" required placeholder=" ")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="bc_15_exp_amount") टक्के खर्च करावयाची रक्कम
                input.form-control(id="bc_15_exp_amount" name="bc_15_exp_amount" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="bc_15_expenditure_scheme") खर्चाच्या बाबी बाबवर / योजनावर
                input.form-control(id="bc_15_expenditure_scheme" name="bc_15_expenditure_scheme" required placeholder="")

