    title कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही

    style.

        label.error {
            color: red;
            font-size: 0.9rem;
        }

body
    include ../../include/navs.pug

    .container 
        div.mt-2
            .text-center
                h2.heading-1.mb-2 नमुना १३ (कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही)

        - 
            const months = [
                "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
                "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
                "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
            ]


        div.d-flex.justify-content-end.gap-3(style='margin-right: 8rem;')
            a.btn.btn-secondary.btn-sm(href=`/namuna/13/list/${post.id}`) कर्मचार्यांची यादी
            a.btn.btn-secondary.btn-sm(href='/namuna/13') पदांची यादी

        form(id='namuna-13-form')
            .form.form-1
                h4(style="text-align:center; font-weight:bold; color:white; background-color:#E9967A ; padding:8px 18px; display:block; margin:10px auto;") नमुना १३ (कर्मचारी नोंदणी)

                .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
                    .col-11.col-md-6.col-lg-3
                        .form-group
                            input(name='post_id' id='post-id' value=post.id hidden) 
                            label.form-label(for="post-name") पदनाम 
                            input.form-control(type="text" id="post-name" name="post_name" value=post.post_name placeholder="Enter post name" readonly)

                    .col-11.col-md-6.col-lg-3 

                        .form-group 
                            label.form-label(for="salary-grade") वेतन श्रेणी
                            input.form-control(type="number" id="salary-grade" name="salary_grade" required)
                    .col-11.col-md-6.col-lg-6
                        .form-group 
                            label.form-label(for="employee-name") कर्मचाऱ्याचे नाव
                            input.form-control(type='text' id="employee-name" name="employee_name"  required)



                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="employment-type") पुर्णकालिक / अंशकालिक
                            select.form-select(id="employment-type" name="employment_type" required)
                                option(value='' selected) -- निवडा --
                                option(value='Full-time') पुर्णकालिक
                                option(value='Part-time') अंशकालिक


                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="appointment-date") नियुक्तीचा दिनांक
                            input.form-control.datepicker(type="text" id="appointment-date" name="appointment_date" required)

                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="order-number") आदेश क्रमांक
                            input.form-control(type="text" id="order-number" name="order_number" required)

                .button-container.text-center
                    button.btn.btn-primary(type="submit" id='submit-namuna-13-entry') Save
