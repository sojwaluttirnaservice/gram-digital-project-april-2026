    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")
    script(src='/asstest/coustom/js/handlers/namuna/namuna-13/namuna-13-page-handler.js' type='module' defer)

    title कर्मचारी यादी

    style.

        label.error {
            color: red;
            font-size: 0.9rem;
        }

        thead, tbody, th, tr, td {
            border: 1px solid black !important;
        }

body
    include ../../include/navs.pug

    .container 
        div.my-4
            .text-center
                h2.heading-1 नमुना १३ (कर्मचारी सूची)

                button.btn.btn-primary.btn-sm.float-right(onclick='window.history.back()') Back

            //- // Form to Add New Entry



            .table-responsive

                if !employees || !employees.length
                    h5.fw-bold.py-4.text-center   नोंदणीकृत कर्मचारी संख्या : 0

                else

                    table.table
                        thead 
                            tr 
                                th अ. क्र
                                th कर्मचाऱ्याचे नाव
                                th वेतन श्रेणी
                                th आदेश क्रमांक
                                th पुर्णकालिक / अंशकालिक
                                th एडीट
                                

                        tbody
                            each employee, index in employees
                                tr 
                                    td #{index + 1}
                                    td #{employee.employee_name}
                                    td #{employee.salary_grade}

                                    td #{employee.order_number}
                                    td #{employee.employment_type == 'Full-time' ? 'पुर्णकालिक ' : 'अंशकालिक' }
                                    td 
                                        a.btn.btn-success.btn-sm(href=`/namuna/13/edit/${employee.id}`) 
                                            i.fa.fa-pencil