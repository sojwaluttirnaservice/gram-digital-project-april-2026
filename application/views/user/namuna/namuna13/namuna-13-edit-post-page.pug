    link(href='/asstest/coustom/css/namuna/namuna-13/namuna-13-create-post-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-13/namuna-13-create-post-page-handler.js' type='module' defer)

    title Edit: Post

    style.

        label.error {
            color: red;
            font-size: 0.9rem;
        }

body
    include ../../include/navs.pug

    .container 
        div.my-4
            .text-center
                h2.heading-1 नमुना १३ (कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही)

        - 
            const months = [
                "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
                "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
                "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
            ]


        .text-end(style='margin-right: 8rem;')
            a.btn.btn-secondary(href='/namuna/13') पदांची यादी

        form(id='namuna-13-post-form')

            .form.form-1
                //- h4.text-center.fw-bold पदाची माहिती
                h4(style="text-align:center; font-weight:bold; color:white; background-color:#4B2C5E ; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना १३ पदाची माहिती


                .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
                    .col-11.col-md-6.col-lg-6 
                        .form-group
                            label.form-label(for="post-name") पदनाम 
                            input.form-control(type="text" id="post-name" name="post_name" placeholder="Enter post name" value=post.post_name required)

                    .col-11.col-md-6.col-lg-3
                        .form-group 
                            label.form-label(for="month") महिना
                            select.form-select(type="number" id="month" name="month" min="1" max="12" required)
                                option(value='' selected) -- निवडा --
                                each month, index in months 
                                    option(value=(index + 1) selected = ((index + 1) == post.month)) #{month}

                    .col-11.col-md-6.col-lg-3 

                        .form-group 
                            label.form-label(for="year") वर्ष
                            input.form-control(type="number" id="year" name="year" value=post.year required)

                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="post-count") पदाची संख्या
                            input.form-control(type="number" id="post-count" name="post_count" value=post.post_count required)

                    //- 
                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="approved-post") मंजूर पदे 
                            input.form-control(type="number" id="approved-post" name="approved_post" value=post.approved_post required)

                    .col-11.col-md-6.col-lg-4
                        .form-group 
                            label.form-label(for="order-date") आदेश दिनांक
                            input(name='id' value=post.id hidden)
                            input.form-control.datepicker(type="text" id="order-date" name="order_date" value=post._order_date required)

                .button-container.text-center
                    button.btn.btn-success(type="submit" id='update-namuna-13-post') Update
