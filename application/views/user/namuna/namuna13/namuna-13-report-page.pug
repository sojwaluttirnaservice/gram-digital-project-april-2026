    title Report - नमुना १३ 

    script(src='/asstest/coustom/js/handlers/namuna/namuna-13/namuna-13-report-page-handler.js' type='module' defer)


    style.
        /* Basic styles for the body */
        body {
            /* font-family: Arial, sans-serif; */
            margin: 0;
            /* padding: 20px; */
        }

        .text-center {
            text-align: center !important; /* Marking as important */
        }

        /* Styles for the table */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: center !important; /* Marking as important */
        }

        th {
            background-color: #f2f2f2;
            font-weight: bold;
        }

        /* Print styles */
        @media print {
            body {
                margin: 0 !important; /* Marking as important */
                padding: 0 !important; /* Marking as important */
            }

            //- #hide-buttons {
            //-     display: none !important; /* Marking as important */
            //- }

            table {
                page-break-inside: auto;
            }

            tr {
                page-break-inside: avoid;
                page-break-after: auto;
            }

            th, td {
                font-size: 12pt !important; /* Marking as important */
            }

            @page {
                size: A4;
                margin: 20mm !important; /* Marking as important */
            }
        }

    body

        include ../../include/navs.pug


        -
            const tableHeaderData = [
                {
                    marathiHeader: 'पदनाम',
                    name: 'post_name',
                },
                {
                    marathiHeader: 'पदाची संख्या',
                    name: 'post_count',
                },
                {
                    marathiHeader: 'मंजूर पदे',
                    name: 'approved_post',
                },
                {
                    marathiHeader: 'आदेश क्रमांक',
                    name: 'order_number',
                },
                {
                    marathiHeader: 'दिनांक',
                    name: '_order_date',
                },
                {
                    marathiHeader: 'पूर्णकाळ / अंशकाळ',
                    name: 'employment_type',
                },
                {
                    marathiHeader: 'मंजूर वेतनश्रेणी',
                    name: 'salary_grade',
                },
                {
                    marathiHeader: 'नियुक्त  केलेल्या कर्मचाऱ्याचे नाव',
                    name: 'employee_name',
                },
                {
                    marathiHeader: 'नियुक्तीचा  दिनांक',
                    name: '_appointment_date',
                },

            ];




        table
            thead

                tr 
                    th(colspan='14' style='')
                        div
                            div(style='display: flex; align-items: center; justify-content: space-between;')

                                div नमुना १३

                                div ग्रामपंचायत कार्यालय 
                                    span #{gp.gp_name}
                                div
                                    img(src="/new-gp-page/main-page/images/header-images/mudra-nav-2.png" style='width: 100px;')

                            div 
                                div.text-center(style='font-size:10px;') महा. ग्रा. पं. लेखा संहिता २०११ (नियम ३९ (२), ४२(२) पहा)

                            div
                                if fromYear && toYear
                                    div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{fromYear} - #{toYear} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही
                                else if (month && year)
                                    div.text-center(style='font-size: 20px; margin-top:0.2rem;') #{month} सन #{year} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही
                                else if year 
                                    div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{year - 1} - #{year} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही

                            div
                                if fromYear && toYear
                                    a.btn.btn-secondary.btn-sm(href=`/namuna/13/print?fromYear=${fromYear}&toYear=${toYear}` target='_blank') Print
                                else if (month && year)
                                    a.btn.btn-secondary.btn-sm(href=`/namuna/13/print?month=${month}&year=${year}` target='_blank') Print
                                else if year 
                                    a.btn.btn-secondary.btn-sm(href=`/namuna/13/print?year=${year}` target='_blank') Print



                tr

                    //- 1
                    th(rowspan='2') अ.क्र.

                    each entry in tableHeaderData
                        th #{entry.marathiHeader}

                    th एडिट  / डिलीट 


            tbody(id='namuna-13-table-body')
                each namunaEntryRow, index in namuna13Details

                    tr 
                        td #{index + 1}

                        each entry in tableHeaderData
                            - let value
                            if namunaEntryRow[entry.name]
                                - value= (entry.name == 'employment_type')? ((namunaEntryRow[entry.name] == 'Full-time') ? 'पुर्णकालिक' : 'अंशकालिक') : namunaEntryRow[entry.name] 
                            else 
                                -value = '-'
                            td #{value}

                        td 
                            .d-flex.gap-2.justify-content-center
                                a.btn.btn-success.btn-sm(href=`/namuna/13/edit/${namunaEntryRow.id}`)
                                    i.fa.fa-pencil

                                button.btn.btn-danger.btn-sm(class='delete-namuna-13-entry-btn' data-namuna13EntryId=namunaEntryRow.id)
                                    i.fa.fa-trash

