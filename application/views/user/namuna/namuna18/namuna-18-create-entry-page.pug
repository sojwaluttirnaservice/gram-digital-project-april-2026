    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-18/namuna-18-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-18/namuna-18-create-entry-page-handler.js' type='module' defer)


    title नमुना १८ - किरकोळ रोकडवही
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना १८ - किरकोळ रोकडवही

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/18') यादी
          a.btn.btn-primary(href='/namuna') नमुने


      form(id='namuna-18-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold जमा
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#008080 ; padding:8px 18px; display:block; margin:10px auto;") जमा
          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="recieved_date") दिनांक
                input.form-control.datepicker(type="text" id="recieved_date" name="recieved_date" required placeholder="दिनांक")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="cheque_number") धनादेश क्रमांक
                input.form-control(type="text" id="cheque_number" name="cheque_number" required placeholder="")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="received_from") कोणाकडून प्राप्त झाले
                textarea.form-control(id="received_from" name="received_from" rows="3" required placeholder="कोणाला दिले")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="recieved_details") तपशील
                textarea.form-control(id="recieved_details" name="recieved_details" rows="3" required placeholder="तपशील")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="recieved_amount") रक्कम
                input.form-control(type="number" id="recieved_amount" name="recieved_amount" required placeholder="रक्कम")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="recieved_advance_amount") अग्रीम
                input.form-control(type="number" id="recieved_advance_amount" name="recieved_advance_amount" rows="3" placeholder="अग्रीम")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="total_recieved_amount") एकूण रक्कम
                input.form-control(type="number" id="total_recieved_amount" name="total_recieved_amount" required placeholder="एकूण रक्कम")


            //- .col-11.col-md-12.col-lg-12
              .form-group
                label.form-label(for="remarks") टीप
                input.form-control(id="remarks" name="remarks" placeholder="टीप")


        .form.form-2
          //- h4.text-center.fw-bold खर्च
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#CD5C5C ; padding:8px 18px; display:block; margin:10px auto;") खर्च


          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="spending_date") दिनांक
                input.form-control.datepicker(type="text" id="spending_date" name="spending_date" required placeholder="दिनांक")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="certificate_number") प्रमाणक क्रमांक
                input.form-control(type="text" id="certificate_number" name="certificate_number" required placeholder="क्रमांक")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="given_to") कोणाला दिले
                textarea.form-control(id="given_to" name="given_to" rows="3" required placeholder="कोणाकडून प्राप्त झाले / कोणाला दिले")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="expense_details") तपशील
                textarea.form-control(id="expense_details" name="expense_details" rows="3" required placeholder="तपशील")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="expense_amount") रक्कम
                input.form-control(type="number" id="expense_amount" name="expense_amount" required placeholder="रक्कम")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="expense_from_advance") अग्रीमातून खर्च
                input.form-control(type="number" id="expense_from_advance" name="expense_from_advance" rows="3" placeholder="अग्रीमातून खर्च")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="total_expense_amount") एकूण रक्कम
                input.form-control(type="number" id="total_expense_amount" name="total_expense_amount" required placeholder="एकूण रक्कम")


            //- .col-11.col-md-12.col-lg-12
              .form-group
                label.form-label(for="remarks") टीप
                input.form-control(id="remarks" name="remarks" placeholder="टीप")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-18-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
