                                each marathiNumber in  ['१', '२', '३', '४', '५', '६', '७', '८', '९', '१०', '११', '१२', '१३', '१४', '१५', '१६', '१७'] 
                                    th #{marathiNumber}


                        tbody 












                        tbody

                            - let correspondingEntries =  monthYearGroup.corresponding_entries || []
                            - let creditEntries = correspondingEntries.filter(entry => entry.transaction_type == 'CREDIT')
                            - let debitEntries = correspondingEntries.filter(entry => entry.transaction_type == 'DEBIT')

                            - let maxRows = Math.max(creditEntries.length || 0,  debitEntries.length || 0)

                            - for(let i = 0; i < maxRows; ++i)

                                - let entry = null
                                tr

                                    - entry = creditEntries[i]

                                    if entry

                                        //- जमा / क्रेडीट
                                        td #{i + 1}

                                        td #{entry._date}
                                        td #{entry.reference_number}
                                        td #{entry.sender_receiver_details}
                                        td #{entry.details}

                                        td #{entry.amount}
                                        td #{entry.advance_transactions}
                                        td #{entry.total_amount}
                                        td 
                                    else
                                        td #{i + 1}
                                        each _ in Array.from({ length: 8 }, (_, i) => i + 1)
                                            td

                                    //- खर्च / अद्याक्षरी
                                    - entry = debitEntries[i]

                                    if entry

                                        //- जमा / क्रेडीट

                                        td #{entry._date}
                                        td #{entry.reference_number}
                                        td #{entry.sender_receiver_details}
                                        td #{entry.details}

                                        td #{entry.amount}
                                        td #{entry.advance_transactions}
                                        td #{entry.total_amount}
                                        td 
                                    else
                                        each _ in Array.from({ length: 8 }, (_, i) => i + 1)
                                            td



                            //- else 
                                tr

                                    //- जमा / क्रेडीट

                                    each _ in Array.from({ length: 8 }, (_, i) => i + 1)
                                        td.d-none

                                    //- खर्च / अद्याक्षरी


                                    td #{entry._date}
                                    td #{entry.reference_number}
                                    td #{entry.sender_receiver_details}
                                    td #{entry.details}

                                    td #{entry.amount}
                                    td #{entry.advance_transactions}
                                    td #{entry.total_amount}
                                    td 


