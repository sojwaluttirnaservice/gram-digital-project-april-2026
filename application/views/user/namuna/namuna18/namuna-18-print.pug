                        td #{namuna18Entry.certificate_number}
                        td #{namuna18Entry.given_to}
                        td #{namuna18Entry.expense_details}
                        td #{namuna18Entry.expense_amount}
                        td #{namuna18Entry.expense_from_advance}
                        td #{namuna18Entry.total_expense_amount}
                        td  



        //- .records 

