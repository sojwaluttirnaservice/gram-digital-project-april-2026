doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-24/namuna-24-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-24/namuna-24-create-entry-page-handler.js' type='module' defer)


    title Edit नमुना २४ जमिनीची नोंदवही 
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug
    - 
      const months = [
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
        "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
      ]
    .container
      h2.heading-1.mt-2.mb-1 Edit नमुना २४ जमिनीची नोंदवही 

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/24') यादी

      if namuna24Entry

        form(id='namuna-24-form').mt-1
          .form.form-1
            //- h4.text-center.fw-bold नमुना १८ नोंदणी

            .row.justify-content-center.justify-content-md-between.gx-4.gy-2
              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="month") महिना
                  select.form-select(id="month" name="month" required)
                    option(value='') --निवडा--
                    each month, monthIndex in months 
                      option(value=(monthIndex + 1) selected = (((monthIndex + 1) == namuna24Entry.month) ? true: false))=month

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="year") वर्ष
                  select.form-select(id="year" name="year" required)
                    option(value='') --निवडा--
                    - let currentYear = new Date().getFullYear()
                    - let startYear = currentYear - 25
                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                      option(value=year selected = ((year == namuna24Entry.year) ? true: false)) #{year}

              .col-11.col-md-6.col-lg-6
                .form-group
                  label.form-label(for="transaction_date") हस्तांतरीत खरेदी किंवा संपादित केल्याची तारीख
                  input.form-control.datepicker(type="text" id="transaction_date" name="transaction_date" required placeholder="" value=namuna24Entry._transaction_date)

              //- Doubtness
              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="transaction_reason") कोणत्या कारणासाठी 
                  input.form-control(type="text" id="transaction_reason" name="transaction_reason" required placeholder=" " value=namuna24Entry.transaction_reason)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="from_party") कोणाकडून
                  input.form-control(id="from_party" name="from_party" required placeholder="" value=namuna24Entry.from_party)

              .col-11.col-md-12.col-lg-4
                .form-group
                  label.form-label(for="agreement_reference") करारनामा, निवाडा इत्यादींचा निर्देश
                  input.form-control(id="agreement_reference" name="agreement_reference" required placeholder="" value=namuna24Entry.agreement_reference)

              //- 
              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="land_area") जमिनीचे क्षेत्रफळ
                  input.form-control(type="number" id="land_area" name="land_area" required placeholder="" value=namuna24Entry.land_area)

              .col-11.col-md-12.col-lg-3
                .form-group
                  label.form-label(for="survey_number") भूमापन क्रमांक
                  input.form-control(type="text" id="survey_number" name="survey_number" placeholder="" value=namuna24Entry.survey_number)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="land_valuation") आकारणी
                  input.form-control(type="number" id="land_valuation" name="land_valuation" required placeholder="" value=namuna24Entry.land_valuation)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="land_boundaries") जमिनीच्या सीमा
                  input.form-control(type="text" id="land_boundaries" name="land_boundaries" required placeholder="" value=namuna24Entry.land_boundaries)

              .col-11.col-md-6.col-lg-7
                .form-group
                  label.form-label(for="land_and_building_purchase") जमिनीसह खरेदी केलेल्या किंवा संपादन केलेल्या कोणत्याही असल्यास
                  input.form-control(type="text" id="land_and_building_purchase" name="land_and_building_purchase" required placeholder="" value=namuna24Entry.land_and_building_purchase)

              .col-11.col-md-6.col-lg-5
                .form-group
                  label.form-label(for="disposal_of_land_and_building") जमिनीची व इमारतीची विल्हेवाट
                  input.form-control(type="text" id="disposal_of_land_and_building" name="disposal_of_land_and_building" required placeholder="" value=namuna24Entry.disposal_of_land_and_building)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="transaction_amount_from_sale") विक्रीपासून मिळालेली रक्कम 
                  input.form-control(type="number" id="transaction_amount_from_sale" name="transaction_amount_from_sale" required placeholder="" value=namuna24Entry.transaction_amount_from_sale)

              .col-11.col-md-6.col-lg-3
                .form-group
                  label.form-label(for="certificate_number") प्रमाणपत्राचा क्रमांक
                  input.form-control(type="text" id="certificate_number" name="certificate_number" required placeholder="" value=namuna24Entry.certificate_number)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="certificate_date") प्रमाणपत्राचा दिनांक
                  input.form-control.datepicker(type="text" id="certificate_date" name="certificate_date" required placeholder="" value=namuna24Entry._certificate_date)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="resolution_number") पंचायतीचा ठराव क्रमांक
                  input.form-control(type="text" id="resolution_number" name="resolution_number" required placeholder="" value=namuna24Entry.resolution_number)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="resolution_date") पंचायतीचा ठराव तारीख
                  input.form-control.datepicker(type="text" id="resolution_date" name="resolution_date" required placeholder="" value=namuna24Entry._resolution_date)

              .col-11.col-md-6.col-lg-4
                .form-group
                  label.form-label(for="authority_order_number") प्रधिकाऱ्याच्या आदेशाचा क्रमांक
                  input.form-control(type="text" id="authority_order_number" name="authority_order_number" required placeholder="" value=namuna24Entry.authority_order_number)

              .col-11.col-md-6.col-lg-6
                .form-group
                  label.form-label(for="authority_order_date") प्रधिकाऱ्याच्या आदेशाचा दिनांक
                  input.form-control.datepicker(type="text" id="authority_order_date" name="authority_order_date" required placeholder="" value=namuna24Entry._authority_order_date)

              .col-11.col-md-12.col-lg-6
                .form-group
                  label.form-label(for="remarks") शेरा
                  input.form-control(id="remarks" name="remarks" placeholder="शेरा" value=namuna24Entry.remarks)

                  input(name='id' value=namuna24Entry.id hidden)


            .d-flex.gap-4.justify-content-center
              button.btn.btn-success(type='button' id="update-namuna-24-entry") Update
              button.btn.btn-secondary(type='reset' id='reset') Reset             
      else 
        h4.fw-bold.text-center संबंधित नोंद उपलब्ध नाही

