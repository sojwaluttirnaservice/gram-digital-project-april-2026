    title नमुना २४ जमिनीची नोंदवही 
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना २४ जमिनीची नोंदवही 
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/24') यादी
      form(id='namuna-24-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना १८ नोंदणी

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="transaction_date") हस्तांतरीत खरेदी किंवा संपादित केल्याची तारीख
                input.form-control.datepicker(type="text" id="transaction_date" name="transaction_date" required placeholder=" ")

            //- Doubtness
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="transaction_reason") कोणत्या कारणासाठी 
                input.form-control(type="text" id="transaction_reason" name="transaction_reason" required placeholder=" ")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="from_party") कोणाकडून
                input.form-control(id="from_party" name="from_party" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="agreement_reference") करारनामा, निवाडा इत्यादींचा निर्देश
                input.form-control(id="agreement_reference" name="agreement_reference" required placeholder="")

            //- 
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="land_area") जमिनीचे क्षेत्रफळ
                input.form-control(type="number" id="land_area" name="land_area" required placeholder="")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="survey_number") भूमापन क्रमांक
                input.form-control(type="text" id="survey_number" name="survey_number" placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="land_valuation") आकारणी
                input.form-control(type="number" id="land_valuation" name="land_valuation" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="land_boundaries") जमिनीच्या सीमा
                input.form-control(type="text" id="land_boundaries" name="land_boundaries" required placeholder="")

            .col-11.col-md-6.col-lg-7
              .form-group
                label.form-label(for="land_and_building_purchase") जमिनीसह खरेदी केलेल्या किंवा संपादन केलेल्या कोणत्याही असल्यास
                input.form-control(type="text" id="land_and_building_purchase" name="land_and_building_purchase" required placeholder="")

            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="disposal_of_land_and_building") जमिनीची व इमारतीची विल्हेवाट
                input.form-control(type="text" id="disposal_of_land_and_building" name="disposal_of_land_and_building" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="transaction_amount_from_sale") विक्रीपासून मिळालेली रक्कम 
                input.form-control(type="number" id="transaction_amount_from_sale" name="transaction_amount_from_sale" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="certificate_number") प्रमाणपत्राचा क्रमांक
                input.form-control(type="text" id="certificate_number" name="certificate_number" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="certificate_date") प्रमाणपत्राचा दिनांक
                input.form-control.datepicker(type="text" id="certificate_date" name="certificate_date" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="resolution_number") पंचायतीचा ठराव क्रमांक
                input.form-control(type="text" id="resolution_number" name="resolution_number" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="resolution_date") पंचायतीचा ठराव तारीख
                input.form-control.datepicker(type="text" id="resolution_date" name="resolution_date" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="authority_order_number") प्रधिकाऱ्याच्या आदेशाचा क्रमांक
                input.form-control(type="text" id="authority_order_number" name="authority_order_number" required placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="authority_order_date") प्रधिकाऱ्याच्या आदेशाचा दिनांक
                input.form-control.datepicker(type="text" id="authority_order_date" name="authority_order_date" required placeholder="")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(id="remarks" name="remarks" placeholder="शेरा")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-24-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
