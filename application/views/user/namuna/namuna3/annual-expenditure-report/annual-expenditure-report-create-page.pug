doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    //- common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/annual-expenditure-report/namuna-3-annual-expenditure-report-page-form-handler.js' type='module' defer)

    title खर्चाचा अहवाल  

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

      th, td {
        border: 1px solid #ccc;
        padding: 10px;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='other-data-form')

        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#191970; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ खर्चाचा अहवाल 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-4
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="man_days_created") वर्षात निर्माण झालेले मनुष्य दिवस
                input.form-control.datepicker(type="text" name="man_days_created" id="man_days_created" placeholder="")

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="tharav_number") ठराव क्रमांक
                input.form-control.datepicker(type="text" name="tharav_number" id="tharav_number" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="approval_order_number") काकास पंचायत समितीने मंजूरात मिळण्याबाबत आदेश क्रमांक
                input.form-control.datepicker(type="text" name="approval_order_number" id="approval_order_number" placeholder="")

      form(id='annual-expenditure-report-form').mt-1
        .form.form-1

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.p-4

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="work_done_name") वर्षात केलेले कामाचे नाव १
                input.form-control.datepicker(type="text" name="work_done_name" id="work_done_name" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="expenditure_on_material") साहित्यावर खर्च २
                input.form-control(type="text" name="expenditure_on_material" id="expenditure_on_material" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="expenditure_on_labor") मजुरीवर खर्च ३
                input.form-control(type="text" name="expenditure_on_labor" id="expenditure_on_labor" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_expenditure") एकूण खर्च ४
                input.form-control(type="text" name="total_expenditure" id="total_expenditure" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="loan_repayment_gp_fund") उसनवार परत (ग्रामनिधी) ५
                input.form-control(type="text" name="loan_repayment_gp_fund" id="loan_repayment_gp_fund" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="loan_repayment_private") उसनवार परत (खाजगी) ६
                input.form-control(type="text" name="loan_repayment_private" id="loan_repayment_private" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_loan_repayment") एकूण उसनवार परत रक्कम ७ (५ + ६)
                input.form-control(type="text" name="total_loan_repayment" id="total_loan_repayment" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_expenditure_8") एकूण खर्च ८ (४ + ७)
                input.form-control(type="text" name="total_expenditure_8" id="total_expenditure_8" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remaining_balance") अखेर शिल्लक 
                input.form-control(type="text" name="remaining_balance" id="remaining_balance" placeholder="")


          //- Submit Button
          div 
            div.d-flex.align-items-center.justify-content-center.gap-2
              button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
              button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
              button.btn.btn-primary.mt-4(type="submit" id='save-annual-expenditure-report-btn') Save Form


      .table-responsive      
        table.mb-5 
          thead#annual-expenditure-report-table-heading

            tr
              //- th(rowspan='2' colspan='1') अनु क्रमांक
              th(rowspan='2' colspan='1') वर्षात केलेले कामाचे नाव
              th(rowspan='2' colspan='1') साहित्यावर खर्च
              th(rowspan='2' colspan='1') मंजुरीवर खर्च
              th(rowspan='2' colspan='1') एकूण खर्च


              th(rowspan='1' colspan='2') उसनवार परत

              th(rowspan='2' colspan='1') एकूण उसनवार परत रक्कम
              th(rowspan='2' colspan='1') एकूण खर्च
              th(rowspan='2' colspan='1') अखेर शिल्लक दि. ______ सन _____
              th(rowspan='2' colspan='1') Action


            tr 
              //- th 
              //- th
              //- th
              //- th

              th(rowspan='1' colspan='1') ग्रामनिधी 
              th(rowspan='1' colspan='1') खाजगी

              //- th
              //- th
              //- th
            tr 
              each num in [1,2,3,4,5,6, '5 + 6 = 7', '4 + 7 = 8', '9 (12 - 8)', '']
                th #{num}

          tbody#annual-expenditure-report-table-body