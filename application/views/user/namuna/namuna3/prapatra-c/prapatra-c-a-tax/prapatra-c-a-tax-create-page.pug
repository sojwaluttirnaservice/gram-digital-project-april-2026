doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    //- common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/prapatra-c-a-tax/namuna-3-prapatra-c-a-tax-page-form-handler.js' type='module' defer)

    title प्रपत्र क (एक)(अ) कर

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='prapatra-c-a-tax-form').mt-1
        .form.form-1

          h4(style="text-align:center; font-weight:bold; color:white; background-color:#8B2E38; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ : प्रपत्र क (एक)(अ) कर

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="property_tax_land_buildings") मालमत्ता कर जमिनी व इमारती यावरील कर
                input.form-control(type='text' name="property_tax_land_buildings" id="property_tax_land_buildings" placeholder="Property Tax for Land and Buildings")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="street_light_tax") दिवाबत्ती कर
                input.form-control(type='text' name="street_light_tax" id="street_light_tax" placeholder="Street Light Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="cleanliness_tax") स्वच्छता कर
                input.form-control(type='text' name="cleanliness_tax" id="cleanliness_tax" placeholder="Cleanliness Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="shop_industry_hotel_tax") दुकाने, लघुउद्योग ग हॉटेल चालविणे यावरील कर
                input.form-control(type='text' name="shop_industry_hotel_tax" id="shop_industry_hotel_tax" placeholder="Shop/Industry/Hotel Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="travel_tax") यात्राकर
                input.form-control(type='text' name="travel_tax" id="travel_tax" placeholder="Travel Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="fair_festival_tax") जत्रा, उत्सव, व इतर मनोरंजन कर
                input.form-control(type='text' name="fair_festival_tax" id="fair_festival_tax" placeholder="Fair/Festival Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="cycle_vehicle_tax") सायकल व इतर वाहनावरील कर
                input.form-control(type='text' name="cycle_vehicle_tax" id="cycle_vehicle_tax" placeholder="Cycle and Vehicle Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="toll_tax") टोलटॅक्स
                input.form-control(type='text' name="toll_tax" id="toll_tax" placeholder="Toll Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="goods_tax") उतरू व मालावरील कर
                input.form-control(type='text' name="goods_tax" id="goods_tax" placeholder="Goods Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="forest_development_tax") वनविकास कर
                input.form-control(type='text' name="forest_development_tax" id="forest_development_tax" placeholder="Forest Development Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="service_tax") सेवाकर
                input.form-control(type='text' name="service_tax" id="service_tax" placeholder="Service Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="trade_or_occupation_tax") व्यापारी किंवा आजीविका यावरील कर (शेतीव्यतिरिक्त)
                input.form-control(type='text' name="trade_or_occupation_tax" id="trade_or_occupation_tax" placeholder="Trade or Occupation Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="cattle_market_commission_tax") गुरांच्या बाजारातील दलालीच्या व्यवसाय व आजीविकेवरील कर
                input.form-control(type='text' name="cattle_market_commission_tax" id="cattle_market_commission_tax" placeholder="Cattle Market Commission Tax")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_taxes") इतर कर
                input.form-control(type='text' name="other_taxes" id="other_taxes" placeholder="Other Taxes")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_tax_1_to_14") एकूण (एक) (अ) कर १ ते १४
                input.form-control(type='text' name="total_tax_1_to_14" id="total_tax_1_to_14" placeholder="Total Tax 1 to 14")

          //- Submit Button
          .text-center
            button.btn.btn-primary.mt-4(type="submit" id='save-prapatra-c-a-tax-btn') Save
