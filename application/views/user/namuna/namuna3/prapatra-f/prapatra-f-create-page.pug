doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    //- common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/prapatra-f/namuna-3-prapatra-f-page-form-handler.js' type='module' defer)

    title प्रपत्र फ 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

      th, td {
        border: 1px solid #ccc;
        padding: 10px;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='prapatra-f-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#8B2E38; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ प्रपत्र फ 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="ps_samiti_dept") पंचायत समिती जिल्हा/विभाग 
                input.form-control(type="text" name="ps_samiti_dept" id="ps_samiti_dept" placeholder="")


            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gram_panchayat_name") ग्रामपंचायतीचे नाव
                input.form-control(type='text' step="any" name="gram_panchayat_name" id="gram_panchayat_name" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="initial_balance") प्रारंभीची शिल्लक
                input.form-control(type='text' step="any" name="initial_balance" id="initial_balance" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="income_excluding_the_initial_balance") प्रारंभीची शिल्लक वगळून उत्त्पन्न
                input.form-control(type='text' step="any" name="income_excluding_the_initial_balance" id="income_excluding_the_initial_balance" placeholder=" ")

            //- For Section 2
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="income_including_the_initial_balance") प्रारंभीची शिल्लक धरून उत्त्पन्न (४ + ५)
                input.form-control(type='text' step="any" name="income_including_the_initial_balance" id="income_including_the_initial_balance" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_expenses") एकूण खर्च (प्रत्रकाचे column)
                input.form-control(type='text' step="any" name="total_expenses" id="total_expenses" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="final_remaining_balance") अखेरची शिल्लक (६ - ७) शिल्लक
                input.form-control(type='text' step="any" name="final_remaining_balance" id="final_remaining_balance" placeholder=" ")


            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(type='text' step="any" name="remarks" id="remarks" placeholder=" ")

        //- Submit Button
        div 
          div.d-flex.align-items-center.justify-content-center.gap-2
            button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
            button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
            button.btn.btn-primary.mt-4(type="submit" id='save-prapatra-f-btn') Save Form



      table.mb-5 
        thead#prapatra-f-table-heading

        tbody#prapatra-f-table-body