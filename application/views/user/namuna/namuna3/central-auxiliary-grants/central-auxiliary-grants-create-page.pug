doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/central-auxiliary-grants/namuna-3-central-auxiliary-grants-form-handler.js' type='module' defer)

    title केंद्र शासन अनुदाने जमा

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३
      form(id='central-auxiliary-grants-form').mt-1
        .form.form-1

          h4(style="text-align:center; font-weight:bold; color:white; background-color:#4682B4; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ केंद्र शासन अनुदाने जमा

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(name='year' id='year' value=year placeholder="Enter Year" readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="golden_jubilee_self_employment_scheme") स्वर्ण जयंती ग्राम स्वरोजगार योजना
                input.form-control(type="text" id="golden_jubilee_self_employment_scheme" name="golden_jubilee_self_employment_scheme" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="jawahar_gram_samruddhi_scheme") जवाहर ग्रामसमृद्धी योजना
                input.form-control(type="text" id="jawahar_gram_samruddhi_scheme" name="jawahar_gram_samruddhi_scheme" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_central_grants") इतर केंद्र शासन अनुदाने
                input.form-control(type="text" id="other_central_grants" name="other_central_grants" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_central_grants_1_to_3") एकूण (तीन) (१ ते ३)
                input.form-control(type="text" id="total_central_grants_1_to_3" name="total_central_grants_1_to_3" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="deposit_security") अनामत प्रतीभूर्ती
                input.form-control(type="text" id="deposit_security" name="deposit_security" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="deposit") ठेवी
                input.form-control(type="text" id="deposit" name="deposit" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="loans") कर्जे
                input.form-control(type="text" id="loans" name="loans" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_narrow_grants") इतर संकीर्ण जमा
                input.form-control(type="text" id="other_narrow_grants" name="other_narrow_grants" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_narrow_grants_1_to_4") एकूण (चार) (१ ते ४)
                input.form-control(type="text" id="total_narrow_grants_1_to_4" name="total_narrow_grants_1_to_4" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="deposit_security_5") अनामत प्रतीभूर्ती ५
                input.form-control(type="text" id="deposit_security_5" name="deposit_security_5" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="deposit_5") ठेवी ५
                input.form-control(type="text" id="deposit_5" name="deposit_5" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="loans_5") कर्ज ५
                input.form-control(type="text" id="loans_5" name="loans_5" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_initial_balance") इतर प्रारंभीची शिल्लक
                input.form-control(type="text" id="other_initial_balance" name="other_initial_balance" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_initial_balance_1_to_4") एकूण (पाच) (१ ते ४)
                input.form-control(type="text" id="total_initial_balance_1_to_4" name="total_initial_balance_1_to_4" placeholder=" ")

          .text-center
            button.btn.btn-primary.mt-4(type="submit" id='save-central-auxiliary-grants-btn') Save
