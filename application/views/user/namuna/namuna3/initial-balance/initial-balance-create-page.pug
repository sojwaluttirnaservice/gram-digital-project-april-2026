doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/initial-balance/namuna-3-initial-balance-form-handler.js' type='module' defer)

    title प्रारंभीची शिल्लक (Initial Balance)

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३
      form(id='initial-balance-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#FFBF00; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ प्रारंभीची शिल्लक

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(name='year' id='year' value=year readonly placeholder="Enter Year")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="jawahar_gram_samruddhi_scheme") जवाहर ग्रामसमृद्धी योजना
                input.form-control(type="number" step="any" id="jawahar_gram_samruddhi_scheme" name="jawahar_gram_samruddhi_scheme" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="village_fund_supply_account") ग्रामनिधी पुरवठा निधी खाते
                input.form-control(type="number" step="any" id="village_fund_supply_account" name="village_fund_supply_account" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gram_panchayat_fund_account") ग्रामपंचायत निधी खाते
                input.form-control(type="number" step="any" id="gram_panchayat_fund_account" name="gram_panchayat_fund_account" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other") इतर
                input.form-control(type="number" step="any" id="other" name="other" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_6_1_to_4") एकूण (सहा) (१ ते ४)
                input.form-control(type="number" step="any" id="total_6_1_to_4" name="total_6_1_to_4" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_with_initial_balance") एकूण जमा (प्रारंभीची शिल्लकेसह)
                input.form-control(type="number" step="any" id="total_with_initial_balance" name="total_with_initial_balance" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_in_year") वर्षात जमा (एक + दोन + तीन + चार)
                input.form-control(type="number" step="any" id="total_in_year" name="total_in_year" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="eligible_income_for_gra_viv_fund") जि. ग्रा. वि. निधी आकारण्या योग्य उत्त्पन्न
                input.form-control(type="number" step="any" id="eligible_income_for_gra_viv_fund" name="eligible_income_for_gra_viv_fund" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="previous_year_income") मागील वर्षात प्राप्त उत्त्पन्न
                input.form-control(type="number" step="any" id="previous_year_income" name="previous_year_income" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="increase_or_decrease") वाढ किंवा घट
                input.form-control(type="text" id="increase_or_decrease" name="increase_or_decrease" placeholder=" ")

          .text-center
            button.btn.btn-primary.mt-4(type="submit" id='save-initial-balance-btn') Save
