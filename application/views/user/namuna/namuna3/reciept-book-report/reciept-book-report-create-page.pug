doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    //- common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/reciept-book-report/namuna-3-reciept-book-report-page-form-handler.js' type='module' defer)

    title पावती पुस्तक विवरण 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

      th, td {
        border: 1px solid #ccc;
        padding: 10px;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='other-data-form')

        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#778899; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ पावती पुस्तक विवरण

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="reciept_books") पावती पुस्तके
                input.form-control.datepicker(type="text" name="reciept_books" id="reciept_books" placeholder="")

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="namuna_10") नमुना १०
                input.form-control.datepicker(type="text" name="namuna_10" id="namuna_10" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="namuna_7") नमुना ७
                input.form-control.datepicker(type="text" name="namuna_7" id="namuna_7" placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="kondwada_number") कोंडवाडा क्रमांक
                input.form-control.datepicker(type="text" name="kondwada_number" id="kondwada_number" placeholder="")

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="gp_fund") ग्राम निधी
                input.form-control.datepicker(type="text" name="gp_fund" id="gp_fund" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gp_water_fund") ग्राम.पं. पाणी पुरवठा
                input.form-control.datepicker(type="text" name="gp_water_fund" id="gp_water_fund" placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="s_g_r_y") सं. ग्रा. रो. यो.
                input.form-control.datepicker(type="text" name="reciept_books" id="reciept_books" placeholder="")

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="b_v_a") बा.वि. आ
                input.form-control.datepicker(type="text" name="b_v_a" id="b_v_a" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="d_v_s_y") द. व. सु. यो.
                input.form-control.datepicker(type="text" name="d_v_s_y" id="d_v_s_y" placeholder="")

      form(id='reciept-book-report-form').mt-1
        .form.form-1
          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.p-3

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gp_member_name") ग्रा.पं. सभासदाचे नाव
                input.form-control.datepicker(type="text" name="gp_member_name" id="gp_member_name" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="post") पद
                input.form-control(type="text" name="post" id="post" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="class") प्रवर्ग
                input.form-control(type="text" name="class" id="class" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="age") वय
                input.form-control(type="text" name="age" id="age" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="education") शिक्षण
                input.form-control(type="text" name="education" id="education" placeholder="")

        //- Submit Button
        div 
          div.d-flex.align-items-center.justify-content-center.gap-2
            button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
            button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
            button.btn.btn-primary.mt-4(type="submit" id='save-reciept-book-report-btn') Save Form


      .table-responsive      
        table.mb-5 
          thead#reciept-book-report-table-heading

            tr 
              th(width='5%') अनु. क्र 
              th ग्रा. पं. सभासदाचे नाव
              th पद
              th प्रवर्ग 
              th वय 
              th शिक्षण
              th Action

            tr 
              each num in [1,2,3,4,5,6, 7]
                th #{num}

          tbody#reciept-book-report-table-body