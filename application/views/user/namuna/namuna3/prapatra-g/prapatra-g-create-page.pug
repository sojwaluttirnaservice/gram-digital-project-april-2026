        title प्रपत्र ग 

        style.
            .heading-1 {
                font-weight: bold !important;
                font-size: 1.4rem;
                text-align: center;
                color: #bb2525;
                border-radius: 15px;
                border: 2px solid #bb2525;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 8px;
                margin: 0 auto 1.4rem;
                width: fit-content;
            }

            label.error {
                color: red;
                font-size: 0.9rem;
            }

            th, td {
                border: 1px solid #ccc;
                padding: 10px;
            }

    body
        include ../../../include/navs.pug
        .container
            h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
            div
                .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
                    a.btn.btn-primary(href='/namuna/3') नमुना ३

            form(id='prapatra-g-form').mt-1
                .form.form-1
                    h4(style="text-align:center; font-weight:bold; color:white; background-color:#8B2E38; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ प्रपत्र ग

                    .row.justify-content-center.justify-content-md-between.gx-4.gy-.px-3

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="year") वर्ष
                                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="tax_name") कराचे नाव
                                input.form-control(type="text" name="tax_name" id="tax_name" placeholder="")


                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="year_start_balance") वर्षाच्या आरंभी येणे असलेली बाकी
                                input.form-control(type='text' step="any" name="year_start_balance" id="year_start_balance" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="requested_for_year") वर्षासाठी केलेली मागणी
                                input.form-control(type='text' step="any" name="requested_for_year" id="requested_for_year" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="amount_to_be_collected") वसूल करावयाची रक्कम
                                input.form-control(type='text' step="any" name="amount_to_be_collected" id="amount_to_be_collected" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="amount_collected") वसूल केलेली रक्कम
                                input.form-control(type='text' step="any" name="amount_collected" id="amount_collected" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="concession_amount") सूट म्हणून दिलेली रक्कम
                                input.form-control(type='text' step="any" name="concession_amount" id="concession_amount" placeholder=" ")


                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="outstanding_previous_year_end") वर्षाच्या अखेरीस मागील थकबाकी
                                input.form-control(type='text' step="any" name="outstanding_previous_year_end" id="outstanding_previous_year_end" placeholder=" ")


                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="outstanding_current_year_end") वर्षाच्या अखेरीस चालू अखेरीस थकबाकी
                                input.form-control(type='text' step="any" name="outstanding_current_year_end" id="outstanding_current_year_end" placeholder=" ")



                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="total_at_year_end") वर्षाच्या अखेरीस एकूण
                                input.form-control(type='text' step="any" name="total_at_year_end" id="total_at_year_end" placeholder=" ")


                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="cash_collection_ratio") वसुलीचे रोकडा प्रमाण
                                input.form-control(type='text' step="any" name="cash_collection_ratio" id="cash_collection_ratio" placeholder=" ")



                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="collection_work_remark") वसुलीच्या कामासंबधीचा शेरा
                                input.form-control(type='text' step="" name="collection_work_remark" id="collection_work_remark" placeholder=" ")


                    //- Submit Button
                    div 
                        div.d-flex.align-items-center.justify-content-center.gap-2
                            button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
                            button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
                            button.btn.btn-primary.mt-4(type="submit" id='save-prapatra-g-btn') Save Form


            .table-responsive.mb-5 
                table
                    
                    thead#prapatra-g-table-heading
                        tr
