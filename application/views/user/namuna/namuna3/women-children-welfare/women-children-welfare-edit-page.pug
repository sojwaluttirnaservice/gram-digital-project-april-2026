    title महिला बाल कल्याण १० टक्के खर्च केल्याचा वार्षिक अहवाल

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/women-children-welfare/namuna-3-women-children-welfare-form-handler.js' type='module' defer)
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }   
  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३
      form(id='women-children-welfare-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#8B2E38; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना ३: महिला बाल कल्याण १० टक्के खर्च केल्याचा वार्षिक अहवाल

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type="number" id="year" name="year" placeholder="वर्ष (उदाहरण: 2025)" value=wcWelfare.year readonly required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="actual_total_income_year") प्रत्यक्ष एकूण उत्त्पन्न (वर्षात)
                input.form-control(type="number" step="0.01" id="actual_total_income_year" name="actual_total_income_year" placeholder="उदाहरण: 1000000" value=wcWelfare.actual_total_income_year required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="women_child_welfare_10_percent_expense") महिला बाल कल्याण १०% खर्च
                input.form-control(type="number" step="0.01" id="women_child_welfare_10_percent_expense" name="women_child_welfare_10_percent_expense" placeholder="उदाहरण: 150000" value=wcWelfare.women_child_welfare_10_percent_expense required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="budget_estimate_amount") अंदाज पत्रकातील तरतूद रक्कम
                input.form-control(type="number" step="0.01" id="budget_estimate_amount" name="budget_estimate_amount" placeholder="उदाहरण: 200000" value=wcWelfare.budget_estimate_amount required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="actual_expenditure_amount") प्रत्यक्ष खर्च केलेली रक्कम
                input.form-control(type="number" step="0.01" id="actual_expenditure_amount" name="actual_expenditure_amount" placeholder="उदाहरण: 180000" value=wcWelfare.actual_expenditure_amount required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="unspent_amount") खर्च न झालेली रक्कम
                input.form-control(type="number" step="0.01" id="unspent_amount" name="unspent_amount" placeholder="उदाहरण: 20000" value=wcWelfare.unspent_amount required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remaining_amount_to_be_spent") खर्च करावयाची शिल्लक रक्कम
                input.form-control(type="number" step="0.01" id="remaining_amount_to_be_spent" name="remaining_amount_to_be_spent" placeholder="उदाहरण: 20000" value=wcWelfare.remaining_amount_to_be_spent required)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="reason_if_not_spent") खर्च न झाल्यास कारणे
                input.form-control(type="text" id="reason_if_not_spent" name="reason_if_not_spent" placeholder="खर्च न झाल्यास कारणे" value=wcWelfare.reason_if_not_spent)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="work_name") कामाचे नाव
                input.form-control(type="text" id="work_name" name="work_name" placeholder="उदाहरण: इमारत बांधकाम" value=wcWelfare.work_name)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="expense_amount") खर्च रक्कम
                input.form-control(type="number" step="0.01" id="expense_amount" name="expense_amount" placeholder="उदाहरण: 100000" value=wcWelfare.expense_amount required)

                input.form-control(name='id' value=wcWelfare.id hidden)

          .text-center
            button.btn.btn-success.mt-4(type="submit" id='update-women-children-welfare-btn') Update
