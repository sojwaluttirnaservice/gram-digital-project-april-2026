doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(http-equiv="X-UA-Compatible" content="ie=edge")
    //- Common CSS
    link(rel="stylesheet" href="/asstest/plugins/bs4/css/bootstrap.css")
    link(rel="stylesheet" href="/asstest/plugins/font-awesome470/css/font-awesome.css")
    link(rel="stylesheet" href="/asstest/plugins/date/jquery-ui.css")
    link(rel="stylesheet" href="/asstest/coustom/css/main.css")
    link(rel="stylesheet" href="/asstest/plugins/select/css/select2.min.css")

    script(src="/asstest/plugins/jquery/jquery-3.3.1.min.js")
    script(src="/asstest/plugins/popper/popper.min.js")
    script(src="/asstest/plugins/date/jquery-ui.js")
    script(src="/asstest/plugins/sweetalert/sweetalert.min.js")
    script(src="/asstest/plugins/notify/notify.js")
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous")

    //- Common JS setups
    script(src="/asstest/coustom/js/base.converter.js")
    script(src="/asstest/coustom/js/common.js")
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href="/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css" rel="stylesheet")
    script(src="/asstest/coustom/js/handlers/namuna/namuna-3/j-patrak/namuna-3-j-patrak-page-form-handler.js" type="module" defer)

    title जे पत्रक 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='j-patrak-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#FF7F50; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना ३ जे पत्रक 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            // Year
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type="text" name="year" id="year" placeholder="Enter Year" value=jPatrak.year readonly)

            // Gram Panchayat Name
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gram_panchayat_name") ग्रामपंचायतीचे नाव
                input.form-control(type="text" name="gram_panchayat_name" id="gram_panchayat_name" placeholder="Enter Gram Panchayat Name" value=jPatrak.gram_panchayat_name)

            // Total Income for the Year
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year_total_income") वर्षाचे एकूण उत्त्पन्न
                input.form-control(type="text" name="year_total_income" id="year_total_income" placeholder="Enter Total Income for the Year" value=jPatrak.year_total_income)

            // Income for construction
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="construction_grant_income") बांधकामासाठी मिळालेली अनुदान निव्वळ उत्त्पन्न सोडून
                input.form-control(type="text" name="construction_grant_income" id="construction_grant_income" placeholder="Enter Construction Grant Income" value=jPatrak.construction_grant_income)

            // Net Income excluding construction grant
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="net_income_excluding_construction_grant") निव्वळ उत्त्पन्न सोडून
                input.form-control(type="text" name="net_income_excluding_construction_grant" id="net_income_excluding_construction_grant" placeholder="Enter Net Income Excluding Construction Grant" value=jPatrak.net_income_excluding_construction_grant)

            // Net Income after construction grant
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="net_income_after_construction_grant") निव्वळ उत्त्पन्नावर कॉ. ५ चे रकमेवर ५% आकाराचे जि. ग्रा. वि. निधी
                input.form-control(type="text" name="net_income_after_construction_grant" id="net_income_after_construction_grant" placeholder="Enter Net Income After Construction Grant" value=jPatrak.net_income_after_construction_grant)

            // Outstanding Loan Installment
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="outstanding_loan_installment") जि. ग्रा. निधीमधून घेतलेल्या कर्जांच्या हफ्त्यांची रक्कम थकीत
                input.form-control(type="text" name="outstanding_loan_installment" id="outstanding_loan_installment" placeholder="Enter Outstanding Loan Installment" value=jPatrak.outstanding_loan_installment)

            // Current Loan Installment
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="current_loan_installment") जि. ग्रा. निधीमधून घेतलेल्या कर्जांच्या हफ्त्यांची रक्कम चालू
                input.form-control(type="text" name="current_loan_installment" id="current_loan_installment" placeholder="Enter Current Loan Installment" value=jPatrak.current_loan_installment)

            // Total Paid Amount
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_paid_amount") एकूण भरलेली रक्कम
                input.form-control(type="text" name="total_paid_amount" id="total_paid_amount" placeholder="Enter Total Paid Amount" value=jPatrak.total_paid_amount)

            // Date of Invoice
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="date_invoice") तारीख/पा. न.
                input.form-control.datepicker(type="text" name="date_invoice" id="date_invoice" placeholder="Enter Date of Invoice" value=jPatrak._date_invoice)

            // Outstanding Amount
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="outstanding_amount") बकाया रक्कम
                input.form-control(type="text" name="outstanding_amount" id="outstanding_amount" placeholder="Enter Outstanding Amount" value=jPatrak.outstanding_amount)

            // Remarks
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(type="text" name="remarks" id="remarks" placeholder="Enter Remarks" value=jPatrak.remarks)

                input.form-control(name='id' value=jPatrak.id hidden)

          // Submit Button
          .text-center
            button.btn.btn-success.mt-4(type="submit" id="update-j-patrak-btn") Update
