doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/transferred-amount/namuna-3-transferred-amount-form-handler.js' type='module' defer)

    title एक (अ) अभिहस्तांतरीत रकमा

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३
      form(id='transferred-amount-form').mt-1
        .form.form-1

          h4(style="text-align:center; font-weight:bold; color:white; background-color:#2C3E50 ; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ : एक (अ) अभिहस्तांतरीत रकमा 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(name='year' id='year' value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="stamp_duty_fee") मुद्रांक शुल्क
                input.form-control(type="text" id="stamp_duty_fee" name="stamp_duty_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="tax_amount") उपकर
                input.form-control(type="text" id="tax_amount" name="tax_amount" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="land_revenue") जमीन महसूल
                input.form-control(type="text" id="land_revenue" name="land_revenue" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="land_uniform_tax") जमीन समानी करण
                input.form-control(type="text" id="land_uniform_tax" name="land_uniform_tax" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="minor_minerals_amount") गौण खनिजे
                input.form-control(type="text" id="minor_minerals_amount" name="minor_minerals_amount" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="road_lighting_subsidy") पथ दिवाबत्ती अनुदान
                input.form-control(type="text" id="road_lighting_subsidy" name="road_lighting_subsidy" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="water_supply_subsidy") नळ पाणी पुरवठा अनुदान ५०%
                input.form-control(type="text" id="water_supply_subsidy" name="water_supply_subsidy" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="backward_tribal_area_support") मागास व आदिवासी क्षेत्रासाठी सहाय्य
                input.form-control(type="text" id="backward_tribal_area_support" name="backward_tribal_area_support" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="travel_subsidy") यात्रा अनुदान
                input.form-control(type="text" id="travel_subsidy" name="travel_subsidy" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="tax_loss_compensation_grant") जकात नुकसान भरपाई अनुदान
                input.form-control(type="text" id="tax_loss_compensation_grant" name="tax_loss_compensation_grant" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_grants") इतर अनुदान
                input.form-control(type="text" id="other_grants" name="other_grants" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_k_amount") एकूण (एक) क (१ ते ११)
                input.form-control(type="text" id="total_k_amount" name="total_k_amount" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_abk_amount") एकूण (अ + ब + क)
                input.form-control(type="text" id="total_abk_amount" name="total_abk_amount" placeholder=" ")

          .text-center
            button.btn.btn-primary.mt-4(type="submit" id='save-transferred-amount-btn') Save
