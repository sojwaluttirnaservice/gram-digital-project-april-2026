        title वार्षिक अहवाल पुरवणी (जिल्हा ग्राम विकास निधी)

        style.
            .heading-1 {
                font-weight: bold !important;
                font-size: 1.4rem;
                text-align: center;
                color: #bb2525;
                border-radius: 15px;
                border: 2px solid #bb2525;
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 8px;
                margin: 0 auto 1.4rem;
                width: fit-content;
            }

            label.error {
                color: red;
                font-size: 0.9rem;
            }

            th, td {
                border: 1px solid #ccc;
                padding: 10px;
            }

        script.
            let _annualReportAddendum = !{JSON.stringify(annualReportAddendum)}

    body
        include ../../../include/navs.pug
        .container
            h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
            div
                .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
                    a.btn.btn-primary(href='/namuna/3') नमुना ३

            form(id='annual-report-addendum-form').mt-1
                .form.form-1
                    h4(style="text-align:center; font-weight:bold; color:white; background-color:#DC143C; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना ३ वार्षिक अहवाल पुरवणी (जिल्हा ग्राम विकास निधी)

                    .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="year") वर्ष
                                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="district") जिल्हा
                                input.form-control(type="text" name="district" id="district" placeholder="")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="gp") ग्रामपंचायत
                                input.form-control(type="text" name="gp" id="gp" placeholder="")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="district_gp_fund") ग्रा. पं. ने चालू वर्षी जि. ग्रा. वि. निधी दिला
                                input.form-control(type="text" name="district_gp_fund" id="district_gp_fund" placeholder="")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="start_balance_4") वर्षारंभी शिल्लक ४
                                input.form-control(type="text" step="any" name="start_balance_4" id="start_balance_4" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="fund_disbursed_5") पंचायातीनी चालू वर्षी दिलेली निधी रक्कम ५
                                input.form-control(type="text" step="any" name="fund_disbursed_5" id="fund_disbursed_5" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="principal_loan_6") देणे रक्कम मुद्दल(कर्ज) ६
                                input.form-control(type="text" step="any" name="principal_loan_6" id="principal_loan_6" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="repaid_loan_6b") परत केली रक्कम(कर्ज) ६ब
                                input.form-control(type="text" step="any" name="repaid_loan_6b" id="repaid_loan_6b" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="interest_due_7") देय रक्कम (व्याज) ७
                                input.form-control(type="text" step="any" name="interest_due_7" id="interest_due_7" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="repaid_interest_7b") व्याज परत केली रक्कम (व्याज) ७ब
                                input.form-control(type="text" step="any" name="repaid_interest_7b" id="repaid_interest_7b" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="investment_interest_govt_8") गुंतुवणूकीवर मिळालेले व्याज (सरकारी) ८
                                input.form-control(type="text" step="any" name="investment_interest_govt_8" id="investment_interest_govt_8" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="investment_interest_other_9") गुंतुवणूकीवर मिळालेले व्याज (इतर) ९
                                input.form-control(type="text" step="any" name="investment_interest_other_9" id="investment_interest_other_9" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="total_income_formula_10") एकूण उत्त्पन्न रकाना ( ५ + ६ब + ७ब + ८ + ९) = (१०)
                                input.form-control(type="text" step="any" name="total_income_formula_10" id="total_income_formula_10" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="total_income_with_balance_11") शिल्लाकेसह एकूण उत्त्पन्न (४ + १०) = ११
                                input.form-control(type="text" step="any" name="total_income_with_balance_11" id="total_income_with_balance_11" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="loan_disbursed_current_year_12") चालू वर्षात पंचायतीला दिलेली कर्ज रक्कम १२
                                input.form-control(type="text" step="any" name="loan_disbursed_current_year_12" id="loan_disbursed_current_year_12" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="invested_amount_govt_13") गुंतवलेली रक्कम (सरकारी) १३
                                input.form-control(type="text" step="any" name="invested_amount_govt_13" id="invested_amount_govt_13" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="invested_amount_other_14") गुंतवलेली रक्कम (इतर) १४
                                input.form-control(type="text" step="any" name="invested_amount_other_14" id="invested_amount_other_14" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="other_expenses_15") इतर खर्च १५
                                input.form-control(type="text" step="any" name="other_expenses_15" id="other_expenses_15" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="total_other_expenses_12_15") इतर खर्च रकाना (१२ + १५)
                                input.form-control(type="text" step="any" name="total_other_expenses_12_15" id="total_other_expenses_12_15" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="outstanding_loans_year_end") वर्षांच्या शेवटी थकीत कर्जांची रक्कम
                                input.form-control(type="text" step="any" name="outstanding_loans_year_end" id="outstanding_loans_year_end" placeholder=" ")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="total_balance_year_end_15") वर्षाअंती शिल्लक एकूण रक्कम १५
                                input.form-control(type="text" step="any" name="total_balance_year_end_15" id="total_balance_year_end_15" placeholder=" ")

                                input(name='id' value=annualReportAddendum.id hidden)
                //- Submit Button
                div 
                    div.d-flex.align-items-center.justify-content-center.gap-2
                        button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
                        button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
                        button.btn.btn-success.mt-4(type="submit" id='update-annual-report-addendum-btn') Update Form


