                td #{prapatraCATax.street_light_tax}
                td #{prapatraCATax.cleanliness_tax}

                td #{prapatraCATax.shop_industry_hotel_tax}
                td #{prapatraCATax.travel_tax}
                td #{prapatraCATax.fair_festival_tax}
                td #{prapatraCATax.cycle_vehicle_tax}
                td #{prapatraCATax.toll_tax}

                td #{prapatraCATax.goods_tax}
                td #{prapatraCATax.forest_development_tax}
                td #{prapatraCATax.service_tax}
                td #{prapatraCATax.trade_or_occupation_tax}
                td #{prapatraCATax.cattle_market_commission_tax}
                td #{prapatraCATax.other_taxes}
