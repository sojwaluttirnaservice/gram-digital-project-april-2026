doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/other-income/namuna-3-other-income-form-handler.js' type='module' defer)

    title एक (ब) करेत्तर उत्त्पन्न 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल) 
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३
      form(id='other-income-form').mt-1
        .form.form-1

          h4(style="text-align:center; font-weight:bold; color:white; background-color:#4B2C5E ; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ एक (ब) करेत्तर उत्त्पन्न 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(name='year' id='year' value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="market_fee") बाजार फी 
                input.form-control(type="text" id="market_fee" name="market_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="tanga_stand_fee") टांगा स्टँड फी
                input.form-control(type="text" id="tanga_stand_fee" name="tanga_stand_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="car_stand_fee") कार स्टँड फी
                input.form-control(type="text" id="car_stand_fee" name="car_stand_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="water_tax") पाणी पट्टी 
                input.form-control(type="text" id="water_tax" name="water_tax" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="cleanliness_fee") स्वच्छता फी
                input.form-control(type="text" id="cleanliness_fee" name="cleanliness_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="cow_grazing_fee") गाय चरण फी
                input.form-control(type="text" id="cow_grazing_fee" name="cow_grazing_fee" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="dvdf_interest_2_5_percent") डी.व्ही.डी. एफ व्याज २.५ टक्के
                input.form-control(type="text" id="dvdf_interest_2_5_percent" name="dvdf_interest_2_5_percent" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="land_rent") जमीन भाडे पट्टी
                input.form-control(type="text" id="land_rent" name="land_rent" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="interest_deposit") व्याज जमा
                input.form-control(type="text" id="interest_deposit" name="interest_deposit" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="land_rent_deposit") जागा भाडे
                input.form-control(type="text" id="land_rent_deposit" name="land_rent_deposit" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="kondwada_deposit") कोंडवाडा जमा
                input.form-control(type="text" id="kondwada_deposit" name="kondwada_deposit" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="donation") देणगी
                input.form-control(type="text" id="donation" name="donation" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="other_deposits") इतर जमा
                input.form-control(type="text" id="other_deposits" name="other_deposits" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_other_income") एकूण (एक) (ब) करेत्तर उत्त्पन्न
                input.form-control(type="text" id="total_other_income" name="total_other_income" placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_income_1_2") एकूण उत्पन्न १+२
                input.form-control(type="text" id="total_income_1_2" name="total_income_1_2" placeholder=" ")

            .text-center
              button.btn.btn-primary.mt-4(type="submit" id='save-other-income-btn') Save
