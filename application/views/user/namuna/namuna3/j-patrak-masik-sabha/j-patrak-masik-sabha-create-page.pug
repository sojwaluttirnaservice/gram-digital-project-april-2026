doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    //- common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    //- Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-3/namuna-3-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-3/j-patrak-masik-sabha/namuna-3-j-patrak-masik-sabha-page-form-handler.js' type='module' defer)

    title जे पत्रक (मासिक सभा) 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='j-patrak-masik-sabha-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#2E8B57; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ जे पत्रक (मासिक सभा) 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            //- ग्रामपंचायतीचे नाव (Name of the Gram Panchayat)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="gram_panchayat_name") ग्रामपंचायतीचे नाव
                input.form-control(type="text" name="gram_panchayat_name" id="gram_panchayat_name" placeholder="Enter Gram Panchayat Name")

            //- एकूण सदस्य संख्या (Total Number of Members)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_members") एकूण सदस्य संख्या
                input.form-control(type="text" name="total_members" id="total_members" placeholder="Enter Total Number of Members")

            //- वर्षात किमान घ्यावयाच्या एकूण सभा (Minimum Total Meetings to Be Held in the Year)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="minimum_meetings_in_year") वर्षात किमान घ्यावयाच्या एकूण सभा
                input.form-control(type="text" name="minimum_meetings_in_year" id="minimum_meetings_in_year" placeholder="Enter Minimum Total Meetings to Be Held in the Year")

            //- वर्षात प्रत्यक्ष घेतलेल्या मासिक सभा (Actual Monthly Meetings Held in the Year)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="actual_monthly_meetings") वर्षात प्रत्यक्ष घेतलेल्या मासिक सभा 
                input.form-control(type="text" name="actual_monthly_meetings" id="actual_monthly_meetings" placeholder="Enter Actual Monthly Meetings Held in the Year")

            //- कोरम अभावी तहकूब सभा (Postponed Meetings Due to Lack of Quorum)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="postponed_due_to_quorum") कोरम अभावी तहकूब सभा 
                input.form-control(type="text" name="postponed_due_to_quorum" id="postponed_due_to_quorum" placeholder="Enter Postponed Meetings Due to Lack of Quorum")

            //- तहकूब सभा पुन्हा घेतल्या किंवा नाही (Were Postponed Meetings Held Again or Not?)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="postponed_meetings_again") तहकूब सभा पुन्हा घेतल्या किंवा नाही 
                input.form-control(type="text" name="postponed_meetings_again" id="postponed_meetings_again" placeholder="Enter Postponed Meetings Again or Not")

            //- महिन्यात किमान १ सभा झाली नसल्यास कोणत्या महिन्यात नाही? न घेतल्याचे कारण (If No Meeting Held in the Month, Which Month and Reason?)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="no_meeting_month_and_reason") महिन्यात किमान १ सभा झाली नसल्यास कोणत्या महिन्यात नाही? न घेतल्याचे कारण 
                input.form-control(type="text" name="no_meeting_month_and_reason" id="no_meeting_month_and_reason" placeholder="Enter Month and Reason if No Meeting Held")

            //- मतदार संख्या (Voter Count)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="voter_count") मतदार संख्या 
                input.form-control(type="text" name="voter_count" id="voter_count" placeholder="Enter Voter Count")

            //- पहिली ग्रामसभा घेतली असल्यास ता. हजर सदस्य (Attendance in First Gram Sabha)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="first_gram_sabha_attendance") पहिली ग्रामसभा घेतली असल्यास ता. हजर सदस्य 
                input.form-control(type="text" name="first_gram_sabha_attendance" id="first_gram_sabha_attendance" placeholder="Enter Attendance in First Gram Sabha")

            //- दुसरी ग्रामसभा घेतली असल्यास ता. हजर सदस्य (Attendance in Second Gram Sabha)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="second_gram_sabha_attendance") दुसरी ग्रामसभा घेतली असल्यास ता. हजर सदस्य 
                input.form-control(type="text" name="second_gram_sabha_attendance" id="second_gram_sabha_attendance" placeholder="Enter Attendance in Second Gram Sabha")

            //- तिसरी ग्रामसभा घेतली असल्यास ता. हजर सदस्य (Attendance in Third Gram Sabha)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="third_gram_sabha_attendance") तिसरी ग्रामसभा घेतली असल्यास ता. हजर सदस्य 
                input.form-control(type="text" name="third_gram_sabha_attendance" id="third_gram_sabha_attendance" placeholder="Enter Attendance in Third Gram Sabha")

            //- प्रत्येक सभेसकोरम होता ? नसल्यास पुन्हा सभा घेतली काय? ता. (Was Quorum Present in Each Meeting? If Not, Was It Reheld?)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="quorum_check_and_reheld") प्रत्येक सभेसकोरम होता ? नसल्यास पुन्हा सभा घेतली काय? ता. 
                input.form-control(type="text" name="quorum_check_and_reheld" id="quorum_check_and_reheld" placeholder="Enter Quorum Status and Whether Reheld")

            //- शेरा (Notes or Remarks)
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा 
                input.form-control(type="text" name="remarks" id="remarks" placeholder="Enter Remarks or Notes")




          //- Submit Button
          .text-center
            button.btn.btn-primary.mt-4(type="submit" id='save-j-patrak-masik-sabha-btn') Save
