    title ग्रामपंचायत फेर आकारणी बाबत 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

      th, td {
        border: 1px solid #ccc;
        padding: 10px;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='gp-cost-revaluation-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#BA55D3; padding:8px 18px; display:block; margin:10px auto;") नमुना ३ ग्रामपंचायत फेर आकारणी बाबत 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(type='text' name="year" id="year" placeholder="Enter Year" value=year readonly)

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="previous_reassessment_implementation_date") मागील फेर आकारणी अमलात आणण्याची तारीख
                input.form-control.datepicker(type="text" name="previous_reassessment_implementation_date" id="previous_reassessment_implementation_date" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="tax_name_assessed") आकारलेल्या कराचे नाव
                input.form-control(type="text" name="tax_name_assessed" id="tax_name_assessed" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="amount_requested_for_year") वर्षासाठी केलेली रक्कम
                input.form-control(type="text" name="amount_requested_for_year" id="amount_requested_for_year" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="reassessment_interval_years") फेर कर दर ४ वर्षानी आकारणी करण्याचे वर्ष
                input.form-control(type="text" name="reassessment_interval_years" id="reassessment_interval_years" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="reassessment_year") फेर कर आकारणी केलेले वर्ष
                input.form-control(type="text" name="reassessment_year" id="reassessment_year" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="tax_name_in_reassessment") फेर आकारणी मध्ये आकारलेल्या कराचे नाव
                input.form-control(type="text" name="tax_name_in_reassessment" id="tax_name_in_reassessment" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="amount_assessed_for_year") आकारणी केलेली रक्कम (वर्षासाठी)
                input.form-control(type="text" name="amount_assessed_for_year" id="amount_assessed_for_year" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="increase_in_income_after_reassessment") फेर कर आकारणी नंतर उत्त्पन्नात वाढ कराची रक्कम
                input.form-control(type="text" name="increase_in_income_after_reassessment" id="increase_in_income_after_reassessment" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_property_count_buildings") एकूण मालमत्ता संख्या इमारती
                input.form-control(type="text" name="total_property_count_buildings" id="total_property_count_buildings" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_property_count_land") एकूण मालमत्ता संख्या जमिनी
                input.form-control(type="text" name="total_property_count_land" id="total_property_count_land" placeholder="")


          //- Submit Button
          div 
            div.d-flex.align-items-center.justify-content-center.gap-2
              button.btn.btn-secondary.mt-4(type="submit" id='add-row-btn') Add row
              button.btn.btn-secondary.mt-4(type='submit' id='update-row-btn') Update Row
              button.btn.btn-primary.mt-4(type="submit" id='save-gp-cost-revaluation-btn') Save Form


      .table-responsive      
