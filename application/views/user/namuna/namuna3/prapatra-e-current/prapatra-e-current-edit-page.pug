    title प्रपत्र इ चालू 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../include/navs.pug
    .container
      h2.heading-1.mt-2.mb-1 नमुना ३: ग्राम पंचायत जमा व खर्च तक्ता (वार्षिक अहवाल)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/3') नमुना ३

      form(id='prapatra-e-current-form').mt-1
        .form.form-1
          h4(style="text-align:center; font-weight:bold; color:white; background-color:#36454F; padding:8px 18px; display:block; margin:10px auto;") Edit नमुना ३ प्रपत्र इ चालू 

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2.px-3
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="year") वर्ष
                input.form-control(name='year' id='year' placeholder="Enter Year" value=prapatraECurrent.year readonly)

            // Upper Half of the Print Part
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="sarpanch_honorarium") सरपंच मानधन
                input.form-control(type="number" step="any" id="sarpanch_honorarium" name="sarpanch_honorarium" value=prapatraECurrent.sarpanch_honorarium placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="member_meeting_allowance") सदस्य बैठक भत्ता
                input.form-control(type="number" step="any" id="member_meeting_allowance" name="member_meeting_allowance" value=prapatraECurrent.member_meeting_allowance placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="member_sarpanch_travel_allowance") सदस्य/सरपंच प्रवास भत्ता
                input.form-control(type="number" step="any" id="member_sarpanch_travel_allowance" name="member_sarpanch_travel_allowance" value=prapatraECurrent.member_sarpanch_travel_allowance placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="employee_salary") कर्माचारी                                  
                input.form-control(type="number" step="any" id="employee_salary" name="employee_salary" value=prapatraECurrent.employee_salary placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="employee_travel_allowance") कर्मचारी प्रवास भत्ता
                input.form-control(type="number" step="any" id="employee_travel_allowance" name="employee_travel_allowance" value=prapatraECurrent.employee_travel_allowance placeholder=" ")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="office_expenses") कार्यालयीन खर्च
                input.form-control(type="number" step="any" id="office_expenses" name="office_expenses" value=prapatraECurrent.office_expenses placeholder=" ")

            .col-11.col-md-6.col-lg-6
