    title नमुना २१ ग्रामपंचायतीच्या कर्मचाऱ्यांच्या वेतन देयकाची नोंदवही
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना २१ ग्रामपंचायतीच्या कर्मचाऱ्यांच्या वेतन देयकाची नोंदवही
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/21') यादी


      form(id='namuna-21-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना १८ नोंदणी

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-2
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}


            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="employee_id_fk") नाव
                select.form-select(type="text" id="employee_id_fk" name="employee_id_fk" required placeholder=" ")
                  option(value='' ) --निवडा--
                  each employee in employees 
                    option(value=employee.id data-employeeName=employee.name data-postName=employee.post_name)=employee.name

                input.form-control(name='employee_name' readonly hidden) 

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="employee_post") कर्मचाऱ्याचे पद
                input.form-control(type="text" id="employee_post" name="employee_post" required readonly)


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="pay_grade") वेतनश्रेणी किंवा विशेष वेतन
                input.form-control(type="text" id="pay_grade" name="pay_grade" required placeholder=" ")

            //- Doubtness
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="salary") वेतन
                input.form-control(type="number" id="salary" name="salary" required placeholder=" ")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="leave_salary") रजा वेतन
                input.form-control(type="number" id="leave_salary" name="leave_salary" required placeholder="")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="placement_salary") स्थानापत्र वेतन
                input.form-control(type="number" id="placement_salary" name="placement_salary" required placeholder="")

            //- 
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="allowances") भत्ते
                input.form-control(type="number" id="allowances" name="allowances" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="future_contribution_reserved") पुढील अधिदानासाठी ठेवलेली रक्कम
                input.form-control(type="number" id="future_contribution_reserved" name="future_contribution_reserved" placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="collections_and_penalties") वसुली व दंड
                input.form-control(type="number" id="collections_and_penalties" name="collections_and_penalties" required placeholder="")

            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="state_pf_contribution")  पुढील अधिदानासाठी ठेवलेली रक्कम (शासन)
                input.form-control(type="number" id="state_pf_contribution" name="state_pf_contribution" required placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="state_other_deductions") वसुली व दंड  (शासन)
                input.form-control(type="number" id="state_other_deductions" name="state_other_deductions" required placeholder="")

            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="gp_pf_contribution") पुढील अधिदानासाठी ठेवलेली रक्कम (ग्रा.पं.)
                input.form-control(type="number" id="gp_pf_contribution" name="gp_pf_contribution" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="gp_other_deductions") वसुली व दंड
                input.form-control(type="number" id="gp_other_deductions" name="gp_other_deductions" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(type="text" id="remarks" name="remarks" placeholder="शेरा")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-21-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
