//- =======================================================
//- MASTER LAYOUT
//- =======================================================
extends ../../../../../include/internal-gp-master-layout.pug

//- =======================================================
//- CUSTOM CSS
//- =======================================================
block custom_css
    style.
        .badge {
            font-size: 13px;
            font-weight: 600;
            padding: 6px 10px;
            border-radius: 20px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .badge-samanya {
            background: #e8f5e9;
            color: #2e7d32;
        }
        table {
            border-collapse: collapse;
        }
        thead, tr, th, td {
            border: 1px solid black;
        }
        td {
            text-align: center;
        }

        .badge-pani {
            background: #e3f2fd;
            color: #1565c0;
        }

//- =======================================================
//- CONTENT
//- =======================================================
block content
    .container-fluid.mt-3

        .row.justify-content-center
            .col-12.col-lg-10

                // =====================================================
                // FORM CARD
                // =====================================================
                .card.shadow-sm.mb-3
                    .card-header.bg-light
                        h5.mb-0
                            i.fa.fa-plus.me-2
                            | नवीन नमुना ५ सामान्य कारण

                    .card-body
                        form#namuna5SamanyReasonForm
                            .row.g-3

                                //- TYPE
                                .col-md-3
                                    label.form-label प्रकार
                                    select.form-select#tax_category(name="tax_category")
                                        option(value="SAMANYA" selected) सामान्य


                                .col-md-3 
                                    label.form-label मुख्य कारण निवडा
                                    select.form-select#mainReasonDropdown
                                        option(value='') --निवडा--
                                        each _mainReason in mainReasons
                                            option(value=_mainReason.main_reason) #{_mainReason.main_reason}
                                        option(value="OTHER") इतर / अन्य कारण
                                //- REASON
                                .col-md-3
                                    label.form-label मुख्य कारण
                                    input.form-control#main_reason(type="text" placeholder="मुख्य कारण लिहा" autocomplete="off")                                 
                                    p.text-danger(style="font-size:0.8rem;") इतर मुख्य कारण असेल तर इथे टाका.

                                //- REASON
                                .col-md-3
                                    label.form-label उप कारण
                                    input.form-control#reason_in_words(type="text" placeholder="उप कारण लिहा" autocomplete="off")

                                //- BUTTON
                                .col-12
                                    .d-flex.align-items-end.justify-content-center
                                        button.btn.btn-primary.w-fit(type="submit")
                                            i.fa.fa-save.me-1
                                            | सेव्ह करा

                // =====================================================
                // TABLE CARD
                // =====================================================
                .card.shadow-sm
                    .card-header.bg-light
                        h5.mb-0
                            i.fa.fa-list.me-2
                            | नमुना ५ सामान्य कारणांची यादी

                    .card-body.p-0
                        .table-responsive
                            table.table.table-striped.table-hover.mb-0.align-middle

                                thead.table-dark
                                    tr
                                        th(style="width:180px") प्रकार
                                        th मुख्य कारण
                                        th उप कारण

                                tbody#reasonTableBody
                                    each n5SamanyaReason in n5SamanyaReasons
                                        tr(class=n5SamanyaReason.tax_category === "PANI" ? "table-primary" : "")
                                            td
                                                if n5SamanyaReason.tax_category === "SAMANYA"
                                                    span.badge.badge-samanya
                                                        i.fa.fa-home.me-1
                                                        | सामान्य
                                                else if n5SamanyaReason.tax_category === "PANI"
                                                    span.badge.badge-pani
                                                        i.fa.fa-tint.me-1
                                                        | पाणी

                                            td #{n5SamanyaReason.main_reason}
                                            td #{n5SamanyaReason.reason_in_words}

//- =======================================================
//- SCRIPTS
//- =======================================================
block custom_js
    //- script(src="https://code.jquery.com/jquery-3.7.1.min.js")

    script.

        $("#mainReasonDropdown").on("change", function () {

            const selectedValue = $(this).val();
            const $input = $("#main_reason");

            if (!selectedValue) {
                // ❌ Nothing selected
                $input.val("").prop("disabled", true);

            } else if (selectedValue === "OTHER") {
                // ✏️ Other selected
                $input.val("").prop("disabled", false).focus();

            } else {
                // ✅ Normal option selected
                $input.val(selectedValue).prop("disabled", false);
            }

        });


        // =====================================================
        // API CALL (ASYNC AWAIT)
        // =====================================================
        async function handleSaveNamuna5SamanyaReason(payload = {}) {
            try {
                const response = await fetch("/namuna/5/samanya/reasons", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        tax_category: payload.tax_category || "SAMANYA",
                        certificate_category: "CERTIFICATE",
                        main_reason: payload.main_reason,
                        reason_in_words: payload.reason_in_words || ""
                    })
                });

                const data = await response.json(); // ✅ clean async await

                const { success, message } = data;

                if (success) {
                    alertjs.success({
                        t: "Success",
                        m: message || "Saved successfully"
                    });
                } else {
                    alertjs.warning({
                        t: "Warning",
                        m: message || "Something went wrong"
                    });
                }

                return data;

            } catch (error) {
                console.error("Fetch Error:", error);

                alertjs.warning({
                    t: "Error",
                    m: "Server error occurred"
                });

                throw error;
            }
        }

        // =====================================================
        // FORM SUBMIT
        // =====================================================
        $("#namuna5SamanyReasonForm").on("submit", async function (e) {
            e.preventDefault();

            const payload = {
                tax_category: $("#tax_category").val() || "SAMANYA",
                main_reason: $("#main_reason").val(),
                reason_in_words: $("#reason_in_words").val().trim() || ""
            };

            if (!payload.reason_in_words) {
                alert("कृपया कारण लिहा");
                return;
            }

            try {
                const res = await handleSaveNamuna5SamanyaReason(payload);

                //- alert("✅ यशस्वीरित्या सेव्ह झाले");

                // reset input
                $("#reason_in_words").val("");

                // reload list
                location.reload();

            } catch (err) {
                alert("❌ सेव्ह करताना त्रुटी आली");
            }
        });