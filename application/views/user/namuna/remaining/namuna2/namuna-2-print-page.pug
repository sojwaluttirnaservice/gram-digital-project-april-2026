                    h3(class="py-8 font-extrabold text-6xl text-center bg-gradient-to-r from-yellow-400 via-yellow-600 to-amber-800 bg-clip-text text-transparent") पुनर्विनियोजन व नियतवाटप विवरणपत्र

                    h4(class='mt-4 text-emerald-500 text-3xl font-extrabold text-center') सन #{fromYear} ते #{toYear}

                    div(class='mt-8')
                        h1(class='font-extrabold text-red-500 text-7xl text-center') ग्रामपंचायत कार्यालय #{gp.gp_name}
                        h3(class='mt-8 font-bold text-red-700 text-5xl text-center') पंचायत समिती #{gp.gp_taluka}, जिल्हा. #{gp.gp_dist}


            //- second page
            div(class="my-print p-2 border-2 border-green-800 bg-white/60 relative h-[100lvh] print-bg")
                .relative.z-10.bg-white.bg-opacity-80.h-full

                    h2(class='text-rose-500 text-2xl text-center') महाराष्ट्र ग्रामपंचायत लेखा संहिता २०११ 
                    h6(class='mt-4 text-green-600 text-2xl text-center') नियम २१ पहा
                    h5(class='mt-4 text-red-600 text-center text-2xl') नमुना २

                    div(class='mt-4')
                        h1(class='font-extrabold text-red-500 text-7xl text-center') ग्रामपंचायत कार्यालय #{gp.gp_name}
                        h3(class='mt-8 font-bold text-red-700 text-5xl text-center') पंचायत समिती #{gp.gp_taluka}, जिल्हा. #{gp.gp_dist}

                    hr 

                    div 
                        h5(class='text-5xl text-center font-extrabold tracking-wider bg-gradient-to-r from-yellow-400 via-yellow-600 to-amber-800 bg-clip-text text-transparent') प्रमाणपत्र
                    
                    div(class='text-blue-600')
                        div(class='text-2xl text-blue-700') 
                            p प्रति,
                            
                            div(class='pl-4')
                                p सरपंच/सचिव/ग्रा.वि.अधिकारी,
                                p ग्रामपंचायत कार्यालय #{gp.gp_name}


                        div 
                            div(class='text-2xl')
                                p(class='w-full text-end') याज कडून प्रमाणित करण्यात येते की,
                                | ग्रामपंचायत कार्यालय #{gp.gp_name} यांचे 
                                | सन #{fromYear} - #{toYear} चे वार्षिक पुनर्विनियोजन व नियतवाटप यांचे विवरणपत्र
                                | मासिक सभा ठराव क्रं. 
                                span(class='inline-block w-24') 
                                | दिनांक 
                                span(class='inline-block w-24') 
                                span अन्वये 
                                | मंजूर करण्यात येऊन मंजुरी करीता सादर
                    
                            div(class='mt-12 flex justify-evenly items-center font-extrabold text-2xl')
                                div(class='flex flex-col items-center') 
                                    div सरपंच
                                    div ग्रामपंचायत #{gp.gp_name}
                                    

                                div(class='flex flex-col items-center')
                                    div सचिव / ग्रा.वि. अ
                                    div ग्रामपंचायत #{gp.gp_name}


            //- third page
            div(class="my-print p-2 border-2 border-green-800 bg-white/60 relative h-[100lvh] print-bg")
                .relative.z-10.bg-white.bg-opacity-80.h-full

                    //- h2(class='text-rose-500 text-2xl text-center') महाराष्ट्र ग्रामपंचायत लेखा संहिता २०११ 
                    //- h6(class='mt-4 text-green-600 text-2xl text-center') नियम २१ पहा
                    //- h5(class='mt-4 text-red-600 text-center text-2xl') नमुना २

                    div(class='mt-4')
                        //- h1(class='font-extrabold text-red-500 text-7xl text-center') ग्रामपंचायत कार्यालय #{gp.gp_name}
                        h3(class='py-8 font-extrabold  bg-gradient-to-r from-yellow-400 via-yellow-600 to-amber-800 bg-clip-text text-transparent text-5xl text-center') पंचायत समिती #{gp.gp_taluka}
                        h5(class='mt-2 text-4xl font-bold text-emerald-600 text-center') जिल्हा परिषद #{gp.gp_dist}

                    hr

                    div 
                        h5(class='text-5xl text-center font-extrabold tracking-wider bg-gradient-to-r from-yellow-400 via-yellow-600 to-amber-800 bg-clip-text text-transparent') प्रमाणपत्र
                    
                    div(class='text-blue-600')
