doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title नमुना २ - Print

        script(src="/asstest/coustom/css/tailwind.js")

        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin="")
        link(href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Marathi:ital@0;1&family=Yatra+One&display=swap" rel="stylesheet")

        script(src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js")
        script(src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js")

        script.
            document.addEventListener('DOMContentLoaded', function(){
                const downloadPdf = () => {
                    const element = document.querySelector('#print');
                    const options = {
                        margin: [0.1, 0.1, 0.1, 0.1],
                        filename: 'namuna2-print.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2, useCORS: true, scrollY: 0 },
                        jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
                    };
                    html2pdf().set(options).from(element).save();
                }

                const downloadPdfBtn = document.getElementById('download-pdf-btn');
                if (downloadPdfBtn) downloadPdfBtn.addEventListener('click', downloadPdf);

                function showHideSignatures(val) {
                    const sarpanchSigns = document.querySelectorAll('.sarpanch-sign');
                    const gramAdhikariSigns = document.querySelectorAll('.gram-adhikari-sign');

                    switch (val) {
                        case '1':
                            sarpanchSigns.forEach(el => el.style.opacity = '1');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '0');
                            break;
                        case '-1':
                            sarpanchSigns.forEach(el => el.style.opacity = '0');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '1');
                            break;
                        case '2':
                            sarpanchSigns.forEach(el => el.style.opacity = '0');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '1');
                            break;
                        case '-2':
                            sarpanchSigns.forEach(el => el.style.opacity = '1');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '0');
                            break;
                        case '3':
                            sarpanchSigns.forEach(el => el.style.opacity = '1');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '1');
                            break;
                        case '-3':
                            sarpanchSigns.forEach(el => el.style.opacity = '0');
                            gramAdhikariSigns.forEach(el => el.style.opacity = '0');
                            break;
                    }
                }

                document.querySelector('.form-select').addEventListener('change', function() {
                    showHideSignatures(this.value);
                });
            })

        style.
            table {
                border-collapse: collapse;
            }

            td, th {
                padding: 0.2rem;
                border: 1px solid black;
            }

            /* 🔥 FIX: Force full border printing */
            table, th, td {
                border: 1px solid #000 !important;
                border-collapse: collapse !important;
            }

            @media print {
                @page {
                    size: A4 landscape;
                }

                .hide-print {
                    display: none !important;
                }

                * {
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                /* 🔥 FIX: Prevent border loss on page breaks */
                table { page-break-inside: auto !important; }
                tr { page-break-inside: avoid !important; page-break-after: auto !important; }
                td, th { border: 1px solid #000 !important; }
            }

            .tiro-devanagari-marathi-regular {
                font-family: "Tiro Devanagari Marathi", serif;
            }

    body
        - let year = ''

        div.hide-print
            div(class="fixed top-[45%] right-[2%] flex flex-col gap-2 z-50")
                button(class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded shadow-md" onclick="window.print()") Print
                //button(class="bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2 rounded shadow-md" id="download-pdf-btn") Download

                select(class="form-select block w-full mt-1 px-3 py-2 bg-white border border-gray-300 rounded-md shadow-sm")
                    option(value='1') सरपंच सही दाखवा
                    option(value='-1') सरपंच सही लपवा
                    option(value='2') ग्रा.अ. सही दाखवा
                    option(value='-2') ग्रा.अ. सही लपवा
                    option(value='3') दोन्ही सही दाखवा
                    option(value='-3') दोन्ही सही लपवा


        #print(class="tiro-devanagari-marathi-regular print:h-[100lvh]")

            //- first page
            div(class="my-print p-2 border-2 border-green-800 bg-white/60 relative h-[100lvh] print-bg")
