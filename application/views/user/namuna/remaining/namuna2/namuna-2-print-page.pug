                                            td.text-center.p-1 #{n2Entry.expense_variation}
                                            td.text-center.p-1 #{n2Entry.expense_remarks}
                                    each _ in Array.from({length: 24})
                                        tr
                                            each _ in Array.from({length: 11})
                                                td.text-center.p-1 
                                                    span(class='opacity-0') -

