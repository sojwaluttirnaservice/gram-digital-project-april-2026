    title नमुना १ - जमा ग्रामनिधी (जमा)

    style.

      thead, tr, th, td {
        border: 1px solid black !important;
        padding: 8px;
      }
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना १ जमा ग्रामनिधी (जमा)
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/1') नमुना १ तपशिल यादी

    //- <button style='${entryIndex == lengthOfEntries - 1 ? '' : 'display:none'}' class="btn btn-success add-table-row">

    div(style='position: fixed; bottom: 1rem; right: 1rem;')

      button.btn.btn-success.add-table-row(type='button' data-isEdit='false')
        i.fa.fa-plus &nbsp;
        | Row

    .container
      h5.text-center सन #{fromYear} ते #{year} 
      .village-funds-table-container(style='margin-top: 0.5rem;  padding: 0.5rem 0;')
        .table-responsive
          table#village-funds.table

        div
          .d-flex.justify-content-center
            button.btn.btn-primary(type='button' id='submit-namuna-1-village-entries-btn') Save

