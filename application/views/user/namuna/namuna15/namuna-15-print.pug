doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")

        title print- उपभोग्य वस्तु साठा लेखा नोंदवही

        style.
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            /* Basic styles for the body */
            body {
                //- font-family: Arial, sans-serif;
                margin: 0;
                //- padding: 20px;
            }

            .text-center {
                text-align: center;
            }

            /* Styles for the table */
            table {
                width: 100%;
                border-collapse: collapse;
            }

            th, td {
                border: 1px solid #ddd;
                padding: 8px;
                text-align: center;
            }

            th {
                background-color: #f2f2f2;
                font-weight: bold;
            }

            /* Print styles */
            @media print {
                body {
                    margin: 0;
                    //- padding: 10px 10px;
                }

                #hide-buttons {
                    display: none;
                }

                table {
                    page-break-inside: avoid;
                }

                tr {
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }

                th, td, tr  {
                    border: 1px solid black !important;
                    font-size: 12px;
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }

                .my-print {
                    padding: 10px;
                }
                @page {
                    size: A4 landscape;
                    margin: 1mm 1mm 1mm 1mm;
                }
            }

        link(rel='stylesheet' href='/asstest/coustom/css/namuna/namuna-1-to-33-print.css')
    body
        div(id='hide-buttons')
            div(style='padding: 1rem 0rem;display: flex; align-items: center; justify-content: center; gap: 2rem;')
                div Print Data Table
                //- // Button to print the table
                button(onclick="window.print()") Print Table

        //- .my-print(style='padding: 10px')
        .my-print(style='')
            table
                thead
                    tr 
                        th(colspan='14')
                            div
                                div(style='display: flex; align-items: center; justify-content: space-between;')
                                    div नमुना १५
                                    div ग्रामपंचायत कार्यालय
                                        span #{gp.gp_name}
                                    div
                                        img(src="/new-gp-page/main-page/images/header-images/mudra-nav-2.png" style='width: 100px;')

                                div 
                                    div.text-center(style='font-size:10px;') महा. ग्रा. पं. लेखा संहिता २०११ नुसार (नियम ११ (१) व (२), २४ (२)(ग) २३, ३३(४)(घ),४७(२),५५(३३ व ५९ (३))

                                div 
                                    div.text-center(style='font-size: 20px; margin-top:0.2rem;')
                                        //- span सन #{fromYear} - #{toYear} या वर्षासाठी 
                                        span उपभोग्य वस्तुसाठा लेखा नोंदणी वही

                    tr
                        th(rowspan='2') अ.क्र.
                        th(rowspan='2') तारीख
                        th(rowspan='2') प्रारंभिक शिल्लक
                        th(rowspan='2') मिळालेल्या वस्तुंची नाव
                        th(rowspan='2') वस्तूंची संख्या किंवा परिमाण
                        th(rowspan='2') एकूण
                        th(rowspan='2') कोणास दिले किंवा कोणत्या प्रयोजनाकरिता
                        th(rowspan='2') दिलेल्या वस्तुंची संख्या किंवा परिणाम
                        th(rowspan='2') शिल्लक
                        th(rowspan='2') वस्तु देणाऱ्या अधिकाऱ्यांचे नाव
                        th(rowspan='2') वस्तु घेणाऱ्या अधिकाऱ्याचे नाव
                        th(rowspan='2') शेरा

                tbody
                    each namunaEntryRow, index in namuna15Details
                        tr
                            td #{index + 1}
                            td #{namunaEntryRow._date}
                            td #{namunaEntryRow.initial_quantity}
                            td #{namunaEntryRow.received_item_name}
                            td #{namunaEntryRow.item_quantity}
                            td #{namunaEntryRow.total}
                            td #{namunaEntryRow.purpose_or_receiver}
                            td #{namunaEntryRow.issued_item_quantity}
                            td #{namunaEntryRow.remaining_quantity}
                            td #{namunaEntryRow.issuing_officer_name}
                            td #{namunaEntryRow.receiving_officer_name}
                            td #{namunaEntryRow.remarks}
