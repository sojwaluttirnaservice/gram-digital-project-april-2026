doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title प्रिंट - नमुना २४

        // common css
        link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
        link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
        link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
        link(rel='stylesheet' href='/asstest/coustom/css/main.css')
        link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script(src='/asstest/plugins/popper/popper.min.js')
        script(src='/asstest/plugins/date/jquery-ui.js')
        script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
        script(src='/asstest/plugins/notify/notify.js')
        script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
        script(src="/asstest/plugins/jquery_validation/additional-methods.js")

        // Bootstrap 5 CSS & JS
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

        // common js setups
        script(src='/asstest/coustom/js/base.converter.js')
        script(src='/asstest/coustom/js/common.js')
        script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

        script(src='/asstest/coustom/js/handlers/namuna/namuna-18/namuna-18-report-page-handler.js' type='module' defer)
        style.
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            /* Basic styles for the body */
            body {
                //- font-family: Arial, sans-serif;
                margin: 0;
                //- padding: 20px;
                font-size: 90%;
            }

            .text-center {
                text-align: center;
            }

            /* Styles for the table */
            table {
                width: 100%;
                border-collapse: collapse;
            }

            th, td {
                border: 1px solid #ddd;
                padding: 8px;
                text-align: center;
            }

            th {
                background-color: #f2f2f2;
                font-weight: bold;
            }

            /* Print styles */
            @media print {
                body {
                    margin: 0;
                    padding: 0;
                }

                #hide-buttons {
                    display: none;
                }

                table {
                    page-break-inside: avoid;
                }

                tr {
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }

                th, td {
                    border: 1px solid black !important;
                    font-size: 12px;
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }


                //- .my-print {
                //-         height: 210mm;
                //-         width: 298mm;

                //- }

                @page {
                    size: A4 landscape;
                    margin: 4mm ;
                    //- padding: 1mm;
                }
            }
    body


        .records 


            div(style='display:flex; align-items:center; justify-content:center; gap: 1rem; margin: 1rem 0;')
                div
                    if fromYear && toYear
                        a.btn.btn-secondary.btn-sm(href=`/namuna/18/print?fromYear=${fromYear}&toYear=${toYear}`) Print
                    else if (month && year)
                        a.btn.btn-secondary.btn-sm(href=`/namuna/18/print?month=${month}&year=${year}`) Print
                    else if year 
                        a.btn.btn-secondary.btn-sm(href=`/namuna/18/print?year=${year}`) Print
                div
                    button.btn.btn-primary.btn-sm(onclick="history.back();") Back

            each monthYearGroup in JSON.parse(namuna18Details)

                .my-print

                    h4 Month: #{monthYearGroup.month}, Year: #{monthYearGroup.year}

                    table

                        thead

                            tr
                                td(colspan='18')
                                    div
                                        div(style='display: flex; align-items: center; justify-content: space-between;')

                                            h4 नमुना २४

                                            h4 ग्रामपंचायत कार्यालय 
                                                span #{gp.gp_name}
                                            div
                                                img(src="/new-gp-page/main-page/images/header-images/mudra-nav-2.png" style='width: 100px;')

                                        div 
                                            h6.text-center(style='font-size:10px;') महा. ग्रा. पं. लेखा संहिता २०११ (नियम २४ (क), ४२ (४) (थ) व ६५ पहा)

                                        div 
                                            if fromYear && toYear
                                                div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{fromYear} - #{toYear}, नमुना १८- किरकोळ रोकडवही 
                                            else if (month && year)
                                                div.text-center(style='font-size: 20px; margin-top:0.2rem;') #{month} सन #{year}, नमुना १८- किरकोळ रोकडवही 
                                            else if year 
                                                div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{year - 1} - #{year}, नमुना १८- किरकोळ रोकडवही 

                                        //- div#hide-buttons
                                            button(onclick='window.print()') Print


                            tr 
                                th(colspan='9') जमा
                                th(colspan='9') खर्च

                            tr
                                //- For CREDIT / जमा

                                th दिनांक
                                th धनादेश क्रमांक
                                th कोणाकडून प्राप्त झाली
                                th तपशील

                                th रक्कम
                                th अग्रीम
                                th एकूण
                                th अद्याक्षरी
                                th Action

                                //- For CREDIT / खर्च

                                th दिनांक
                                th प्रमाणपत्र क्रमांक
                                th कोणास रक्कम दिली
                                th तपशील

                                th रक्कम
                                th अग्रीमातून खर्च
                                th एकूण
                                th अद्याक्षरी
                                th Action

                            tr 
                                //-
                                each marathiNumber in  ['१', '२', '३', '४', '५', '६', '७', '८', '९', '१०', '११', '१२', '१३', '१४', '१५', '१६', '१७', '१८'] 
                                    th #{marathiNumber}


                        tbody

                            - let correspondingEntries =  monthYearGroup.corresponding_entries || []
                            - let creditEntries = correspondingEntries.filter(entry => entry.transaction_type == 'CREDIT')
                            - let debitEntries = correspondingEntries.filter(entry => entry.transaction_type == 'DEBIT')

                            - let maxRows = Math.max(creditEntries.length || 0,  debitEntries.length || 0)

                            - for(let i = 0; i < maxRows; ++i)

                                - let entry = null
                                tr

                                    - entry = creditEntries[i]

                                    if entry

                                        //- जमा / क्रेडीट

                                        td #{entry._date}
                                        td #{entry.reference_number}
                                        td #{entry.sender_receiver_details}
                                        td #{entry.details}

                                        td #{entry.amount}
                                        td #{entry.advance_transactions}
                                        td #{entry.total_amount}
                                        td
                                        td
                                            div(style='display:flex; align-items:center; justify-content:center; gap:0.2rem;')
                                                a.btn.btn-success.btn-sm(href=`/namuna/18/edit/${entry.id}`)
                                                    i.fa.fa-pencil
                                                button.btn.btn-danger.btn-sm(button='type' class='delete-namuna-18-entry-btn' data-namuna18Entry=entry.id)
                                                    i.fa.fa-trash
                                    else
                                        each _ in Array.from({ length: 9 }, (_, i) => i + 1)
                                            td

                                    //- खर्च / अद्याक्षरी
                                    - entry = debitEntries[i]

                                    if entry

                                        //- जमा / क्रेडीट

                                        td #{entry._date}
                                        td #{entry.reference_number}
                                        td #{entry.sender_receiver_details}
                                        td #{entry.details}

                                        td #{entry.amount}
                                        td #{entry.advance_transactions}
                                        td #{entry.total_amount}
                                        td 
                                            div(style='display:flex; align-items:center; justify-content:center; gap:0.2rem;')
                                                a.btn.btn-success.btn-sm(href=`/namuna/18/edit/${entry.id}`)
                                                    i.fa.fa-pencil
                                                button.btn.btn-danger.btn-sm(button='type' class='delete-namuna-18-entry-btn' data-namuna18Entry=entry.id)
                                                    i.fa.fa-trash
                                    else
                                        each _ in Array.from({ length: 9 }, (_, i) => i + 1)
                                            td



                            //- else 
                                tr

                                    //- जमा / क्रेडीट

                                    each _ in Array.from({ length: 8 }, (_, i) => i + 1)
                                        td.d-none

                                    //- खर्च / अद्याक्षरी


                                    td #{entry._date}
                                    td #{entry.reference_number}
                                    td #{entry.sender_receiver_details}
                                    td #{entry.details}

                                    td #{entry.amount}
                                    td #{entry.advance_transactions}
                                    td #{entry.total_amount}
                                    td 


