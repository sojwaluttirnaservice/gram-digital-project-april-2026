    title नमुना ३० ग्रामपंचायत लेखापरीक्षा आक्षेप पूर्तता नोंदवही 

    style.


      label.error {
        color: red;
        font-size: 0.8rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना ३० ग्रामपंचायत लेखापरीक्षा आक्षेप पूर्तता नोंदवही 

      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/30') यादी

      form(id='namuna-30-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना ३० नोंदणी

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2

            //- ============================
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="audit_report_year") लेखापरीक्षण अहवाल वर्ष
                input.form-control(type="number" id="audit_report_year" name="audit_report_year" required placeholder="लेखापरीक्षण अहवाल वर्ष")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="objection_count") आक्षेपांची संख्या
                input.form-control(type="number" id="objection_count" name="objection_count" required placeholder="आक्षेपांची संख्या")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="objection_sequence") आक्षेप अनुक्रमांक
                input.form-control(type="text" id="objection_sequence" name="objection_sequence" required placeholder="आक्षेप अनुक्रमांक")



            //- ============================
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="report_received_date") लेखापरीक्षण अहवाल प्राप्त झाल्याचा दिनांक
                input.form-control.datepicker(type="text" id="report_received_date" name="report_received_date" required placeholder="लेखापरीक्षण अहवाल प्राप्त झाल्याचा दिनांक")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="info_only_objection_count") केवळ माहितीसाठी आक्षेपांची संख्या
                input.form-control(type="number" id="info_only_objection_count" name="info_only_objection_count" placeholder="केवळ माहितीसाठी आक्षेपांची संख्या")

            //- ============================
            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="info_only_objection_sequence") केवळ माहितीसाठी आक्षेप क्रमांक
                input.form-control(type="text" id="info_only_objection_sequence" name="info_only_objection_sequence" placeholder="केवळ माहितीसाठी आक्षेप अनुक्रमांक")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="resolve_objection_sequence") पूर्तता करावयाचे आक्षेप क्रमांक
                input.form-control(type="text" id="resolve_objection_sequence" name="resolve_objection_sequence" required placeholder="पूर्तता करावयाचे आक्षेप अनुक्रमांक")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="resolve_objection_count") पूर्तता करावयाचे आक्षेपांची संख्या
                input.form-control(type="number" id="resolve_objection_count" name="resolve_objection_count" required placeholder="पूर्तता करावयाचे आक्षेपांची संख्या")


            //- ============================
            //- print col number 8
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="resolved_objection_outward_number") पूर्तता केलेले आक्षेप पंचायत समितीकडे पाठविल्याचा जावक क्रमांक
                input.form-control(type="text" id="resolved_objection_outward_number" name="resolved_objection_outward_number" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="resolved_objection_outward_date") पूर्तता केलेले आक्षेप पंचायत समितीकडे पाठविल्याचा  दिनांक
                input.form-control.datepicker(type="text" id="resolved_objection_outward_date" name="resolved_objection_outward_date" placeholder="")

            //- ============================
            //- print column number 9
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="resolution_forwarded_number") पूर्तता केलेले आक्षेप पंचायत समितीने जि.प. कडे / लेखा परीक्षाकडे पाठविलेल्याचा ठराव क्रमांक
                input.form-control(type="text" id="resolution_forwarded_number" name="resolution_forwarded_number" placeholder="")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="resolution_forwarded_date") पूर्तता केलेले आक्षेप पंचायत समितीने जि.प. कडे / लेखा परीक्षाकडे पाठविलेल्याचा  जावक क्रमांक दिनांक
                input.form-control.datepicker(type="text" id="resolution_forwarded_date" name="resolution_forwarded_date" placeholder="")

            //- ============================
            //- print column number 10
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="zp_approved_objection_sequence") जि. प. / लेखा परीक्षक यांनी मंजूर केलेले आक्षेपांची संख्या आक्षेप क्रमांक
                input.form-control(type="text" id="zp_approved_objection_sequence" name="zp_approved_objection_sequence" placeholder="मंजूर आक्षेप अनुक्रमांक")

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="zp_approved_objection_count") जि. प. / लेखा परीक्षक यांनी मंजूर केलेले आक्षेपांची संख्या
                input.form-control(type="number" id="zp_approved_objection_count" name="zp_approved_objection_count" placeholder="मंजूर आक्षेपांची संख्या")


            //- ============================
            //- print column number 11 to 15
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="book_adjustment_details") पुस्तकी समायोजन
                input.form-control(type="text" id="book_adjustment_details" name="book_adjustment_details" placeholder="पुस्तकी समायोजन")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="recovery_details") वसुली
                input.form-control(type="text" id="recovery_details" name="recovery_details" placeholder="वसुली")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="assessment_details") मुल्यांकन
                input.form-control(type="text" id="assessment_details" name="assessment_details" placeholder="मुल्यांकन")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="irregularity_details") नियमबाहय
                input.form-control(type="text" id="irregularity_details" name="irregularity_details" placeholder="नियमबाहय")


            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="total_remaining_objection_count") एकूण
                input.form-control(type="text" id="total_remaining_objection_count" name="total_remaining_objection_count" placeholder="एकूण")


            //- ============================
            //- print column number 16
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="remarks") शेरा
                input.form-control(id="remarks" name="remarks" placeholder="शेरा")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-30-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
