doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title प्रिंट नमुना १७

        style.
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            /* Basic styles for the body */
            body {
                //- font-family: Arial, sans-serif;
                margin: 0;
                //- padding: 20px;
            }

            .text-center {
                text-align: center;
            }

            /* Styles for the table */
            table {
                width: 100%;
                border-collapse: collapse;
            }

            th, td {
                border: 1px solid #ddd;
                padding: 8px;
                text-align: center;
            }

            th {
                background-color: #f2f2f2;
                font-weight: bold;
            }

            /* Print styles */
            @media print {
                body {
                    margin: 0;
                    padding: 0;
                }

                #hide-buttons {
                    display: none;
                }

                table {
                    page-break-inside: avoid;
                }

                tr {
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }

                th, td {
                    border: 1px solid black !important;
                    font-size: 12px;
                    page-break-inside: avoid;
                    page-break-after: avoid;
                }


                //- .my-print {
                //-         height: 210mm;
                //-         width: 298mm;

                //- }

                @page {
                    size: A4 landscape;
                    margin: 4mm ;
                    //- padding: 1mm;
                }
            }

        link(rel='stylesheet' href='/asstest/coustom/css/namuna/namuna-1-to-33-print.css')

    body

