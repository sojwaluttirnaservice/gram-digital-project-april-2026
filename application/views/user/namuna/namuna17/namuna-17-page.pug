    title नमुना १७ (अग्रीम दिलेल्या / अनामत ठेवलेल्या रकमांची नोंदवही)

    style.

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem; /* Automatically center horizontally */
        width: fit-content; /* Allow width to adjust based on content */
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

      /* Basic styles for the body */
      body {
        //- font-family: Arial, sans-serif;
        margin: 0;
        //- padding: 20px;
      }

      .text-center {
        text-align: center;
      }

      /* Styles for the table */
      table {
        width: 100%;
        border-collapse: collapse;
      }

      th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: center;
      }

      th {
        //- background-color: #f2f2f2;
        font-weight: bold;
      }


  body
    include ../../include/navs.pug

    -
      const months = [
        "०४ (एप्रिल)", "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
        "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)" ,
        "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)"
      ]
    .container
      h2.heading-1.mt-2.mb-1 नमुना १७ (अग्रीम दिलेल्या / अनामत ठेवलेल्या रकमांची नोंदवही)

      div.my-4
        .d-flex.justify-content-end.align-items-center.gap-4 
          a.btn.btn-primary(href='/namuna/17/create') नवीन नोंदणी
          a.btn.btn-secondary(href='/namuna/17/print' target = '/blank') प्रिंट

      //- div.d-flex.gap-4.justify-content-center.mb-4

        div 
          select.form-select(name='show-report-by')
            option(value='-1') --Select Report Type--
            option(value='1') फक्त वर्ष
            option(value='2') वर्ष श्रेणी
            option(value='3') महिना व वर्ष

        - let startYear = 2020
        - let currentYear = new Date().getFullYear()

        div(id='show-report-by-div')
          div(data-target='1' style='display:none')
            div.d-flex.gap-2
              select.form-select(name='selected_year' id='selected-year')
                option(value='') -- Select --
                each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                  option(value=year) #{year}

          div(data-target='2' style='display:none')
            div.d-flex.gap-2
              div
                select.form-select(name='selected_from_year' id='selected-from-year')
                  option(value='') -- Select --
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                    option(value=year) #{year}
              div 
                select.form-select(name='selected_to_year' id='selected-to-year')
                  option(value='') -- Select --
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i + 1)
                    option(value=year) #{year}

          div(data-target='3' style='display:none')
            div.d-flex.gap-2
              div
                select.form-select(name='selected_month' id='selected-month')
                  option(value='-1') --Select Month --
                  - for(let month = 1; month <= 12; month++)
                    option(value=month)= month
              div
                select.form-select(name='selected_year_2' id='selected-year-2')
                  option(value='') -- Select Year--
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                    option(value=year) #{year}

        //- button.btn.btn-success(type='button' id='submit-all-entries-btn' role='button' aria-label='Submit all form entries' data-action='submit-all') Submit All

        div
          button.btn.btn-secondary(id='show-namuna-16-report-btn') Report


      if namuna17Details && namuna17Details.length > 0

        div(style='border: 1px solid lightgray;')

          .table-responsive

            table 

              thead

                //- tr 
                  th(colspan='23' )
                    div
                      div(style='display: flex; align-items: center; justify-content: space-between;')

                        div नमुना १७

                        div ग्रामपंचायत कार्यालय 
                          span #{gp.gp_name}
                        div
                          img(src="/new-gp-page/main-page/images/header-images/mudra-nav-2.png" style='width: 100px;')

                      div 
                        div.text-center(style='font-size:10px;') महा. ग्रा. पं. लेखा संहिता २०११ (नियम ६३ ६६(१) व (२) पहा)

                      div 
                        if fromYear && toYear
                          div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{fromYear} - #{toYear} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही
                        else if (month && year)
                          div.text-center(style='font-size: 20px; margin-top:0.2rem;') #{month} सन #{year} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही
                        else if year 
                          div.text-center(style='font-size: 20px; margin-top:0.2rem;') सन #{year - 1} - #{year} कर्मचारी वर्गाची सूची व वेतनश्रेणी नोंदवही

                      //- div#hide-buttons
                        button(onclick='window.print()') Print

                tr
                  th(rowspan='2') महिना व तारीख 
                  th(rowspan='2') पक्षधारकाचे नाव
                  th(rowspan='2') अग्रीम रकमेचा किंवा अनामत ठेवलेल्या रकमेचा तपशील

                  th(rowspan='2') प्रमाणक क्रमांक किंवा पावती क्रमांक रक्कम 
                  th(rowspan='2') रक्कम
                  th(rowspan='2') मासिक एकूण

                  th(rowspan='1' colspan='12') रोख परतफेड किंवा समायोजन

                  th(rowspan='2') एकूण परतफेड
                  th(rowspan='2') परतफेडीची तारीख किंवा समायोजनाच्या प्रमाणपत्राचा क्रमांक
                  th(rowspan='2') वर्षाच्या अखेरची शिल्लक
                  th(rowspan='2') शेरा
                  th(rowspan='2') Action 

                tr 
                  //- th()
                  //- th()
                  //- th()

                  //- th()
                  //- th()
                  //- th()

                  //- for months
                  each month in months 
                    th(rowspan='1' colspan='1') #{month} रु. पै.

                  //- th
                  //- th
                  //- th
                  //- th

                tr
                  th १
                  th २
                  th ३
                  th ४
                  th ५
                  th ६
                  th ७
                  th ८
                  th ९
                  th १०
                  th ११
                  th १२
                  th १३
                  th १४
                  th १५
                  th १६
                  th १७
                  th १८
                  th १९
                  th २०
                  th २१
                  th २२
                  th २३
                  //- th २४
                  //- th २५


              tbody 

                each n17Entry, index in namuna17Details

                  tr 
                    td 
                    td #{n17Entry.person_name}
                    td
                    td #{n17Entry.order_number}

                    td #{n17Entry.payment_amount} 
                    td 
                    td 
                    td 

                    td 
                    td 
                    td 
                    td 

                    td 
                    td 
                    td 
                    td 

                    td 
                    td 
                    td 
                    td 

                    td 
                    td
                    td 
                      .d-flex.gap-2.justify-content-center
                        a.btn.btn-success.btn-sm(href=`/namuna/17/edit/${n17Entry.id}`)
                          i.fa.fa-pencil

                        button.btn.btn-danger.btn-sm(class='delete-namuna-17-entry-btn' data-namuna17EntryId=n17Entry.id)
                          i.fa.fa-trash



      else 
        h2.text-center कोणत्याही नोंदी उपलब्ध नाही
