    title नमुना १७ - अग्रीम दिलेल्या / अनामत ठेवलेल्या रकमांची नोंदवही
    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem; /* Automatically center horizontally */
        width: fit-content; /* Allow width to adjust based on content */
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना १७ - अग्रीम दिलेल्या / अनामत ठेवलेल्या रकमांची नोंदवही

      div.d-flex.gap-4.justify-content-end.mb-4(style='margin-right:8rem; gap:1rem;')
        a.btn.btn-primary(href='/namuna/17') नमुना १७ यादी
        a.btn.btn-primary(href='/namuna') नमुने
      //- div.d-flex.gap-4.justify-content-center.mb-4

        div 
          select.form-select(name='show-report-by')
            option(value='-1') --Select Report Type--
            option(value='1') फक्त वर्ष
            option(value='2') वर्ष श्रेणी
            option(value='3') महिना व वर्ष

        - let startYear = 2020
        - let currentYear = new Date().getFullYear()

        div(id='show-report-by-div')
          div(data-target='1' style='display:none')
            div.d-flex.gap-2
              select.form-select(name='selected_year' id='selected-year')
                option(value='') -- Select --
                each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                  option(value=year) #{year}

          div(data-target='2' style='display:none')
            div.d-flex.gap-2
              div
                select.form-select(name='selected_from_year' id='selected-from-year')
                  option(value='') -- Select --
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                    option(value=year) #{year}
              div 
                select.form-select(name='selected_to_year' id='selected-to-year')
                  option(value='') -- Select --
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i + 1)
                    option(value=year) #{year}

          div(data-target='3' style='display:none')
            div.d-flex.gap-2
              div
                select.form-select(name='selected_month' id='selected-month')
                  option(value='-1') --Select Month --
                  - for(let month = 1; month <= 12; month++)
                    option(value=month)= month
              div
                select.form-select(name='selected_year_2' id='selected-year-2')
                  option(value='') -- Select Year--
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i)
                    option(value=year) #{year}

        //- button.btn.btn-success(type='button' id='submit-all-entries-btn' role='button' aria-label='Submit all form entries' data-action='submit-all') Submit All

        div
          button.btn.btn-secondary(id='show-namuna-16-report-btn') Report

      -
        const months = [
          "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
          "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
          "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
        ]

      form(id='namuna-17-form').mt-1
        .form.form-1
          //- h4.text-center.fw-bold नमुना १७ नोंदणी

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="person-name") व्यक्तीचे नाव
                input.form-control(type="text" id="person-name" name="person_name" required placeholder="व्यक्तीचे नाव")

            .col-11.col-md-6.col-lg-6 
              .form-group 
                label.form-label(for="company-name") कंपनीचे नाव
                input.form-control(type="text" id="company-name" name="company_name" required placeholder="कंपनीचे नाव")

            .col-11.col-md-12.col-lg-12
              .form-group 
                label.form-label(for="work-description") कामाचे विवरण
                textarea.form-control(id="work-description" name="work_description" rows="3" placeholder="कामाचे विवरण")


            .col-11.col-md-6.col-lg-4
              .form-group 
                label.form-label(for="order-number") आदेश क्रमांक
                input.form-control(id="order-number" name="order_number" placeholder="आदेश क्रमांक")

            .col-11.col-md-6.col-lg-4
              .form-group 
                label.form-label(for="payment-amount") भरण्याची रक्कम
                input.form-control(type="number" id="payment-amount" name="payment_amount" required placeholder="उदा. 18000")

            .col-11.col-md-6.col-lg-4
              .form-group 
                label.form-label(for="date") दिनांक 
                input.form-control.datepicker(type="text" id="date" name="date" required placeholder="दिनांक")

            .col-11.col-md-6.col-lg-4
              .form-group 
                label.form-label(for="remarks") शेरा
                input.form-control(id="remarks" name="remarks" placeholder="")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-17-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
