        link(href='/asstest/coustom/css/namuna/namuna-33/namuna-33-page.css' rel='stylesheet')
        link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/handlers/namuna/namuna-33/namuna-33-create-entry-page-handler.js' type='module' defer)

        title नमुना ३३ - वृक्षतोड नोंदवही

    body
        include ../../include/navs.pug

        .container
            h2.heading-1.mt-1 नमुना ३३ - वृक्षतोड नोंदवही

            div
                .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
                    a.btn.btn-primary(href='/namuna/33') यादी

            form(id='namuna-33-form').mt-1
                .form.form-1
                    //- h4.text-center.fw-bold नमुना ३३ - वृक्षतोड नोंदवही
                    - 
                        const months = [
                            "०१ (जानेवारी)", "०२ (फेब्रुवारी)", "०३ (मार्च)", "०४ (एप्रिल)", 
                            "०५ (मे)", "०६ (जून)", "०७ (जुलै)", "०८ (ऑगस्ट)", 
                            "०९ (सप्टेंबर)", "१० (ऑक्टोबर)", "११ (नोव्हेंबर)", "१२ (डिसेंबर)"
                        ]
                    .row.justify-content-center.justify-content-md-between.gx-4.gy-2
                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="month") महिना
                                select.form-select(id="month" name="month" required)
                                    option(value='') --निवडा--
                                    each month, monthIndex in months 
                                        option(value=(monthIndex + 1)) #{month}

                        .col-11.col-md-6.col-lg-2
                            .form-group
                                label.form-label(for="year") वर्ष
                                select.form-select(id="year" name="year" required)
                                    option(value='') --निवडा--
                                    - let currentYear = new Date().getFullYear()
                                    - let startYear = currentYear - 25
                                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                                        option(value=year) #{year}

                        .col-11.col-md-6.col-lg-7
                            .form-group
                                label.form-label(for="tree-type") वृक्षाचा प्रकार
                                input.form-control(type="text" id="tree-type" name="tree_type" required placeholder="वृक्षाचा प्रकार")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="land-or-road-details") जमिनीचा / रस्त्याचा तपशिल (आधारसामग्रीसह)
                                textarea.form-control(type="text" id="land-or-road-details" name="land_or_road_details" required placeholder="उदाहरण: जमीन तपशिल")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="tree-additional-info") वृक्षाविषयीची अधिक माहिती
                                textarea.form-control(type="text" id="tree-additional-info" name="tree_additional_info" placeholder="वृक्षाविषयी अधिक माहिती")

                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="tree-count") वृक्षांची संख्या
                                input.form-control(type="number" id="tree-count" name="tree_count" required placeholder="वृक्षांची संख्या")

                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="expected-annual-income") अपेक्षित वार्षिक उत्पन्न
                                input.form-control(type="number" step="0.01" id="expected-annual-income" name="expected_annual_income" placeholder="अपेक्षित वार्षिक उत्पन्न")

                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="actual-income-received") प्रत्यक्ष प्राप्त उत्पन्न
                                input.form-control(type="number" step="0.01" id="actual-income-received" name="actual_income_received" placeholder="प्रत्यक्ष प्राप्त उत्पन्न")

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="tree-cut-or-destroyed-details") वृक्ष तोडल्यास नष्ट झाल्यास त्याबाबतचा तपशिल
                                input.form-control(type="text" id="tree-cut-or-destroyed-details" name="tree_cut_or_destroyed_details" placeholder="वृक्ष तोडल्यास नष्ट झाल्यास तपशिल")

                        //- .col-11.col-md-12.col-lg-6
                            .form-group
                                label.form-label(for="remarks") टीप
                                input.form-control(id="remarks" name="remarks" placeholder="टीप")

                    .d-flex.gap-4.justify-content-center
                        button.btn.btn-primary(type='button' id="submit-namuna-33-entry") Save
                        button.btn.btn-secondary(type='reset' id='reset') Reset
