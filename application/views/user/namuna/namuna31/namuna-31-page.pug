                  td #{namuna31Entry.daily_allowance_amount}

                  td #{namuna31Entry.travel_reason}
                  td #{namuna31Entry.total_travel_amount}
                  td #{namuna31Entry.remarks}

                  td 

                    .d-flex.align-items-center.justify-content-center.gap-1
                      a.btn.btn-success.btn-sm(href=`/namuna/31/edit/${namuna31Entry.id}`)
                        i.fa.fa-pencil

                      button.btn.btn-danger.btn-sm(class='delete-namuna-31-entry-btn' data-namuna31Entry=namuna31Entry.id)
                        i.fa.fa-trash