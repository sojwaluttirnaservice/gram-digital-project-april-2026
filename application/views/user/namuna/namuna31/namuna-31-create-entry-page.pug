        link(href='/asstest/coustom/css/namuna/namuna-31/namuna-31-page.css' rel='stylesheet')
        link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/handlers/namuna/namuna-31/namuna-31-create-entry-page-handler.js' type='module' defer)


        title नमुना ३१ प्रवास भत्ता देयक 

    body
        include ../../include/navs.pug

        .container
            h2.heading-1.mt-2.mb-1 नमुना ३१ प्रवास भत्ता देयक 
            div
                .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
                    a.btn.btn-primary(href='/namuna/31') यादी
            form(id='namuna-31-form').mt-1
                .form.form-1


                    .row.justify-content-center.justify-content-md-between.gx-4.gy-2
                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="month") महिना
                                select.form-select(id="month" name="month" required)
                                    option(value='') --निवडा--
                                    option(value="1") ०१ (जानेवारी)
                                    option(value="2") ०२ (फेब्रुवारी)
                                    option(value="3") ०३ (मार्च)
                                    option(value="4") ०४ (एप्रिल)
                                    option(value="5") ०५ (मे)
                                    option(value="6") ०६ (जून)
                                    option(value="7") ०७ (जुलै)
                                    option(value="8") ०८ (ऑगस्ट)
                                    option(value="9") ०९ (सप्टेंबर)
                                    option(value="10") १० (ऑक्टोबर)
                                    option(value="11") ११ (नोव्हेंबर)
                                    option(value="12") १२ (डिसेंबर)

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="year") वर्ष
                                select.form-select(id="year" name="year" required)
                                    option(value='') --निवडा--
                                    - let currentYear = new Date().getFullYear()
                                    - let startYear = currentYear - 25
                                    each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                                        option(value=year) #{year}

                        .col-11.col-md-6.col-lg-6
                            .form-group
                                label.form-label(for="name_of_person") व्यक्तीचे नाव 
                                input.form-control(type="text" id="name_of_person" name="name_of_person" required placeholder="(e.g., सरपंच, सदस्य)")

                        //- 
                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="office_location") कार्यालयाचे ठिकाण
                                input.form-control(type="text" id="office_location" name="office_location" required placeholder=" ")


                        //- DEPARTURE
                        .col-11.col-md-12.col-lg-4
                            .form-group
                                label.form-label(for="departure_place") निगमन ठिकाण
                                input.form-control(id="departure_place" name="departure_place" required placeholder="")

                        .col-11.col-md-12.col-lg-4
                            .form-group
                                label.form-label(for="departure_date") निगमन तारीख
                                input.form-control.datepicker(id="departure_date" name="departure_date" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="departure_time") निगमन वेळ
                                input.form-control.timepicker(type="text" id="departure_time" name="departure_time" required placeholder="")

                        //- ARRIVAL
                        .col-11.col-md-12.col-lg-3
                            .form-group
                                label.form-label(for="arrival_place") आगमन ठिकाण
                                input.form-control(type="text" id="arrival_place" name="arrival_place" placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="arrival_date") आगमन तारीख
                                input.form-control.datepicker(type="text" id="arrival_date" name="arrival_date" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="arrival_time") आगमन वेळ
                                input.form-control.timepicker(type="text" id="arrival_time" name="arrival_time" required placeholder="")

                        //- प्रवासाचे साधन
                        .col-11.col-md-6.col-lg-7
                            .form-group
                                label.form-label(for="means_of_travel") प्रवासाचे साधन
                                input.form-control(type="text" id="means_of_travel" name="means_of_travel" required placeholder="रेल्वे, बोट")

                        .col-11.col-md-6.col-lg-5
                            .form-group
                                label.form-label(for="rail_boat_name_class") रेल्वे किंवा बोटीचे नाव / वर्ग
                                input.form-control(type="text" id="rail_boat_name_class" name="rail_boat_name_class" required placeholder="")


                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="ticket_count") प्रवासाचे तिकीटांची संख्या
                                input.form-control(type="number" id="ticket_count" name="ticket_count" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="ticket_amount") तिकीटांची रक्कम
                                input.form-control(type="number" id="ticket_amount" name="ticket_amount" required placeholder="")

                        //- Distance
                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="road_distance_km")  रस्त्याने केलेला प्रवास (किमी)
                                input.form-control(type="number" id="road_distance_km" name="road_distance_km" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="road_rate_per_km") रस्त्याचे दर (प्रति किलोमीटर)
                                input.form-control(type="number" id="road_rate_per_km" name="road_rate_per_km" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="road_amount") रस्त्याने प्रवासाची रक्कम
                                input.form-control(type="number" id="road_amount" name="road_amount" required placeholder="")


                        //- भत्ता
                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="daily_allowance_days") भत्ता मिळालेल्या दिवसांची संख्या
                                input.form-control(type="number" id="daily_allowance_days" name="daily_allowance_days" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="daily_allowance_rate") दैनिक भत्ता दर
                                input.form-control(type="number" id="daily_allowance_rate" name="daily_allowance_rate" required placeholder="")

                        .col-11.col-md-6.col-lg-3
                            .form-group
                                label.form-label(for="daily_allowance_amount") दैनिक भत्त्याची रक्कम
                                input.form-control(type="number" id="daily_allowance_amount" name="daily_allowance_amount" required placeholder="")


                        .col-11.col-md-6.col-lg-8
                            .form-group
                                label.form-label(for="travel_reason") प्रवासाचे कारण
                                input.form-control(type="text" id="travel_reason" name="travel_reason" required placeholder="")


                        .col-11.col-md-6.col-lg-4
                            .form-group
                                label.form-label(for="total_travel_amount") एकूण रक्कम(प्रत्येक स्तंभाची बेरीज)
                                input.form-control(type="number" id="total_travel_amount" name="total_travel_amount" required placeholder="")


                        .col-11.col-md-12.col-lg-8
                            .form-group
                                label.form-label(for="remarks") शेरा
                                input.form-control(id="remarks" name="remarks" placeholder="शेरा")

                    .d-flex.gap-4.justify-content-center
                        button.btn.btn-primary(type='button' id="submit-namuna-31-entry") Save
                        button.btn.btn-secondary(type='reset' id='reset') Reset
