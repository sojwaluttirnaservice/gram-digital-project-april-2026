doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  

    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")

    // Bootstrap 5 CSS & JS
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    link(href='/asstest/coustom/css/namuna/namuna-22/namuna-22-page.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/namuna/namuna-22/namuna-22-create-entry-page-handler.js' type='module' defer)

    title नमुना २२ स्थावर मालमत्ता नोंदवही (रस्ते व जमिनीव्यतिरिक्त) 

    style.
      .heading-1 {
        font-weight: bold !important;
        font-size: 1.4rem;
        text-align: center;
        color: #bb2525;
        border-radius: 15px;
        border: 2px solid #bb2525;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 8px;
        margin: 0 auto 1.4rem;
        width: fit-content;
      }

      label.error {
        color: red;
        font-size: 0.9rem;
      }

  body
    include ../../include/navs.pug

    .container
      h2.heading-1.mt-2.mb-1 नमुना २२ स्थावर मालमत्ता नोंदवही (रस्ते व जमिनीव्यतिरिक्त) 
      div
        .d-flex.align-items-center.justify-content-end(style="gap: 1rem;")
          a.btn.btn-primary(href='/namuna/22') यादी
      form(id='namuna-22-form').mt-1
        .form.form-1

          .row.justify-content-center.justify-content-md-between.gx-4.gy-2

            //- row 1
            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="month") महिना
                select.form-select(id="month" name="month" required)
                  option(value='') --निवडा--
                  option(value="1") ०१ (जानेवारी)
                  option(value="2") ०२ (फेब्रुवारी)
                  option(value="3") ०३ (मार्च)
                  option(value="4") ०४ (एप्रिल)
                  option(value="5") ०५ (मे)
                  option(value="6") ०६ (जून)
                  option(value="7") ०७ (जुलै)
                  option(value="8") ०८ (ऑगस्ट)
                  option(value="9") ०९ (सप्टेंबर)
                  option(value="10") १० (ऑक्टोबर)
                  option(value="11") ११ (नोव्हेंबर)
                  option(value="12") १२ (डिसेंबर)

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="year") वर्ष
                select.form-select(id="year" name="year" required)
                  option(value='') --निवडा--
                  - let currentYear = new Date().getFullYear()
                  - let startYear = currentYear - 25
                  each year in Array.from({length: currentYear - startYear + 1}, (v, i) => startYear + i).reverse()
                    option(value=year) #{year}

            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="acquisition_date") संपादनाची खरेदेची किंवा उभारणीची तारीख
                input.form-control.datepicker(type="text" id="acquisition_date" name="acquisition_date" required placeholder="दिनांक")

            //- row 2
            .col-11.col-md-6.col-lg-6
              .form-group
                label.form-label(for="resolution_number") ज्या अन्वये मालमत्ता संपादित केली त्या आदेशांची व पंचायत ठरावाचे क्रमांक
                input.form-control(type="text" id="resolution_number" name="resolution_number" required placeholder="")

            .col-11.col-md-12.col-lg-6
              .form-group
                label.form-label(for="resolution_date") ज्या अन्वये मालमत्ता संपादित केली त्या आदेशांची व पंचायत ठरावाचे दिनांक
                input.form-control.datepicker(id="resolution_date" name="resolution_date"  required placeholder="")

            //- row 3
            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="survey_number") मालमत्तेचा भूमापन क्रमांक
                input.form-control(id="survey_number" name="survey_number" rows="3" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="property_description") मालमत्तेचे वर्णन
                input.form-control(type="text" id="property_description" name="property_description" required placeholder="")

            .col-11.col-md-12.col-lg-4
              .form-group
                label.form-label(for="usage_reason") कोणत्या कारणासाठी वापर केला
                input.form-control(type="text" id="usage_reason" name="usage_reason" placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="construction_or_editing_expense") उभारणीचा किंवा संपादनाचा खर्च
                input.form-control(type="text" id="construction_or_editing_expense" name="construction_or_editing_expense" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="repairs_expenditure_date") दुरुस्त्यांवर खर्चाची तारीख
                input.form-control.datepicker(type="text" id="repairs_expenditure_date" name="repairs_expenditure_date" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="ongoing_repairs") चालू दुरुस्त्या 
                input.form-control(type="text" id="ongoing_repairs" name="ongoing_repairs" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="special_repairs") विशेष दुरुस्त्या
                input.form-control(type="text" id="special_repairs" name="special_repairs" required placeholder="")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="original_construction") मूळ बांधकाम
                input.form-control(type="text" id="original_construction" name="original_construction" required placeholder="")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="original_construction_type") मूळ बांधकामाचे स्वरूप
                input.form-control(type="text" id="original_construction_type" name="original_construction_type" required placeholder="")

            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="year_end_depreciation") वर्ष अखेरीस घटलेली किंमत
                input.form-control(type="text" id="year_end_depreciation" name="year_end_depreciation" required placeholder="")


            .col-11.col-md-6.col-lg-3
              .form-group
                label.form-label(for="disposal_resolution_number") मालमत्ता विल्हेवाट लावण्याचा ठराव क्रमांक
                input.form-control(type="text" id="disposal_resolution_number" name="disposal_resolution_number" required placeholder="")


            .col-11.col-md-6.col-lg-5
              .form-group
                label.form-label(for="disposal_order_number") मालमत्ता विल्हेवाट लावण्याचा आदेश क्रमांक
                input.form-control(type="text" id="disposal_order_number" name="disposal_order_number" required placeholder="")

            .col-11.col-md-6.col-lg-4
              .form-group
                label.form-label(for="disposal_order_date") मालमत्ता विल्हेवाट लावण्याची तारीख
                input.form-control.datepicker(type="text" id="disposal_order_date" name="disposal_order_date" required placeholder="")

            .col-11.col-md-12.col-lg-3
              .form-group
                label.form-label(for="remarks") शेरा 
                input.form-control(id="remarks" name="remarks" placeholder=" शेरा")

          .d-flex.gap-4.justify-content-center
            button.btn.btn-primary(type='button' id="submit-namuna-22-entry") Save
            button.btn.btn-secondary(type='reset' id='reset') Reset
