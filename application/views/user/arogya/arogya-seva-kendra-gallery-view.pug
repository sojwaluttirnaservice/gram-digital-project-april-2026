extends ../include/index-page-master-layout.pug	
block internal_css
    style.
        a{
            text-decoration: none;
        }

        .gallery-container {
            width: 100%;
        }

        .gallery {
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr 1fr 1fr;
            column-gap: 1.2rem;
            row-gap: 2.5rem;
        }

        .gallery img {
            width: 100%;
            height: 100%;
            border: 5px solid #d6d1d1;
            box-shadow: 0 3px 5px rgba(0, 0, 0, 0.3);
            object-fit: cover;
            transition: all 200ms ease-in-out;
        }

        .gallery img:hover {
            transform: scale(1.03);
        }

        @media (max-width: 992px) {
            .gallery {
                grid-template-columns: 1fr 1fr 1fr;
            }
        }

        @media (max-width: 768px) {
            .gallery {
                grid-template-columns: 1fr 1fr;
            }
        }

        @media (max-width: 576px) {
            .gallery {
                grid-template-columns: 1fr;
            }
        }
block content


    section(class='py-6')
        .container

            h4.general-heading(class='sticky text-center text-xl md:text-2xl font-bold my-text-blue-dark tracking-wider w-fit mx-auto px-8 pb-2 border-b-2')  
                <i class="fa-solid fa-images"></i>
                span.ml-2  #{arogyaSevaKendraDetails.arogya_seva_kendra_name} Gallery


            div.gallery-container(class='mt-8')
                if galleryPhotos == null || galleryPhotos.length == 0
                    div.text-center
                        - let noPhotos = { mr: 'फोटो उपलब्ध नाहीत.', hi: 'फोटो उपलब्ध नहीं हैं।', en: 'No photos available.' };
                        h3.text-center.text-3xl.font-bold #{noPhotos[language]}
                else
                    .gallery
                        each photo in galleryPhotos

                            -let galleryImagePath = `/new-gp-page/main-page/files/arogya-seva-kendra-gallery/${photo.gallery_image_name}`
                            a(href=galleryImagePath, data-lightbox="models" data-title="")
                                img(src=galleryImagePath, style='height: 14rem')


