extends ./occupation-noc-print-layout.pug

block declaration_body

    div(class="text-lg leading-loose text-justify mt-6")

        p महोदय / महोदया,

        p(class="mt-4")
            | मी खाली सही करणारा अर्जदार श्री./श्रीमती 
            span(class="font-extrabold") #{occupationNoc.applicant_name}
            |  राहणार : 
            span(class="font-extrabold") #{occupationNoc.applicant_address}
            |  मोबाईल नं. : 
            span(class="font-extrabold") #{occupationNoc.applicant_mobile}
            |  माझ्या 
            span(class="font-extrabold")
                | #{occupationNoc.land_ownership == 'Owner' ? 'मालकीच्या' : 'भाडेपट्ट्याच्या'}
            |  जमिनीवर खान व्यवसाय (वाळू / दगड / मुरूम / इतर) सुरू करण्याचा मानस आहे.

        p(class="mt-3")
            | सदर जमीन गट क्रमांक : 
            span(class="font-extrabold") #{occupationNoc.survey_no || '________'}
            |  मौजे : 
            span(class="font-extrabold") #{occupationNoc.applicant_village}
            |  तालुका : 
            span(class="font-extrabold") #{occupationNoc.applicant_taluka}
            |  जिल्हा : 
            span(class="font-extrabold") #{occupationNoc.applicant_district}
            |  येथे स्थित आहे.

        p(class="mt-3")
            | सदर ठिकाणी खान व्यवसाय करण्यासाठी शासन नियमांनुसार ग्रामपंचायतीचे
            |  ना हरकत प्रमाणपत्र (NOC) आवश्यक असल्याने मला सदर NOC देण्यात यावे,
            |  ही नम्र विनंती.

        p(class="mt-3")
            | मी खात्रीपूर्वक नमूद करतो की, सदर व्यवसायामुळे गावातील नागरिकांना कोणताही त्रास होणार नाही
            |  तसेच पर्यावरण व शासन नियमांचे पूर्णपणे पालन करण्यात येईल.

        p(class="mt-3")
            | तरी मला खान व्यवसायासाठी ना हरकत प्रमाणपत्र देण्यात यावे,
            |  ही नम्र विनंती.

        div(class="mt-8 text-right")
            p धन्यवाद.
            p आपला विश्वासू,
