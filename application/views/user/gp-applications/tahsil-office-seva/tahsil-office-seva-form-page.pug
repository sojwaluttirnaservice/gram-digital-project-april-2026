extends ../../include/index-page-master-layout.pug

block internal_css
    style.
        body { 
            animation: fadeInAnimation ease 2s; 
            animation-iteration-count: 1; 
            animation-fill-mode: forwards; 
        } 
        @keyframes fadeInAnimation { 
            0% { opacity: 0; } 
            100% { opacity: 1; } 
        }

block content
    section(class='py-4')

        .container
            h3.general-heading(class='text-center text-xl md:text-3xl font-bold tracking-wider')
                | नागरिकांना सेवा सुविधा अर्ज

            - let qrLinks = [{ endpoint: "https://maharashtra.gov.in", label: "महाराष्ट्र शासन" }, { endpoint: "https://cscservices.mahaonline.gov.in/Dashboard/Login.aspx", label: "आपले सरकार सेवा केंद्र" }, { endpoint: "https://mahaonline.gov.in/", label: "महा - ऑनलाईन डिजिटल महाराष्ट्र" }]
            div(data-qrLinks=JSON.stringify(qrLinks) hidden)
            
            div(class='mt-4 flex justify-center gap-6 flex-wrap')
                    
                each _qrLink, _ind in qrLinks
                    div(class='flex flex-col items-center w-48')


                        div(id=`qr-code-${_ind}` class='citizen-qrs flex justify-center items-center' data-endpoint=_qrLink.endpoint size='24')
                
                        a(href=_qrLink.endpoint target='_blank' class='text-center font-semibold mb-2 text-blue-700 hover:underline')
                            | #{_qrLink.label}
    
    
    
    //- // ===============================
    //- // Mobile Check
    //- // ===============================
        .container
            h5(class='text-center font-semibold mb-1') अर्जदार मोबाईल क्रमांक तपासणी
            p(class='text-center text-sm text-gray-600 mb-4')
                | अर्ज करण्यासाठी मोबाईल क्रमांक प्रविष्ट करा

            div(id='check-by-mobile' class='my-2')
                div(class='flex justify-center gap-3 items-center')
                    label(for='mobile_input' class='text-sm font-medium') मोबाईल क्रमांक :
                    input(
                        type='text'
                        id='mobile_input'
                        class='py-1 px-2 border border-gray-600 outline-none max-w-52 bg-stone-100'
                        maxlength='10'
                        placeholder='उदा. 9876543210'
                    )
                    button(
                        type='button'
                        id='check-mobile-btn'
                        class='px-4 py-1 border border-gray-700 bg-gray-200 font-medium'
                    ) तपासा

                p(
                    id='mobile-status-text'
                    class='text-sm text-blue-700 mt-3 text-center font-medium'
                    style='display:none;'
                ) मोबाईल क्रमांक तपासणी सुरू आहे...

    //- ===============================
    //- Application Form
    //- ===============================
    section#form-section(class='py-8 md:py-16 bg-gray-100')
        .container
            form(
                id='tahsil-office-seva-form'
                class='md:w-[80%] mx-auto flex flex-col gap-4'
                enctype='multipart/form-data'
            )

                // ===============================
                // Applicant Information
                // ===============================
                .form-card(class='flex flex-col gap-4')
                    .form-card-heading(class='w-fit bg-white rounded-md mx-auto py-2 px-8 border shadow-lg font-bold text-xl')
                        | अर्जदाराची माहिती

                    .form-body(class='shadow-lg border bg-white px-2 md:px-8 py-4 rounded-md grid grid-cols-1 md:grid-cols-2 gap-4')

                        .input-group(class='px-2')
                            label(class='font-bold') अर्जदाराचे नाव
                                span(class='text-red-500') *
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md flex gap-2 bg-stone-100')
                                i(class='fas fa-user')
                                input(
                                    type='text'
                                    name='applicant_name'
                                    class='flex-grow bg-stone-100 outline-none'
                                    required
                                )

                        .input-group(class='px-2')
                            label(class='font-bold') मोबाईल क्रमांक
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md flex gap-2 bg-stone-100')
                                i(class='fas fa-phone')
                                input(
                                    type='text'
                                    name='applicant_mobile'
                                    class='flex-grow bg-stone-100 outline-none'
                                    maxlength="10"
                                )

                        .input-group(class='px-2')
                            label(class='font-bold') आधार क्रमांक
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md flex gap-2 bg-stone-100')
                                i(class='fas fa-id-card')
                                input(
                                    type='text'
                                    name='applicant_aadhaar'
                                    class='flex-grow bg-stone-100 outline-none'
                                    maxlength="12"
                                )

                        .input-group(class='px-2')
                            label(class='font-bold') अर्ज दिनांक
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md flex gap-2 bg-stone-100')
                                i(class='fas fa-id-card')
                                input.datepicker(
                                    type='text'
                                    name='createdAt'
                                    class='flex-grow bg-stone-100 outline-none'
                                )

                        .input-group(class='px-2 md:col-span-2')
                            label(class='font-bold') पत्ता
                                span(class='text-red-500') *
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md flex gap-2 bg-stone-100')
                                i(class='fas fa-map-marker-alt mt-2')
                                textarea(
                                    name='applicant_address'
                                    rows='2'
                                    class='flex-grow bg-stone-100 outline-none'
                                    required
                                )

                // ===============================
                // Subject Selection
                // ===============================
                .form-card(class='flex flex-col gap-4')
                    .form-card-heading(class='w-fit bg-white rounded-md mx-auto py-2 px-8 border shadow-lg font-bold text-xl')
                        | सेवा विषय निवड

                    .form-body(class='shadow-lg border bg-white px-2 md:px-8 py-4 rounded-md')

                        .input-group(class='px-2')
                            div(class='flex items-center gap-2')
                                label(class='font-bold') सेवा विषय
                                    span(class='text-red-500') *
                                    //- // Hidden field to store numeric ID
                                    input(type='hidden' class='bg-white' name='subject_id' id='subject_id' value='')
                                //- div(class='service-website-container')
                            .input-holder(class='relative w-full border px-4 py-1 rounded-md bg-stone-100')
                                select(
                                    id='service_subject_select'
                                    name='subject'  
                                    class='w-full bg-stone-100 outline-none'
                                    required
                                )
                                    option(value='') -- सेवा विषय निवडा --
                                    each subject in subjects
                                        //- // value is subject_name so it submits text
                                        option(value=subject.subject_name)= subject.subject_name

                // ===============================
                // Dynamic Documents Section
                // ===============================
                .form-card(class='flex flex-col gap-4')
                    .form-card-heading(class='w-fit bg-white rounded-md mx-auto py-2 px-8 border shadow-lg font-bold text-xl')
                        | आवश्यक कागदपत्रे

                    .form-body(
                        id='documents-container'
                        class='shadow-lg border bg-white px-2 md:px-8 py-4 rounded-md grid grid-cols-1 md:grid-cols-2 gap-4'
                    )
                        p(class='text-sm text-gray-600 md:col-span-2 text-center')
                            | कृपया सेवा विषय निवडा

                // ===============================
                // Submit
                // ===============================
                .buttons-container(class='text-center mt-4')
                    button(
                        type='submit'
                        id='save-tahsil-seva-btn'
                        class='px-10 py-2 rounded-md bg-emerald-600 text-white font-bold hover:bg-emerald-700'
                    ) जतन करा

    script.
        let _SERVICE_SUBJECTS = !{JSON.stringify(subjects)};

        

    script(src='/asstest/coustom/js/handlers/gp-applications/tahsil-office-seva/tahsil-office-seva-form-handler.js')
