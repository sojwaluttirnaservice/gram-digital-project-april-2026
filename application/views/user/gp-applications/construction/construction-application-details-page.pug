extends ../../include/index-page-master-layout.pug

block internal_css
    style.
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

block content
    if !constructionApplication
        div(class='bg-amber-50 border-l-4 border-amber-500 rounded-lg p-5 text-center mx-auto max-w-md mt-10 shadow-lg')
            h3(class='text-amber-700 font-bold text-lg mb-2') अर्ज उपलब्ध नाही
            p(class='text-gray-700 leading-relaxed')
                | दिलेल्या अर्ज क्रमांकाची माहिती उपलब्ध नाही.
                br
                | कृपया अर्ज क्रमांक तपासा.

    else
        - const status = constructionApplication.application_status
        - const docs = (() => { try { return JSON.parse(constructionApplication.attached_documents || '[]') } catch(e){ return [] } })()
        - const directionsBase = '/uploads/images/construction/directions'
        - const certificateBase = '/uploads/images/construction/certificates'

        div(class='container mx-auto p-4 max-w-xl scrollbar-hide')

            // ================= HEADER =================
            div(class='flex items-center justify-between mb-1')
                h2(class='text-2xl font-bold text-gray-800') #{constructionApplication.application_subject || 'इमारत बांधकाम परवानगी अर्ज'}
                span(class=`text-sm font-semibold px-3 py-1 rounded-full text-white ${
                    status === 'RESOLVED' ? 'bg-green-600' :
                    status === 'ACCEPTED' ? 'bg-blue-500' :
                    status === 'REJECTED' ? 'bg-red-500' :
                    'bg-yellow-500'
                }`)
                    | #{status === 'RESOLVED' ? 'पूर्तता झाली' : status === 'ACCEPTED' ? 'मंजूर' : status === 'REJECTED' ? 'नाकारलेली' : 'प्रलंबित'}

            // ONLY ADDED LINE
            p(class='text-sm text-gray-600 mb-4')
                span(class='font-semibold') बांधकाम परवानगी अर्ज क्रमांक:
                |  #{constructionApplication.id}

            p(class='text-sm text-gray-600 mb-4')
                span(class='font-semibold') अर्जाची नोंदणी दिनांक:
                |  #{constructionApplication._application_date || '-'}

            // ================= APPLICANT INFO =================
            div(class='bg-white shadow-md rounded-lg p-4 mb-4')
                div(class='mb-2')
                    p(class='text-gray-500 text-sm') अर्जदाराचे नाव:
                    span(class='font-semibold ml-1') #{constructionApplication.malmatta_dharak_name}

                div(class='grid grid-cols-1 md:grid-cols-2 gap-4')
                    div
                        p(class='text-gray-500 text-sm') मोबाईल:
                        span(class='font-semibold') #{constructionApplication.applicant_mobile}
                        p(class='text-gray-500 text-sm mt-1') आधार:
                        span(class='font-semibold') #{constructionApplication.applicant_adhar}
                    div
                        p(class='text-gray-500 text-sm') ग्रामपंचायत:
                        span(class='font-semibold') #{constructionApplication.gp_name}
                        p(class='text-gray-500 text-sm mt-1') मालमत्ता क्रमांक:
                        span(class='font-semibold') #{constructionApplication.malmatta_no}

                div(class='mt-2')
                    p(class='text-gray-500 text-sm') पत्ता:
                    span(class='font-semibold block') #{constructionApplication.applicant_address}

            // ================= ATTACHED DOCUMENTS =================
            div(class='bg-white shadow-md rounded-lg p-4 mb-4')
                h3(class='font-semibold text-lg mb-3') जोडलेली कागदपत्रे
                if !docs.length
                    p(class='text-sm text-gray-500') कोणतीही कागदपत्रे उपलब्ध नाहीत
                else
                    div(class='grid grid-cols-1 md:grid-cols-2 gap-3')
                        each doc, i in docs
                            div(class='border rounded p-3')
                                p(class='font-semibold text-sm mb-1') #{i + 1}. #{doc.document_name}
                                span(class=`text-xs px-2 py-0.5 rounded text-white ${doc.type === 'MANDATORY' ? 'bg-red-500' : 'bg-gray-500'}`) #{doc.type === 'MANDATORY' ? 'अनिवार्य' : 'ऐच्छिक'}
                                div(class='mt-2')
                                    a(class='text-blue-500 hover:underline text-sm' target='_blank' href=`${doc.saved_dir}/${doc.document_saved_name}`) कागदपत्र पहा

            // ================= LANDMARK DETAILS =================
            div(class='bg-white shadow-md rounded-lg p-4 mb-4')
                h3(class='font-semibold text-lg mb-3') दिशानुसार स्थळ माहिती

                each label, dir in { east: 'पूर्व', west: 'पश्चिम', north: 'उत्तर', south: 'दक्षिण' }
                    - const img = constructionApplication[`${dir}_landmark_image_name`]
                    - const lat = constructionApplication[`${dir}_landmark_image_latitude`]
                    - const lng = constructionApplication[`${dir}_landmark_image_longitude`]

                    div(class='border rounded p-3 mb-3')
                        p(class='font-semibold mb-1') #{label}
                        div(class='flex flex-col gap-1 text-sm')
                            if img
                                a(class='text-blue-500 hover:underline' target='_blank' href=`${directionsBase}/${img}`) फोटो पहा
                            else
                                span(class='text-gray-500') फोटो उपलब्ध नाही

                            if lat && lng
                                a(class='text-blue-500 hover:underline' target='_blank' href=`https://www.google.com/maps?q=${lat},${lng}`) लोकेशन पहा
                            else
                                span(class='text-gray-500') लोकेशन उपलब्ध नाही

            // ================= ACCEPTED =================
            if status === 'ACCEPTED'
                div(class='bg-blue-50 border-l-4 border-blue-500 shadow-md rounded-lg p-4 mb-4')
                    h3(class='font-semibold text-blue-700 mb-2') अर्ज मंजूर
                    p(class='text-sm') दिनांक: #{constructionApplication.date_of_acceptance || '-'}
                    p(class='text-sm') शेरा: #{constructionApplication.acceptance_remark || '-'}

            // ================= REJECTED =================
            if status === 'REJECTED'
                div(class='bg-red-50 border-l-4 border-red-500 shadow-md rounded-lg p-4 mb-4')
                    h3(class='font-semibold text-red-700 mb-2') अर्ज नाकारलेला
                    p(class='text-sm') दिनांक: #{constructionApplication.date_of_rejection || '-'}
                    p(class='text-sm') कारण: #{constructionApplication.rejection_remark || '-'}

            // ================= RESOLVED =================
            if status === 'RESOLVED'
                div(class='bg-green-50 border-l-4 border-green-500 shadow-md rounded-lg p-4 mb-4')
                    h3(class='font-semibold text-green-700 mb-3') अर्जाची पूर्तता
                    div(class='grid grid-cols-1 md:grid-cols-2 gap-3 text-sm')
                        div
                            p(class='text-gray-500') मासिक सभा दिनांक
                            span(class='font-semibold') #{constructionApplication._masik_sabha_date || '-'}
                        div
                            p(class='text-gray-500') मासिक ठराव क्रमांक
                            span(class='font-semibold') #{constructionApplication.masik_tharav_number || '-'}
                        div
                            p(class='text-gray-500') निवारण मालमत्ता क्रमांक
                            span(class='font-semibold') #{constructionApplication.resolution_malmatta_number || '-'}
                        div
                            p(class='text-gray-500') पूर्तता शेरा
                            span(class='font-semibold') #{constructionApplication.resolution_remark || '-'}

                        div(class='col-span-1 md:col-span-2')
                            p(class='text-gray-500') बांधकाम प्रमाणपत्र
                            if constructionApplication.construction_certification_doc_name
                                a(class='text-blue-500 hover:underline' target='_blank' href=`${certificateBase}/${constructionApplication.construction_certification_doc_name}`) प्रमाणपत्र पहा
                            else
                                span(class='text-gray-500') उपलब्ध नाही
