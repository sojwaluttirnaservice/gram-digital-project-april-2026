    title कर वसुली अहवाल - ग्रामपंचायत अधिकारी  लिस्ट

    style.
        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#f0d688 !important;
        }
        body{
            
            height:100vh;
        }

        .modal-dialog {
            width: 98%;
            height: 92%;
            padding: 0;
        }
        @media (min-width: 576px) {
            .modal-dialog {
                max-width: none; 
            }
        }
        #newKarVasuliAvahalButton {
            height: 2.4rem !important;
        }

body
    include ../include/navs.pug
    .container
        .row.p-0.p-1.pt-3

            .col-12 
                center
                    h5.heading-1 ग्रामपंचायत अधिकारी कर वसुली अहवाल
            .col-12
                div.d-flex.justify-content-between.align-items-center.mb-4

                    div.form-group.btn.btn-primary
                        label.mr-3.font-weight-bold(for='selectAvahalYear') वर्ष निवडा

                        select#selectAvahalYear.pt-1.pb-1.pl-2.pr-2.flex-end(for='years')
                            option(value='-1') -- वर्ष -- 
                            each year in years 
                                option(value=year) #{year}

                    button#newKarVasuliAvahalButton.btn.btn-primary
                        i.fa.fa-plus
                        | &nbsp; नवीन ग्रामपंचायत अधिकारी कर वसुली अहवाल

            .col-12.d-flex.justify-content-center.align-items-center
                table.table.table-bordered.text-center.m-0.w-50.d-none
                    thead
                        tr.bg-primary.text-white
                            th महिना
                            th एडिट 
                            th प्रिंट करा
                            th डिलीट करा
                    tbody#karVasuliList


    .modal#newKarVasuliAvahalModal(tabindex='-1')
        .modal-dialog.d-flex.justify-content-center.align-items-center(style='margin: 0 auto;')
            .modal-content.modal-sm.w-auto
                .modal-header
                    h5.modal-title ग्रामपंचायत अधिकारी कर वसुली अहवाल 
                .modal-body
                    div.form-group
                        label(for='monthDropdown') महिना 
                        select(name='month' id='monthDropdown' class='form-control')
                            - 
                                let months = [
                                    {name: "January", id: '01'}, 
                                    {name: "February", id: '02'}, 
                                    {name: "March", id: '03'}, 
                                    {name: "April", id: '04'}, 
                                    {name: "May", id: '05'}, 
                                    {name: "June", id: '06'}, 
                                    {name: "July", id: '07'}, 
                                    {name: "August", id: '08'}, 
                                    {name: "September", id: '09'}, 
                                    {name: "October", id: '10'}, 
                                    {name: "November", id: '11'}, 
                                    {name: "December", id: '12'}, 
                                ]
                            option(value=-1) --Select Month--
                            each month in months 
                                option(value=month.id) #{month.name}

                    div.form-group
                        label(for='karVasuliAvahalYear') वर्ष
                        input.form-control(type='text' maxlength=4 id='karVasuliAvahalYear' name='karVasuliAvahalYear' value='')

                .modal-footer.d-flex.justify-content-center
                    button.btn.btn-secondary.closeKarVasuliAvahalModal(type='button' data-bs-dismiss='modal') Close
                    button.btn.btn-primary#addNewKarVasuli(type='button') Save changes
