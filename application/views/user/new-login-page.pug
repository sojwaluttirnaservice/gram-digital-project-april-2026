            /* ===================================================
            UNIVERSAL Lazy-Loading Base Styles
            =================================================== */

            .lazy-image,
            //- .lazy-video,
            .lazy-lottie {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                z-index: 20;
            }

            /* ===================================================
            1️⃣ IMAGES - Lazy Loading
            =================================================== */

            .lazy-image {
                opacity: 0;
                transition: opacity 0.3s ease-in-out;
                object-fit: cover;
                border-radius: 1.5rem;  /* Or rounded-full if needed in markup */
            }

            .lazy-image.loaded {
                opacity: 1;
            }


            /* ===================================================
            2️⃣ VIDEOS - Lazy Loading
            =================================================== */

            .lazy-video {
                opacity: 0;
                transition: opacity 0.3s ease-in-out;
            }

            .lazy-video.loaded {
                opacity: 1;
            }


            /* ===================================================
            3️⃣ LOTTIE Animations - Lazy Loading
            =================================================== */

            .lazy-lottie {
                visibility: hidden;
                opacity: 0;
                transition: visibility 0s linear 0.3s, opacity 0.3s ease-in-out;
            }

            .lazy-lottie.loaded {
                visibility: visible;
                transition-delay: 0s;
                opacity: 1;
            }


            /* ===================================================
            Shimmer Placeholder
            =================================================== */

            .shimmer-placeholder {
                background: linear-gradient(
                    to right,
                    #eeeeee 8%,
                    #dddddd 18%,
                    #eeeeee 33%
                );
                background-size: 800px 104px;
                animation: shimmer 1.2s infinite linear;
                opacity: 1;
                transition: opacity 0.3s ease-in-out;
                border-radius: 1.5rem;  /* Or rounded-full in markup as needed */
            }

            /* ===================================================
            Shimmer Animation Keyframes
            =================================================== */

            @keyframes shimmer {
                0% {
                    background-position: -800px 0;
                }
                100% {
                    background-position: 800px 0;
                }
            }


            /* Main calendar background */
            .ui-datepicker {
                z-index: 99999 !important;
                background: #ffffff !important;
                color: #000000 !important;
                border: 1px solid #ccc;
                box-shadow: 0 4px 8px rgba(0,0,0,0.1)
            }

            /* Header (month/year bar) */
            .ui-datepicker-header {
                background: #ffffff !important;
                color: #000000 !important;
                border: none;
            }

            /* Month & Year dropdowns */
            .ui-datepicker select {
                background-color: #ffffff !important;
                color: #000000 !important;
                border: 1px solid #ccc !important;
            }

            /* Individual options (important for some browsers) */
            .ui-datepicker select option {
            background-color: #ffffff !important;
            color: #000000 !important;
            }

            /* Hover / focus fix */
            .ui-datepicker select:focus {
                outline: none;
                background-color: #ffffff !important;
                color: #000000 !important;
            }


