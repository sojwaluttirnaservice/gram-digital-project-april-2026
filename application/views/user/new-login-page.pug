    script.
        $(document).ready(function() {

            const $gpInput = $("#gp_code");
            const $loginFields = $("#login-fields");



            function populateDatabaseDropdown(dbList) {

                const dropdown = document.getElementById("dbId");

                const defaultOption = document.createElement("option");
                defaultOption.value = "";
                defaultOption.textContent = "Select Village";
                defaultOption.disabled = true;
                defaultOption.selected = true;
                dropdown.appendChild(defaultOption);

                // 🔥 map + append options
                dbList.forEach(_dbEntry => {

                    const label = _dbEntry.db_type === "PRIMARY"
                        ? "चालू वर्ष"
                        : `${_dbEntry.fromYear} ते ${_dbEntry.toYear}`;

                    const option = document.createElement("option");
                    option.value = _dbEntry.id; // ✅ now using id
                    option.textContent = label;

                    dropdown.appendChild(option);
                });
            }

            const verifyGpCode = async ($btn, gpCode) => {
                


                const originalText = $btn.text();
                console.log("verifygin the button", $btn)

                $btn.prop('disabled', true).text('Verifying...');
                 

                try {

                    
                    const response = await fetch("/gp-code", {
                        method: "POST",
                        body: JSON.stringify({ gp_code: gpCode }),
                        headers: {
                            "Content-Type": "application/json"
                        }
                    });
                   
                    const { success, message , data} = await response.json();

                   console.log(data)

                    if (success) {

                        alertjs.success({
                            t: "SUCCESS",
                            m: "GP Code verified successfully"
                        }, () => {

                            $("#login-fields").slideDown(200);
                            $("#gp_code").prop("readonly", true);

                            // ✅ hide button after success
                            $("#verify-gp-btn").fadeOut(200);



                            populateDatabaseDropdown(data.dbList || [])

                        });

                        return;
                    }

                    alertjs.warning({
                        t: "Warning",
                        m: message
                    });

                } catch (err) {

                    console.error(err);

                    alertjs.warning({
                        t: "Error",
                        m: "Error verifying GP Code"
                    });

                } finally {

                    $btn.prop('disabled', false).text(originalText);
                }
            };

            $(document).on('click', '#verify-gp-btn', async function (e) {
                e.preventDefault();

                const gpCode = $("#gp_code").val()?.trim();

                if (!gpCode) {
                    alertjs.warning({
                        t: "Warning",
                        m: "GP Code आवश्यक आहे"
                    });
                    return;
                }

                await verifyGpCode($(this), gpCode);
            });

            let otpBox = document.getElementById('otp-box')
            let loginBtn = document.querySelector('[data-sendSendOtpBtn]');
            let loginWithOtpBtn = document.querySelector('[data-loginWithOtpBtn]')

            //- Authentication of the user 
            $(document).on('click', '#login-btn', async function(e) {
                e.preventDefault()

                const $btn = $(this);
                const originalText = $btn.text();

                // disable button + loading text
                $btn.prop('disabled', true).text('Sending OTP...');

                const loginData = new FormData(document.getElementById('login-form'));

                try {
                    const _response = await fetch('/new-login', {
                        method: 'POST',
                        body: loginData
                    })

                    const {success, message} = await _response.json();

                    if(success) {

                        alertjs.success({
                            t: 'SUCCESS',
                            m: "सदर लॉगिन साठी OTP तुमच्या मोबाईल वर पाठवला आहे."
                        }, () =>{
                            otpBox.style.display = "block";
                            document.getElementById('otp').setAttribute('required', 'required');
                            loginBtn.style.display = "none";
                            loginWithOtpBtn.style.display = "block";
                        })

                        return;
                    }

                    alertjs.warning({
                        t: "Warning",
                        m: message
                    })

                } catch(err){
                    console.error('Error whilte trying to login:', err)
                    alertjs.warning({
                        t: 'Error',
                        m: 'Error while trying to login'
                    })
                } finally {
                    // re-enable button
                    $btn.prop('disabled', false).text(originalText);
                }
            })


            $(document).on('click', "#loginWithOtpBtn", async function(e){
                e.preventDefault();

                let otpValue = $('#otp').val();

                if(!otpValue?.trim()){
                    alertjs.warning({
                        t: "Warning",
                        m: 'Enter An Otp'
                    })
                    return;
                }

                const $btn = $(this);
                const originalText = $btn.text();

                // disable button + loading text
                $btn.prop('disabled', true).text('Verifying OTP...');

                const loginData = new FormData(document.getElementById('login-form'));

                try {
                    const _response = await fetch('/otpCheck', {
                        method: 'POST',
                        body: loginData
                    })

                    const {success, message} = await _response.json();

                    if(success) {
                        alertjs.success({
                            t: 'SUCCESS',
                            m: message
                        }, () =>{
                            const warningTextEl = document.getElementById("warning-text");
                            let continueOn = null;

                            if (warningTextEl) {
                                continueOn = warningTextEl.getAttribute("data-continue");
                            }

                            window.location.href = continueOn ? continueOn : "/";
                        })

                        return;
                    }

                    alertjs.warning({
                        t: "Warning",
                        m: message
                    })

                } catch(err){
                    console.error('Error whilte trying to login:', err)
                    alertjs.warning({
                        t: 'Error',
                        m: 'Error while trying to login'
                    })
                } finally {
                    // re-enable button
                    $btn.prop('disabled', false).text(originalText);
                }
            })
        })
