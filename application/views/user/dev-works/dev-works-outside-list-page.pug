//- =======================================================
//- OUTSIDE MASTER LAYOUT
//- =======================================================
extends ../include/index-page-master-layout.pug

block internal_css

block content

    section(class='py-8 md:py-14 bg-gradient-to-b from-sky-50 to-green-50')

        div(class='container mx-auto px-4')

            //- ===================================================
            //- SECTION HEADER
            //- ===================================================
            div(class='text-center mb-10')

                div(class='inline-flex items-center justify-center w-16 h-16 rounded-full bg-sky-100 text-sky-700 mb-4 shadow-sm')

                    i(class='fa fa-building text-2xl')

                h2(class='text-3xl md:text-4xl font-bold text-gray-800 mb-3')

                    | विकास कामे

                p(class='text-gray-600 max-w-3xl mx-auto')

                    | ग्रामपंचायत अंतर्गत सुरू असलेली, पूर्ण झालेली व आगामी विकास कामांची माहिती



            //- ===================================================
            //- DEV WORKS LIST
            //- ===================================================
            div(class='max-w-6xl mx-auto space-y-5')

                if devWorksList && devWorksList.length > 0

                    each item, index in devWorksList

                        details(class='group bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden')

                            summary(class='list-none cursor-pointer select-none')

                                div(class='p-5 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5 hover:bg-sky-50 transition')

                                    //- ==================================
                                    //- LEFT CONTENT
                                    //- ==================================
                                    div(class='flex-1')

                                        div(class='flex flex-wrap items-center gap-2 mb-3')

                                            span(class='inline-flex items-center px-3 py-1 rounded-full bg-sky-100 text-sky-700 text-sm font-semibold')

                                                | #{item.from_year} - #{item.to_year}

                                            if item.scheme

                                                span(class='inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-700 text-sm font-medium')

                                                    | #{item.scheme}

                                            if item.status === 'ONGOING'

                                                span(class='inline-flex items-center px-3 py-1 rounded-full bg-yellow-100 text-yellow-700 text-sm font-medium')

                                                    i(class='fa fa-spinner mr-2')

                                                    | सुरू

                                            else if item.status === 'COMPLETE'

                                                span(class='inline-flex items-center px-3 py-1 rounded-full bg-green-100 text-green-700 text-sm font-medium')

                                                    i(class='fa fa-check mr-2')

                                                    | पूर्ण

                                            else if item.status === 'UPCOMING'

                                                span(class='inline-flex items-center px-3 py-1 rounded-full bg-gray-200 text-gray-700 text-sm font-medium')

                                                    i(class='fa fa-clock-o mr-2')

                                                    | आगामी

                                        h3(class='text-xl font-bold text-gray-800 leading-snug')

                                            | #{item.title || 'विकास काम माहिती'}

                                        p(class='text-sm text-gray-500 mt-2')

                                            | नोंद क्रमांक : #{index + 1}



                                    //- ==================================
                                    //- RIGHT ACTIONS
                                    //- ==================================
                                    div(class='flex flex-wrap items-center gap-3')

                                        if item.images_count > 0

                                            a(
                                                class='inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-sky-600 hover:bg-sky-700 text-white text-sm font-medium transition'
                                                href=`/dev-works/images-list/${item.id}`
                                                onclick='event.stopPropagation();'
                                            )

                                                i(class='fa fa-image')

                                                | #{item.images_count} फोटो

                                        if item.uploaded_document

                                            a(
                                                class='inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-green-600 hover:bg-green-700 text-white text-sm font-medium transition'
                                                href=`/uploads/docs/dev-works/docs/${item.uploaded_document}`
                                                target='_blank'
                                                onclick='event.stopPropagation();'
                                            )

                                                i(class='fa fa-file-pdf-o')

                                                | दस्तऐवज

                                        div(class='w-10 h-10 rounded-full bg-sky-100 flex items-center justify-center text-sky-700 group-open:rotate-180 transition-transform duration-300')

                                            i(class='fa fa-chevron-down')



                            //- ===================================================
                            //- ACCORDION BODY
                            //- ===================================================
                            div(class='border-t border-gray-100 bg-white')

                                div(class='p-5 grid grid-cols-1 lg:grid-cols-3 gap-5')

                                    //- ==================================
                                    //- BASIC DETAILS
                                    //- ==================================
                                    div(class='lg:col-span-1')

                                        div(class='bg-sky-50 rounded-2xl p-5 h-full')

                                            h4(class='text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2')

                                                i(class='fa fa-info-circle text-sky-600')

                                                | काम माहिती

                                            div(class='space-y-4 text-sm')

                                                div

                                                    p(class='text-gray-500 mb-1')
                                                        | आर्थिक वर्ष

                                                    p(class='font-semibold text-gray-800')

                                                        | #{item.from_year} ते #{item.to_year}

                                                div

                                                    p(class='text-gray-500 mb-1')
                                                        | योजना

                                                    p(class='font-semibold text-gray-800')

                                                        | #{item.scheme || '-'}

                                                div

                                                    p(class='text-gray-500 mb-1')
                                                        | स्थिती

                                                    p(class='font-semibold text-gray-800')

                                                        | #{item.status || '-'}

                                                div

                                                    p(class='text-gray-500 mb-1')
                                                        | फोटो

                                                    p(class='font-semibold text-gray-800')

                                                        | #{item.images_count || 0}



                                    //- ==================================
                                    //- IMAGE PREVIEW
                                    //- ==================================
                                    div(class='lg:col-span-2')

                                        div(class='bg-gray-50 rounded-2xl p-5 h-full')

                                            div(class='flex items-center justify-between mb-4')

                                                h4(class='text-lg font-semibold text-gray-800 flex items-center gap-2')

                                                    i(class='fa fa-picture-o text-green-600')

                                                    | विकास कामे फोटो

                                                if item.images_count > 0

                                                    a(
                                                        class='text-sm font-medium text-sky-700 hover:text-sky-900'
                                                        href=`/dev-works/images-list/${item.id}`
                                                    )

                                                        | सर्व फोटो पहा →

                                            if item.images_count > 0

                                                div(class='grid grid-cols-2 md:grid-cols-3 gap-4')

                                                    each image in item.images.slice(0, 3)

                                                        a(
                                                            class='group relative overflow-hidden rounded-2xl shadow-sm bg-white'
                                                            href=`/uploads/images/dev-works/images/${image.uploaded_image}`
                                                            target='_blank'
                                                        )

                                                            img(
                                                                class='w-full h-44 object-cover group-hover:scale-105 transition duration-300'
                                                                src=`/uploads/images/dev-works/images/${image.uploaded_image}`
                                                            )

                                                            div(class='absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 to-transparent p-3')

                                                                p(class='text-white text-sm font-medium truncate')

                                                                    | #{image.title}

                                            else

                                                div(class='flex flex-col items-center justify-center py-10 text-center')

                                                    i(class='fa fa-image text-4xl text-gray-300 mb-3')

                                                    p(class='text-gray-500')

                                                        | फोटो उपलब्ध नाहीत

                else

                    div(class='bg-white rounded-3xl shadow-sm border border-gray-200 p-10 text-center')

                        div(class='w-20 h-20 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-5')

                            i(class='fa fa-folder-open text-4xl text-gray-400')

                        h3(class='text-2xl font-bold text-gray-700 mb-2')

                            | कोणतीही विकास कामे उपलब्ध नाहीत

                        p(class='text-gray-500')

                            | कृपया नंतर पुन्हा भेट द्या