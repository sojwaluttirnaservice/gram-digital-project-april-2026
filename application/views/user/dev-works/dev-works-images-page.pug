//- =======================================================
//- MASTER LAYOUT
//- =======================================================
extends ../include/internal-gp-master-layout.pug

block custom_js
    script(src='/asstest/coustom/js/handlers/dev-works/dev-works-images-page-handler.js')

block content

    div.container-fluid.mt-4

        .row.justify-content-center

            .col-12.col-xl-11

                //- ===================================================
                //- HEADER
                //- ===================================================
                .card.shadow-sm.mb-3(style="background: oklch(86.9% 0.022 252.894);")

                    .card-body.py-3.d-flex.flex-column.flex-md-row.align-items-center.justify-content-between.gap-3

                        div

                            h4.mb-1

                                i.fa.fa-image.me-2

                                | विकास कामे फोटोज

                            p.text-muted.mb-0

                                | विकास काम संबंधित फोटो अपलोड करा

                        div.d-flex.flex-wrap(style='gap:0.5rem;')

                            a.btn.btn-secondary.btn-sm(href='/dev-works')

                                i.fa.fa-arrow-left.me-1
                                | मागे जा

                            //- a.btn.btn-primary.btn-sm(href=`/dev-works/edit/${devWorksDetails.id}`)

                                i.fa.fa-pencil.me-1
                                | Edit Details



                //- ===================================================
                //- BASIC DETAILS
                //- ===================================================
                .card.shadow-sm.mb-3

                    .card-body.py-3

                        .row.align-items-center

                            .col-md-3.mb-2.mb-md-0

                                small.text-muted.d-block
                                    | आर्थिक वर्ष

                                span.badge.bg-primary
                                    | #{devWorksDetails.from_year} ते #{devWorksDetails.to_year}

                            .col-md-3.mb-2.mb-md-0

                                small.text-muted.d-block
                                    | शीर्षक

                                div.fw-semibold
                                    | #{devWorksDetails.title || '-'}

                            .col-md-3.mb-2.mb-md-0

                                small.text-muted.d-block
                                    | योजना

                                div
                                    | #{devWorksDetails.scheme || '-'}

                            .col-md-3

                                small.text-muted.d-block
                                    | दस्तऐवज

                                if devWorksDetails.uploaded_document

                                    a.btn.btn-sm.btn-success(
                                        href=`/uploads/docs/dev-works/docs/${devWorksDetails.uploaded_document}`
                                        target='_blank'
                                    )

                                        i.fa.fa-file-pdf-o.me-1
                                        | पहा

                                else

                                    span.text-muted
                                        | -



                //- ===================================================
                //- IMAGE FORM
                //- ===================================================
                .card.shadow-sm.mb-3

                    .card-header.py-2

                        h6.mb-0

                            i.fa.fa-upload.me-2

                            | नवीन फोटो अपलोड करा

                    .card-body.py-3

                        form#dev-work-image-form(method='POST' enctype='multipart/form-data')

                            input(
                                type='hidden'
                                name='dev_works_id_fk'
                                id='dev_works_id_fk'
                                value=devWorksDetails.id
                            )

                            .row

                                .col-md-4.mb-3

                                    .form-group

                                        label.form-label(for='title')

                                            | शीर्षक
                                            span.text-danger *

                                        input.form-control(
                                            type='text'
                                            name='title'
                                            id='title'
                                            placeholder='प्रतिमेचे शीर्षक'
                                            maxlength='120'
                                            required
                                        )



                                .col-md-4.mb-3

                                    .form-group

                                        label.form-label(for='desc')

                                            | वर्णन

                                        input.form-control(
                                            type='text'
                                            name='desc'
                                            id='desc'
                                            placeholder='प्रतिमेचे वर्णन'
                                            maxlength='200'
                                        )



                                .col-md-4.mb-3

                                    .form-group

                                        label.form-label(for='image')

                                            | फोटो
                                            span.text-danger *

                                        input.form-control(
                                            type='file'
                                            name='image'
                                            id='image'
                                            accept='.jpg,.jpeg,.png,.webp'
                                            required
                                        )



                            .d-flex.justify-content-end

                                button.btn.btn-primary.btn-sm(
                                    type='submit'
                                    id='save-dev-work-image-btn'
                                )

                                    i.fa.fa-save.me-1
                                    | फोटो जतन करा



                //- ===================================================
                //- IMAGE LIST
                //- ===================================================
                .card.shadow-sm

                    .card-header.py-2.d-flex.justify-content-between.align-items-center

                        h6.mb-0

                            i.fa.fa-picture-o.me-2

                            | अपलोड केलेल्या फोटो

                        span.badge.bg-secondary
                            | #{images ? images.length : 0}

                    .card-body.py-3

                        if images && images.length > 0

                            .row

                                each image in images

                                    .col-md-4.col-lg-3.mb-3

                                        .card.shadow-sm.h-100.border-0

                                            a(
                                                href=`/uploads/images/dev-works/images/${image.uploaded_image}`
                                                target='_blank'
                                            )

                                                img.card-img-top(
                                                    src=`/uploads/images/dev-works/images/${image.uploaded_image}`
                                                    style='height:200px; object-fit:cover;'
                                                )

                                            .card-body.p-3.d-flex.flex-column

                                                h6.mb-1.text-truncate
                                                    | #{image.title}

                                                p.text-muted.small.flex-grow-1.mb-2(style='min-height:40px;')
                                                    | #{image.desc || '-'}

                                                button.btn.btn-danger.btn-sm.delete-dev-work-image-btn(
                                                    type='button'
                                                    data-id=image.id
                                                )

                                                    i.fa.fa-trash.me-1
                                                    | Delete

                        else

                            .text-center.py-4

                                i.fa.fa-image.fa-3x.text-muted.mb-3

                                h6.text-muted.mb-1
                                    | कोणतीही फोटो उपलब्ध नाही

                                p.text-muted.mb-0
                                    | कृपया नवीन फोटो अपलोड करा