                                            label.font-weight-bold(for='my-input') नवीन धारक
                                            input#newNewDharak.form-control-sm.form-control(type='text' name='newNewDharak' value="-")
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') दिनांक
                                            input#newPherfarDate.form-control-sm.form-control(type='text' name='newPherfarDate' value="-")
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') ठराव क्रमांक
                                            input#newPherfarTharav.form-control-sm.form-control(type='text' name='newPherfarTharav' value="-")
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') कोणत्या दस्तावेजनी
                                            select#newPherfarDocument.form-control(type='text' name='newPherfarDocument')
                                                option(value="") -- निवडा --
                                                //- 
                                                tion(value=value) #{value}
                                        .form-group.col-12 
                                            input.pherfar-text.form-control-sm.form-control(type='text' disabled)
                            .col-4.mt-5
                                .card
                                    .card-header.bg-warning.font-weight-bold जागेची माहिती
                                    .card-body
                                        .form-group
                                            label.font-weight-bold(for='my-input') गट क्र./भुमापण क्र. /नगर भामपण क्र
                                            input#newGaatNo.form-control-sm.form-control(type='text' name='newGaatNo')
                                        .form-group
                                            label.font-weight-bold(for='my-input') घरकुल असल्यास
                                            select#gharkulYojna.form-control(type='text' name='gharkulYojna')
                                                //- each value,index in gharkulYojanaList
                                                //-   option(value=value.id) #{value.text}

                                        .form-group
                                            label.font-weight-bold(for='my-input') शौच्छालय
                                            select#havingToilet.form-control(type='text' name='havingToilet')
                                                //- each value,index in ["होय","नाही"]
                                                //-   option(value=value) #{value}
                            .col-4.mt-5
                                .card
                                    .card-header.bg-warning.font-weight-bold क्षेत्रफळ माहिती
                                    .card-body.row
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') जागेची लांबी (पु./प.)
                                            input#newAreaHeight.isNaN.form-control-sm.form-control(type='text' name='newAreaHeight')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') जागेची रुंदी (उ./द.)
                                            input#newAreaWidth.isNaN.form-control-sm.form-control(type='text' name='newAreaWidth')
                                        .form-group.col-12    
                                            label.font-weight-bold(for='my-input') एकूण जागेचे क्षेत्रफळ (चौ.फुट)
                                            input#newTotalArea.form-control-sm.form-control(type='text' name='newTotalArea')
                                        .form-group.col-12
                                            label.font-weight-bold(for='my-input') एकूण जागेची चौ.मी.
                                            input#newTotalAreaSquareMeter.form-control-sm.form-control(type='text' name='newTotalAreaSquareMeter' )
                            .col-4.mt-5
                                .card
                                    .card-header.bg-warning.font-weight-bold दिशा माहिती
                                    .card-body.row
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') पूर्वेस
                                            input#newEastLandmark.form-control-sm.form-control(type='text' name='newEastLandmark')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') पश्चिमेस
                                            input#newWestLandmark.form-control-sm.form-control(type='text' name='newWestLandmark')
                                        .form-group.col-6   
                                            label.font-weight-bold(for='my-input') उत्तरेस
                                            input#newNorthLandmark.form-control-sm.form-control(type='text' name='newNorthLandmark')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') दक्षिणेस
                                            input#newSouthLandmark.form-control-sm.form-control(type='text' name='newSouthLandmark')
                                        .form-group.col-12
                                            label.font-weight-bold(for='my-input') बोजा/शेरा
                                            textarea#newBojaShera.form-control-sm.form-control(type='text' name='newBojaShera' value="-")
                            .col-6
                                .card
                                    .card-body.row
                                        .form-group.col-12
                                            label.font-weight-bold(for='my-input') मीटर फोटो
                                            input#image1.form-control-sm.form-control(type='file')
                                            img#image-1-preview(src="" alt="" width="100%" style="border:1px solid" height="400")

                            .col-12
                                .form-group.col-12.mt-4
                                    button#removeUserDetails.btn.btn-danger.float-right.ml-3 
                                        span.fa.fa-trash.mr-2
                                        | नमुना ८ काढून काढा

                                    button#moveMore.btn.btn-primary.float-right.ml-3 
                                        span.fa.fa-forward.mr-2
                                        | नमुना ८ कर दुरीस्ती
                                    button#saveNewUserForm.btn.btn-success.float-right
                                        span.fa.fa-floppy-o.mr-2
                                        | माहिती जतन करा

                    .modal-footer.d-none
                        button.btn.btn-primary(type='button') Save changes
                        button.btn.btn-secondary(type='button' data-dismiss='modal') Close
        .modal#masterModal1(tabindex='-1' role='dialog')
            .modal-dialog(role='document')
                .modal-content
                    .modal-header
                        h5.modal-title Modal title
                        button.close(type='button' data-dismiss='modal' aria-label='Close')
                            span(aria-hidden='true') ×
                    .modal-body 
                        .row
                            .col-6.offset-4.mb-3
                                form.form-inline
                                    .form-group.mx-sm-3.mb-2
                                        select#selectSearch.form-control.text-secondary
                                            option(value="1") नाव
                                            option(value="2") मामत्ता क्र
                                            option(value="3") अनु/घर क्रमांक टाका
                                            option(value='4') भोगवटदाराचे नाव
                                    .form-group.mx-sm-3.mb-2
                                        input#homeId1-type.form-control(type='text' placeholder='')
                                        input#homeId1.form-control(type='hidden' placeholder='')
                                    button#btnGetUserDetails1.btn.btn-primary.mb-2(type='submit') माहित पहा






        .modal#yearModal.fade(tabindex='-1' role='dialog')
            .modal-dialog(role='document' style='max-width: 700px !important')
                .modal-content
                    .modal-header
                        h5.modal-title
                        button.close(type='button' data-dismiss='modal' aria-label='Close')
                            span(aria-hidden='true') ×
                    .modal-body 
                        .row
                            .col-5
                                .form-group.mb-2
                                    input#date1.form-control(placeholder="---- पासून वर्ष ----")
                            .col-1
                                .form-group.mt-2.text-center
                                    span.font-weight-bold ते
                            .col-5  
                                .form-group.mb-2
                                    input#date2.form-control(placeholder="---- पासून वर्ष ----")
                            .col-12
                                .d-flex.align-items-center.justify-content-center(style='gap:0.2rem;')

                                    button#btnGetPrintSpace.btn.btn-primary(type='button') Print

        .row.d-flex.justify-content-center.mt-3
