body.back-image
    include ./include/navs.pug

    .container-fluid
        .modal#masterModal(tabindex='-1' role='dialog')
            .modal-dialog(role='document')
                .modal-content
                    .modal-header
                        h5.modal-title Modal title
                        button.close(type='button' data-dismiss='modal' aria-label='Close')
                            span(aria-hidden='true') ×
                    .modal-body 
                        .row
                            .col-6.offset-4.mb-3
                                form.form-inline
                                    .form-group.mx-sm-3.mb-2
                                        select#selectSearch-1.form-control
                                            option(value="1") नाव
                                            option(value="2") मामत्ता क्र
                                            option(value="3") अनु/घर क्रमांक टाका
                                            option(value='4') भोगवटदाराचे नाव
                                    .form-group.mx-sm-3.mb-2
                                        input#homeId-type.form-control(type='text' placeholder='विकल्प निवडा')
                                        input#homeId.form-control(type='hidden' placeholder='विकल्प निवडा')
                                    button#btnGetUserDetails.btn.btn-primary.mb-2(type='submit') माहित पहा

                        form.row#divUserDetails.d-none
                            .col-4
                                .card
                                    .card-header.bg-warning.font-weight-bold मालमत्ता माहिती
                                    .card-body.row
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') अनु क्रमांक
                                            input.myMainId.form-control-sm.form-control(type='text' value="" readonly)
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') घर क्रमांक
                                            input.myMainId.form-control-sm.form-control(type='text' value="" readonly)
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') मालमत्ता क्र.
                                            input#newMalmattaNo.form-control-sm.form-control(type='text' name='newMalmattaNo')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') वार्ड नं
                                            input#newWardNo.form-control-sm.form-control(type='text' name='newWardNo')
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') जुनाघर क्र.
                                            input#oldHomeNo.form-control-sm.form-control(type='text' name='oldHomeNo')
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') वि. पाणीकर
                                            input#spacialWaterTax.form-control-sm.form-control(type='text' name='spacialWaterTax')
                                        .form-group.col-4
                                            label.font-weight-bold(for='my-input') सा. पाणीकर
                                            input#generalWaterTax.form-control-sm.form-control(type='text' name='generalWaterTax')
                            .col-8
                                .card
                                    .card-header.bg-warning.font-weight-bold मालकाची माहिती
                                    .card-body.row
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') मालमत्ता धारकाचे नाव व पत्नीचे नाव
                                            input#newOwnerName.form-control-sm.form-control(type='text' name='newOwnerName')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') भोगवटदाराचे नाव
                                            input#newSecondOwnerName.form-control-sm.form-control(type='text' name='newSecondOwnerName')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') मोबाईल क्रमांक 
                                            input#newMobileNo.form-control-sm.form-control(type='text' name='newMobileNo' maxlength="10")
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') आधार क्रं.
                                            input#newAadharNo.form-control-sm.form-control(type='text' name='newAadharNo' maxlength="12")
                                        .form-group.col-6    
                                            label.font-weight-bold(for='my-input') ग्रामपंचायत
                                            input#newGramPanchayet.form-control-sm.form-control(type='text' name='newGramPanchayet')
                                        .form-group.col-6
                                            label.font-weight-bold(for='my-input') गावाचे नाव
                                            input#newVillageName.form-control-sm.form-control(type='text' name='newVillageName')
                            .col-12.mt-5
                                .card
                                    .card-header.bg-warning.font-weight-bold  मालमत्तेचा फेरफार
                                    .card-body.row
