    //- div 
        .container 

            ul.nav.nav-tabs#myTab(role="tablist")

                li.nav-item(role='presentation')

                    a.nav-link.active#samanya-tab(data-toggle="tab" href="#samanya" role="tab" aria-controls="samanya" aria-selected="true") Home

                li.nav-item(role='presentation')

                    a.nav-link#pani-tab(data-toggle="tab" href="#pani" role="tab" aria-controls="pani" aria-selected="true") Home


            div 

                //- TAble for samanya
                div(class='tab-pane fade show active' id="samanya" role="tabpanel" aria-labelledby="samanya-tab")

                    h3.fw-bold.text-center सामान्य यादी

                    .table-responsive
                        table(style='width:100%')

                            thead 
                                tr
                                    th अनु क्र.
                                    th मालमत्ता क्रमांक
                                    th मालमत्ता धारकाचे नाव
                                    th संपूर्ण सामान्य कर 
                                    th भरणा दिनांक

                                    th पावती प्रिंट

                            tbody 
                                each samanyaKarBharanaEntry, index in samanyaKarBharanaList
                                    tr
                                        td #{index + 1}
                                        td #{samanyaKarBharanaEntry.feu_malmattaNo}
                                        td #{samanyaKarBharanaEntry.feu_ownerName}
                                        td #{samanyaKarBharanaEntry.tpl_totalSampurnaTax}
                                        td #{samanyaKarBharanaEntry._tpl_bharnaDate}
                                        td 
                                            .d-flex.align-items-center.justify-content-center 
                                                a.btn.btn-sm.btn-primary(href=`/print/tax-payer/samanya?t_no=${samanyaKarBharanaEntry.samanya_tax_list_id}&i=${samanyaKarBharanaEntry.user_id}` ) Print


                //- talbe for water
                div(class='tab-pane fade' id="pani" role="tabpanel" aria-labelledby="pani-tab")

                    h3.fw-bold.text-center पाणी यादी

                    .table-responsive
                        table(style='width:100%')

                            thead 
                                tr
                                    th अनु क्र.
                                    th मालमत्ता क्रमांक
                                    th मालमत्ता धारकाचे नाव
                                    th संपूर्ण सामान्य कर 
                                    th भरणा दिनांक

                                    th पावती प्रिंट

                            tbody 
                                each paniKarBharanaEntry, index in paniKarBharanaList
                                    tr
                                        td #{index + 1}
                                        td #{paniKarBharanaEntry.feu_malmattaNo}
                                        td #{paniKarBharanaEntry.feu_ownerName}
                                        td #{paniKarBharanaEntry.tpl_totalSampurnaTax}
                                        td #{paniKarBharanaEntry._tpl_bharnaDate}
                                        td 
                                            .d-flex.align-items-center.justify-content-center 
                                                a.btn.btn-sm.btn-primary(href=`/print/tax-payer/pani?t_no=${paniKarBharanaEntry.pani_tax_list_id}&i=${paniKarBharanaEntry.user_id}` ) Print


div.container
