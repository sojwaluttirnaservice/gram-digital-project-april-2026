body
    include ../include/navs.pug
    .modal#masterModal(tabindex='-1' role='dialog')
        .modal-dialog.modal-dialog-centered(role='document' style='width: 90%; margin-inline: auto;')
            .modal-content
                .modal-header
                    h5.modal-title(style="margin-left: calc(38%)") कर वसुली नोंदणी 
                    button.close(type='button' data-dismiss='modal' aria-label='Close')
                        span(aria-hidden='true') ×
                .modal-body 
                    .row
                        .col-6.offset-4.mb-3
                            form.form-inline
                                .form-group.mx-sm-3.mb-2
                                    select#selectSearch-1.form-control
                                        option(value="1") नाव
                                        option(value="2") मालमत्ता क्र
                                        option(value="3") अनु/घर क्रमांक टाका
                                        option(value='4') भोगवटदाराचे नाव
                                .form-group.mx-sm-3.mb-2
                                    input#homeId-type.form-control(type='text' placeholder='विकल्प निवडा')
                                    input#homeId.form-control(type='hidden' placeholder='विकल्प निवडा')
                                button#btnGetUserDetails.btn.btn-primary.mb-2(type='submit' ) माहिती पहा 

                    form.row#divUserDetails.d-none
                        .col-12.col-md-6
                            .card
                                .card-header.bg-warning.font-weight-bold मालमत्ता माहिती
                                .card-body
                                    .row
                                        .col-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') अनु क्रमांक
                                                input.myMainId.form-control-sm.form-control#anuKramank(type='text'  readonly)
                                        .col-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') घर क्रमांक
                                                input.myMainId.form-control-sm.form-control(type='text' value="" readonly)
                                        .col-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') मालमत्ता क्र.
                                                input#newMalmattaNo.form-control-sm.form-control(type='text' name='newMalmattaNo' readonly)
                                        .col-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') वार्ड नं
                                                input#newWardNo.form-control-sm.form-control(type='text' name='newWardNo' readonly)
                                        .col-12
                                            .form-group
                                                label.font-weight-bold(for='my-input') जुना घर क्रमांक
                                                input#oldHomeNo.form-control-sm.form-control(type='text' name='oldHomeNo' readonly)


                        .col-12.col-md-6
                            .card
                                .card-header.bg-warning.font-weight-bold मालकाची माहिती
                                .card-body
                                    .row
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') मालमत्ता धारकाचे नाव व पत्नीचे नाव
                                                input#newOwnerName.form-control-sm.form-control(type='text' name='newOwnerName' readonly)
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') भोगवटदाराचे नाव
                                                input#newSecondOwnerName.form-control-sm.form-control(type='text' name='newSecondOwnerName' readonly)
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') मोबाईल क्रमांक 
                                                input#newMobileNo.form-control-sm.form-control(type='text' name='newMobileNo' readonly)
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') आधार क्रं.
                                                input#newAadharNo.form-control-sm.form-control(type='text' name='newAadharNo' readonly)
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') ग्रामपंचायत
                                                input#newGramPanchayet.form-control-sm.form-control(type='text' name='newGramPanchayet' readonly)
                                        .col-12.col-md-6
                                            .form-group
                                                label.font-weight-bold(for='my-input') गावाचे नाव
                                                input#newVillageName.form-control-sm.form-control(type='text' name='newVillageName' readonly)

                            .mt-2.d-flex.justify-content-center(style='gap: 1rem;')
                                button#goPani.float-right.btn.btn-primary पाणी कर भरा
                                button#goSamanya.float-right.mr-3.btn.btn-info सामान्य कर भरा
    .container
        .row
            .col-12.mt-3
