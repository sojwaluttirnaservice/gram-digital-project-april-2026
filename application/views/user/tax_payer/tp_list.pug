    //- modals for report will beh here all - 4 

    //- this one is for annual samanaya report ------------------
    .modal.fade#annual-report-samanya(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog.modal-dialog-centered(style="max-width: 500px;")
            .modal-content
                .modal-header
                    h5.modal-title#exampleModalLabel वार्षिक अहवाल प्रिंट (सामान्य)
                    button.close(type="button" data-dismiss="modal" aria-label="Close")
                        span(aria-hidden="true") ×
                .modal-body


                    div(style='display: flex; align-items: center; gap: 1rem;')

                        div
                            input.form-control(type='number' placeholder='वर्षापासून e.g. 2024' id='fromYearSamanya')


                        div ते

                        div
                            input.form-control(type='number' placeholder='वर्षापर्यंत e.g. 2025' id='endYearSamanya')

                .modal-footer
                    button.btn.btn-secondary(type="button" data-dismiss="modal") Close
                    button.btn.btn-primary(type="button" id='annual-report-samanya-print-btn') Print



    .modal.fade#monthly-report-samanya(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
