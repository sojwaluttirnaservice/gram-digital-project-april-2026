doctype html
head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
    link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')


    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js") 
    //toggle
    script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
    // extras

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src="https://checkout.razorpay.com/v1/checkout.js")
    style.
        .error {
            background-color:yellow;
            padding:2px;
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
body
    include ../include/navs-1.pug
    .container-fluid
        .row.p-0
            .col-12.p-0
                .card-group
                    .card.bg-light-gray
                        .card-body
                            .col-lg-8.offset-lg-2.col-12
                                center
                                    input#homeId-type(type="hidden")
                                    h4.font-weight-bold नमुना ९ सामान्य करासंदर्भात वसुली फॉर्म (Mobile)

                                div.d-flex.justify-content-end
                                    a.btn.btn-primary.btn(href=`/payment/u/history?malmattaNo=${user.feu_malmattaNo}&paymentFor=${1}` target='_blank') History

                                .form-group.mt-4
                                    .col-12
                                        .card
                                            .card-header.bg-warning
                                                .font-weight-bold.text-center धारकाची माहिती
                                            .card-body
                                                .row
                                                    .col-6.col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') अनु / घर क्रमांक
                                                            input.form-control-sm.form-control(type='text' disabled value=user.id)
                                                    .col-6.col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input')  मालमत्ता क्र.
                                                            input.form-control-sm.form-control(id='malmattaNo' type='text' disabled value=user.feu_malmattaNo)
                                                    .col-6.col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') वार्ड नं
                                                            input.form-control-sm.form-control(type='text' disabled value=user.feu_wardNo)
                                                    .col-6.col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') जुना घर क्रमांक
                                                            input.form-control-sm.form-control(type='text' disabled value=user.feu_homeNo)
                                                    .col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') पेमेंट मोबाइल नों.
                                                            input.form-control-sm.form-control#paymentMobileNumber(type='text'  value=user.feu_mobileNo maxlength='10')

                                                    .col-lg-3
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') आधार क्रं.
                                                            input.form-control-sm.form-control(type='text' disabled value=user.feu_aadharNo maxlength="12")
                                                    .col-lg-6
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') मालमत्ता धारकाचे नाव व पत्नीचे नाव
                                                            input.form-control-sm.form-control(type='text' id="personName" readonly value=user.feu_ownerName)
                                                    .col-lg-6
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') भोगवटदाराचे नाव
                                                            input.form-control-sm.form-control(type='text' disabled value=user.feu_secondOwnerName)
                                                    .col-lg-6
                                                        .form-group
                                                            label.font-weight-bold(for='my-input') गट क्र./भुमापण क्र. /नगर भामपण क्र
                                                            input.form-control-sm.form-control(type='text' disabled value=user.feu_gaatNo)

                                                    .col-lg-6
                                                        .form-group 
                                                            label.font-weight-bold UTR NUMBER /Transaction number
                                                            input.form-control-sm.form-control(id='transaction_number' type='text' maxlength='45') 

                                                    .col-lg-6
                                                        .form-group 
                                                            label.font-weight-bold Payment Screenshot
                                                            input.form-control-sm.form-control(id='paymentScreenshot' type='file' accept='image/*') 

                                                    .col-12 
                                                        div(class='d-flex justify-content-center align-items-center gap-4')

                                                            - let size = '8rem;'
                                                            div
                                                                //- p(style='font-size:0.9rem; color: #0c5460; background-color: #d1ecf1; border: 1px solid #bee5eb; padding: 0.5rem; border-radius: 4px;')
                                                                p(style='font-size:0.9rem; color: #721c24; background-color: #f8d7da; border: 1px solid #f5c6cb; padding: 0.5rem; border-radius: 4px;')
                                                                    | खालील QR कोड स्कॅन करून त्यावर कर भरणा करा. त्यानंतर वरील इनपुट बॉक्समध्ये UTR क्रमांक आणि पेमेंटचा स्क्रीनशॉट अपलोड करा. नंतर, भरणा रक्कम टाका आणि 'वसुली भरणा करा' बटणावर क्लिक करा.
                                                                img(style=`display:block;margin-inline:auto;width:${size};height:${size}` src='/new-gp-page/main-page/files/qr-codes/' + qrCodes.bank_qr_code_image_name)


                            .col-12.p-0
                                .row
                                    //- LEFT COLUMN
                                    .col-lg-6
                                        table.table.table-bordered.bg-table-on-gray 
                                            tbody
                                                tr
                                                    th(colspan="5").text-center.bg-warning सामान्य कर 

                                                //- कर
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील इमारत कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastBuildingTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू इमारत कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentBuildingTax)

                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील दंड कर (५%):
                                                        input.form-control(disabled type="text" value=formNineSavedDetails.lastTaxFine)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू कारवार सूट:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastTaxRelief)

                                                
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील दिवा कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastDivaTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू दिवा कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentDivaTax)
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील आरोग्य कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastArogyaTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू आरोग्य कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentArogyaTax)
                                                

                                                //- New taxes
                                                //- cleaning tax
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील स्वच्छता कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastCleaningTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू स्वच्छता कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentCleaningTax)
                                                
                                                //- fire
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील अग्नी कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastFireblegateTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू अग्नी कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentFireblegateTax)
                                                
                                                //- tree
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील वृक्ष कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastTreeTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू वृक्ष कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentTreeTax)
                                                
                                                //- education
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील शिक्षण कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastEducationTax)
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू शिक्षण कर:
                                                        input.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentEducationTax)
                                                
 
                                                //- new taxes end

                                                tr
                                                    td(width="25%") 
                                                        span.font-weight-bold चेक नं 
                                                        input.form-control(type="text" placeholder="चेक नं" value=(formNineSavedDetails.checkNo ? formNineSavedDetails.checkNo : ""))

                                                - let totalLastSamanyaTax = formNineSavedDetails.lastBuildingTax + formNineSavedDetails.lastTaxFine + formNineSavedDetails.lastDivaTax + formNineSavedDetails.lastArogyaTax + formNineSavedDetails.lastCleaningTax + formNineSavedDetails.lastFireblegateTax + formNineSavedDetails.lastTreeTax + formNineSavedDetails.lastEducationTax
                                                - let totalCurrentSamanyaTax = formNineSavedDetails.currentBuildingTax + formNineSavedDetails.lastTaxRelief + formNineSavedDetails.currentDivaTax + formNineSavedDetails.currentArogyaTax + formNineSavedDetails.currentCleaningTax + formNineSavedDetails.currentFireblegateTax + formNineSavedDetails.currentTreeTax + formNineSavedDetails.currentEducationTax

                                                tr 
                                                    td
                                                        small.font-weight-bold मागील एकूण सामान्य कर:
                                                        input.form-control#totalPreviousSamanyaTax(readonly type="text" value=totalLastSamanyaTax)
                                                    td
                                                        small.font-weight-bold चालू एकूण सामान्य कर:
                                                        input.form-control(readonly type="text" value=totalCurrentSamanyaTax)

                                                - let totalSampurnaTax = totalLastSamanyaTax + totalCurrentSamanyaTax
                                                tr.bg-info
                                                    td.p-2
                                                    td.p-2
                                                        small.font-weight-bold.text-white एकूण सामान्य कर:
                                                        input.form-control(disabled type="text" value=totalSampurnaTax)
                                    
                                    
                                    //- RIGHT COLUMN
                                    .col-lg-6

                                        
                                        //- CURRENT TAx Filled for user => .currentTaxFilling
                                        //- The purpose of this class .currentTaxFilling is to track all the input fields of current Tax and make them readonly=true or readonly false
                                        //- If previous tax is all cleared, then it wont be marked as readonly, but if even if smallest previous amount is pending, then all the current tax input fields will be marked as readonly


                                        table.table.table-bordered.bg-table-on-gray 
                                            tbody
                                                tr
                                                    th(colspan="5").text-center.bg-warning वसुली कर भरा

                                                //- building
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील इमारत कर:
                                                        input#lastBuildingTax.isNaN.form-control(type="text" value="0" data-i="1")
                                                        input#formNineId.form-control(type="hidden" value=formNineSavedDetails.id)
                                                        input#userId.form-control(type="hidden" value=formNineSavedDetails.user_id)

                                                    td(width="25%") 
                                                        small.font-weight-bold चालू इमारत कर:
                                                        input.currentTaxFilling#currentBuildingTax.isNaN.form-control(type="text" value='0')
                                                
                                                //- TAx Fine and relief
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील दंड कर (५%):
                                                        input#lastTaxFine.isNaN.form-control(type="text" value="0")
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू कारवार सूट:
                                                        input.currentTaxFilling#lastTaxRelief.isNaN.form-control(type="text" value="0" )


                                                //- Diva tax
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील दिवा कर:
                                                        input#lastDivaTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू दिवा कर:
                                                        input.currentTaxFilling#currentDivaTax.isNaN.form-control(type="text" value="0")
                                                
                                                //- Arogya
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील आरोग्य कर:
                                                        input#lastArogyaTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू आरोग्य कर:
                                                        input.currentTaxFilling#currentArogyaTax.isNaN.form-control(type="text" value="0")
                                                

                                                //- NEW TAXES 

                                                //- Cleaning
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील स्वच्छता कर:
                                                        input#lastCleaningTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू स्वच्छता कर:
                                                        input.currentTaxFilling#currentCleaningTax.isNaN.form-control(type="text" value="0")

                                                //- Fireblegate
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील अग्नी कर:
                                                        input#lastFireblegateTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू अग्नी कर:
                                                        input.currentTaxFilling#currentFireblegateTax.isNaN.form-control(type="text" value="0")


                                                //- Tree
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील वृक्ष कर:
                                                        input#lastTreeTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू वृक्ष कर:
                                                        input.currentTaxFilling#currentTreeTax.isNaN.form-control(type="text" value="0")

                                                //- Education
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold मागील शिक्षण कर:
                                                        input#lastEducationTax.isNaN.form-control(type="text" value="0" )
                                                    td(width="25%") 
                                                        small.font-weight-bold चालू शिक्षण कर:
                                                        input.currentTaxFilling#currentEducationTax.isNaN.form-control(type="text" value="0")

                                                //- END NEW TAXES

                                                                                               
                                                tr
                                                    td(width="25%") 
                                                        small.font-weight-bold भरणा दिनांक:
                                                        input#bharnaDate.form-control(type="text" placeholder="dd-mm-yyyy" autocomplete="off")
                                                    td(width="25%") 
                                                        small.font-weight-bold अक्षरी भरणा :
                                                        input#amountInWords.form-control(type="text" value="" )

                                                tr
                                                    td(width="25%") 
                                                        span.font-weight-bold चेक नं 
                                                        input#checkNo.form-control(type="text" placeholder="चेक नं")

                                                tr.bg-info
                                                    td.p-2
                                                    td.p-2
                                                        span.font-weight-bold.text-white एकूण वसुली कर:
                                                        input#totalSampurnaTax.form-control(type="text" value="0" readonly name="totalSampurnaTax")

                                        div(class="alert alert-danger mt-3" style="font-size:0.9rem;")
                                            strong लक्षात ठेवा: 
                                            | जर मागील कर बाकी असेल तर आधी तो पूर्ण करा, त्याशिवाय तुम्हाला चालू कर भरणा करता येणार नाही.
                                            br
                                            | मागील कराची रक्कम ₹1000 किंवा त्यापेक्षा कमी असल्यास, ती पूर्ण भरणे आवश्यक आहे.
                                            br
                                            | ₹1000 पेक्षा जास्त असल्यास, किमान 50% रक्कम भरणे आवश्यक आहे.
                                        #saveVasuliDetails.btn.btn-success.float-right वसुली भरणा करा. 
    
    
    
    
    
    script.
        var details = !{taxDetails}[0];
        var user = !{jsUser}[0];
        console.log(user)
    script(src='/asstest/coustom/js/handlers/tax-payer-manager-payment.js')  
    script.
        $(function(){
            $('#bharnaDate').datepicker({
                dateFormat: 'dd-mm-yy'
                })
        })