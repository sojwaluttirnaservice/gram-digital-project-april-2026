                                    input.amountText#lastTaxFine.isNaN.form-control(type="text" value=formNineSavedDetails.lastTaxFine)
                                .col-6 
                                    span.font-weight-bold चालू कारवार सूट:
                                    input.amountText#lastTaxRelief.isNaN.form-control(type="text" value=formNineSavedDetails.lastTaxRelief )


                                .col-6
                                    span.font-weight-bold मागील दिवा कर:
                                    input.amountText#lastDivaTax.isNaN.form-control(type="text" value=formNineSavedDetails.lastDivaTax )
                                .col-6 
