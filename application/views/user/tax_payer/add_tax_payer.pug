    style.
        .error {
            background-color:yellow;
            padding:2px;
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        #tableRow div{
            //- background: #c4c8b4;
            background: #E3E1D9;
            padding: 0.6rem 1rem;
            border: 1px solid white;
        }

        @media (max-width: 768px){
            #tableRow div{
                font-size: 0.9rem;
            }
        }
    script.
        let malNo = !{JSON.stringify(user.feu_malmattaNo)}

        let userId = !{JSON.stringify(user.id)}

        $(() => {
            $('.isNaN').on("input", function(e){
                let val = $(this).val();
                if(isNaN(val)){
                    $(this).val("")
                }else{
                    $(this).val(+val);
                }
            })
        })

body
    include ../include/navs.pug
    .container-fluid.bg-light-gray(style='padding-block: 1rem;')
        .row.justify-content-center(style='gap: 1rem !important;')

            .col-12.text-center.mt-4
                input#homeId-type(type="hidden")
                h4.font-weight-bold नमुना ९ सामान्य करासंदर्भात वसुली फॉर्म (Desktop)

            .col-12.col-md-8
                .card
                    .card-header.font-weight-bold.text-center(style='background: oklch(84.1% 0.238 128.85);') धारकाची माहिती
                    .card-body

                        .row
                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input') अनु / घर क्रमांक
                                    input.form-control-sm.form-control(type='text' disabled value=user.id)

                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input')  मालमत्ता क्र.
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_malmattaNo)

                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input') वार्ड नं
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_wardNo)

                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input') जुना घर क्रमांक
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_homeNo)

                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input') मोबाइल नों.
                                    input.form-control-sm.form-control#feu_mobile_no(type='text' disabled value=user.feu_mobileNo maxlength="10")

                            .col-6.col-md-3
                                .form-group
                                    label.font-weight-bold(for='my-input') आधार क्रं.
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_aadharNo maxlength="12")

                            .col-12.col-md-6
                                .form-group
                                    label.font-weight-bold(for='my-input') मालमत्ता धारकाचे नाव व पत्नीचे नाव
                                    input.form-control-sm.form-control.pay-owner-name(type='text' disabled value=user.feu_ownerName)

                            .col-12.col-md-6
                                .form-group
                                    label.font-weight-bold(for='my-input') भोगवटदाराचे नाव
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_secondOwnerName)

                            .col-12.col-md-6
                                .form-group
                                    label.font-weight-bold(for='my-input') गट क्र./भुमापण क्र. /नगर भामपण क्र
                                    input.form-control-sm.form-control(type='text' disabled value=user.feu_gaatNo)


            .col-12.col-md-11
                .row(style='row-gap: 1rem;')
                    //- left column
                    .col-12.col-md-6
                        .row#tableRow
                            .col-12.text-center.font-weight-bold(style='background: oklch(84.1% 0.238 128.85);') सामान्य कर 

                            //- मागील कर
                            .col-6 
                                span.fw-bold मागील इमारत कर:
                                //- input(type="checkbox" id='resetTaxToZeroSamanyaCheckbox').ml-2
                                //- input(id='previewDataLastBuildingTaxClone' type='hidden' value=formNineSavedDetails.lastBuildingTax)
                                input#previewDataLastBuildingTax.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastBuildingTax )

                            .col-6 
                                span.font-weight-bold चालू इमारत कर:
                                input#previewDataCurrentBuildingTax.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentBuildingTax)

                            .col-6 
                                span.font-weight-bold मागील दंड कर (५%):
                                //- input(id='previewDataLastTaxFineClone' type='hidden' value=formNineSavedDetails.lastTaxFine)
                                input#previewDataLastTaxFine.form-control(disabled type="text" value=formNineSavedDetails.lastTaxFine)
                            .col-6 
                                span.font-weight-bold चालू कारवार सूट:
                                input#previewDataLastTaxRelief.isNaN.form-control(disabled type="text" value=formNineSavedDetails.lastTaxRelief)

                            .col-6 
                                span.font-weight-bold मागील दिवा कर:
