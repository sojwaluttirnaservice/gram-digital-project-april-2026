                                .col-6 
                                    span.font-weight-bold मागील आरोग्य कर:
                                    input.amountText#lastArogyaTax.isNaN.form-control(type="text" value=formNineSavedDetails.lastArogyaTax )
                                .col-6 
                                    span.font-weight-bold चालू आरोग्य कर:
                                    input.amountText#currentArogyaTax.isNaN.form-control(type="text" value=formNineSavedDetails.currentArogyaTax)


                                .col-6 
                                    span.font-weight-bold मागील स्वच्छता कर:
                                    input.amountText#lastCleaningTax.isNaN.form-control( type="text" value=formNineSavedDetails.lastCleaningTax)
                                .col-6 
                                    span.font-weight-bold चालू स्वच्छता कर:
                                    input.amountText#currentCleaningTax.isNaN.form-control( type="text" value=formNineSavedDetails.currentCleaningTax )

                                .col-6 
                                    span.font-weight-bold मागील अग्नी  कर:
                                    input.amountText#lastFireblegateTax.isNaN.form-control( type="text" value=formNineSavedDetails.lastFireblegateTax)
                                .col-6 
                                    span.font-weight-bold चालू अग्नी कर:
                                    input.amountText#currentFireblegateTax.isNaN.form-control( type="text" value=formNineSavedDetails.currentFireblegateTax )

                                .col-6 
                                    span.font-weight-bold मागील वृक्ष कर:
                                    input.amountText#lastTreeTax.isNaN.form-control( type="text" value=formNineSavedDetails.lastTreeTax)
                                .col-6 
                                    span.font-weight-bold चालू वृक्ष कर:
                                    input.amountText#currentTreeTax.isNaN.form-control( type="text" value=formNineSavedDetails.currentTreeTax )

                                .col-6 
                                    span.font-weight-bold मागील शिक्षण कर:
                                    input.amountText#lastEducationTax.isNaN.form-control( type="text" value=formNineSavedDetails.lastEducationTax)

                                .col-6
                                    span.font-weight-bold चालू शिक्षण कर:
                                    input.amountText#currentEducationTax.isNaN.form-control( type="text" value=formNineSavedDetails.currentEducationTax )


                                //- total calculation
                                .col-6(style='background-color:wheat;')
                                    span.font-weight-bold मागील एकूण वसुली कर:
                                    input.amountText#lastTotalVasuliTax.isNaN.form-control(readonly type="text")

                                .col-6(style='background-color:wheat;')
                                    span.font-weight-bold चालू एकूण वसुली कर:
                                    input.amountText#currentTotalVasuliTax.isNaN.form-control(readonly type="text" )


                                .col-6 
                                    span.font-weight-bold भरणा दिनांक:
                                    input#bharnaDate.form-control(type="text" placeholder="DD/MM/YYYY" autocomplete="off")
                                .col-6 
                                    span.font-weight-bold चेक नं 
                                    input#checkNo.form-control(type="text" placeholder="चेक नं")
                                .col-12(colspan="5")
                                    span.font-weight-bold अक्षरी भरणा :
                                    input#amountInWords.form-control(type="text" value="" )
                                .col-12
                                    span.font-weight-bold एकूण वसुली कर:
                                    input#totalSampurnaTax.form-control(type="text" value="0" readonly name="totalSampurnaTax")
                        div
                            button#saveVasuliDetails.btn.btn-success.float-right वसुली जतन करा


    include ../include/payment-type-modal.pug

