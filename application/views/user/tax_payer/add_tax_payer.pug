                                input#previewDataCurrentEducationTax.isNaN.form-control(disabled type="text" value=formNineSavedDetails.currentEducationTax )


                            //- total calculation
                            .col-6(style='background-color:wheat;')

                                - let totalLastSamanyaTax = formNineSavedDetails.lastBuildingTax + formNineSavedDetails.lastTaxFine + formNineSavedDetails.lastDivaTax + formNineSavedDetails.lastArogyaTax + formNineSavedDetails.lastCleaningTax + formNineSavedDetails.lastFireblegateTax + formNineSavedDetails.lastTreeTax + formNineSavedDetails.lastEducationTax
                                span.font-weight-bold मागील एकूण सामान्य कर:
                                input.amountText#lastTotalSamanyaTax.isNaN.form-control(readonly type="text" value= totalLastSamanyaTax)

                            .col-6(style='background-color:wheat;')

                                - let totalCurrentSamanyaTax = formNineSavedDetails.currentBuildingTax + formNineSavedDetails.lastTaxRelief + formNineSavedDetails.currentDivaTax + formNineSavedDetails.currentArogyaTax + formNineSavedDetails.currentCleaningTax + formNineSavedDetails.currentFireblegateTax + formNineSavedDetails.currentTreeTax + formNineSavedDetails.currentEducationTax
                                span.font-weight-bold चालू एकूण सामान्य कर:
                                input.amountText#currentTotalSamanyaTax.isNaN.form-control(readonly type="text" value=totalCurrentSamanyaTax)




                            .col-6 
                                span.font-weight-bold भरणा दिनांक:
                                input.form-control(disabled type="text" placeholder="dd-mm-yyyy" autocomplete="off")
                            .col-6 
                                span.font-weight-bold चेक नं 
                                input.form-control(disabled type="text" placeholder="चेक नं" value=(formNineSavedDetails.checkNo ? formNineSavedDetails.checkNo : ""))
                            .col-12
                                span.font-weight-bold अक्षरी भरणा :
                                input.form-control(disabled type="text" value="" )
                            .col-12
                                span.font-weight-bold एकूण सामान्य कर:
                                - let totalSampurnaTax = totalLastSamanyaTax + totalCurrentSamanyaTax
                                input.form-control(disabled type="text" value=totalSampurnaTax)

                        p#tax-notice.text-danger.fw-bold.d-flex.d-none मागील करभरणा बाकी असल्यास चालू करभरणा करता येणार नाही.   


                    //- right column
                    .col-12.col-md-6
                        table.table.table-bordered.bg-table-on-gray
