    style.
        body{
            
            height:100vh;
        }
        #parentTable{
            border-collapse: 'collapse';
            border: 1px solid black;
            width: 100%;

        }
        tr, td{
            white-space: normal; /* Enable text wrapping */
            word-wrap: break-word; 
        }

        #parentTable tr, 
        #parentTable td{
            border: 1px solid black;  
            padding: 0.3rem;  
            font-size: 0.8rem;
        }

        #childTable{
            width: 100%;
            border: none;
        }

        textarea:focus{
            box-shadow: none;
            border: none;
            //- background-color: grey; 
            resize: none;
        }

        label.error {
            color: red;
            font-size: 0.75rem;
        }

        @media print {
            @page{
                size: A4 landscape;
            }
            #form-sabha-show-form-btn {
                display: none;
            }
            .banner-header{
                display: none;
                background: black;  
            }
            .banner-header{
                display: none !important;
            }
        }

    script.
        let _isEdit = !{JSON.stringify(isEdit)}
    script(src='/asstest/coustom/js/handlers/tharav/masikSabhaTharavManager.js')


body.w-100.p-2
    include ../include/navs.pug


    h4.ml-5.mt-4.text-center
        i.fa.fa-file-zip-o
        | &nbsp;&nbsp;मासिक ठराव यादी
    div.d-inline-block.float-right.mb-2
        a(href="/tharav/new").btn.btn-success.btn-sm.ml-2 नवीन जोडा

    //- .text-end.mx-auto.my-3(style='width:89% !important') 
    //-     button.btn.btn-primary#form-sabha-print-view-btn प्रिंट बघा
    //-     button.btn.btn-primary#form-sabha-show-form-btn फॉर्म बघा

    .table-responsive 
        table.table.table-bordered.text-center.w-75.mx-auto.mt-3
            thead
                tr.bg-primary.text-white
                    th.bg-primary.text-white(width="15%") अनु क्र
                    th.bg-primary.text-white(width='15%') ठराव नाव
                    th.bg-primary.text-white(width="20%") दिनांक
                    th.bg-primary.text-white(width="13%") वेळ
                    th.bg-primary.text-white(width="10%") प्रिंट 
                    th.bg-primary.text-white(width="10%") सुधारणा  
                    th.bg-primary.text-white(width="10%") डिलीट
                    th.bg-primary.text-white(width="14%") सेंड मेसेज 
            tbody#tharavList
                if (tharavList.length == 0)
                    tr.m-0.p-0
                        td(colspan="15").text-center.text-danger यादी रिकामी आहे
                else
                    each value,index in tharavList
                        tr
                            td.bg-transparent #{index+1}
                            td.bg-transparent #{value.sabha_subject} 
                            td.bg-transparent#sabhaDate #{value.sabha_date}
                            td.bg-transparent #{value.sabha_time}
                            td.bg-transparent
                                button.btn.printTharavBtn(data-printId=value.id data-sabhaDate=value.sabha_date) 
                                    i.fa.fa-print.text-primary.hand
                            td.bg-transparent
                                button.editTharavBtn.btn(data-editId=value.id)
                                    i.fa.fa-edit.text-success
                            td.bg-transparent
                                button.btn.deleteTharavBtn(data-deleteId=value.id)
                                    i.fa.fa-trash.text-danger.hand
                            td.bg-transparent
                                button.btn.sendTharavMessageBtn
                                    i.fa.fa-envelope
