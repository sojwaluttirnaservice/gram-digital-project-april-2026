body.back-image
  include ./include/navs.pug
  .container-fluid
    .modal#masterModal(tabindex='-1', role='dialog')
      .modal-dialog(role='document')
        .modal-content
          .modal-header
            h5.modal-title Modal title
            button.close(type='button', data-dismiss='modal', aria-label='Close')
              span(aria-hidden='true') ×
          .modal-body 
              .row
                .col-6.offset-4.mb-3
                  form.form-inline
                    .form-group.mx-sm-3.mb-2
                      input#homeId.form-control(type='number', placeholder='अनु/घर क्रमांक टाका')
                    button#btnGetUserDetails.btn.btn-primary.mb-2(type='submit') माहित पहा
              
              form.row#divUserDetails.d-none
                .col-4
                  .card
                    .card-header.bg-warning.font-weight-bold मालमत्ता माहिती
                    .card-body.row
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') अनु क्रमांक
                          input.myMainId.form-control-sm.form-control(type='text', value="" readonly)
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') घर क्रमांक
                          input.myMainId.form-control-sm.form-control(type='text', value="" readonly)
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') मालमत्ता क्र.
                          input#newMalmattaNo.form-control-sm.form-control(type='text', name='newMalmattaNo')
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') वार्ड नं
                          input#newWardNo.form-control-sm.form-control(type='text', name='newWardNo')
                      .form-group.col-12
                          label.font-weight-bold(for='my-input') जुना घर क्रमांक
                          input#oldHomeNo.form-control-sm.form-control(type='text', name='oldHomeNo')
                .col-8
                  .card
                    .card-header.bg-warning.font-weight-bold मालकाची माहिती
                    .card-body.row
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') मालमत्ता धारकाचे नाव व पत्नीचे नाव
                          input#newOwnerName.form-control-sm.form-control(type='text', name='newOwnerName')
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') भोगवटदाराचे नाव
                          input#newSecondOwnerName.form-control-sm.form-control(type='text', name='newSecondOwnerName')
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') मोबाईल क्रमांक 
                          input#newMobileNo.form-control-sm.form-control(type='text', name='newMobileNo' maxlength="10")
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') आधार क्रं.
                          input#newAadharNo.form-control-sm.form-control(type='text', name='newAadharNo' maxlength="12")
                      .form-group.col-6    
                          label.font-weight-bold(for='my-input') ग्रामपंचायत
                          input#newGramPanchayet.form-control-sm.form-control(type='text', name='newGramPanchayet')
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') गावाचे नाव
                          input#newVillageName.form-control-sm.form-control(type='text', name='newVillageName')
                .col-4.mt-5
                      .card
                        .card-header.bg-warning.font-weight-bold जागेची माहिती
                        .card-body
                          .form-group
                              label.font-weight-bold(for='my-input') गट क्र./भुमापण क्र. /नगर भामपण क्र
                              input#newGaatNo.form-control-sm.form-control(type='text', name='newGaatNo')
                          .form-group
                              label.font-weight-bold(for='my-input') घरकुल असल्यास
                              select#gharkulYojna.form-control(type='text', name='gharkulYojna')
                                each value,index in gharkulYojanaList
                                  option(value=value.id) #{value.text}

                          .form-group
                              label.font-weight-bold(for='my-input') शौच्छालय
                              select#havingToilet.form-control(type='text', name='havingToilet')
                                each value,index in ["होय","नाही"]
                                  option(value=value) #{value}
                .col-4.mt-5
                      .card
                        .card-header.bg-warning.font-weight-bold क्षेत्रफळ माहिती
                        .card-body.row
                          .form-group.col-6
                              label.font-weight-bold(for='my-input') जागेची लांबी (पु./प.)
                              input#newAreaHeight.isNaN.form-control-sm.form-control(type='text', name='newAreaHeight')
                          .form-group.col-6
                              label.font-weight-bold(for='my-input') जागेची रुंदी (उ./द.)
                              input#newAreaWidth.isNaN.form-control-sm.form-control(type='text', name='newAreaWidth')
                          .form-group.col-12    
                              label.font-weight-bold(for='my-input') एकूण जागेचे क्षेत्रफळ (चौ.फुट)
                              input#newTotalArea.form-control-sm.form-control(type='text', name='newTotalArea')
                          .form-group.col-12
                            label.font-weight-bold(for='my-input') एकूण जागेची चौ.मी.
                            input#newTotalAreaSquareMeter.form-control-sm.form-control(type='text', name='newTotalAreaSquareMeter' readonly=true)
                .col-4.mt-5
                  .card
                    .card-header.bg-warning.font-weight-bold दिशा माहिती
                    .card-body.row
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') पूर्वेस
                          input#newEastLandmark.form-control-sm.form-control(type='text', name='newEastLandmark')
                      .form-group.col-6
                          label.font-weight-bold(for='my-input') पश्चिमेस
                          input#newWestLandmark.form-control-sm.form-control(type='text', name='newWestLandmark')
                      .form-group.col-6   
                          label.font-weight-bold(for='my-input') उत्तरेस
                          input#newNorthLandmark.form-control-sm.form-control(type='text', name='newNorthLandmark')
                      .form-group.col-6
                        label.font-weight-bold(for='my-input') दक्षिणेस
                        input#newSouthLandmark.form-control-sm.form-control(type='text', name='newSouthLandmark')
                      .form-group.col-12.mt-4
                        button#moveMore.btn.btn-primary.float-right.ml-3 
                          span.fa.fa-forward.mr-2
                          | नमुना ८ कर दुरीस्ती
                        button#saveNewUserForm.btn.btn-success.float-right
                          span.fa.fa-floppy-o.mr-2
                          | माहिती जतन करा
                               
          .modal-footer.d-none
            button.btn.btn-primary(type='button') Save changes
            button.btn.btn-secondary(type='button', data-dismiss='modal') Close


