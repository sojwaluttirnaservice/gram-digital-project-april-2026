    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    
    .hand:hover{
      background-color:#ecc6db
    }
    @media (min-width: 576px) {
    .modal-dialog { max-width: none; }
      }

      .modal-dialog {
        width: 98%;
