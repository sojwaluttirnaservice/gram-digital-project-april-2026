              .col-8.offset-2.mt-5
                .row
                  .col-6
                    .card
                      .card-body
                        table.table.table-bordered
                          thead
                            tr
                              th.bg-warning.font-weight-bold.text-center कराच्या संदर्भात 
                            tr
                              th.hand.getForm8 
                                span नमुना ८ नोदणी फॉर्म  	
