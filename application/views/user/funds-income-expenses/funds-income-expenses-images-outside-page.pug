extends ../include/index-page-master-layout.pug

block internal_css

block content

    section(class='py-8 md:py-14 bg-gradient-to-b from-sky-50 to-white min-h-screen')

        div(class='container mx-auto px-4')

            //- ===================================================
            //- TOP HEADER
            //- ===================================================
            div(class='max-w-6xl mx-auto mb-8')

                div(class='bg-white rounded-3xl shadow-sm border border-sky-100 overflow-hidden')

                    div(class='p-6 md:p-8')

                        div(class='flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6')

                            //- LEFT
                            div

                                div(class='flex flex-wrap items-center gap-3 mb-3')

                                    span(class='inline-flex items-center px-4 py-1.5 rounded-full bg-sky-100 text-sky-700 text-sm font-semibold')
                                        | #{fundIncomeExpenseDetails.from_year} - #{fundIncomeExpenseDetails.to_year}

                                    if images && images.length > 0
                                        span(class='inline-flex items-center px-4 py-1.5 rounded-full bg-green-100 text-green-700 text-sm font-semibold')
                                            | #{images.length} छायाचित्रे

                                h1(class='text-2xl md:text-3xl font-bold text-gray-800 mb-3')
                                    | #{fundIncomeExpenseDetails.title || 'निधी उत्पन्न व खर्चाचा माहिती'}

                                p(class='text-gray-600 leading-relaxed max-w-3xl')
                                    | सदर आर्थिक वर्षासाठी निधी उत्पन्न व खर्चाचा संबंधित छायाचित्रे व माहिती खाली उपलब्ध आहे.


                            //- RIGHT
                            div(class='flex flex-wrap items-center gap-3')

                                a(
                                    class='inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-green-600 hover:bg-green-700 text-white font-medium transition'
                                    href=`/uploads/docs/funds/docs/${fundIncomeExpenseDetails.uploaded_document}`
                                    target='_blank'
                                )
                                    i(class='fa fa-file-pdf-o')
                                    | दस्तऐवज पहा

                                a(
                                    class='inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-sky-600 hover:bg-sky-700 text-white font-medium transition'
                                    href='/fund-income-expenses/list'
                                )
                                    i(class='fa fa-arrow-left')
                                    | मागे जा



            //- ===================================================
            //- GALLERY
            //- ===================================================
            if images && images.length > 0

                div(class='max-w-6xl mx-auto')

                    div(class='grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6')

                        each image, index in images

                            a(
                                class='group bg-white rounded-3xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition duration-300'
                                href=`/uploads/images/funds/images/${image.uploaded_image}`
                                target='_blank'
                            )

                                //- IMAGE
                                div(class='relative overflow-hidden')

                                    img(
                                        class='w-full h-64 object-cover group-hover:scale-110 transition duration-500'
                                        src=`/uploads/images/funds/images/${image.uploaded_image}`
                                        alt=image.title
                                    )

                                    div(class='absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent')

                                    div(class='absolute top-4 right-4')

                                        div(class='w-10 h-10 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white')
                                            i(class='fa fa-expand')



                                //- CONTENT
                                div(class='p-5')

                                    div(class='flex items-start justify-between gap-3 mb-3')

                                        h3(class='text-lg font-semibold text-gray-800 line-clamp-2')
                                            | #{image.title}

                                        span(class='shrink-0 w-8 h-8 rounded-full bg-sky-100 text-sky-700 flex items-center justify-center text-sm font-bold')
                                            | #{index + 1}

                                    if image.desc

                                        p(class='text-sm text-gray-600 leading-relaxed line-clamp-3')
                                            | #{image.desc}

                                    else

                                        p(class='text-sm text-gray-400 italic')
                                            | वर्णन उपलब्ध नाही



            else

                div(class='max-w-4xl mx-auto')

                    div(class='bg-white rounded-3xl shadow-sm border border-dashed border-gray-300 p-14 text-center')

                        div(class='w-24 h-24 mx-auto rounded-full bg-sky-100 text-sky-700 flex items-center justify-center mb-6')
                            i(class='fa fa-image text-4xl')

                        h3(class='text-2xl font-bold text-gray-800 mb-3')
                            | छायाचित्रे उपलब्ध नाहीत

                        p(class='text-gray-500 max-w-xl mx-auto')
                            | सदर निधी उत्पन्न व खर्चाचा तपशीलासाठी अद्याप कोणतीही छायाचित्रे अपलोड केलेली नाहीत.