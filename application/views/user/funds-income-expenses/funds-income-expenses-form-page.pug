//- =======================================================
//- MASTER LAYOUT
//- =======================================================
extends ../include/internal-gp-master-layout.pug

block custom_js
    script(src='/asstest/coustom/js/handlers/fund-income-expenses/fund-income-expenses-form-handler.js')

block content

    -
        const startYear = 2015;
        const endYear = 2040;

    div.container-fluid.mt-4

        .row.justify-content-center

            .col-12.col-xl-8

                //- ===================================================
                //- HEADER
                //- ===================================================
                .card.shadow-sm.mb-4(style="background: oklch(86.9% 0.022 252.894);")

                    .card-body.d-flex.flex-column.flex-md-row.align-items-center.justify-content-between.gap-3

                        div
                            h4.mb-1
                                i.fa.fa-money.me-2
                                | निधी उत्पन्न व खर्चाचा तपशील नोंदणी

                            p.text-muted.mb-0
                                | वित्तीय वर्षानुसार निधी उत्पन्न व खर्चाचा माहिती भरा

                        div
                            a.btn.btn-secondary.btn-sm(href='/fund-income-expenses')
                                i.fa.fa-arrow-left.me-1
                                | मागे जा



                //- ===================================================
                //- FORM CARD
                //- ===================================================
                .card.shadow-sm

                    .card-header
                        h5.mb-0
                            i.fa.fa-plus-circle.me-2
                            | नवीन नोंद

                    .card-body

                        form#fund-income-expense-form(method='POST' enctype='multipart/form-data')

                            .row

                                //- =====================================
                                //- FROM YEAR
                                //- =====================================
                                .col-md-6.mb-3

                                    .form-group

                                        label.form-label(for='from_year')
                                            | वित्तीय वर्ष सुरुवात
                                            span.text-danger *

                                        select.form-select(name='from_year' id='from_year' required)

                                            option(value='') -- वर्ष निवडा --

                                            each year in Array.from({ length: endYear - startYear + 1 }, (_, i) => startYear + i)

                                                option(value=year)
                                                    | #{year}



                                //- =====================================
                                //- TO YEAR
                                //- =====================================
                                .col-md-6.mb-3

                                    .form-group

                                        label.form-label(for='to_year')
                                            | वित्तीय वर्ष समाप्त
                                            span.text-danger *

                                        select.form-select(name='to_year' id='to_year' required)

                                            option(value='') -- वर्ष निवडा --

                                            each year in Array.from({ length: endYear - startYear + 1 }, (_, i) => startYear + i)

                                                option(value=year)
                                                    | #{year}



                                //- =====================================
                                //- TITLE
                                //- =====================================
                                .col-md-12.mb-3

                                    .form-group

                                        label.form-label(for='title')
                                            | शीर्षक

                                        input.form-control(type='text' id='title' name='title' placeholder='शीर्षक प्रविष्ट करा' maxlength='200')



                                //- =====================================
                                //- DOCUMENT
                                //- =====================================
                                .col-md-12.mb-4

                                    .form-group

                                        label.form-label(for='document')
                                            | दस्तऐवज अपलोड करा
                                            span.text-danger *

                                        input.form-control(type='file' id='document' name='document' accept='.pdf,.doc,.docx,.jpg,.jpeg,.png' required)

                                        small.text-muted
                                            | PDF, DOC, DOCX, JPG, PNG फाइल स्वीकारल्या जातील



                            //- =========================================
                            //- SUBMIT BUTTON
                            //- =========================================
                            .d-flex.justify-content-end.mt-3

                                button.btn.btn-primary(type='submit' id='save-fund-income-expense-btn')
                                    i.fa.fa-save.me-1
                                    | जतन करा