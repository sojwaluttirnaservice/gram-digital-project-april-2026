                                                    td.text-center.p-1 #{Math.round(row.last)}
                                                    - totalCurrent += Math.round(row.current) 
                                                    td.text-center.p-1 #{Math.round(row.current)}
                                                    - totalBoth += Math.round(row.last + row.current)
                                                    td.text-center.p-1 #{Math.round(row.last + row.current)}

