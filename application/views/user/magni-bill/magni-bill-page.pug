        button(type='button' id='print-bank-qr-code-samanya-kar-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
                p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center") 
                    i.fa.fa-qrcode.fa-2x
                    small Bank Qr Code सामान्य कर मागणी बिल 

        button(type='button' id='print-bank-qr-code-magni-bill-other-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
