    title मागणी बिल प्रिंट
    style.

        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#fffd70 !important;
        }
        .bg-warning{
            background-color:#fffd70 !important;
        }
        .hand:hover{
            background-color:#ecc6db
        }
        @media (min-width: 576px) {
            .modal-dialog { max-width: none; }
        }
        .modal-dialog {
            width: 98%;
            height: 92%;
            padding: 0;
        }

body.back-image
    include ../include/navs.pug


    .modal#yearModal1(tabindex='-1' role='dialog')
        .modal-dialog.modal-dialog-centered(role='document' style="width:70% !important; margin: auto auto;")
            .modal-content
                .modal-header
                    h5.modal-title
                    button.close(type='button' data-dismiss='modal' aria-label='Close')
                        span(aria-hidden='true') ×
                .modal-body 
                    .row.justify-content-center
                        .col-12.col-md-3
                            .form-group.mb-2
                                input#date11.form-control(placeholder="---- पासून वर्ष ----")
                        .col-12.col-md-1
                            .form-group.mt-2.text-center
                                span.font-weight-bold ते
                        .col-12.col-md-3
                            .form-group.mb-2
                                input#date21.form-control(placeholder="---- पासून वर्ष ----")
                        .col-12.col-md-1
                            .form-group.mt-2.text-center
                                span.font-weight-bold आणि
                        .col-12.col-md-3
                            .form-group.mb-2
                                input#date31.form-control(placeholder="--- दिनांक ---")

                        .col-12
                            .form-group.mb-2(style='width: 14rem; margin-inline: auto;')
                                select.form-control(id='printFormat')
                                    option(value='old' selected) Old Print Format
                                    option(value='new') New Print Format

                        .col-12
                            center
                                button#print-btn.btn.btn-primary.mb-2(type='submit') प्रिंट क्रमांक

    .row.d-flex.justify-content-center
        .col-6
            h5.heading-1 मागणी बिल प्रिंट 


    .row.justify-content-center

        button(type='button' id='print-samanya-kar-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
                p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center") 
                    i.fa.fa-file-text-o.fa-2x
                    small  सामान्य कर मागणी बिल 

        button(type='button' id='print-watertax-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
                p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center") 
                    i.fa.fa-tint.fa-2x
                    small पाणी कर मागणी बिल 

        button(type='button' id='print-magni-bill-other-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
                p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center") 
                    i.fa.fa-files-o.fa-2x
