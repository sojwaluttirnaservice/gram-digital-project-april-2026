        button(type='button' id='print-9-c-bank-magni-bill-btn').col-5.col-md-2.p-2.box.box--white
            .commonModalFrom(class="d-flex justify-content-center align-items-center") 
                p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center") 
                    i.fa.fa-bank.fa-2x
                    small 9 क bank मागणी बील


        button(type='button' id='print-9-c-magni-bill-btn').col-5.col-md-2.p-2.box.box--white
