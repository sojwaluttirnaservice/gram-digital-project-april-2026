  style.
    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    body{
      
      height:100vh;
    }

    @media (max-width: 768px){
      tr,td {
        font-size: 0.8rem !important;
      }
      td {
        vertical-align: middle;
      }
    }


    @media (min-width: 576px) {
    .modal-dialog { max-width: none; }
      }
      .modal-dialog {
        width: 98%;
        height: 92%;
        padding: 0;
      }

body
  include ../include/navs.pug
  .modal#marriageModel(tabindex='-1' role='dialog')
    .modal-dialog(role='document' style="width:60% !important;")
      .modal-content
        .modal-header
          h5.modal-title
          button.close(type='button' data-dismiss='modal' aria-label='Close')
            span(aria-hidden='true') ×
        .modal-body 
          .row
            .col-3
            .col-3
              .form-group.mb-2
                input#printPlace.form-control(placeholder="---- ठिकाण ----")
            .col-1
              .form-group.mt-2.text-center
                span.font-weight-bold आणि
            .col-3
              .form-group.mb-2
                input#date31.form-control(placeholder="--- दिनांक ---")
                input#idData.form-control(type="hidden" placeholder="--- दिनांक ---")
                input#p_type.form-control(type="hidden" placeholder="--- दिनांक ---")
            .col-12
              center
                button#btnPrintCertificate.btn.btn-primary.mb-2(type='submit') प्रिंट करा

  .container-fluid
    .row.justify-content-center
      .col-12.mt-3.text-center
        h4.heading-1 प्रमाणपत्र नोंदणी यादी
        a(href="certificate/add-new").float-right.btn.btn-primary.mr-2
          span.fa.fa-plus
          |  नवीन नोंदणी करा 
        button.btn.btn-primary.mr-2.float-right( onclick='history.back();') Back
      .col-11
        .table-responsive
          table.table.table-bordered.text-center
            thead
              tr.bg-info.text-white
                th(width="5%") जा.क्र
                th(width="15%") आधार क्र
                th(width="25%") नाव
                th(width="13%") गाव
                th(width="13%") तालुका
                th(width="13%") जिल्हा
                th(width="7%") थकबाकी
                th(width="10%") निराधार
                th(width="5%") काढा
                th(width='5%') एडीट
            tbody#marriageList
              if(list.length == 0)
                tr
                  td(colspan="15").text-center.text-danger प्रमाणपत्र यादी रिकामी आहे
              else
                each value,index in list
                  tr
                    td #{index + 1}
                    td #{value.certificateAadharE}
                    td #{value.certificateHolderNameE}
                    td #{value.certificateVillageE}
                    td #{value.certificateTalukaE}
                    td #{value.certificateDistE}
                    td
                      span.fa.fa-print.text-success.hand.print-certificate-button(data-id = value.id data-type="1")
                    td
                      span.fa.fa-print.text-primary.hand.print-certificate-button(data-id = value.id data-type="2")
                    td 
                      span.removeCertificate.fa.fa-trash.text-danger.hand(data-id = value.id)
                      type
                    td 
                      button.btn.editCertificate.fa.fa-edit.text-primary.hand(data-id=value.id type='button')



