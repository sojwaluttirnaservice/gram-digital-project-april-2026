doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title #{title}

        script(src="/asstest/coustom/css/tailwind.js")

        link(rel="preconnect" href="https://fonts.googleapis.com")
        link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin="")
        link(href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Marathi&family=Yatra+One&display=swap" rel="stylesheet")

        script(src='/asstest/plugins/qrcodejs/qrcode.min.js')

        style.
            table { border-collapse: collapse; width: 100%; }
            td, th {
                padding: 0.3rem;
                border: 1px solid #000;
                font-size: 0.75rem;
                vertical-align: top;
            }

            @media print {
                @page { size: landscape; margin: 10mm; }
                .hide-print { display: none !important; }
                * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
                thead { display: table-header-group; }
                tr { break-inside: avoid; }
            }

            .qrcode {
                width: 30mm;
                height: 30mm;
            }

    body
        div#toolbar.hide-print(style="position:fixed; top:25px; right:10px; z-index:9999; display:flex; gap:10px; align-items:center;")

            - let isAll = (!hasAabhaCard && !hasAyushmanCard && !hasDownloadedApp)
            - let isAabha = (hasAabhaCard == '1')
            - let isAyushman = (hasAyushmanCard == '1')
            - let isMeriApp = (hasDownloadedApp == 'meri_gram_panchayat')
            - let isDecisionApp = (hasDownloadedApp == 'panchayat_decision')
            - let isGramSamvad = (hasDownloadedApp == 'gram_samvad')

            select#nagrikFilter.form-select(style='width:220px; padding: 1rem;')

                option(value='' selected=isAll) सर्व (All) #{isAll ? `(${nagrikList.length})` : ''}

                option(value='hasAabhaCard=1' selected=isAabha) आभा कार्ड आहे #{isAabha ? `(${nagrikList.length})` : ''}

                option(value='hasAyushmanCard=1' selected=isAyushman) आयुष्मान कार्ड आहे #{isAyushman ? `(${nagrikList.length})` : ''}

                option(value='hasDownloadedApp=meri_gram_panchayat' selected=isMeriApp) मेरी पंचायत ॲप #{isMeriApp ? `(${nagrikList.length})` : ''}

                option(value='hasDownloadedApp=panchayat_decision' selected=isDecisionApp) पंचायत निर्णय ॲप #{isDecisionApp ? `(${nagrikList.length})` : ''}

                option(value='hasDownloadedApp=gram_samvad' selected=isGramSamvad) ग्राम संवाद ॲप #{isGramSamvad ? `(${nagrikList.length})` : ''}

            button(onclick="window.print()" style="padding:6px 12px; background:#2563eb; color:white; border:none; border-radius:4px; cursor:pointer")
                | Print

        if !(nagrikList && nagrikList.length)
            h2.text-center.text-red-500.mt-10 No records found

        else
            #print
                table
                    thead
                        tr
                            th(colspan='10')
                                b ग्रामपंचायत सदस्य यादी

                        tr
                            th अ. क्र.
                            th ID
                            th नाव / पत्ता / संपर्क
                            th मोबाईल
                            th ई-मेल
                            th जन्म दिनांक
                            th व्यवसाय
                            th रक्त गट
                            th गाव
                            th QR Code

                    tbody
                        each n, i in nagrikList
                            tr
                                td #{i + 1}
                                td #{n.id}

                                td
                                    div
                                        b नाव: 
                                        | #{n.fName}
                                    if n.fVillage
                                        div
                                            b गाव:
                                            | #{n.fVillage}

                                td
                                    div #{n.fMobile}
                                    if n.fAltMobile
                                        div #{n.fAltMobile}

                                td #{n.fEmail}
                                td #{n.dob}
                                td #{n.fOccupation}
                                td #{n.fBloodGroup}
                                td #{n.fVillage}

                                // QR CODE (UNCHANGED LOGIC)
                                td
                                    div(class='flex justify-center p-1')
                                        - let qrId = `qrcode-${n.id}`
                                        div.qrcode(id=qrId)

script.
    (function(){
        let _nagrikList = !{JSON.stringify(nagrikList)}

        if(_nagrikList){
            _nagrikList.forEach((_nagrik) =>{
                generateQRCode(_nagrik.id);
            })
        }

        function generateQRCode(nagrikId){
            let qrUrl = window.location.origin + "/nagrik/n/" + nagrikId;
            new QRCode(document.getElementById(`qrcode-${nagrikId}`), qrUrl)
        }
    })()

script.

    const select = document.getElementById("nagrikFilter");

        // Set selected value from URL
        const params = new URLSearchParams(window.location.search);

        if (params.has("hasAabhaCard")) {
            select.value = "hasAabhaCard=1";
        }

        if (params.has("hasAyushmanCard")) {
            select.value = "hasAyushmanCard=1";
        }

        if (params.has("hasDownloadedApp")) {
            select.value = "hasDownloadedApp=" + params.get("hasDownloadedApp");
        }

        // On change → merge params (DO NOT REMOVE EXISTING ONES)
        select.addEventListener("change", function () {

            const url = new URL(window.location.href);

            // only remove filter params (NOT your yearToYear, type, etc.)
            url.searchParams.delete("hasAabhaCard");
            url.searchParams.delete("hasAyushmanCard");
            url.searchParams.delete("hasDownloadedApp");

            if (this.value) {
                const [key, val] = this.value.split("=");
                url.searchParams.set(key, val);
            }

            window.location.href = url.toString();
        });
