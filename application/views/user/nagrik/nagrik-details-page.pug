extends ../include/index-page-master-layout.pug

block content

    - const maskMobile = (mobile) => !mobile ? "-" : mobile.toString().slice(0, 2) + "XXXXXX" + mobile.toString().slice(-2);
    - const maskAadhar = (aadhar) => !aadhar ? "-" : "XXXX-XXXX-" + aadhar.toString().replace(/\D/g, "").slice(-4);

    section(class='bg-gray-50 min-h-screen py-8 md:py-14')

        .max-w-5xl.mx-auto.px-4

            if !nagrik

                div(class='bg-white rounded-2xl shadow p-10 text-center text-red-500 text-lg font-semibold')
                    i(class='fa-solid fa-circle-exclamation mr-2')
                    | कोणतीही माहिती उपलब्ध नाही.

            else

                // HEADER
                div(class='bg-white rounded-2xl shadow-lg overflow-hidden')

                    div(class='bg-gradient-to-r from-sky-700 to-green-700 px-6 py-6 text-white')

                        div(class='flex flex-col md:flex-row md:items-center gap-5')

                            div

                                if nagrik.fImage
                                    img(src=`${imageBaseUrl}/${nagrik.fImage}` alt=nagrik.fName class='w-28 h-28 rounded-full object-cover border-4 border-white shadow' onerror='this.src="/img/fallback/default-avatar-fallback-img.jpg"')
                                else
                                    div(class='w-28 h-28 rounded-full bg-white/20 flex items-center justify-center text-4xl font-bold')
                                        = nagrik.fName ? nagrik.fName.charAt(0) : "N"

                            div(class='flex-1')

                                h1(class='text-2xl md:text-3xl font-bold')
                                    = nagrik.fName

                                p(class='mt-2 text-blue-100')
                                    i(class='fa-solid fa-users mr-2')
                                    | ग्रामपंचायत सदस्य माहिती

                                div(class='mt-4 flex flex-wrap gap-3')

                                    if nagrik.fVillage
                                        span(class='bg-white/20 px-3 py-1 rounded-full text-sm')
                                            i(class='fa-solid fa-location-dot mr-2')
                                            | #{nagrik.fVillage}

                                    if nagrik.fOccupation
                                        span(class='bg-white/20 px-3 py-1 rounded-full text-sm')
                                            i(class='fa-solid fa-briefcase mr-2')
                                            | #{nagrik.fOccupation}

                                    if nagrik.fBloodGroup
                                        span(class='bg-red-500/80 px-3 py-1 rounded-full text-sm')
                                            i(class='fa-solid fa-droplet mr-2')
                                            | #{nagrik.fBloodGroup}

                // CONTENT
                div(class='grid grid-cols-1 md:grid-cols-2 gap-6 mt-8')

                    // PERSONAL DETAILS
                    div(class='bg-white rounded-2xl shadow p-6')

                        h2(class='text-lg font-bold text-gray-800 border-b pb-3 mb-5')
                            i(class='fa-solid fa-user mr-2 text-blue-600')
                            | वैयक्तिक माहिती

                        .space-y-4

                            div
                                p(class='text-sm text-gray-500')
                                    i(class='fa-solid fa-id-card mr-2')
                                    | सदस्य ID
                                p(class='font-semibold text-gray-800')
                                    = nagrik.id

                            div
                                p(class='text-sm text-gray-500')
                                    i(class='fa-solid fa-address-card mr-2')
                                    | आधार क्रमांक
                                p(class='font-semibold text-gray-800')
                                    = maskAadhar(nagrik.fAadhar)

                            div
                                p(class='text-sm text-gray-500')
                                    i(class='fa-solid fa-phone mr-2')
                                    | मोबाईल क्रमांक
                                p(class='font-semibold text-gray-800')
                                    = maskMobile(nagrik.fMobile)

                            if nagrik.fAltMobile
                                div
                                    p(class='text-sm text-gray-500')
                                        i(class='fa-solid fa-mobile-screen mr-2')
                                        | पर्यायी मोबाईल
                                    p(class='font-semibold text-gray-800')
                                        = maskMobile(nagrik.fAltMobile)

                            if nagrik.fEmail
                                div
                                    p(class='text-sm text-gray-500')
                                        i(class='fa-solid fa-envelope mr-2')
                                        | ई-मेल
                                    p(class='font-semibold text-gray-800 break-all')
                                        = nagrik.fEmail

                            if nagrik.fDob
                                div
                                    p(class='text-sm text-gray-500')
                                        i(class='fa-solid fa-cake-candles mr-2')
                                        | जन्म दिनांक
                                    p(class='font-semibold text-gray-800')
                                        | #{nagrik.dob != '00/00/0000' ? nagrik.dob : '-'}

                            if nagrik.fVillage
                                div
                                    p(class='text-sm text-gray-500')
                                        i(class='fa-solid fa-location-dot mr-2')
                                        | गाव
                                    p(class='font-semibold text-gray-800')
                                        = nagrik.fVillage

                            if nagrik.fOccupation
                                div
                                    p(class='text-sm text-gray-500')
                                        i(class='fa-solid fa-briefcase mr-2')
                                        | व्यवसाय
                                    p(class='font-semibold text-gray-800')
                                        = nagrik.fOccupation

                    // GOVT SERVICES
                    div(class='bg-white rounded-2xl shadow p-6')

                        h2(class='text-lg font-bold text-gray-800 border-b pb-3 mb-5')
                            i(class='fa-solid fa-shield-heart mr-2 text-green-600')
                            | शासकीय सेवा व ॲप्स

                        .space-y-5

                            if nagrik.has_aabha_card === "YES"

                                div(class='border rounded-xl p-4 bg-blue-50 border-blue-200')

                                    div(class='flex items-center justify-between')

                                        h3(class='font-semibold text-blue-800')
                                            i(class='fa-solid fa-heart-pulse mr-2')
                                            | आभा कार्ड

                                        span(class='bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full')
                                            i(class='fa-solid fa-check mr-1')
                                            | उपलब्ध

                                    if nagrik.aabha_card_number
                                        p(class='mt-3 text-gray-700')
                                            b क्रमांक:
                                            |  XXXX XXXX #{nagrik.aabha_card_number.slice(-4)}

                            if nagrik.has_ayushman_card === "YES"

                                div(class='border rounded-xl p-4 bg-green-50 border-green-200')

                                    div(class='flex items-center justify-between')

                                        h3(class='font-semibold text-green-800')
                                            i(class='fa-solid fa-notes-medical mr-2')
                                            | आयुष्मान कार्ड

                                        span(class='bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full')
                                            i(class='fa-solid fa-check mr-1')
                                            | उपलब्ध

                                    if nagrik.ayushman_card_number
                                        p(class='mt-3 text-gray-700')
                                            b क्रमांक:
                                            |  XXXX XXXX #{nagrik.ayushman_card_number.slice(-4)}

                                    if nagrik.ayushman_bharat_yojana_name
                                        p(class='mt-2 text-gray-700')
                                            b योजना:
                                            |  #{nagrik.ayushman_bharat_yojana_name}

                            div(class='space-y-3')

                                h3(class='font-semibold text-gray-800')
                                    i(class='fa-solid fa-mobile-screen-button mr-2')
                                    | डाउनलोड केलेली ॲप्स

                                if nagrik.has_downloaded_meri_gram_panchayat_app === "YES"
                                    div(class='flex items-center gap-3 bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3')
                                        i(class='fa-solid fa-circle-check text-green-600 text-lg')
                                        span मेरी ग्राम पंचायत ॲप

                                if nagrik.has_downloaded_panchayat_decision_app === "YES"
                                    div(class='flex items-center gap-3 bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3')
                                        i(class='fa-solid fa-circle-check text-green-600 text-lg')
                                        span पंचायत निर्णय ॲप

                                if nagrik.has_downloaded_gram_samvad_app === "YES"
                                    div(class='flex items-center gap-3 bg-indigo-50 border border-indigo-200 rounded-lg px-4 py-3')
                                        i(class='fa-solid fa-circle-check text-green-600 text-lg')
                                        span ग्राम संवाद ॲप

                                if nagrik.has_downloaded_meri_gram_panchayat_app !== "YES" && nagrik.has_downloaded_panchayat_decision_app !== "YES" && nagrik.has_downloaded_gram_samvad_app !== "YES"
                                    div(class='text-gray-500 text-sm')
                                        i(class='fa-solid fa-circle-info mr-2')
                                        | कोणतेही ॲप डाउनलोड केलेले नाही.

                div(class='text-center mt-10 text-sm text-gray-500')
                    i(class='fa-regular fa-copyright mr-1')
                    | ग्रामपंचायत सदस्य माहिती प्रणाली