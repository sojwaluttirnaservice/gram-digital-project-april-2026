            img(src="/print/certificates/open-data.png" style="height: 3.4rem; width: auto; object-fit: ;")
            img(src="/print/certificates/my-gov.jpg" style="height: 3.4rem; width: auto; object-fit: ;")
            img(src="/print/certificates/digital-india.jpg" style="height: 3.4rem; width: auto; object-fit: ;")

