doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title पाणी कर भरणा

        script(src='/asstest/coustom/css/tailwind.js')


        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Marathi:ital@0;1&family=Yatra+One&display=swap" rel="stylesheet">

        script(src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" integrity="sha512-GsLlZN/3F2ErC5ifS5QtgpiJtWd43JWSuIgh7mbzZ8zBps+dvLusV+eNQATqgA/HdeKFVgA5v3S/cIrLF7QnIg==" crossorigin="anonymous" referrerpolicy="no-referrer")

        script.
            document.addEventListener('DOMContentLoaded', function(){
                const downloadPdf = () => {
                    const element = document.querySelector('#print');
                    const options = {
                        margin: [0.1, 0.1, 0.1, 0.1],
                        filename: 'form8-receipt.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2, useCORS: true, scrollY: 0 },
                        jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
                    };
                    html2pdf().set(options).from(element).save();
                }
                const downloadPdfBtn = document.getElementById('download-pdf-btn');
                if (downloadPdfBtn) {
                    downloadPdfBtn.addEventListener('click', downloadPdf);
                }
            })

        style.
            table {
                border-collapse: collapse;
            }
            td, th {
                padding: 0.2rem;
                border: 1px solid #f472b6;
            }
            @media print {
                .hide-print {
                    display: none;
                }

                .my-print{
                    width: 210mm;
                    height: 298mm;
                }
            }


            .tiro-devanagari-marathi-regular {
                font-family: "Tiro Devanagari Marathi", serif;
                font-weight: 400;
                font-style: normal;
            }

            .tiro-devanagari-marathi-regular-italic {
                font-family: "Tiro Devanagari Marathi", serif;
                font-weight: 400;
                font-style: italic;
            }


    body(class="bg-gray-100 text-gray-800")

        - var date = new Date();
        - date1 = waterTax.myDate
        - year = date.getFullYear()


        div.hide-print

            div(class="fixed top-[45%] right-[2%] flex flex-col gap-2 z-50")
                button(class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded shadow-md" onclick="window.print()") Print
                button(class="bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2 rounded shadow-md" id="download-pdf-btn") Download

        #print.tiro-devanagari-marathi-regular
            div(class="my-print border border-gray-500 bg-white/90 p-4 mt-4 mb-4 mx-auto relative" style="width:7.6in; height:11.3in;")

                div(class='absolute top-[10%] z-[-5] w-[86%]')
                    img(src='/img/background/bg-tricolor.png' class='w-full')

                div(class='absolute bottom-[10px] z-[-5] w-[95%]')
                    img(src='/img/background/clean-india.jpg' class='w-full')

                div(class="border-b pb-2 mb-2")
                    div(class="grid grid-cols-9 gap-4 items-center")
                        div(class="col-span-2 flex justify-center items-center")
                            div(class="w-20 h-20 flex items-center justify-center text-xs font-bold")
                                img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")

                        div(class="col-span-5 text-center")
                            p(class="text-2xl font-semibold underline underline-offset-4")
                                span ग्रामपंचायत 
                                span.text-rose-800.font-bold #{gp.gp_name}
                            p(class='text-base')
                                span पं. स. 
                                span.font-bold #{gp.gp_taluka}, 
                                span जि. 
                                span.font-bold #{gp.gp_dist}
                            p(class="text-xs font-semibold") महा.प्रा.पं.लेखा संहिता २०११ (नियम ३२(५) पहा)

                            p(class="text-base font-semibold")
                                span.text-pink-900 पाणी कर 
                                span व 
                                span.text-pink-900 फी 
                                span बाबत पावती
                            p(class="text-lg font-bold tracking-wide underline underline-offset-4 text-blue-700") Payment Receipt

                        div(class="col-span-2 flex justify-center items-center")
                            div(class="w-20 h-20 flex items-center justify-center text-xs font-bold")
                                img(class='w-20 h-20' src='/new-gp-page/main-page/files/qr-codes/' + qrCodes.bank_qr_code_water_image_name)


                .px-2
                    .space-y-1

                        //- .grid.grid-cols-4.text-sm.text-gray-700.font-medium.border.rounded
                            div.p-2.border-r पुरवठा क्रमांक
                            div.p-2.border-r पावती क्रमांक
                            div.p-2.border-r जुना मालमत्ता क्र.
                            div.p-2.border-r जुना संगणक क्र. -


                        p.border.p-2.text-sm.font-medium.primary मालमत्ता धारकाचे नाव: 
                            span.font-bold #{form8UserData.feu_ownerName}

                        //- .grid.grid-cols-3.text-sm.text-gray-700.font-medium.border.rounded
                            div.p-2.border-r वार्ड क्रमांक : #{form8UserData.feu_wardNo ? form8UserData.feu_wardNo : '-'}
                            div.p-2.border-r मालमत्ता क्रमांक : 
                                span.font-bold #{form8UserData.feu_malmattaNo}#{form8UserData.feu_oblik_malmatta_id && form8UserData.feu_oblik_malmatta_id !== 0 && form8UserData.feu_oblik_malmatta_id !== '-' ? '/' + form8UserData.feu_oblik_malmatta_id : ''}

                            //- div.p-2.border-r भाग क्रमांक.
                            //- div.p-2.border-r UPIC ID : 

                            div.p-2 पत्ता: ग्रामपंचायत 
                                span.font-bold #{gp.gp_name}

                        .grid.grid-cols-6.text-sm.text-gray-700.font-medium.border.rounded
                            div.p-2.border-r.col-span-1 वार्ड क्र. : #{form8UserData.feu_wardNo ? form8UserData.feu_wardNo : '-'}
                            div.p-2.border-r.col-span-1 मालमत्ता क्र. : 
                                span.font-bold #{form8UserData.feu_malmattaNo}#{form8UserData.feu_oblik_malmatta_id && form8UserData.feu_oblik_malmatta_id !== 0 && form8UserData.feu_oblik_malmatta_id !== '-' ? '/' + form8UserData.feu_oblik_malmatta_id : ''}

                            //- div.p-2.border-r भाग क्रमांक.
                            //- div.p-2.border-r UPIC ID : 

                            div.p-2.border-r.col-span-2 Transaction No : 
                                span.font-bold #{transactionNumber && transactionNumber != '' ? transactionNumber : (paymentHistory && paymentHistory.length > 0 && paymentHistory[paymentHistory.length - 1] ? paymentHistory[paymentHistory.length - 1].transaction_number : '-')}

                            div.p-2.col-span-2 पत्ता: ग्रामपंचायत 
                                span.font-bold #{gp.gp_name}                        

                        .grid.grid-cols-2.border.text-sm
                            div.p-2.font-medium भोगवटदाराचे नाव : 
                                span.font-bold #{form8UserData.feu_secondOwnerName}


                        //- .grid.grid-cols-2.border.text-sm
                        //- div.p-2 Transaction Id :
                            span.font-bold -

                        p.border.p-2.text-sm श्री/श्रीमती 
                            span.font-bold #{form8UserData.feu_ownerName} 
                            span यांच्याकडून सन 
                            span.font-bold #{year} - #{year + 1} 
                            span या वर्षासाठी नळ क्रमांक 
                            span.font-bold #{form8UserData.feu_malmattaNo}
                            span , बील क्रमांक 
                            span.font-bold #{waterTax.id} 
                            span बाबत पुढील सामान्य कराची रक्कम प्राप्त झाली आहे.

                .pt-4.px-4
                    table.table-auto.w-full.text-sm.border.border-pink-300
                        thead.bg-pink-100.text-pink-800
                            tr
                                th.p-2.text-center(width="10%") अ. क्र.
                                th.p-2.text-center(width="30%") कराचे नाव (रू)
                                th.p-2.text-center(width="20%") मागील कर (रू)
                                th.p-2.text-center(width="20%") चालू कर (रू)
                                th.p-2.text-center(width="20%") एकूण (रू)

                        tbody
                            - 
                                let taxes = [
                                    {name: 'सामान्य पाणी कर', last: waterTax.tpl_lastGenealWaterTax, current: waterTax.tpl_currentGenealWaterTax},
                                    {name: 'विशेष पाणी कर', last: waterTax.tpl_lastSpacialWaterTax, current: waterTax.tpl_currentSpacialWaterTax},
                                    {name: 'नोटिस फी / दंड फी', last: 0, current: 0},
                                    {name: 'वारंट फी', last: 0, current: 0},
                                ]


                            each row, index in taxes 
                                tr
                                    td.text-center.p-2 #{index + 1}
                                    td.p-2 #{row.name}
                                    td.text-center.p-2 #{Math.round(row.last)}
                                    td.text-center.p-2 #{Math.round(row.current)}
                                    td.text-center.p-2 #{Math.round(row.last + row.current)}

                            tr.bg-gray-100.font-semibold
                                td.text-center.p-2 -
                                td.p-2 एकूण कर
                                td.text-center.p-2 #{Math.round(waterTax.tpl_lastGenealWaterTax) + Math.round(waterTax.tpl_lastSpacialWaterTax)}
                                td.text-center.p-2 #{Math.round(waterTax.tpl_currentGenealWaterTax) + Math.round(waterTax.tpl_currentSpacialWaterTax)}
                                td.text-center.p-2 #{Math.round(waterTax.tpl_lastGenealWaterTax + waterTax.tpl_currentGenealWaterTax) + Math.round(waterTax.tpl_lastSpacialWaterTax + waterTax.tpl_currentSpacialWaterTax)}

                //- heer go
                .pt-1.px-4
                    if !paymentHistory || paymentHistory.length === 0
                        div(class="text-center text-gray-600 text-sm border border-dashed border-gray-400 py-6 rounded-md")
                            p(class="font-medium text-base text-gray-700") कोणतीही पावती उपलब्ध नाही.
                            p(class="text-sm text-gray-500 mt-1") ही मालमत्ता सध्या कोणत्याही भरणा इतिहासासह संलग्न नाही.

                    else

                        div.mt-2
                            h2.text-lg.font-bold.text-pink-700.border-b-2.border-pink-300.inline-block.pb-1 कर भरणा तपशिल
                            p.text-sm.text-gray-600.mt-1 नागरिकांनी केलेल्या कर भरण्याच्या नोंदी खाली दिलेल्या यादीत पाहू शकता.

                        div(class="mt-4 overflow-x-auto rounded-md shadow border border-pink-300")
                            table(class="min-w-full text-sm text-gray-800 bg-white/50")
                                thead(class="bg-pink-100/50 text-pink-800")
                                    tr
                                        th(class="p-2 text-left border-b border-pink-300") पावती क्रमांक
                                        th(class="p-2 text-left border-b border-pink-300") Transaction No.
                                        th(class="p-2 text-right border-b border-pink-300") भरणा रक्कम (रू)
                                        th(class="p-2 text-center border-b border-pink-300") भरणा पद्धत
                                        th(class="p-2 text-center border-b border-pink-300") भरणा स्थिती
                                        th(class="p-2 text-center border-b border-pink-300") पेमेंट भरणा फोटो
                                        th(class="p-2 text-left border-b border-pink-300") दिनांक

                                tbody
                                    each paymentHistoryRecord in paymentHistory
                                        tr(class="hover:bg-pink-50 transition-colors duration-150")
                                            td(class="p-2 border-b border-pink-200") #{paymentHistoryRecord.id}
                                            td(class="p-2 border-b border-pink-200 font-bold") #{paymentHistoryRecord.transaction_number && paymentHistoryRecord.transaction_number != '-' ? paymentHistoryRecord.transaction_number : 'नगद भरणा' }
                                            td(class="p-2 text-right border-b border-pink-200") ₹#{paymentHistoryRecord.payment_amount}
                                            td(class="p-2 text-center border-b border-pink-200")
                                                span(class=`inline-block px-2 py-1 rounded-full text-xs font-semibold ${paymentHistoryRecord.payment_mode == 0 ? 'bg-red-600 text-white' : 'bg-green-600 text-white'}`)
                                                    | #{paymentHistoryRecord.payment_mode == 0 ? 'ऑफलाइन' : 'ऑनलाइन'}
                                                    td(class="p-2 text-center border-b border-pink-200") 
                                                        - let payStatus = paymentHistoryRecord.approval_status

                                                        if payStatus == 'PENDING'
                                                            span(class="px-2 py-1 rounded-full text-yellow-800 bg-yellow-100 font-semibold") AWAITING APPROVAL
                                                        if payStatus == 'REJECTED'
                                                            span(class="px-2 py-1 rounded-full text-red-800 bg-red-100 font-semibold") REJECTED
                                                        
                                                        if payStatus == null || payStatus == 'APPROVED'
                                                            span(class="px-2 py-1 rounded-full text-green-800 bg-green-100 font-semibold") PAID 
                                                            
                                            td(class="p-2 text-center border-b border-pink-200")
                                                if paymentHistoryRecord && paymentHistoryRecord.payment_screenshot_image_name
                                                    - let imageUrl = `/uploads/images/gp/payments/paymentScreenshots/${paymentHistoryRecord.payment_screenshot_image_name}`
                                                    div(class='flex justify-center')
                                                        a.flex.items-center.gap-1(href=imageUrl, target='_blank' title='View Payment Screenshot')
                                                            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" width="20" height="20" fill="currentColor" class="text-green-600")
                                                                path(d="M0 112.5L0 422.3c0 18 10.1 35 27 41.3c87 32.5 174 10.3 261-11.9c79.8-20.3 159.6-40.7 239.3-18.9c23 6.3 48.7-9.5 48.7-33.4l0-309.9c0-18-10.1-35-27-41.3C462 15.9 375 38.1 288 60.3C208.2 80.6 128.4 100.9 48.7 79.1C25.6 72.8 0 88.6 0 112.5zM288 352c-44.2 0-80-43-80-96s35.8-96 80-96s80 43 80 96s-35.8 96-80 96zM64 352c35.3 0 64 28.7 64 64l-64 0 0-64zm64-208c0 35.3-28.7 64-64 64l0-64 64 0zM512 304l0 64-64 0c0-35.3 28.7-64 64-64zM448 96l64 0 0 64c-35.3 0-64-28.7-64-64z")
                                                            span.text-sm.text-green-600 View Screenshot

                                                else 
                                                    | -


                                            td(class="p-2 border-b border-pink-200") 
                                                - const date = new Date(paymentHistoryRecord.payment_date)
                                                | #{isNaN(date.getTime()) ? '-' : date.toLocaleString('en-GB', { timeZone: 'Asia/Kolkata', day: '2-digit', month: '2-digit', year: 'numeric' }).replaceAll('/', '-')}



                //- // After the paymentHistory table

                - 
                    //- // Calculate total paid
                    let totalPaid = 0;
                    if (paymentHistory && paymentHistory.length > 0) {
                        totalPaid = paymentHistory.reduce((sum, rec) => sum + Number(rec.payment_amount), 0);
                    }

                    //- // Calculate total tax (reuse your existing sum logic)
                    const totalTax = Math.round(
                        waterTax.tpl_lastGenealWaterTax + waterTax.tpl_currentGenealWaterTax +
                        waterTax.tpl_lastSpacialWaterTax + waterTax.tpl_currentSpacialWaterTax
                        );

                div.mt-1.border-t.border-pink-300.pt-4.px-2
                    .flex.justify-between
                        p.font-semibold.text-pink-700.text-base.mb-1 एकूण कराची रक्कम: 
                            span.font-bold.ml-2 ₹#{totalTax}

                        p.font-semibold.text-pink-700.text-base.mb-3 एकूण भरलेली रक्कम: 
                            span.font-bold.ml-2 ₹#{totalPaid}

                    if totalPaid >= totalTax
                        p(class="text-green-700 font-semibold text-center text-base bg-green-100/50 px-4 py-2 rounded shadow-md")
                            | धन्यवाद! आपण पूर्ण कर रक्कम भरली आहे.
                    else if totalPaid > 0
                        - const remaining = totalTax - totalPaid;
                        p(class="text-yellow-700 font-semibold text-center text-base bg-yellow-100/50 px-4 py-2 rounded shadow-md")

                            | आपण एकूण कर रकमेपैकी 
                            span.font-bold ₹#{totalPaid} 
                            | भरले आहे. पाणी कर भरणा रक्कम 
                            span.font-bold ₹#{remaining} 
                            | बाकी आहे.
                    else
                        p(class="text-red-700/50 font-semibold text-center text-base bg-red-100 px-4 py-2 rounded shadow-md")
                            | कोणतीही कर भरणा अद्याप झालेली नाही.



                div.mt-2

                    div(class='flex justify-end gap-4')
                        div
                            div
                                img(src=`/uploads/images/gp/stamps/${gp.gp_office_stamp_image_name}` style='width:95px; aspect-ratio:1/1;' onerror="this.src='/img/fallback/no-image-found.png'")

                        div
                            div(class='flex flex-col justify-center')
                                div(class='flex justify-center') 
                                    img(src='/print/gs.jpeg' style='width:180px; height:58px;')

                                div(class='text-sm')
                                    p.text-center वसुली धारकाची सही
                                    p.text-center ग्रामपंचायत कार्यालय #{gp.gp_name}, पं. स. #{gp.gp_taluka}





