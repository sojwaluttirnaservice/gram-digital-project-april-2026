doctype html
head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN' crossorigin='anonymous')



    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js' defer)
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")
    //mask plugin jquery
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js")

    //toggle

    // extras
    script(src='/asstest/plugins/select/js/select2.full.min.js')
    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')

    link(href="https://cdn.jsdelivr.net/npm/bootstrap5-toggle@5.0.4/css/bootstrap5-toggle.min.css" rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap5-toggle@5.0.4/js/bootstrap5-toggle.ecmas.min.js")
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js' integrity='sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL' crossorigin='anonymous')
    script(src='/asstest/coustom/js/handlers/sms/gramsandeshseva-handler.js')

    style.
        .toggle.btn{
            border-radius: 20rem !important;
            height: 5px !important;
            width: 6rem !important;
        }

        table{
            border-collapse: collapse;
        }

        thead, tr, th, td {
            border: 1px solid gray;
        }
        th {
            text-align: center;
            color: white;
            padding: 4px 10px;
        }
        tr {
            text-align: center;
        }

        tr{
            font-size: 0.8rem;
            padding: 4px 10px;
        }

        .scroll-content {
            height: 3rem;
            overflow-y: scroll;
            padding: 10px;
            margin: 5px;
        }
        .scroll-content::-webkit-scrollbar {
            width: 3px; /* Set the width of the scrollbar */
        }
        .scroll-content::-webkit-scrollbar-thumb {
            background-color: #888; /* Set the color of the scrollbar thumb */
            border-radius: 4px; /* Optional: Set the border radius for a rounded appearance */
        }
        .scroll-content::-webkit-scrollbar-track {
            background-color: wheat; /* Set the color of the scrollbar track */
        }


        //- .toggle-group{
        //- 	width: 100% !important;
        //- }


body
    include ../include/navs.pug

    .container
        .mt-3
            h2.text-center संदेश इतिहास 
            .d-flex.justify-content-start.align-items-center.gap-2

                //- button.btn.btn-primary(id='nagrikNondaniBtn') नागरिक
                //- button.btn.btn-success(id='formEightUsersBtn') नमुना ८
                a.btn.btn-success(id='messageRecord' href='/sms/gram-sandesh-seva-view') संदेश पाठवा 


        .mt-3(style='margin-bottom: 3rem !important;')

            if smsRecords.length === 0
            
                .text-center No sms history
            else
                div(style='overflow-x: scroll')
                    table
                        thead
                            th.bg-primary(width='2%') क्र
                            th.bg-primary(width='30%') संदेश
                            th.bg-primary(width='6%') दिनांक
                            th.bg-primary(width='6%') वेळ
                            th.bg-primary(width='2%') एकूण संदेश 
                            th.bg-primary(width='30%') मोबाईल
                            th.bg-primary(width='2%') स्टेटस

                        tbody
                            each record, index in smsRecords
                                tr
                                    td #{index + 1}
                                    td(width="30%")
                                        div.scroll-content #{record.message}
                                    td #{record.date}
                                    td #{record.time}
                                    td #{record.send_count > 0 ? record.send_count: 0}
                                    td(width="30%" )
                                        div.scroll-content(style=" white-space: initial; word-break: break-word;") #{(JSON.parse(record.reciever_mobile))}
                                    td #{record.success}
