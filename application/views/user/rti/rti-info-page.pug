block internal_js
    script.
        $(document).ready(function () {
            // Generic Tabs
            $('.tab-btn').on('click', function () {
                const tab = $(this).data('tab');

                $('.tab-btn')
                    .removeClass('border-blue-600 text-blue-600 bg-blue-50')
                    .addClass('border-transparent text-gray-600');

                $(this)
                    .removeClass('border-transparent text-gray-600')
                    .addClass('border-blue-600 text-blue-600 bg-blue-50');

                $('.tab-content:visible').fadeOut(100, function () {
                    $('.tab-content').addClass('hidden');
                    $('.tab-content[data-tab="' + tab + '"]')
                        .removeClass('hidden')
                        .hide()
                        .fadeIn(200);
                });
            });

            // Generic Accordion
            $('.accordion-btn').on('click', function () {
                const targetId = $(this).data('target');
                const $content = $('#' + targetId);

                $content.toggleClass('show');

                const $icon = $(this).find('.accordion-icon');
                $icon.text($content.hasClass('show') ? '−' : '+');
            });

            /* =========================================================
            1. BASIC STYLING (Applied via JS)
            ========================================================= */

            $('.accordion').css({
                //- maxWidth: '900px',
                margin: '0 auto'
            });

            $('.accordion-item').css({
                border: '1px solid #e5e7eb',
                borderRadius: '10px',
                marginBottom: '12px',
                overflow: 'hidden',
                background: '#ffffff',
                boxShadow: '0 2px 6px rgba(0,0,0,0.05)'
            });

            $('.accordion-btn').css({
                width: '100%',
                padding: '15px',
                background: '#f9fafb',
                border: 'none',
                cursor: 'pointer',
                fontWeight: '600',
                display: 'flex',
                alignItems: 'center',
                gap: '10px'
            });

            $('.accordion-body').css({
                display: 'none',
                padding: '15px',
                lineHeight: '1.6',
                color: '#374151'
            });

            $('.icon').css({
                fontWeight: 'bold',
                fontSize: '18px'
            });

            /* =========================================================
            2. TAB FUNCTIONALITY
            ========================================================= */

            /**
            * Handles tab switching
            * - Activates clicked tab
            * - Shows corresponding content
            */
            $('.tab-btn').on('click', function () {

                const tab = $(this).data('tab');

                // Reset all buttons
                $('.tab-btn').css({
                    background: '#e5e7eb',
                    color: '#000'
                });

                // Highlight active tab
                $(this).css({
                    background: '#2563eb',
                    color: '#fff'
                });

                // Hide all tab contents
                $('.tab-content').hide();

                // Show selected tab
                $('.tab-content[data-tab="' + tab + '"]').fadeIn(200);
            });

            /* =========================================================
            3. ACCORDION FUNCTIONALITY
            ========================================================= */

            /**
            * Accordion behavior:
            * - Opens clicked item
            * - Closes others
            * - Toggles + / − icon
            * - Highlights active item
            */
            $('.accordion-btn').on('click', function () {

                const targetId = $(this).data('target');
                const $content = $('#' + targetId);

                // Close all other sections
                $('.accordion-body').not($content).slideUp();
                $('.accordion-btn .icon').text('+');

                // Remove active highlight
                $('.accordion-btn').css('background', '#f9fafb');

                // Toggle current section
                $content.stop(true, true).slideToggle();

                // Toggle icon
                const $icon = $(this).find('.icon');
                $icon.text($content.is(':visible') ? '−' : '+');

                // Highlight active button
                $(this).css('background', '#e0f2fe');


            });

            /* =========================================================
            4. SPECIAL STYLING (IMPORTANT SECTION)
            ========================================================= */

            /**
            * Highlight "restricted information" section
            * (item6 in your Pug)
            */
            $('#item6').parent().css({
                border: '1px solid #ef4444',
                background: '#fef2f2'
            });

            /* =========================================================
            5. DEFAULT STATES
            ========================================================= */

            // Activate first tab
            $('.tab-btn').first().click();

            // Open first accordion item
            $('.accordion-btn').first().click();

        });

