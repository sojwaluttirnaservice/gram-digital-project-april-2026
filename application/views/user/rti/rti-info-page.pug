extends ../include/index-page-master-layout.pug
block content
    section(class='relative pb-10 md:pb-16 bg-gray-50')

        // Banner
        div(class='relative h-44 md:h-64 lg:h-80 overflow-hidden')
            img(src='https://rti.maharashtra.gov.in/images/BannerImg1.jpg' class='absolute inset-0 w-full h-full object-cover')
            div(class='absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-black/20')
            div(class='relative z-10 flex items-center justify-center h-full text-white text-center px-4')
                div
                    h2(class='text-xl md:text-3xl font-bold') माहितीचा अधिकार (RTI)
                    p(class='text-sm md:text-base mt-2') पारदर्शकता आणि उत्तरदायित्वासाठी महत्त्वाचा कायदा

        // Main Content
        .container.mt-8
            div(class='bg-white shadow-md rounded-xl p-4 md:p-6')

                // Tabs
                div(class='w-full')
                    div(class='flex flex-wrap gap-2 border-b mb-6')
                        button(class='tab-btn px-4 py-2 rounded-t-lg border-b-2 font-medium transition-all duration-200 border-blue-600 text-blue-600 bg-blue-50' data-tab='1') समग्र माहिती
                        button(class='tab-btn px-4 py-2 rounded-t-lg border-b-2 font-medium transition-all duration-200 border-transparent text-gray-600 hover:bg-gray-100' data-tab='2') अर्ज नमुने व कायदा

                    // Tab Contents
                    div
                        // Tab 1
                        div.tab-content(data-tab="1")
                            .accordion

                                // 1. माहिती म्हणजे काय
                                .accordion-item
                                    button.accordion-btn(data-target='item1')
                                        span.icon +
                                        span.title माहिती म्हणजे नक्की काय?

                                    .accordion-body(id='item1')
                                        p माहिती म्हणजे नोंदी, कागदपत्रे, शेरे, मेमो, ई-मेल्स, सल्ले, मते, प्रसिद्धीपत्रके, आदेश, परिपत्रके, रोजनिशी, करारनामा, अहवाल, कागद, उदाहरणे, नमुने या आणि अशा स्वरूपातील कोणतेही साहित्य तसेच इलेक्ट्रॉनिक माध्यमात असलेली माहिती.
                                        p * मात्र फाईलींवरील शेरे यांचा समावेश होत नाही.

                                // 2. माहितीचा अधिकार म्हणजे काय
                                .accordion-item
                                    button.accordion-btn(data-target='item2')
                                        span.icon +
                                        span.title माहितीचा अधिकार म्हणजे काय?

                                    .accordion-body(id='item2')
                                        p भारताच्या राज्यघटनेनुसार, भारत ही लोकशाही राष्ट्र आहे, म्हणजेच लोकांनी स्वतःसाठी आणि लोकांसाठी उभे केलेले राज्य. स्वतंत्रतेनंतर अनेक दशक उलटले, तरी आजच्या काळात नागरिकांचा मतदानाव्यतिरिक्त राज्यकारभारात सक्रिय सहभाग तुलनेने कमी दिसतो. प्रत्यक्षात, भारतासारख्या लोकशाही देशात प्रत्येक नागरिकाने राज्य आणि केंद्र सरकारच्या कामकाजात सक्रीय भूमिका पार पाडणे अत्यंत आवश्यक आहे.

                                        p यासाठी नागरिकांना राज्यघटनेतून मूलभूत हक्क दिले गेले आहेत. हे हक्क नागरिकांना सरकारच्या निर्णय प्रक्रियेबाबत मत मांडण्याचा, प्रशासनाची कार्यपद्धती समजून घेण्याचा, आणि सार्वजनिक हिताशी संबंधित बाबींवर माहिती मिळवण्याचा अधिकार प्रदान करतात. विशेषतः, माहितीचा अधिकार अधिनियम, २००५ हाही कायदा नागरिकांना त्यांच्या हक्कांचा वापर करून सरकारच्या कामकाजावर पारदर्शकपणे लक्ष ठेवण्याची संधी देण्यासाठी अस्तित्वात आहे.

                                // 3. अधिकारात समाविष्ट बाबी
                                .accordion-item
                                    button.accordion-btn(data-target='item3')
                                        span.icon +
                                        span.title या अधिकारात समाविष्ट बाबी

                                    .accordion-body(id='item3')
                                        p माहितीचा अधिकार अंतर्गत मिळवता येणारी माहिती खालीलप्रमाणे आहे:

                                        ul(class='list-decimal pl-4')
                                            li काम, कागदपत्रे, नोंदी यांची तपासणी करणे
                                            li कागदपत्रे किंवा नोंदी यांच्या प्रमाणित प्रती मिळवणे तसेच त्यांची टिपणे काढणे
                                            li साहित्याच्या प्रमाणित प्रती मिळवणे
                                            li माहिती छापील प्रत (प्रिंटआऊटस्), सीडी, फ्लॉपी, टेप्स, व्हिडिओ रेकॉर्डस् किंवा इतर कोणत्याही ईलेक्ट्रॉनिक माध्यमाद्वारे मिळवणे
                                            li कार्यालयाचे नाव, पत्ता, दूरध्वनी क्रमांक
                                            li कार्यालयाची कामकाजाची वेळ
                                            li जनमाहिती अधिकार्‍यांची नावे
                                            li कार्यालयाची कामकाजाची पद्धत व उद्दिष्टे
                                            li कार्यालयात उपलब्ध असलेली माहिती
                                            li विविध अर्जांचे नमुने
                                            li कर्मचार्‍यांची नावे व इतर माहिती
                                            li उपलब्ध निधी व लाभार्थ्यांची यादी
                                            li योजनांची माहिती, योजनांवर अथवा लाभार्थ्यांवर झालेला खर्च
                                            li परिपत्रके, उपलब्ध प्रकाशने व त्याची किंमत
                                            li कर्मचार्‍यांचे वेतन
                                            li अंदाजपत्रक

                                // 4. कोणती माहिती मिळू शकते
                                .accordion-item
                                    button.accordion-btn(data-target='item4')
                                        span.icon +
                                        span.title कोणती माहिती मिळू शकते?

                                    .accordion-body(id='item4')
                                        p हे अधिकारी सर्व प्रशासकीय खात्यांत किंवा कार्यालयांत सार्वजनिक अधिकार्यांद्वारे नेमण्यात आलेले असतात. ते नागरीकांना त्यांनी मागितलेल्या माहितीनुसार माहिती देण्याचे काम करतात. जर ते सहाय्यकाची मदत घेत असतील, तर अशा व्यक्तीसही जन माहिती अधिकारी म्हणून वागवले जाते.

                                        p कोणा कडून माहिती घेता येणार नाही ?

                                        p राष्ट्राच्या संरक्षणाच्या दृष्टीने संवेदनशील क्षेत्र, व्यक्तीगत स्वरुपाची माहिती, खाजगी कंपनी, विनाअनुदानीत संस्था, खाजगी विद्युतीय पुरवठादार कंपनी इत्यादीकडून माहिती मागता येत नाही. खालील प्रकारची माहिती देखील या कायद्याअंतर्गत मिळवता येत नाही:

                                        ul(class='list-decimal pl-4')
                                            li भारताची सार्वभौमता, एकात्मता, सुरक्षा, वैज्ञानिक किंवा आर्थिक बाबी, परराष्ट्रीय संबंध इत्यादींना धोका पोहोचणार अशी माहिती किंवा जी गुन्ह्यांना प्रोत्साहन देऊ शकते.
                                            li न्यायालयाने प्रसिद्ध करण्यास नकार दिलेली किंवा ज्यामुळे न्यायालयाचा अवमान होईल अशी माहिती.
                                            li माहिती जी उघड केल्यास संसद किंवा विधीमंडळाच्या स्वातंत्र्याला बाधा येईल.
                                            li व्यावसायिक गोपनीयता, व्यापारी गुपिते किंवा बुद्धीजीवी मालमत्ता यांचा समावेश असलेली माहिती, जी उघड केल्यास तिसऱ्या पक्षाच्या स्पर्धात्मक स्थानाला धोका पोहोचू शकतो; परंतु प्रतिस्पर्धी पक्षाला हरकत नसेल तर माहिती उघड करता येऊ शकते.
                                            li एखाद्या व्यक्तीच्या विश्वसनीय नात्यांमधून मिळालेली माहिती; प्रतिस्पर्धी पक्षाला हरकत नसेल तर उघड केली जाऊ शकते.
                                            li परराष्ट्र सरकारकडून मिळवलेली माहिती, जी उघड केल्यास व्यक्तीच्या जीविताला धोका निर्माण होऊ शकतो किंवा कायद्याची अंमलबजावणी गुप्तपणे मदत करणाऱ्याचे नाव उघड होऊ शकते किंवा सुरक्षेच्या कारणास्तव आहे.
                                            li माहिती जी शोधकार्यात किंवा आरोपींवरील कारवाईत अडथळा निर्माण करू शकते.
                                            li मंत्रीमंडळ, सचिव व इतर अधिकार्यांमध्ये होणाऱ्या चर्चेचे तपशील व कॅबिनेट कागदपत्रे.
                                            li सामाजिक कार्याशी किंवा जनहिताशी संबंध नसलेली वैयक्तीक माहिती, जी उघड केल्यास एखाद्या व्यक्तीच्या खाजगी आयुष्याचा भंग होऊ शकतो.
                                            li मात्र, एखाद्या घटनेत व्यक्तीला अथवा पक्षाला होणारा त्रास जनहिताच्या तुलनेत कमी महत्त्वाचा असल्यास, अशी माहिती उघड केली जाऊ शकते.

                                // 5. जन माहिती अधिकारी
                                .accordion-item
                                    button.accordion-btn(data-target='item5')
                                        span.icon +
                                        span.title जन माहिती अधिकारी कोण?

                                    .accordion-body(id='item5')
                                        p हे अधिकारी सर्व प्रशासकीय खात्यांत किंवा कार्यालयांत सार्वजनिक अधिकार्यांद्वारे नेमलेले असतात. ते नागरिकांना त्यांच्या मागणीनुसार माहिती पुरवण्याचे काम करतात. या कामासाठी ते सहाय्यकाची मदत घेत असल्यास, अशा व्यक्तीलाही जन माहिती अधिकारी म्हणून मानले जाते.

                                        p कोणा कडून माहिती घेता येणार नाही ?

                                        p राष्ट्राच्या संरक्षणाच्या दृष्टीने संवेदनशील क्षेत्रे, वैयक्तिक स्वरूपाची माहिती, खाजगी कंपन्या, विनाअनुदानीत संस्था, तसेच खाजगी विद्युत पुरवठादार कंपन्यांकडून या कायद्याअंतर्गत माहिती मागता येत नाही. तसेच खालील प्रकारची माहितीही उपलब्ध होत नाही:

                                        ul(class='list-decimal pl-4')
                                            li भारताची सार्वभौमता, एकात्मता, सुरक्षा, वैज्ञानिक किंवा आर्थिक हित, तसेच परराष्ट्रीय संबंध यांना धोका पोहोचवणारी किंवा गुन्ह्यांना प्रोत्साहन देणारी माहिती
                                            li न्यायालयाने जाहीर करण्यास मनाई केलेली किंवा ज्यामुळे न्यायालयाचा अवमान होऊ शकतो अशी माहिती
                                            li संसद किंवा विधीमंडळाच्या स्वातंत्र्यावर परिणाम करणारी माहिती
                                            li व्यावसायिक गोपनीयता, व्यापारी गुपिते किंवा बौद्धिक संपदा यासंबंधित माहिती, जी उघड केल्यास तृतीय पक्षाच्या स्पर्धात्मक स्थितीवर परिणाम होऊ शकतो (मात्र संबंधित पक्षाची हरकत नसल्यास माहिती दिली जाऊ शकते)
                                            li विश्वासाच्या नात्यांमधून मिळालेली माहिती (संबंधित पक्षाची हरकत नसल्यास उघड केली जाऊ शकते)
                                            li परदेशी सरकारकडून प्राप्त माहिती, जी उघड केल्यास एखाद्याच्या जीवितास धोका निर्माण होऊ शकतो किंवा गुप्त सहाय्य करणाऱ्या व्यक्तीची ओळख उघड होऊ शकते
                                            li तपासकार्य किंवा आरोपींवरील कारवाईमध्ये अडथळा निर्माण करणारी माहिती
                                            li मंत्रीमंडळ, सचिव व इतर अधिकारी यांच्यातील चर्चेचे तपशील व कॅबिनेट कागदपत्रे
                                            li सामाजिक कार्याशी किंवा जनहिताशी संबंध नसलेली वैयक्तिक माहिती, जी उघड केल्यास व्यक्तीच्या गोपनीयतेचा भंग होऊ शकतो
                                            li तथापि, जनहिताच्या तुलनेत व्यक्ती किंवा पक्षाला होणारा त्रास कमी महत्त्वाचा असल्यास, संबंधित माहिती उघड केली जाऊ शकते

                                // 6. कोणती माहिती मिळणार नाही
                                .accordion-item
                                    button.accordion-btn(data-target='item6')
                                        span.icon +
                                        span.title कोणती माहिती मिळणार नाही?

                                    .accordion-body(id='item6')
                                        ul(class='list-disc pl-4')
                                            li राष्ट्रीय सुरक्षा संबंधित माहिती
                                            li न्यायालयाने बंद केलेली माहिती
                                            li संसद/विधानमंडळ विशेषाधिकार
                                            li व्यापारी गुपिते
                                            li वैयक्तिक खाजगी माहिती
                                            li परराष्ट्र माहिती
                                            li तपासात अडथळा आणणारी माहिती

                                // 7. अर्ज कसा करावा
                                .accordion-item
                                    button.accordion-btn(data-target='item7')
                                        span.icon +
                                        span.title अर्ज कसा करावा?

                                    .accordion-body(id='item7')

                                        p माहितीचा अधिकार अर्ज कसा करावा??

                                        p माहितीसाठीचा अर्ज (RTI Application) तुम्ही टपालाद्वारे, ऑनलाईन किंवा प्रत्यक्ष संबंधित कार्यालयात जाऊन सादर करू शकता.

                                        p माहिती मिळवण्यासाठी अर्जाच्या पद्धती:
                                        ul(class='list-decimal pl-4')
                                            li ऑफलाईन पद्धत (Offline)
                                            li ऑनलाइन पद्धत (Online)


                                        br
                                        p अर्ज करण्याची प्रक्रिया:

                                        ul(class='list-decimal pl-4')
                                            li जनमाहिती अधिकार्‍याकडे इंग्रजी, हिंदी किंवा संबंधित राज्याच्या अधिकृत भाषेत लेखी किंवा इलेक्ट्रॉनिक माध्यमातून अर्ज सादर करावा.
                                            li अर्जामध्ये आवश्यक माहितीचा स्पष्ट तपशील द्यावा.
                                            li माहिती का हवी आहे हे नमूद करणे बंधनकारक नाही.
                                            li शासनाने ठरवलेली फी भरावी.

                                        br
                                        p महत्त्वाच्या बाबी:

                                        ul(class='list-decimal pl-4')
                                            li माहिती कशासाठी हवी आहे हे नमूद करण्याची आवश्यकता नाही.
                                            li अर्ज दाखल केल्यानंतर ३० दिवसांच्या आत माहिती देणे बंधनकारक असते.
                                            li एखाद्या व्यक्तीच्या जीवितरक्षणासाठी किंवा स्वातंत्र्याशी संबंधित तातडीची माहिती ४८ तासांच्या आत मिळवता येते.
                                            li माहितीच्या प्रत्येक पानासाठी रु. २ शुल्क आकारले जाते; याबाबत संबंधित विभागाकडून पूर्वसूचना दिली जाते.
                                            li ३० दिवसांनंतर माहिती दिल्यास ती मोफत देणे बंधनकारक असते.
                                            li ३० दिवसांत माहिती न मिळाल्यास किंवा अपुरी/दिशाभूल करणारी माहिती मिळाल्यास प्रथम अपिलीय अधिकार्‍याकडे अपील करता येते.
                                            li पहिल्या अपिलानंतरही ३० दिवसांत समाधानकारक माहिती न मिळाल्यास पुढील ९० दिवसांत दुसरे अपील आयुक्तांकडे करता येते.

                                        br
                                        p माहिती अधिकाऱ्याला कोणती शिक्षा होऊ शकते?

                                        ul(class='list-decimal pl-4')
                                            li कोणत्याही योग्य कारणाशिवाय अर्ज स्वीकारण्यास नकार दिल्यास
                                            li ठराविक वेळेत माहिती न दिल्यास
                                            li जाणूनबुजून चुकीची, अपूर्ण किंवा दिशाभूल करणारी माहिती दिल्यास
                                            li माहिती देण्यास अडथळा निर्माण केल्यास
                                            li माहितीची विनंती अनुचित हेतूने नाकारल्यास

                                        br
                                        p अशा प्रकरणांमध्ये संबंधित माहिती अधिकाऱ्यावर दररोज रु. २५० प्रमाणे दंड आकारला जाऊ शकतो, जो कमाल रु. २५,००० पर्यंत जाऊ शकतो. याशिवाय, त्यांच्यावर शिस्तभंगाची कारवाईही केली जाऊ शकते.

                                // 8. शुल्क माहिती
                                .accordion-item
                                    button.accordion-btn(data-target='item8')
                                        span.icon +
                                        span.title माहिती मिळवण्यासाठी काही खर्च येतो का ?

                                    .accordion-body(id='item8')
                                        p होय, माहितीसाठीच्या कागदपत्रांचा खर्च पुढीलप्रमाणे आहे. मात्र अर्जदार दारिद्र्यरेषेखालील (BPL) असल्यास कोणताही खर्च आकारला जात नाही.

                                        br
                                        p कागदपत्रांचा खर्च:

                                        ul(class='list-decimal pl-4')
                                            li विविध कागदपत्रांची झेरॉक्स — प्रति पान रु. २
                                            li आवश्यक माहितीची सीडी किंवा फ्लॉपी — प्रत्येकी रु. ५०
                                            li कार्यालयातील कागदपत्रांची पाहणी — पहिला तास विनामूल्य
                                            li एक तासापेक्षा अधिक वेळ पाहणी — प्रति तास रु. ५
                                            li माहिती पोस्टाद्वारे हवी असल्यास — पोस्टाचा प्रत्यक्ष खर्च आकारला जातो

                                        br
                                        p इतर महत्त्वाच्या बाबी:

                                            ul(class='list-decimal pl-4')
                                            li अर्जदाराला आकारलेल्या शुल्काच्या पुनर्तपासणीसाठी संबंधित समितीकडे अपील करता येते.
                                            li जनमाहिती अधिकारी ठरवलेल्या वेळेत माहिती देण्यात अयशस्वी ठरल्यास, संबंधित माहिती अर्जदारास विनामूल्य देणे बंधनकारक आहे.

                                // 9. अपील प्रक्रिया
                                .accordion-item
                                    button.accordion-btn(data-target='item9')
                                        span.icon +
                                        span.title अर्जदाराने अपील कसे करावे?

                                    .accordion-body(id='item9')
                                        p जर अर्जदाराने मागितलेली माहिती अपूर्ण, चुकीची किंवा दिशाभूल करणारी मिळाली, अथवा माहिती नाकारण्यात आली, तर संबंधित अर्जदाराला जनमाहिती अधिकार्‍याविरुद्ध अपिलीय अधिकार्‍याकडे अपील करता येते. हे अपील ३० दिवसांच्या आत करणे आवश्यक आहे.

                                        p अपिलीय अधिकारी हा जनमाहिती अधिकार्‍यापेक्षा अधिक अनुभवी आणि संबंधित कामकाजाची सखोल माहिती असलेला अधिकारी असतो. त्याने आपल्या अधिकारांचा वापर निष्पक्षपणे करणे अपेक्षित आहे.

                                        br
                                        p अपील करण्याची प्रक्रिया:

                                        ul(class='list-decimal pl-4')
                                            li अपील अर्ज सादर करताना कागदावर रु. २० चा न्यायालयीन मुद्रांक (Court Fee Stamp) लावावा.
                                            li अर्जामध्ये अर्जदाराचे नाव, पत्ता तसेच संबंधित जनमाहिती अधिकार्‍याचा तपशील नमूद करावा.
                                            li कोणती माहिती मिळाली नाही किंवा अपूर्ण मिळाली याचा स्पष्ट उल्लेख करावा.
                                            li तक्रारीचे स्वरूप किंवा अपील करण्याचे कारण सविस्तर लिहावे.
                                            li अर्जावर शेवटी सही करून तो संबंधित कार्यालयात सादर करावा.
                                            li अर्ज सादर केल्यानंतर त्याची पोच (Acknowledgement) घ्यावी.

                                        br
                                        p अपिलीय अधिकार्‍याकडे अपील दाखल केल्यानंतर, अर्जाच्या दिनांकापासून साधारणतः ४५ दिवसांच्या आत माहिती प्राप्त होऊ शकते.

                                // 10. दंड
                                .accordion-item
                                    button.accordion-btn(data-target='item10')
                                        span.icon +
                                        span.title दुसरे अपील कसे करावे ?

                                    .accordion-body(id='item10')
                                        p दुसरे अपील कसे करावे ?

                                        p अर्जदाराने मागितलेली माहिती अपिलीय अधिकार्‍याकडूनही न मिळाल्यास, अथवा चुकीची किंवा अपूर्ण मिळाल्यास आणि त्याबाबत समाधान न झाल्यास, अर्जदार राज्य माहिती आयुक्तांकडे ९० दिवसांच्या आत दुसरे अपील करू शकतो.

                                        br
                                        p दुसरे अपील करण्याची प्रक्रिया:
                                        ul(class='list-decimal pl-4')
                                            li अपील अर्ज सादर करताना कागदावर रु. २० चा न्यायालयीन मुद्रांक (Court Fee Stamp) लावावा.
                                            li अर्जामध्ये अर्जदाराचे नाव, पत्ता तसेच जनमाहिती अधिकार्‍याचा तपशील नमूद करावा.
                                            li अपेक्षित माहिती मिळाली नाही किंवा अपूर्ण/चुकीची मिळाली याचा स्पष्ट उल्लेख करावा.
                                            li तक्रारीचे स्वरूप किंवा अपील करण्याचे कारण सविस्तर लिहावे.
                                            li अर्जावर शेवटी सही करून तो संबंधित कार्यालयात सादर करावा.
                                            li अर्ज सादर केल्यानंतर त्याची पोच (Acknowledgement) घ्यावी.


