  div(id='mentioned-qr-target-tag' style='display: none;' data-target='qr-code-container' data-targetUrl="" data-size='130')
  - var pageCount = 0;
  - var lastBuildingTax = 0;
  - var currentBuildingTax = 0;
  - var totalBuildingTax = 0;
  - var lastDivaTax = 0;
