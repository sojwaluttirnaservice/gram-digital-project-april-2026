                  - currentSpacialWaterTax += Math.round(val.currentSpacialWaterTax) ;
                  - totalSpacialWaterTax += Math.round(val.totalSpacialWaterTax) ;
                  - lastGenealWaterTax += Math.round(val.lastGenealWaterTax) ;
