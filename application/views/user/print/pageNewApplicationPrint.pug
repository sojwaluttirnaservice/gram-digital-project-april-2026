doctype html
html(lang='en')
  head
    title #{title}
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    script(src='https://cdn.tailwindcss.com')

    script(src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js")
    script(src="/asstest/coustom/js/handlers/common/generate-qr-code-util-handler.js" defer)

    style.
      @media print {
        @page { 
            size: A4 portrait; 
            margin: 6mm; 
            border: 1px solid black;
        }
        .hide-print {
            display: none;
        }
        body { width: 210mm; }
      }

    script.
        window.print();

  body(class='bg-slate-300 flex justify-center py-4')
    div(id='mentioned-qr-target-tag' style='display: none;' data-target='qr-code-container' data-targetUrl=`/print-application/${data.id}` data-size='80')


    div.hide-print(class='fixed bottom-6 right-6 z-[9999]')
        button(onclick='window.print()' class='bg-blue-600 hover:bg-blue-700 text-white rounded-md px-4 py-2 shadow-lg transition duration-200') Print

    // ===== A4 PAGE =====
    div(class='w-[210mm] min-h-[277mm] bg-white relative font-serif text-[14px] text-slate-800 flex flex-col')

      // ===== WATERMARK =====
      img(
        src='/img/water-mark-images/Seal_of_Maharashtra.png'
        class='absolute w-[400px] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-8 pointer-events-none'
        style='filter: grayscale(100%) contrast(120%);'
      )

      // ===== TRICOLOR STRIP =====
      div(class='absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-orange-500 via-white to-green-600 opacity-35')
      div(class='absolute bottom-0 left-0 w-full h-2 bg-gradient-to-r from-orange-500 via-white to-green-600 opacity-35')

      // ===== CONTENT WRAPPER =====
      div(class='relative z-10 flex flex-col flex-grow m-6 p-6 rounded-md bg-white')

        // ================= HEADER SECTION =================
        div(class='relative mb-4')

          // QR TOP RIGHT
          div(class='absolute right-0 top-0')
            div#qr-code-container(class=' border rounded-md flex items-center justify-center text-xs text-blue-900 font-semibold bg-white')
              | QR Code

          // Legal Line
          div(class='text-center text-[12px] text-amber-900 tracking-wide font-semibold mb-1')
            | महाराष्ट्र लोकसेवा हक्क अध्यादेश २०१५ क्र.- आरटीएस- २०१५/प्र. क्र. ३२/प स -५, दिनांक १४ जुलै २०१५

          // Office
          div(class='text-center border-b-2 border-blue-900 pb-3 mb-4')
            h2(class='text-[20px] font-bold tracking-wide text-blue-900')
              | ग्रामपंचायत कार्यालय #{zp.gp_name}
            p(class='text-sm text-rose-900 mt-1 font-medium')
              | ता. #{zp.gp_taluka} | जिल्हा #{zp.gp_dist}

          // Title
          div(class='text-center border-2 border-blue-900 rounded-md py-1 mb-3 bg-blue-50')
            h3(class='text-[14px] font-bold text-blue-900')
              | महाराष्ट्र लोकसेवा हक्क अध्यादेश २०१५ अंतर्गत दाखल / प्रमाणपत्र मिळण्याकरिता अर्जाचा नमुना


        // ================= META INFO =================
        div(class='flex justify-between mb-6')

          div(class='leading-snug font-medium')
            p प्रति,
            p सरपंच / ग्रामपंचायत अधिकारी
            p ग्रामपंचायत #{zp.gp_name}

          div(class='text-right space-y-1')
            div
              span(class='text-slate-600') अर्ज क्र. :
              span(class='ml-2 font-bold text-blue-900') #{data.id}
            div
              span(class='text-slate-600') दिनांक :
              span(class='ml-2 font-bold text-blue-900') #{data.create_date}


        // ================= APPLICANT =================
        div(class='bg-blue-50 border-2 border-blue-900 rounded-lg p-3 mb-3')

          h4(class='text-sm font-bold text-blue-900 mb-2 uppercase tracking-wide')
            | अर्जदार तपशील

          div(class='grid grid-cols-2 gap-y-1 gap-x-8 font-medium')

            - 
                let fields = [
                    { label: 'नाव', value: data.formName },
                    { label: 'पत्ता', value: `${data.formAddress}, ता. ${zp.gp_taluka}, जि. ${zp.gp_dist}` },
                    { label: 'दूरध्वनी', value: data.formMobile },
                    { label: 'आधार क्रमांक', value: data.formAadhar },
                    { label: 'ई-मेल', value: data.formEmail || '-' }
                ]

            each field in fields
              div
                span(class='text-rose-900') #{field.label} :
                span(class='ml-2') #{field.value}


        // ================= SUBJECT =================
        div(class='mb-4')
          h5(class='font-bold text-rose-900 mb-1')
            | विषय : महाराष्ट्र लोकसेवा हक्क अधिनियम २०१५ अंतर्गत प्रमाणपत्र अर्ज
          p(class='leading-snug font-medium')
            | मी वरील नमूद पत्त्यावर वास्तव्यास असून खालील दाखल्याची आवश्यकता आहे.


        // ================= TABLE =================
        div(class='border-2 border-blue-900 rounded-md mb-6')
          table(class='w-full border-collapse text-sm')

            thead(class='bg-blue-100')
              tr
                th(class='p-1 border border-blue-900 font-bold text-blue-900 text-center') क्र.
                th(class='p-1 border border-blue-900 font-bold text-blue-900 text-center') कोणासाठी
                th(class='p-1 border border-blue-900 font-bold text-blue-900 text-center') दाखल्याची नोंद
                th(class='p-1 border border-blue-900 font-bold text-blue-900 text-center') स्थिती

            tbody
              each val, i in doc
                tr
                  td(class='p-1 border border-blue-900 text-center') #{i + 1}
                  td(class='p-1 border border-blue-900 text-center') #{val.docCol1 || data.formName}
                  td(class='p-1 border border-blue-900 text-center') #{val.docTitle}
                  td(class='p-1 border border-blue-900 text-center font-semibold text-green-700') होय


        // ================= DECLARATION =================
        p(class='leading-snug font-medium mb-6')
          | आवश्यक शुल्क भरण्यास मी तयार असून प्रमाणपत्र देण्यात यावे ही नम्र विनंती.


        // ================= SIGNATURE =================
        div(class='flex justify-between items-end mb-8')

          div
            p अंगठा / स्वाक्षरी

          div(class='text-right')
            p(class='font-bold text-blue-900') आपला विश्वासू
            p(class='mt-6 border-t-2 border-blue-900 w-44 text-center pt-1')
              | अर्जदार स्वाक्षरी


        // ================= RECEIPT =================
        div(class='mt-auto pt-4 border-t-2 border-dashed border-blue-900')

          h4(class='text-center font-bold text-blue-900 mb-2') पोच पावती

          p(class='leading-snug font-medium mb-3')
            | श्री / श्रीमती 
            span(class='font-bold text-rose-900') #{data.formName}
            |  यांचा 
            span(class='font-bold text-rose-900') #{doc1.docTitle} #{doc2 ? (' व ' + doc2.docTitle) : ''}
            |  अर्ज दिनांक 
            span(class='font-bold text-blue-900') #{data.create_date}
            |  रोजी प्राप्त झाला.

          div(class='flex justify-between font-medium')
            p
              | अर्ज क्र. 
              span(class='font-bold text-blue-900') #{data.id}
            p(class='font-bold text-blue-900') पदनिर्देशित अधिकारी