doctype html
head
  title पेमेंट पावती 
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  meta(http-equiv='X-UA-Compatible' content='ie=edge')
  script(src="/asstest/plugins/qrcodejs/qrcode.min.js")
  // COMMON CSS
  link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')

  //- COMMON JS
  script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
  script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
  script(src='/asstest/coustom/js/common.js')
  script(src="/asstest/coustom/js/handlers/pagination.js")
  style.

    @media print {
      @page { 
        size: auto;
          margin: 7mm 7mm 4mm 10mm;
        }
        body {
          margin:0;
          padding:0;
        }
        body {
          transform: scale(1);
        }
        img {
          page-break-inside: avoid;
        }
        .p-hide{
          display:none
        }
        .pagination {
          display: none;
        }
      }  

      .main-heading {
        margin-left:10%
      }

      .heading-second{
        margin-left:30%
      }

      .heading-second-2{
        margin-left:30%
      }

      .set-p-break {
        page-break-before: always;
      }

      .c-0 {
        page-break-before: always;
      }

      .img{
        width:65px;
        height:70px;
      }

      .img1{
        margin-top:-10px;
        width:70px;
        height:90px;
      }

      p{
        font-size:15px !important;
      }

      .qrcode img{
        width:100%;
        height:100%;
      }

      .pavati-text {
        font-size: 1.5rem !important;
        font-weight: bold; 
      }

body
  div(class='')
    div(style="position:relative;display:inline-block;width:290mm;height:200mm !important")
      img(src="/print/certificate-payment-recipt.jpg" alt="" style="width:100%;height:100%;")
      div(style="position: absolute;top:0;width:100%")
        //- - var url = '/home_map_image/home_photo/'+val.feu_image

        p.pavati-text(style="position:absolute;left:25rem;top:5.2rem") #{gp.gp_name},  प.स. #{gp.gp_taluka} जि. #{gp.gp_dist}
        p.pavati-text(style="position:absolute;left:10rem;top:12.2rem") #{payDetails.payment_date}
        p.pavati-text(style="position:absolute;left:56.5rem;top:12.2rem") #{payDetails.id}

        p.pavati-text(style="position:absolute;left:13rem;top:32.5rem") #{payDetails.payment_amount} /-
        p.pavati-text(style="position:absolute;left:14.4rem;top:28rem") #{payDetails.amountInwords}
        p.pavati-text(style="position:absolute;left:14.5rem;top:18.8rem;") #{payDetails.recipient_name}
        p.pavati-text(style="position:absolute;left:14.3rem;top:23.5rem;") #{payDetails.certificate_name}

        small(style="position:absolute;left:56rem;top:37.3rem")
          //- Removed signature
          //- img(src="/print/sp1.jpeg" alt="" srcset="" width="99") 
