        script.
            document.addEventListener('DOMContentLoaded', function(){
                const downloadPdf = () => {
                    const element = document.querySelector('#print');
                    const options = {
                        margin: [0.1, 0.1, 0.1, 0.1],
                        filename: 'form8-receipt.pdf',
                        image: { type: 'jpeg', quality: 0.98 },
                        html2canvas: { scale: 2, useCORS: true, scrollY: 0 },
                        jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait' }
                    };
                    html2pdf().set(options).from(element).save();
                }
                const downloadPdfBtn = document.getElementById('download-pdf-btn');
                if (downloadPdfBtn) {
                    downloadPdfBtn.addEventListener('click', downloadPdf);
                }



                // Your code here
                const _gp = !{JSON.stringify(gp)};
                console.log(_gp)
                let website = window.location.origin;
                const _waterTax = !{JSON.stringify(waterTax)};
                website += `/qr-scan/tpw?wId=${_waterTax.id}&f8U=${_waterTax.user_id}`

                const giveQr = (qrId) => new QRCode(
                    qrId,

                    {
                        text: website,
                        width: 95, // Set width here
                        height: 95, // Set height here
                        colorDark: '#000000',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.H, // Optional: error correction level
                    }
                );

                giveQr('qr-code1')
                giveQr('qr-code2')
            })

