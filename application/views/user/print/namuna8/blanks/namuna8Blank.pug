body.back-image
    include ../../../include/navs.pug

    .container-fluid

        .row.d-flex.justify-content-center
            .col-6
                h5.heading-1 नमुना ८ Blank प्रिंट 
        - 
            let form8BlankPrintTabs = 
                [
                    {id: -1, tabLabel: "नमुना ८ Blank (No Image)", link: "/namuna/8/blank/o-image"},
                    {id: -1, tabLabel: "नमुना ८ Blank (QR & Image)", link: "/namuna/8/blank/form-8-image"}
                ]

        .row.justify-content-center
            each form8Tab, key in form8BlankPrintTabs
                .col-4.col-md-2.p-2.box.box--white
                    //- if it's supposed to be a link, let it behave as a  link
                    if form8Tab.link 
                        a.commonModalFrom(href=form8Tab.link target="_blank" style="color: inherit; text-decoration: none;" class="d-flex justify-content-center align-items-center") 
                            p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center")
                                i.fa.fa-print.fa-2x
                                small #{form8Tab.tabLabel}
                    else
                        .commonModalFrom(data-id=form8Tab.id class="d-flex justify-content-center align-items-center") 
                            p.box__title(style='gap: 0.2rem;' class="d-flex justify-content-center align-items-center")
                                i.fa.fa-print.fa-2x
                                small #{form8Tab.tabLabel}