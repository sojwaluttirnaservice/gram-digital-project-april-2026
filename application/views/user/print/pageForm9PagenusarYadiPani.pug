doctype html
head
	title नमुना 9 यादी पाणी पेज नुसार 
	meta(charset='UTF-8')
	meta(name='viewport' content='width.p-1.m-0=device-width.p-1.m-0, initial-scale=1.0')
	meta(http-equiv='X-UA-Compatible' content='ie=edge')
	// common css
	link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')

	style.

		@media print {
			@page{
				size: A4 potrait;
			}
			.my-print{
				position: relative;
				page-break-before: always;
			}
			table{
				//- page-break-inside: avoid;
			}
			.waterMark{
				position: absolute;
				opacity: 0.3;
				width: 100%;
				height: 100%;
			}
		}

		table, th, td{
			border: 1px solid black;
			padding: 3px; 
			text-align:center;
			border-collapse:collapse;
		}
		.body-f-size {
			font-size: 1rem !important;
		}
		.head-f-size {
			font-size: 15px;
			text: bold;
			text-align: center;
		}
		.center{
			text-align: center;
		}
		.waterMark{
			position: absolute;
			opacity: 0.3;
			top: calc(50% - 250px);
			left: calc(50% - 250px);
			width: 500px;
			height: 500px;
		}
body
	img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")
	div.d-flex.justify-content-between.pt-4.pb-4.mx-3
		div.d-flex.flex-column.justify-content-center.align-items-center.text-align-center
			img(src="/img/header-images/mudra-nav.jpg" width="95" height="40")
		div.d-flex.justify-content-center.text-center(style="color: red; font-weight: bold;")
			p ग्राम पंचायत कार्यालय #{zp.gp_name} पंचायत समिती  #{zp.gp_taluka} जिल्हा #{zp.gp_dist} अंतिम नमुना 9 सण #{year1} ते  #{year2}  ची सामान्य व विशेष पाणी कर पद्धतीने यादी  पेज नुसार
		div.d-flex.flex-column.justify-content-center.align-items-center
			img.float-right(src="/img/header-images/g-sevalogo-new.jpeg" width="100" height="40")

	table(style="width:100%;")
		thead
			tr.head-f-size
				th अनु.क्र. 
				th मालमत्ता क्र ते पर्यंत 
				th पण क्र नुसार एकूण विशेष व सामान्य पाणी कर 

				th एकूण पेज मागील विशेष पाणी कर 
				th एकूण पेज चालू विशेष पाणी कर 
				th एकूण पेज मागील व चालू विशेष पाणी कर 
				th एकूण पेज मागील सार्वजिनक पाणी कर 
				th एकूण पेज चालू सार्वजिनक पाणी कर 
				th एकूण पेज मागील व चालू सार्वजिनक पाणी कर 
				th संपूर्ण एकूण पेज मागणी 

		- 
			let totalLastSpecialWaterTax = 0;
			let totalCurrentSpecialWaterTax = 0;

			let totalLastCommonWaterTax = 0;
			let totalCurrentCommonWaterTax = 0;

			let totalTotalWaterTax = 0;

		tbody
			each el, i in data
				tr.body-f-size
					th #{i+1} 
					th मालमत्ता क्र #{el.malmattaNoFrom} ते #{el.malmattaNoTo} पर्यंत 
					th पान क्र #{i+1}

					- totalLastSpecialWaterTax += el.lastSpecialWaterTax
					th #{el.lastSpecialWaterTax}
					- totalCurrentSpecialWaterTax += el.currentSpecialWaterTax
					th #{el.currentSpecialWaterTax} 
					th #{el.totalSpecialWaterTax} 

					- totalLastCommonWaterTax += el.lastCommonWaterTax
					th #{el.lastCommonWaterTax}
					- totalCurrentCommonWaterTax += el.currentCommonWaterTax
					th #{el.currentCommonWaterTax} 
					th #{el.totalCommonWaterTax}

					- totalTotalWaterTax += el.totalWaterTax
					th #{el.totalWaterTax}

			tr.body-f-size
				th(colspan='3') Total

				th #{totalLastSpecialWaterTax}
				th #{totalCurrentSpecialWaterTax}
				th #{totalLastSpecialWaterTax + totalCurrentSpecialWaterTax}

				th #{totalLastCommonWaterTax}
				th #{totalCurrentCommonWaterTax}
				th #{totalLastCommonWaterTax + totalCurrentCommonWaterTax}

					th #{totalTotalWaterTax}
