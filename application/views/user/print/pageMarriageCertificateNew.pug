doctype html
headlocati
    title Marriage Certificate
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')

    //- script(src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.js")
    //- script(src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js" integrity="sha512-r6rDA7W6ZeQhvl8S7yRVQUKVHdexq+GAlNkNNqVC7YyIV+NwqCTJe2hDWCiffTyRNOeGEzRRJ9ifvRm/HCzGYg==" crossorigin="anonymous" referrerpolicy="no-referrer")


    script(src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js")


    script.
        document.addEventListener('DOMContentLoaded', function() {
            // Your code here
            //- console.log('Document fully loaded and parsed');
            const _gp = !{JSON.stringify(zp)};
            const _data = !{JSON.stringify(userInfo)}

            //- const baseUrl = window.location.origin;
            //- const _dataString = `नोंदणी क्र: ${_data.id}\nवराचे  नाव : ${_data.marriageHusbandNameM}\nवधूचे नाव :${_data.marriageWifeNameM}\nनोंदणी दिनांक : ${_data.registration_date}\nग्रामपंचायत: ${_gp.gp_name}\nलिंक: <a href=${window.location.href}>Click</a>`;
            //- var qrcode = new QRCode(document.getElementById('qr-code'), {text: _dataString, width:200, height:200});	
            //- let website =  window.location.origin
            let website = window.location.origin
            website += `/qr-scan/marriage-certificate?id=${_data[0].id}`

            var qrcode = new QRCode(
                'qr-code',

                {
                    text: website,
                    width: 85, // Set width here
                    height: 85, // Set height here
                    colorDark: '#000000',
                    colorLight: '#ffffff',
                    correctLevel: QRCode.CorrectLevel.H, // Optional: error correction level
                }
            );

        });
    style.


        #qr-code img{
            width: 100%;
            height: 100%;
        }

        .bl{
            border-left: 1px solid black;
        }
        .br{
            border-right: 1px solid black;
        }
        .bt{
            border-top: 1px solid black;
        }
        .bb{
            border-bottom: 1px solid black;
        }

        .bold {
            font-weight: bold;
        }

        .semibold {
            font-weight: 700;
        }

        .print-page {
            width: 70%;
            margin-left: auto;
            margin-right: auto;
        }

        @media print {
            @page { 
                size: A4;

            }
            body {
                margin:0;
                padding:0;
            }
            body {transform: scale(1);}

            .my-print {
                margin: 3mm 2mm 3mm 2mm;
            }

            .print-page{
                width: 100% !important;
            }

            #hide-buttons{
                display: none;
            }
        }


body
    div(style="")

        #hide-buttons 
            button.btn.btn-primary(onclick='window.print();' style='position: fixed; top:49%; left: 2rem;') Print

        .print-page.semibold(style='height: 100%;')
            each val,index in userInfo

                div(style='height: 5%;')
                    div.bold.text-center शासन निर्णय क्रमांक: आरटीएस -२०१५/प्र.क्र ३२/ प्र.रा-५, दिनांक १४ जुलै, २०१५

                    div(style='width: 100%; height:5px; background-color: black;')

                div(style='border: 1px solid black; height: 95%;')

                    //- Photo sign container

                    div.bb(style="display: grid; grid-template-columns:repeat(3, 1fr)")

                        //- Husband's Photo
                        div(style='padding:1rem;')
                            div(style='display:flex; align-items:center; justify-content:center')
                                - image_h = "/upload/"+ val.image_h;
                                img(src=image_h, alt="" width="145" height="180")

                        //- Satyamev jayate
                        div(style='padding:1rem;').bl.br
                            div(style='display:flex; align-items:center; justify-content:center')
                                - image_satyamev_jayate = "/img/certificates/satyamev-no-bg.png"
                                img(src=image_satyamev_jayate, alt="" width="145" height="180")

                        //- Wife's Photo
                        div(style='padding:1rem;')
                            div(style='display:flex; align-items:center; justify-content:center')
                                - image_w = "/upload/"+ val.image_w;
                                img(src=image_w, alt="" width="145" height="180")

                    //- ? certificate.created_date.split('-').reverse().join('-') : '-' Information container

                    div
                        div(style='display: grid; grid-template-columns: 2fr 6fr 2fr;')

                            div(style='display: flex; align-items: center; justify-content: center')
                                //- #qr-code(style='width: 190px !important; height: 190px;')
                                #qr-code(style='width: 150px !important; height: 150px;')

                            div(style='')
                                h5.mt-4.bold.text-center महाराष्ट्र शासन

                                div(style='display: flex; flex-direction: column; gap: rem; justify-content:center; align-items:center;')
                                    p भाग चार -ब महाराष्ट्र शासन राजपत्र, मे २०, १९९९/ वैशाख ३०, शके १९२१
                                    p नमुना - 'इ' / FORM "E"
                                    p विवाह नोंदणीचे प्रमाणपत्र
                                    p CERTIFICATE OF REGISTRATION OF MARRIAGE 
                                    p (पहा कलम ६ (१) आणि नियम ५) / (See Section 6(1) and Rule 5)

                            div(style='display: flex; align-items: center; justify-content: center')

                                img(src='/img/water-mark-images/Seal_of_Maharashtra.png' style='width: 170px !important; height: 170px;')

                        //- Husband wife marriage info container
                        div(style='padding:0 2rem; display: flex; flex-direction: column; align-items-center; justify-content: center;')
                            div 
                                p प्रमाणित करण्यात येते की,
                                p Certified that the marriage between,


                            div
                                p पतीचे नाव : #{val.marriageHusbandNameM} , आधारकार्ड क्रमांक : #{val.marriageHusbandAadharM} 
                                P Husband's Name : #{val.marriageHusbandNameE}, Adhar Card Number: #{val.marriageHusbandAadharE}

                            div 
                                p राहणार : #{val.marriageHusbandAddressM} आणि
                                p Residing at : #{val.marriageHusbandAddressE} and

                            div 
                                p पत्नीचे नाव : #{val.marriageWifeNameM}, आधारकार्ड क्रमांक : #{val.marriageWifeAddressM} 
                                p Wife's Name : #{val.marriageWifedNameE}, Adhar Card Number : #{val.marriageWifedAadharE} 

                            div 
                                p राहणार : #{val.marriageWifeAddressM} आणि
                                p Residing at : #{val.marriageWifeAddressE} and

                            div 
                                p यांचा विवाह दिनांक : #{val.marriageDateM} रोजी #{val.marriagePlaceM} येथे(ठिकाणी)
                                p Solemnized on : #{val.marriageDate} at #{val.marriagePlaceE}

                            div
                                p विवाह विधी संपन्न झाला. त्यांची महाराष्ट्र विवाह मंडळाचे विनीनियम आणि विवाह नोंद विधेयक, १९९८
                                p Register of Marriages maintained under the Maharashtra Regulation of Marriage Bureaus And Registration of Marriages Act 1998

                            div 
                                p अन्वये ठेवण्यात आलेल्या नोंदविवाहाचा खंड क्रमांक : #{val.marriageVolumeM} च्या अनुक्रमांक : #{val.marriageAnuKramankM} वर
                                p of volume : #{val.marriageVolume} serial No. : #{val.marriageAnuKramank}

                            div 
                                p दिनांक : #{val.registration_date_two} रोजी माझ्याकडून नोंदणी करण्यात आली आहे.
                                p On : #{val.registration_date} registered by me.

                            div 
                                p ठिकाण/ Place : #{val.marriagePlaceM} / #{val.marriagePlaceE}
                                p दिनांक/Date : #{val.registration_date ? val.registration_date : '-'} 
                                    if val.registration_date_two 
                                        span (#{val.registration_date_two})

                        div(style='padding:0 2rem; display: flex; justify-content: space-between; align-items: center;') 

                            div
                                p ग्रामपंचायत कार्यालय, #{zp.gp_name}

                            div
                                div(style='display:flex; flex-direction:column;justify-center;')
                                    img(src='/print/gs.jpeg' class=`${zp.gramsevak_sign_display === 1 ? "" : 'd-none'}` alt='gramsevak sign' onerror="this.style.display='none'" style='width: 6rem !important; height: 2.4rem !important; display: block; margin-inline: auto; margin-bottom:0.2rem;')
                                    div.text-center 
                                        p निबंधक/ विवाह नोंदणी तथा / Register of Marriage
                                        p ग्रामपंचायत अधिकारी तथा सचिव/ Gramsevak/Village Development Officer  




