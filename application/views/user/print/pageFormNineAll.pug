						th(width='') मागील सामान्य पाणी कर 
						th(width='') चालू सामान्य पाणी कर 
						th(width='') एकूण सामान्य पाणी कर 

						th(width='') संपूर्ण पाणी कर 

						th(width='') संपूर्ण एकूण कर

					tr(style='font-size: 1.2rem !important')
						td.srNo(width='') 1
						td(width='') 2
						td(width='') 3
						td(width='') 4 
						td(width='') 5

