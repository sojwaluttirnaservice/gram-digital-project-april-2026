						td(width='') 35
						td(width='') 36
						td(width='') 37

				tbody


					-
						let totalLastBuildingTax = 0;
						let totalCurrentBuildingTax = 0;

						let totalLastTaxFine = 0;

						let totalLastDivaTax = 0;
						let totalCurrentDivaTax = 0;

						let totalLastArogyaTax = 0;
						let totalCurrentArogyaTax = 0;

						let totalLastEducationTax = 0;
						let totalCurrentEducationTax = 0;

						let totalLastCleaningTax = 0;
						let totalCurrentCleaningTax = 0;

						let totalLastFireblegateTax = 0;
						let totalCurrentFireblegateTax = 0;

						let totalLastTreeTax = 0;
						let totalCurrentTreeTax = 0;

						let totalTotalSamanyaTax = 0;

						let totalLastSpecialWaterTax = 0;
						let totalCurrentSpecialWaterTax = 0;

						let totalLastGeneralWaterTax = 0;
						let totalCurrentGeneralTax = 0;


						let totalTotalWaterTax = 0;

						let totalSamanyaPlusWaterTax = 0;

					each el, i in data 
						tr.body-f-size
							td #{i+1}
							td #{el.feu_malmattaNo}
							td #{el.feu_homeNo}
							td #{el.feu_ownerName}
							td #{el.feu_secondOwnerName}
							td #{el.feu_mobileNo}

							- totalLastBuildingTax += el.lastBuildingTax
							td #{el.lastBuildingTax} 
							- totalCurrentBuildingTax += el.currentBuildingTax
							td #{el.currentBuildingTax}
							td #{el._totalBuildingTax}


							- totalLastTaxFine += el.lastTaxFine
							td #{el.lastTaxFine}

							- totalLastDivaTax += el.lastDivaTax					
							td #{el.lastDivaTax} 
							- totalCurrentDivaTax += el.currentDivaTax
							td #{el.currentDivaTax}
							td #{el._totalDivaTax}

							- totalLastArogyaTax += el.lastArogyaTax
							td #{el.lastArogyaTax}
							- totalCurrentArogyaTax += el.currentArogyaTax	
							td #{el.currentArogyaTax}
							td #{el._totalArogyaTax}

							- totalLastEducationTax += el.lastEducationTax
							td #{el.lastEducationTax}
							- totalCurrentEducationTax += el.currentEducationTax
							td #{el.currentEducationTax}
							td #{el._totalEducationTax}

							- totalLastCleaningTax += el.lastCleaningTax
							td #{el.lastCleaningTax}
							- totalCurrentCleaningTax += el.currentCleaningTax
							td #{el.currentCleaningTax}
							td #{el._totalCleaningTax}

							- totalLastFireblegateTax += el.lastFireblegateTax
							td #{el.lastFireblegateTax}
							- totalCurrentFireblegateTax += el.currentFireblegateTax
							td #{el.currentFireblegateTax}
							td #{el._totalFireblegateTax}

							- totalLastTreeTax += el.lastTreeTax
							td #{el.lastTreeTax}
							- totalCurrentTreeTax += el.currentTreeTax
							td #{el.currentTreeTax}
							td #{el._totalTreeTax}


							- totalTotalSamanyaTax += el._totalSamanyaTax
							td #{el._totalSamanyaTax}


							- totalLastSpecialWaterTax += el.lastSpacialWaterTax
							td #{el.lastSpacialWaterTax}
							- totalCurrentSpecialWaterTax += el.currentSpacialWaterTax
							td #{el.currentSpacialWaterTax}
							td #{el._totalSpacialWaterTax}

							- totalLastGeneralWaterTax += el.lastGenealWaterTax
							td #{el.lastGenealWaterTax}
							- totalCurrentGeneralTax += el.currentGenealWaterTax
							td #{el.currentGenealWaterTax}
							td #{el._totalGenealWaterTax}


							- totalTotalWaterTax += el.totalWaterTax
							td #{el.totalWaterTax}

							- totalSamanyaPlusWaterTax += (el._totalSamanyaTax + el.totalWaterTax)
							td #{el._totalSamanyaTax + el.totalWaterTax}
						- numbers++;



					//- tfoot 
					tr 
						//- index
						th(colspan='5') Total 
						//- malmatta
						//- th 
						//- home no
						//- th 
						//- owner
						//- th 
						//- second owner name
						//- th

						//- building taxes 
						th #{totalLastBuildingTax}
						th #{totalCurrentBuildingTax}
						th #{totalLastBuildingTax + totalCurrentBuildingTax}

						//- lastTAxfine
						th #{totalLastTaxFine}

						//- diva Taxes
						th #{totalLastDivaTax}
						th #{totalCurrentDivaTax}
						th #{totalLastDivaTax + totalCurrentDivaTax}

						//- arogya Taxes
						th #{totalLastArogyaTax}
						th #{totalCurrentArogyaTax}
						th #{totalLastArogyaTax + totalCurrentArogyaTax}


						//- education
						th #{totalLastEducationTax}
						th #{totalCurrentEducationTax}
						th #{totalLastEducationTax + totalCurrentEducationTax}

						//- cleaning
						th #{totalLastCleaningTax}
						th #{totalCurrentCleaningTax}
						th #{totalLastCleaningTax + totalCurrentCleaningTax}

						//- fireblegate
						th #{totalLastFireblegateTax}
						th #{totalCurrentFireblegateTax}
						th #{totalLastFireblegateTax + totalCurrentFireblegateTax}

						//- tree tax
						th #{totalLastTreeTax}
						th #{totalCurrentTreeTax}
						th #{totalLastTreeTax + totalCurrentTreeTax}

						//- total Samanya tax
						th #{totalTotalSamanyaTax}

						//- special water tax
						th #{totalLastSpecialWaterTax}
						th #{totalCurrentSpecialWaterTax}
						th #{totalLastSpecialWaterTax + totalCurrentSpecialWaterTax}

						//- general water tax
						th #{totalLastGeneralWaterTax}
						th #{totalCurrentGeneralTax}
						th #{totalLastGeneralWaterTax + totalCurrentGeneralTax}

						//- totaltotalWAterTax ()
						th #{totalTotalWaterTax}

						//- samanya plus water
						th #{totalSamanyaPlusWaterTax}
