doctype html
head
	title नमुना ९ वसुली यादी (सामान्य व पाणी कर) इ.दि.आ.स्व.कर
	meta(charset='UTF-8')
	meta(name='viewport' content='width.p-1.m-0=device-width.p-1.m-0, initial-scale=1.0')
	meta(http-equiv='X-UA-Compatible' content='ie=edge')
	// common css
	link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')

	style.

		@media print {
			@page{
				//- size: legal landscape;
				size: landscape;
			}
			.my-print{
				position: relative;
				page-break-before: always;
				margin: 0 auto;
			}
			table{
				//- page-break-inside: avoid;
			}
			.waterMark{
				position: absolute;
				opacity: 0.3;
				width: 100%;
				height: 100%;
			}
		}

		table, th, td{
			border: 1px solid black;
			padding: 3px; 
			text-align:center;
		}
		.body-f-size {
			font-size: 1rem !important;
		}
		.head-f-size {
			font-size: 15px;
			text: bold;
			text-align: center;
		}
		.center{
			text-align: center;
		}
		.form9Heading{
			font-size: 1.4rem;
			font-weight: bold; 
			color: red;
		}
		.waterMark{
			position: absolute;
			opacity: 0.3;
			top: calc(50% - 180px);
			left: calc(50% - 250px);
			width: 500px;
			height: 500px;
		}
		.my-print {
			position: relative; 
			width: 100%;
		}
body  
	- let numbers = 0;
		.my-print
			img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")
			div.d-flex.justify-content-between.pt-4.pb-4.mx-3
				div.d-flex.flex-column.justify-content-center.align-items-center.text-align-center
					img(src="/img/header-images/mudra-nav.jpg" width="95" height="40")
				div.d-flex.justify-content-center.text-center.flex-column
					p.m-0.p-0.form9Heading ग्राम पंचायत कार्यालय #{zp.gp_name} पंचायत समिती  #{zp.gp_taluka} जिल्हा #{zp.gp_dist} 
					p.m-0.p-0.form9Heading वसुली नोंद वही #{year.year1}- #{year.year2}
				div.d-flex.flex-column.justify-content-center.align-items-center
					img.float-right(src="/img/header-images/g-sevalogo-new.jpeg" width="100" height="40")

			table(style="width:100% !important; height:100%;")
				thead
					tr.head-f-size
						th.srNo(width='') अनु.क्र. 
						th(width='') मा.क्र.
						th(width='') जुना मा.क्र.
						th(width='') मालकाचे नाव 
						th(width='') भोगवटदाराचे नाव
