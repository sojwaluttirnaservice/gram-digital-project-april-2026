							td #{el.feu_mobileNo}

							- totalLastBuildingTax += el.lastBuildingTax
							td(style='width:6%') #{el.lastBuildingTax}
							- totalCurrentBuildingTax += el.currentBuildingTax
							td(style='width:6%') #{el.currentBuildingTax}
							td(style='width:6%') #{el._totalBuildingTax}

							- totalLastTaxFine += el.lastTaxFine
