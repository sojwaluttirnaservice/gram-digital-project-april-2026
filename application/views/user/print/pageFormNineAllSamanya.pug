doctype html
head
	title (नमुना ९ वसुली यादी (सामान्य व पाणी कर))
	meta(charset='UTF-8')
	meta(name='viewport' content='width.p-1.m-0=device-width.p-1.m-0, initial-scale=1.0')
	meta(http-equiv='X-UA-Compatible' content='ie=edge')
	// common css
	//- link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')

	style.

		*{
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		@media print {
			@page{
				//- size: A4 landscape;
				size: landscape;
				padding: 1rem;
			}
			.my-print{
				position: relative;
				page-break-before: always;
				margin: 0 auto;
			}
			table{
				//- page-break-inside: avoid;
			}
			.waterMark{
				position: absolute;
				opacity: 0.3;
				width: 100%;
				height: 100%;
			}
			#hide-buttons {
				display: none;
			}
		}

		table, th, td{
			border: 1px solid black;
			padding: 3px; 
			text-align:center;
			border-collapse: collapse;
		}
		.body-f-size {
			font-size: 1rem !important;
		}
		.head-f-size {
			font-size: 15px;
			text: bold;
			text-align: center;
		}
		.center{
			text-align: center;
		}
		.form9Heading{
			font-size: 1.4rem;
			font-weight: bold; 
			color: red;
		}
		.waterMark{
			position: absolute;
			opacity: 0.3;
			top: calc(50% - 180px);
			left: calc(50% - 250px);
			width: 500px;
			height: 500px;
		}
		.my-print {
			position: relative; 
			width: 100%;
		}
