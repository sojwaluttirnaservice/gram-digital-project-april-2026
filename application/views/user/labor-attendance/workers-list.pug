doctype html
head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    title #{title}

    // Common CSS
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
    link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

    // Scripts
    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")  
    script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js") 
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src='/asstest/coustom/js/labor-attendance/labor-attendance-worker-list-handler.js')

    script.
        $(function() {
            $(document).on('click','#open-month-year-modal-btn', function(e){
                e.preventDefault();
                $('#monthYearModal').modal('show');
            });
        })

    style.
        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#f0d688 !important;
        }
        body{
            
            height:100vh;
        }
        @media (min-width: 576px) {
            .modal-dialog { 
                max-width: none; 
            }
        }
        .modal-dialog {
            width: 98%;
            height: 92%;
            padding: 0;
        }

body
    include ../include/navs.pug

    //- .modal.fade#monthYearModal(tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true")
        .modal-dialog
            .modal-content(style='max-width: 600px').mx-auto
                .modal-header
                    h4.modal-title.fs-5#exampleModalLabel महिना वर्ष निवडा
                    button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
                .modal-body
                    .row.justify-content-center
                        .col-3
                            input.form-control(type='text' name='year' placeholder='Year')
                .modal-footer
                    button.btn.btn-primary(type="button" id='print-bpl-work-record-btn') प्रिंट करा

    .container-fluid

        if !work 
            h2.mt-4.text-center सदर कामाची कोणतीही नोंद मिळाली नाही
        else
            .row
                .col-12.mt-3
                    h4.ml-5.text-center
                        span.fa.fa-id-card
                        | &nbsp; मजुरांची यादी


                        a(href=`/labor-attendance/workers/${work.id}/create`).float-right.btn.btn-primary.btn-sm.mr-2
                            span.fa.fa-plus
                            |  सदर कामासाठी नवीन कामगार जोडा 

                        a(href="/labor-attendance/work/list").float-right.btn.btn-primary.btn-sm.mr-2
                            |  कामांची यादी 
                       
                        a(href=`/labor-attendance/work/edit/${work.id}`).float-right.btn.btn-primary.btn-sm.mr-2
                            span.fa.fa-edit
                            |  कामाची माहिती एडिट करा  

                .col-12
                    .px-3
                        div(class='my-4 p-2 row justify-content-between' style='row-gap:0.4rem; border: 1px solid gray; background:white; border-radius: 0.3rem;')
                            div.col-6.col-md-4
                                span.font-weight-bold कामाचे नाव :  
                                span #{work.name}
                            
                            div.col-6.col-md-3 
                                span.font-weight-bold प्रारंभ दिवस :
                                span #{work._start_date}

                            div.col-6.col-md-3 
                                span.font-weight-bold अंतिम दिवस :
                                span #{work._end_date}
                            
                            div.col-6.col-md-2
                                //- span.font-weight-bold
                                a.btn.btn-primary.btn-sm(href=`/labor-attendance/print/${work.id}` target="_blank") कामाच्या हजेरीची प्रत

                .col-12
                    .table-responsive(style='margin-bottom: 5rem;')
                        table.table.table-bordered.text-center
                            thead
                                tr.bg-success.text-white
                                    th(width="5%") अ. क्र.
                                    th(width="20%") कामगाराचे नाव 
                                    th(width="20%") कामगाराचा संपर्क
                                    th(width="10%") मजुरी दर (प्रति दिवस)
                                    th(width="10%") दंड
                                    th(width="15%") Action

                            tbody#worksList
                                if workers == null || workers.length == 0
                                    tr 
                                        td(colspan='9') कोणतीही नोंद उपलब्ध नाही.
                                else 
                                    each worker, index in workers 
                                        tr 
                                            td #{index + 1}
                                            td #{worker.worker_name}
                                            td #{worker.worker_phone ? worker.worker_phone : '-'}
                                            td #{worker.daily_rate}
                                            td #{worker.fine}
                                            td
                                                div(class='d-flex align-items-center justify-content-center')
                                                    a.btn.text-primary(href=`/labor-attendance/workers/edit/${worker.id}` target="_self")
                                                        i.fa.fa-edit

                                                    button.btn.text-danger(class='delete-labor-worker-btn' data-laborWorkerId=`${worker.id}`)
                                                        i.fa.fa-trash

                                                    a.btn.text-primary(href=`/labor-attendance/attendance/sheet/${work.id}/${worker.id}` target="_self")
                                                        
                                                        svg(xmlns="http://www.w3.org/2000/svg", width="20", height="20" fill='blue' viewBox="0 0 640 640")
                                                            path(d="M256 72C322.3 72 376 125.7 376 192C376 258.3 322.3 312 256 312C189.7 312 136 258.3 136 192C136 125.7 189.7 72 256 72zM226.3 368L285.7 368C289.6 368 293.6 368.1 297.5 368.4C281.3 396.6 272 429.2 272 464C272 505.8 285.4 544.5 308 576L77.7 576C61.3 576 48 562.7 48 546.3C48 447.8 127.8 368 226.3 368zM320 464C320 384.5 384.5 320 464 320C543.5 320 608 384.5 608 464C608 543.5 543.5 608 464 608C384.5 608 320 543.5 320 464zM464 384C455.2 384 448 391.2 448 400L448 464C448 472.8 455.2 480 464 480L512 480C520.8 480 528 472.8 528 464C528 455.2 520.8 448 512 448L480 448L480 400C480 391.2 472.8 384 464 384z")

                                                    //- for printing the attendance report for corresponding work and workre id 
                                                    //- a.btn.text-primary(href=`/labor-attendance/attendance/sheet/${work.id}/${worker.id}` target="_blank")
                                                        i.fa.fa-print