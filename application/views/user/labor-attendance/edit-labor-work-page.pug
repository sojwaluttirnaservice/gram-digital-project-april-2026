doctype html
html(lang='en')
    head

        title #{title}
        meta(charset='UTF-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        meta(http-equiv='X-UA-Compatible' content='ie=edge')
        //- Common CSS
        link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
        link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
        link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
        link(rel='stylesheet' href='/asstest/coustom/css/main.css')
        link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')
        link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

        //- Scripts
        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script(src='/asstest/plugins/popper/popper.min.js')
        script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
        script(src='/asstest/plugins/date/jquery-ui.js')
        script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
        script(src='/asstest/plugins/notify/notify.js')
        script(src='/asstest/plugins/jquery_validation/jquery.validate.min.js')
        script(src='/asstest/plugins/jquery_validation/additional-methods.js')
        script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js')
        script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
        script(src='/asstest/plugins/select/js/select2.full.min.js')
        script(src='/asstest/coustom/js/base.converter.js')
        script(src='/asstest/coustom/js/common.js')

        link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
        link(href='/asstest/coustom/css/forms/form.css' rel='stylesheet')
        link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/labor-attendance/labor-attendance-work-form-handler.js')


    body.w-100
        include ../include/navs.pug

        section
            .container
                h2.heading-1.text-center Edit कामाची नोंदणी


                if !work
                    h4.text-center सदर कामाबद्दल कोणतीही माहिती मिळाली नाही. चुकीचा आयडी.

                else

                    .text-end
                        a.btn.btn-primary.mr-2(href=`/labor-attendance/workers/list/${work.id}`) कामगाराची यादी
                        a.btn.btn-primary.text-light(href='/labor-attendance/work/list') कामाची यादी बघा

                    form(id='labor-attendance-work-form')
                        .form.form-1
                            .row.justify-content-center.gx-4.gy-2

                                //- // Applicant Name
                                .col-12.col-md-6
                                    label.form-label कामाचे नाव
                                    input.form-control(type='text' name='name' placeholder='अर्जदाराचे पूर्ण नाव', value=work.name required)

                                //- // Amount
                                .col-12.col-md-6
                                    label.form-label कामाचे स्थळ
                                    input.form-control(type='text' name='location' placeholder='उदा. 5000', value=work.location required)

                                //- // Amount in Words
                                .col-12.col-md-6
                                    label.form-label प्रारंभ दिनांक
                                    input.form-control.datepicker(type='text' name='start_date' placeholder='उदा. 25-05-2025' autocomplete='off' value=work._start_date)

                                //- // Court Date
                                .col-12.col-md-6
                                    label.form-label अंतिम दिनांक
                                    input.form-control.datepicker(type='text' name='end_date' placeholder='उदा. 25-05-2025' autocomplete='off' value=work._end_date)

                                    input.form-control(name='id' value=work.id hidden)

                                //- // Month
                                //- .col-12.col-md-3
                                    label.form-label महिना (1 ते 12)
                                    input.form-control(type='number' name='month' min='1' max='12' required)

                                //- // Year
                                //- .col-12.col-md-3
                                    label.form-label वर्ष
                                    input.form-control(type='number' name='year' min='2020' max='2099' required)

                                //- // Submit Button
                                .col-12.text-center.mt-4
                                    button.btn.btn-success#update-labor-attendance-work-btn(type='click') अपडेट करा
