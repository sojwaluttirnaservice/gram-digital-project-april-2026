doctype html
html(lang='en')
    head

        title #{title}
        meta(charset='UTF-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        meta(http-equiv='X-UA-Compatible' content='ie=edge')
        //- Common CSS
        link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
        link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
        link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
        link(rel='stylesheet' href='/asstest/coustom/css/main.css')
        link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')
        link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

        //- Scripts
        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script(src='/asstest/plugins/popper/popper.min.js')
        script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
        script(src='/asstest/plugins/date/jquery-ui.js')
        script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
        script(src='/asstest/plugins/notify/notify.js')
        script(src='/asstest/plugins/jquery_validation/jquery.validate.min.js')
        script(src='/asstest/plugins/jquery_validation/additional-methods.js')
        script(src='https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js')
        script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
        script(src='/asstest/plugins/select/js/select2.full.min.js')
        script(src='/asstest/coustom/js/base.converter.js')
        script(src='/asstest/coustom/js/common.js')

        link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')
        link(href='/asstest/coustom/css/forms/form.css' rel='stylesheet')
        link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/labor-attendance/labor-attendance-worker-form-handler.js')

    body.w-100
        include ../include/navs.pug

        section
            .container
                h2.heading-1.text-center नवीन कामगाराची नोंदणी करा
                .text-end
                    a.btn.btn-primary.mr-2(href=`/labor-attendance/workers/list/${work.id}`) कामगाराची यादी  
                    a.btn.btn-primary.text-light(href='/labor-attendance/work/list') कामाची यादी बघा



                form(id='worker-form')
                    if !worker 
                        h4.text-center कोणत्याही कर्मचाऱ्याची नोंद मिळाली नाही.

                    else
                        div(class='d-flex align-items-center gap-2 justify-content-between')
                            p 
                                span.fw-bold कामाचे नाव :  
                                span #{work.name}

                            p 
                                span.fw-bold प्रारंभ दिवस :
                                span #{work._start_date}

                            p 
                                span.fw-bold अंतिम दिवस :
                                span #{work._end_date}


                        .form.form-1
                            .row.justify-content-center.gx-4.gy-2

                                //- // Applicant Name
                                .col-12.col-md-6
                                    label.form-label कामगाराचे नाव
                                    input.form-control(type='text' name='worker_name' placeholder='कामगाराचे पूर्ण नाव', value=worker.worker_name required)

                                //- // Amount
                                .col-12.col-md-6
                                    label.form-label कामगाराचा मोबाईल क्र. (Optional)
                                    input.form-control(type='text' name='worker_phone' placeholder='e.g. 9898198232' maxlength='10' value=worker.worker_phone)

                                //- // Amount in Words
                                .col-12.col-md-6
                                    label.form-label कर्मचाऱ्याचा आधार क्र. (Optional)
                                    input.form-control(type='text' name='worker_aadhar' placeholder='' autocomplete='off' maxlength='12' value=worker.worker_aadhar)

                                //- // Court Date
                                .col-12.col-md-6
                                    label.form-label प्रति दिवस मजुरी (रु.)
                                    input.form-control(type='number' name='daily_rate' placeholder='' autocomplete='off' min='0' max='10000' value=worker.daily_rate)



                                //- Fine
                                .col-12.col-md-6
                                    label.form-label दंड 
                                    input.form-control(type='number' name='fine' value=worker.fine min="0")

                                    input.form-control(hidden name='work_id_fk' value=worker.work_id_fk)
                                    input.form-control(hidden name='id' value=worker.id)

                                .col-12.col-md-6
                                    //- label

                                //- // Submit Button
                                .col-12.text-center.mt-4
                                    button.btn.btn-success#update-worker-btn(type='click') अपडेट करा
