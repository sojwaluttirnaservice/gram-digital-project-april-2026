    //- extras
    script(src='/asstest/plugins/select/js/select2.full.min.js')
    //- common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')

    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN' crossorigin='anonymous')
    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js' integrity='sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL' crossorigin='anonymous')

    link(href='/asstest/coustom/css/gp-notice/gp-atikraman-notice-form.css' rel='stylesheet')
    link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
    script(src='/asstest/coustom/js/handlers/gp-notice/gp-atikraman-notice-form-handler.js')


body.w-100
    include ../include/navs.pug


    section 
        .container 
            h2.heading-1.text-center  अतिक्रमण नोटीस फॉर्म 

       
            form(id='gp-atikraman-notice-form')

                .form.form-1

                    .row.justify-content-center.justify-content-md-between.gx-4.gy-2
                        .col-11.col-md-6.col-lg-6
                            .form-group 
                                label.form-label(for="") नाव
                                input.form-control.is-number(type='text' name='name'   required)

                        .col-11.col-md-6.col-lg-6
                            .form-group 
                                label.form-label(for="") पत्ता
                                input.form-control.is-number(type='text' name='address' required)

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="") दिनांक
                                input.form-control.is-number(type='text' name='date' required autocomplete='off')

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="") मालमत्ता क्रमांक
                                input.form-control.is-number(type='text' name='malmatta_no' required)

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="") पूर्वेस
                                input.form-control.is-number(type='text' name='east_landmark'   required)

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="")  पच्छिमेस
                                input.form-control.is-number(type='text' name='west_landmark' required)

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="")  उत्त्तरेस
                                input.form-control.is-number(type='text' name='north_landmark' required)
                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="")  दक्षिणेस
                                input.form-control.is-number(type='text' name='south_landmark' required)

                        .col-11.col-md-6.col-lg-4
                            .form-group 
                                label.form-label(for="")  रोडचे नाव
                                input.form-control.is-number(type='text' name='road_name' required)





                .button-container 
                    button.btn.btn-primary(type='button' id='save-gp-atikraman-notice-btn') Save
                    
