        .row.p-0.p-1.pt-3
            .col-12
                center
                    a(href="/gp-notice/gp-atikraman-notice-form").float-right.btn.btn-primary.btn-sm.mr-2 अतिक्रमण नोटीस नोंदणी 

                    h5.font-weight-bold.m-3 अतिक्रमण नोटीस यादी

            .col-12
                div.table-responsive
                    table.table.table-bordered.text-center.m-0
                        thead
                            tr.bg-primary.text-white
                                th(width="8%") अनु क्र 
                                th(width='10%') दिनांक
                                th(width="25%") नाव
                                th(width="15%") सुधारणा
                                th(width="15%") काढा
                                th(width="10%") अतिक्रमण नोटीस प्रिंट 
                                th(width="10%") पंचनामा नोटीस प्रिंट 
                        tbody
                            if(gpAtikramanNoticeList.length == 0)
                                tr
                                    td(colspan="15").text-center.text-danger नवीन अर्ज नोंदणी यादी रिकामी आहे
                            else
                                each _notice, _index in gpAtikramanNoticeList
                                    tr
                                        td(width="8%") #{_index+1}
                                        td(width="25%") #{_notice._date}
                                        td(width="15%") #{_notice.name}

                                        td(width='5%')
                                            a.btn(href=`/gp-notice/edit-gp-atikraman-notice-form/${_notice.id}` style='font-size: 1.3rem')
                                                i.fa.fa-pencil-square.text-success

                                        td(width="15%") 
                                            button.btn(class='delete-gp-atikraman-notice-btn' data-noticeId=_notice.id style='font-size: 1.3rem')
                                                i.fa.fa-trash.text-danger
                                        td(width="15%") 
                                            a.btn(href=`/gp-notice/gp-atikraman-notice-print/${_notice.id}` style='font-size: 1.3rem')
                                                i.fa.fa-print.text-primary
                                        td(width="15%")
                                            a.btn(href=`/gp-notice/gp-panchnama-notice-print/${_notice.id}` style='font-size: 1.3rem')
                                                i.fa.fa-print.text-primary
                                        
                                        

