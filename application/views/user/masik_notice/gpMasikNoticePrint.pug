                            div.col-12
                                p.ml-5.mb-1 या शिवाय अधाक्ष्यांच्या परवानगीने वेळेवर येणार विषय

                .col-12
                    .footer
                        .d-flex.flex-column.justify-content-center.align-items-end.font-weight-bold.pr-5
                            //- Removed signature
                            //- img(src="/print/sp1.jpeg" alt="" class='sarpanchaSign')
                            p.mb-3.mr-5 सरपंच 
                            p.mb-3 ग्रामपंचायत कार्यालय #{gp.gp_name} प. स. #{gp.gp_taluka}
