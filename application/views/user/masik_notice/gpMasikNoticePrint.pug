    script(src="/asstest/plugins/qrcodejs/qrcode.min.js")

    script.
        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('date-input').addEventListener('input', function(e){

                e.preventDefault();
                const dateValue = new Date(e.target.value);

                const formattedDate = ("0" + dateValue.getDate()).slice(-2) + "/" +
                    ("0" + (dateValue.getMonth() + 1)).slice(-2) + "/" +
                    dateValue.getFullYear();

                const noticeDateElements = document.querySelectorAll('.notice-print-date');

                noticeDateElements.forEach(element => {
                    element.textContent = formattedDate;
                });
            })
        })

body
    -const marathiDayNames = ['रविवार', 'सोमवार', 'मंगळवार', 'बुधवार', 'गुरुवार', 'शुक्रवार', 'शनिवार'];
    -const marathiDayNamesSuffix = ['रविवारी', 'सोमवारी', 'मंगळवारी', 'बुधवारी', 'गुरुवारी', 'शुक्रवारी', 'शनिवारी'];

    input(id="date-input" name="date_input" type="date")

    - let _members = memberList.filter((_m) => (_m && (_m.p_name == "सरपंच" || _m.p_name == "उपसरपंच" || _m.p_name == 'ग्रामसेवक' || _m.p_name == 'ग्रामविकास अधिकारी' || _m.p_name == 'ग्रामपंचायत अधिकारी' || _m.p_name == "सदस्य/सदस्या")))

    each member, i in _members 
        div
            .my-print.m-0.p-0(style='gap: 3rem;')
                - 
                    let _date = notice.notice_date.split('/');
                    let _noticeDate = [_date[1], _date[0], _date[2]].join('/')
                if showWatermark == true || showWatermark == "true"
                    img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")
                .col-12
                    .title-section
                        .d-flex.justify-content-center.align-items-center.flex-column
                            h1.text-red.mb-3 ग्रामपंचायत कार्यालय #{gp.gp_name}
                            h2.text-red पंचायत समिती #{gp.gp_taluka}, जिल्हा #{gp.gp_dist}

                .col-12
                    .date-section
                        .d-flex.justify-content-center.align-items-center(style='gap: 1.5rem')
                            p.mb-2 #{sabhaDetails.sabhaType}  क्रमांक: #{notice.notice_number === 0 ? '   -   ' : notice.notice_number}
                            p.mb-2 दिनांक: 
                                span.text-red(class="notice-print-date") #{_noticeDate}
                            p.mb-2 सभासद ग्रामपंचायत

                - let months = ["January","February","March","April","May","June","July","August","September","October","November","December"]

                .col-12
                    .notice-text
                        p.font-weight-bold.mb-1 प्रती ,
                        p.mb-1.font-weight-bold &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
                            if (member.p_name == 'ग्रामसेवक' || member.p_name == 'ग्रामविकास अधिकारी' || member.p_name == 'ग्रामपंचायत अधिकारी')
                                | कार्यालयीन प्रत
                            else 
                                | श्री / श्रीमती - #{member.name} (#{member.p_name}) ( आधार न. - #{member.sadasyaAadhar} ) ( मो न. - #{member.sadasyaMobile} )
                            
                        if sabhaDetails.sabhaType == "महिला सभा" || sabhaDetails.sabhaType == "तहकुभ महिला सभा"
                            //- h4.sabhaVishayHeading.text-red जाहीर नोटिस 
                            p.sabhaVishayHeading ** 
                                span.text-red महिला सभा 
                                | ** 
                            p.mb-4(style='line-height: 2;') ग्रामपंचायत 
                                span.font-weight-bold #{gp.gp_name} 
                                | अंतर्गत 
                                span.font-weight-bold #{gp.gp_name} 
                                | येथील सर्वत्र महिला नागरिकांना सूचित करण्यात येते कि, ग्रामपंचायत 
                                span.font-weight-bold #{gp.gp_name} 
                                | खालील प्रमाणे विषयास अनुसरून 
                                span.font-weight-bold #{sabhaDetails.sabhaType} 
                                | दिनांक 
                                span.font-weight-bold.text-red #{_noticeDate} 
                                | रोजी 
                                span.font-weight-bold #{notice.notice_scheule} #{notice.notice_time} 
                                | वाजता, 
                                span.font-weight-bold #{notice.notice_place}  
                                | येथे घेण्यात येणार आहे, तेरी सर्वत्र महिला भगिनींनी महिला सभेला हजार राहावे, ही विनंती. 

                            p.sabhaVishayHeading ** विषय ** 
                            ol 
                                li मागील ग्रामसभेचे कामकाज वाचून कायम करणे.
                                li दिनांक #{_noticeDate} चे ग्राम सभेतील विषयावर चर्चा करणे 
                                li आमचा गाव आमचा विकास सन #{_date[2]} - #{Number(_date[2]) + 1} चा कृती आराखडा तयार करणे
                                li या शिवाय अधाक्ष्यांच्या परवानगीने वेळेवर येणार विषय
                                each subject in noticeSubject   
