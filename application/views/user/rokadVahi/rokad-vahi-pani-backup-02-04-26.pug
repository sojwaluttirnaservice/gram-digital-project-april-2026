extends ../master-layout/master-layout
block custom_js
    script(src='/asstest/coustom/js/handlers/rokadVahiManger.js')

block internal_css
    style.
        @media print {
            @page{
                size: A4 landscape;
            }
        }

        .waterMark{
            position: absolute;
            opacity: 0.3;
            top: calc(50% - 250px);
            left: calc(50% - 250px);
            width: 500px;
            height: 500px;
        }

        body {
            height: 210mm; 
            width: 297mm;
            //- border: 1px solid black;
        }
        .my-print{
            position: relative;
            padding: 5px !important;
        }

        .fs-7 {
            font-size: 0.8rem !important;
        }
block content
    include ./year-dropdown-component.pug

    .my-print.m-0.p-0.d-flex.flex-column
        //- img.waterMark(src="/img/water-mark-images/Seal_of_Maharashtra.png")
        div
            div.d-flex.justify-content-between.pt-2.pb-2
                div.d-flex.flex-column.justify-content-center.align-items-center.text-align-center
                    img(src="/img/header-images/mudra-nav.jpg" width="95" height="40")
                    span.fw-semibold 
                    span.fw-semibold वर्ष- 2023
                div.d-flex.flex-column.align-items-center.justify-content-center
                    p.fw-semibold ग्रामपंचायत कार्यालय #{gp.gp_name} प. स. #{gp.gp_dist} 
                    p.fw-semibold(style='font-size:0.6rem;') महा. ग्रा. पं. लेखा संहिता २०११ (नियम २१,२२ (२),(३),(४),(५), व (६),२५(१),३२(५),३३(२),(३),व (४)(च),३६(२)३८(१) आणि ६६(१) पहा)
                    p.fw-bold.fs-4 दैनिक रोकड वही (पाणी)

                div.d-flex.flex-column.justify-content-center.align-items-center
                    img.float-right(src="/img/header-images/g-sevalogo-new.jpeg" width="115" height="40")
                    p.fw-semibold पान क्र:- 
        div
            table.table.table-bordered
                thead 
                    tr.text-center
                        th.fs-7(rowspan="3") अनु.क्र.
                        th.fs-7(rowspan="3") पावती क्रमांक 
                        th.fs-7(rowspan="3") कोणाकडून मिळाली ते
                        th.fs-7(rowspan="3") मोबाईल न.

                        th.fs-7(rowspan="1" colspan="6") जमा रकमेचा तपशील

                        th.fs-7(rowspan="3") प्रमाणपत्र नाव
                        th.fs-7(rowspan="3") रुपये
                        th.fs-7(rowspan="3") पेमेंट मोड
                        th.fs-7(rowspan="3") दिनांक
                        th.fs-7(rowspan="3") शेरा

                    tr 

                        //- 
                        //- 
                        //- 
                        //- 

                        th.fs-7(rowspan="1" colspan="3") मागील पाणी कर
                        th.fs-7(rowspan="1" colspan="3") चालू पाणी कर



                    tr 
                        //- 
                        //- 
                        //- 
                        //- 

                        th.fs-7(rowspan="1" colspan="1") सामान्य 
                        th.fs-7(rowspan="1" colspan="1") विशेष 
                        th.fs-7(rowspan="1" colspan="1") एकूण 

                        th.fs-7(rowspan="1" colspan="1") सामान्य 
                        th.fs-7(rowspan="1" colspan="1") विशेष 
                        th.fs-7(rowspan="1" colspan="1") एकूण 


                    - let totalCols = 15;
                    tr.text-center
                        each _, _index in Array.from({length: totalCols})
                            th #{_index + 1}
                tbody.rokadVahiData
                    if((!paymentDetails || paymentDetails.length == 0))
                        tr 
                            td.text-center.fw-bold(colspan=totalCols) माहिती उपलब्ध नाही
                    else
                        each detail, index in paymentDetails
                            - let pramanpatra_name

                            case detail.payment_for
                                when 1
                                    - pramanpatra_name = 'सामान्य कर पावती'
                                    break
                                when 2
                                    - pramanpatra_name = 'पाणी कर पावती'
                                    break
                                when 3
                                    - pramanpatra_name = 'विवाह नोंदणी प्रमाणपत्र'
                                    break
                                when 4
                                    - pramanpatra_name = 'रहिवासी स्वयंघोषितपत्र'
                                    break
                                when 5
                                    - pramanpatra_name = 'नमुना ८ प्रिंट'
                                    break
                                when 6
                                    - pramanpatra_name = 'थकबाकी/निराधार प्रमाणपत्र'
                                    break
                                default
                                    - pramanpatra_name = '-'
                                    break

                            tr 
                                th #{index + 1} 
                                th #{detail.id}
                                th #{detail.recipient_name}
                                th -
                                
                                //- td #{detail.tpl_lastGenealWaterTax}
                                //- td #{detail.tpl_lastSpacialWaterTax}
                                //- //- sum of above of 2
                                //- td #{}

                                //- td #{detail.tpl_currentGenealWaterTax}
                                //- td #{detail.tpl_currentSpacialWaterTax}
                                //- //- sum of above of 2
                                //- td #{}

                                - const lg = detail.tpl_lastGenealWaterTax;
                                - const ls = detail.tpl_lastSpacialWaterTax;

                                - const cg = detail.tpl_currentGenealWaterTax;
                                - const cs = detail.tpl_currentSpacialWaterTax;

                                - const lastWaterAllNull = [lg, ls].every(v => v == null);
                                - const currentWaterAllNull = [cg, cs].every(v => v == null);

                                - const lastWaterSum = (lg != null ? lg : 0) + (ls != null ? ls : 0);
                                - const currentWaterSum = (cg != null ? cg : 0) + (cs != null ? cs : 0);

                                td #{lg != null ? lg : '-'}
                                td #{ls != null ? ls : '-'}
                                td #{lastWaterAllNull ? '-' : lastWaterSum}

                                td #{cg != null ? cg : '-'}
                                td #{cs != null ? cs : '-'}
                                td #{currentWaterAllNull ? '-' : currentWaterSum}

                                th #{pramanpatra_name}
                                th #{detail.payment_amount}
                                th #{detail.payment_mode === 1 ? 'ऑनलाईन' : 'ऑफलाईन'}
                                - let _date = detail.payment_date.split('-').reverse().join('/')
                                th #{_date}
                                th -
