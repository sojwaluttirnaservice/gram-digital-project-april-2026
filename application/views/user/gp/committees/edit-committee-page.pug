doctype html
html(lang='en')
    head
        meta(charset='UTF-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        meta(http-equiv='X-UA-Compatible' content='ie=edge')


        title #{title}
        //- common css
        link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
        link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
        link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
        link(rel='stylesheet' href='/asstest/coustom/css/main.css')
        link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
        link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script(src='/asstest/plugins/popper/popper.min.js')
        script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
        script(src='/asstest/plugins/date/jquery-ui.js')  
        script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
        script(src='/asstest/plugins/notify/notify.js')
        script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
        script(src="/asstest/plugins/jquery_validation/additional-methods.js")  
        //-mask plugin jquery
        script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js") 

        //-toggle
        script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
        //- extras
        script(src='/asstest/plugins/select/js/select2.full.min.js')
        //- common js setups
        script(src='/asstest/coustom/js/base.converter.js')
        script(src='/asstest/coustom/js/common.js')

        link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN' crossorigin='anonymous')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js' integrity='sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL' crossorigin='anonymous')

        link(href='/asstest/coustom/css/gp/awards/award-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/handlers/gp/committees/committees-form-handler.js')


    body.w-100
        include ../../include/navs.pug

        section 
            .container
                div
                    h2.heading-1.text-center समिती फॉर्म Edit
                .text-end
                    a.btn.btn-primary.text-light(href='/committees') यादी बघा

                form(id='committee-form')
                    .form.form-1
                        .row.g-3
                            .col-md-6
                                .form-group
                                    label(for='committee_name') समितीचे नाव
                                    input.form-control#committee_name(type='text' name='committee_name' value=committee.committee_name placeholder='e.g निगराणी समिती' required)

                            .col-md-6
                                .form-group
                                    label(for='resolution_number') ठराव क्रमांक
                                    input.form-control#resolution_number(type='text' name='resolution_number' value=committee.resolution_number placeholder='' required)

                            .col-md-12
                                .form-group
                                    label(for='resolution_date') ठराव दिनांक
                                    input.form-control#resolution_date.datepicker(name='resolution_date' value=committee._resolution_date placeholder='')

                                    input(name='id' value=committee.id hidden)

                        .text-end.mt-3
                            button.btn.btn-success#update-committee-btn(type='submit') अपडेट करा
