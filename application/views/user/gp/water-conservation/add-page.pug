doctype html
html(lang='en')
    head
        meta(charset='UTF-8')
        meta(name='viewport' content='width=device-width, initial-scale=1.0')
        meta(http-equiv='X-UA-Compatible' content='ie=edge')
        title #{title}
        link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
        link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
        link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
        link(rel='stylesheet' href='/asstest/coustom/css/main.css')
        link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
        link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')

        script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
        script(src='/asstest/plugins/popper/popper.min.js')
        script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
        script(src='/asstest/plugins/date/jquery-ui.js')  
        script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
        script(src='/asstest/plugins/notify/notify.js')
        script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
        script(src="/asstest/plugins/jquery_validation/additional-methods.js")  
        //-mask plugin jquery
        script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js") 

        //-toggle
        script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
        //- extras
        script(src='/asstest/plugins/select/js/select2.full.min.js')
        //- common js setups
        script(src='/asstest/coustom/js/base.converter.js')
        script(src='/asstest/coustom/js/common.js')

        link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN' crossorigin='anonymous')
        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js' integrity='sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL' crossorigin='anonymous')

        link(href='/asstest/coustom/css/gp/water-conservation/water-conservation-form.css' rel='stylesheet')
        link(href='/asstest/coustom/css/namuna/common-new-form.css' rel='stylesheet')
        script(src='/asstest/coustom/js/handlers/gp/water-conservation/water-conservation-form-handler.js')
    body.w-100
        include ../../include/navs.pug
        section
            .container
                div
                    h2.heading-1.text-center जल संधारण संरचना फॉर्म
                .text-end
                    a.btn.btn-primary.text-light(href='/water-conservation') यादी बघा

                form(id='water-conservation-form')
                    .form.form-1
                        .row.g-3
                            .col-md-6
                                .form-group
                                    label(for='structure_name') संरचनेचे नाव
                                    input.form-control#structure_name(type='text' name='structure_name' required)
                            //- .col-md-6
                                .form-group
                                    label(for='village_name') गावाचे नाव
                                    input.form-control#village_name(type='text' name='village_name')
                            //- .col-md-6
                                .form-group
                                    label(for='taluka_name') तालुका
                                    input.form-control#taluka_name(type='text' name='taluka_name')
                            .col-md-6
                                .form-group
                                    label(for='structure_length_m') लांबी (मीटर)
                                    input.form-control#structure_length_m(type='text' name='structure_length_m')
                            .col-md-6
                                .form-group
                                    label(for='storage_capacity_cubic_m') साठवण क्षमता (घन मी.)
                                    input.form-control#storage_capacity_cubic_m(type='text' name='storage_capacity_cubic_m')
                            //- .col-md-6
                                .form-group
                                    label(for='contact_mobile') संपर्क मोबाईल
                                    input.form-control#contact_mobile(type='text' name='contact_mobile')
                            //- .col-md-6
                                .form-group
                                    label(for='geo_latitude') अक्षांश (Latitude)
                                    input.form-control#geo_latitude(type='text' name='geo_latitude')
                            //- .col-md-6
                                .form-group
                                    label(for='geo_longitude') रेखांश (Longitude)
                                    input.form-control#geo_longitude(type='text' name='geo_longitude')
                            //- .col-md-12
                                .form-group
                                    label(for='description') माहिती / टिप्पणी
                                    textarea.form-control#description(name='description' rows='3')
                        .text-end.mt-3
                            button.btn.btn-primary#save-water-conservation-btn(type='submit') जतन करा
