extends main_layout
block content
  style.
    #udghatan {
      padding: 0 !important; // override inline padding-right added from js
}
#udghatan .modal-dialog {
  width: 100%;
  max-width: none;
  height: 100%;
  margin: 0;
}
#udghatan .modal-content {
  height: 100%;
  border: 0;
  border-radius: 0;
}
#udghatan .modal-body {
  overflow-y: auto;
}

  // Navigation
  if(gp.gp_is_live == 0)
    #udghatan.modal.fade(tabindex='-1' role='dialog' aria-labelledby='modelTitleId' aria-hidden='true')
      .modal-dialog(role='document')
        .modal-content
          .alert.alert-warning.mb-0.pt-1.pb-1(role='alert ')
            .row.top-banner
              .col-2.text-left
                img(src="/img/header-images/sant-gadge-baba-1.png" alt="",)
              .col-8.text-center
                img(src="/img/header-images/main-welcome.png" alt="" style="width: 200px;")
              .col-2.text-right
                img(src="/img/header-images/sant-gadge-baba-11.png" alt="")
          .modal-body
            center
              img(src="/gp/asstes/images/udgharan/final-web.jpg" style="width:40%;height:80vh;border:2px solid")
              div
                button#start.btn.btn-outline-success.pl-5.pr-5.mt-2 सुरु करा

  else
    .alert.alert-warning.mb-0.pt-1.pb-1(role='alert ')
      .row.top-banner
        .col-2.text-left
          img(src="/img/header-images/sant-gadge-baba-1.png" alt="",)
        .col-8.text-center
          img(src="/img/header-images/main-welcome.png" alt="" style="width: 200px;")
        .col-2.text-right
          img(src="/img/header-images/sant-gadge-baba-11.png" alt="")
    nav.navbar.navbar-expand-lg.navbar-dark.bg-brown.static-top
      .container
        a.navbar-brand.font-weight-bold(href='#')
          span.text-warning #{gp.gp_name} 
          | ग्रामपंचायत
        button.navbar-toggler(type='button' data-toggle='collapse' data-target='#navbarResponsive' aria-controls='navbarResponsive' aria-expanded='false' aria-label='Toggle navigation')
          span.navbar-toggler-icon
        #navbarResponsive.collapse.navbar-collapse
          ul.navbar-nav.ml-auto
            li.nav-item.active
              a.nav-link(href='#')
                | होम
                span.sr-only (current)
            li.nav-item
              a.nav-link(href='#') फोटो
            li.nav-item
              a.nav-link(href='#') ग्राम माहिती
            li.nav-item
              a.nav-link(href='#') आमची कार्ये
            li.nav-item
              a.nav-link(href='#') ग्राम उदिष्ट
            li.nav-item
              a.nav-link(href='#') नेतृत्व
            li.nav-item
              a.nav-link(href='#') संपर्क
            li.nav-item
              a.nav-link(href='#') अर्ज भरा
          button.float-right#newApplicationNavigation.btn.btn-primary.btn-sm(type='button') अर्ज भरा
          button.text-right#loginNavigation.btn.btn-success.btn-sm.ml-1(type='button') ग्राम लोग इन
    // Page Content
    .container-fluid
      .row
        .col-lg-12
          .main-top
            .row
              if(notice.length == 0)
                .col-3
              .col-6
                div.gp-brand-banner
                  p.text-1 जिल्हा स्मार्ट | आदर्श गाव | तंटामुक्त गाव
                  p.text-3 ता. #{gp.gp_taluka}, जी.#{gp.gp_dist}
                  p.text-2  #{gp.gp_name} 
                  img.img-fluid.img-thumbnail.mt-2.main-home-image(src='/gp/asstes/images/gp/main.jpg' alt='image')
              if(notice.length !== 0)
                .col-6
                  .main-notice-list-div.mt-2
                    .card
                      .card-body
                        h4.card-title.main-notice-list-title नोटीस:-
                        p.card-text
                        marquee.main-notice-list-ul-div(direction="up")
                          ul.notice-main-list.mt-2
                            each gp_notice in notice
                              li.notice-list-item
                                div
                                  span #{gp_notice.notice}
        .col-12
          .card.mt-4.mb-4
            .card-body.mt-4.mb-4
              h4.card-title.h4.text-center.font-weight-bold.text-primary
                i.fa.fa-home.mr-1(aria-hidden='true')
                | ग्रामपंचायत #{gp.gp_name} बद्दल माहिती
              - var gp_info_one = JSON.parse(gp.gp_info_one)
              each mahiti in gp_info_one
                p.card-text.text-center.text-secondary
                  i.fa.fa-check-square.mr-1(aria-hidden='true') 
                  span #{mahiti.info}
              p.card-text.text-center.text-secondary
                i.fa.fa-check-square.mr-1(aria-hidden='true') 
                | या ग्रामपंचायत मध्ये एकूण #{gp.gp_ward} वार्ड आहेत.
              p.card-text.text-center.text-secondary
                i.fa.fa-check-square.mr-1(aria-hidden='true') 
                | ग्रामपंचायत #{gp.gp_name} मध्ये ग्रामपंचायत पदाधिकारी पदांची संख्या #{gp.gp_sadasya} आहे.
        - var maleSex = 0;
        - var femaleSex = 0;
        each village,index in sub_village 
          - maleSex +=  village.gp_male;
          - femaleSex +=  village.gp_female;
          if(sub_count == 1 && index == 0)
            .col-6.mb-4.offset-3.mb-2
              .card
                .card-header.text-center.badge-danger
                  | #{village.gp_name} लोकसंख्या बद्दल माहिती.
                .card-body.bg-light-warning.font-weight-bold
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | या गावाची लोकसंख्या जनगणना २०११ नुसार #{village.gp_male + village.gp_female} लोकसंख्या आहे.
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | त्या मध्ये पुरुष #{village.gp_male} आहे.
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | तर स्त्रिया #{village.gp_female} इतक्यांचा समावेश आहे.
          else
            .col-6
              .card
                .card-header.text-center.badge-danger
                  | #{village.gp_name} लोकसंख्या बद्दल माहिती.
                .card-body.bg-light-warning.font-weight-bold
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | या गावाची लोकसंख्या जनगणना २०११ नुसार #{village.gp_male + village.gp_female} लोकसंख्या आहे.
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | त्या मध्ये पुरुष #{village.gp_male} आहे.
                  p.card-text
                    i.fa.fa-users.mr-1.text-primary(aria-hidden='true')
                    | तर स्त्रिया #{village.gp_female} इतक्यांचा समावेश आहे.
        .col-12
          section#counts.counts.section-bg
            .container
              .row.justify-content-end
                .col-lg-3.col-md-5.col-6.d-md-flex.align-items-md-stretch
                  .count-box
                    span(data-toggle='counter-up') #{maleSex + femaleSex}
                    p लोकसंख्या
                .col-lg-3.col-md-5.col-6.d-md-flex.align-items-md-stretch
                  .count-box
                    span(data-toggle='counter-up') #{maleSex}
                    p पुरुष
                .col-lg-3.col-md-5.col-6.d-md-flex.align-items-md-stretch
                  .count-box
                    span(data-toggle='counter-up') #{femaleSex}
                    p स्त्रिया
                .col-lg-3.col-md-5.col-6.d-md-flex.align-items-md-stretch
                  .count-box
                    span(data-toggle='counter-up') #{gp.gp_ward}
                    p वार्ड संख्या
        .col-12.mb-4
          .card
            .card-body
              h4.card-title.h4.text-center.font-weight-bold.text-primary
                i.fa.fa-gears.mr-1(aria-hidden='true')
                | आमची कार्ये
              .row
                .col-10.offset-1
                  .grampanchayet-work.owl-carousel.owl-theme.mt-2
                    - var gp_info_three = JSON.parse(gp.gp_info_three)
                    each mahiti in gp_info_three
                      .item
                        p.p-2.text-center.h5.text-secondary #{mahiti.info}

        .col-12.mb-4
          .card
            .card-body
              h4.card-title.h4.text-center.font-weight-bold.text-primary
                i.fa.fa-thumbs-o-up.mr-1(aria-hidden='true')
                | ग्राम पंचायतीचे उद्दिष्टे
              .row
                .col-10.offset-1
                  .grampanchayet-udisth.mt-2
                    .item
                      p.p-2.text-center.h5.text-secondary स्वच्छ भारत अभियान अंतर्गत १०० % गाव हगदारी मुक्त केले आहे.
                    .item
                      p.p-2.text-center.h5.text-secondary कर वसुली १००% पूर्ण  केली आहे.
                    .item
                      p.p-2.text-center.h5.text-secondary शुद्ध पाणी पुरवठा करणे.
                    .item
                      p.p-2.text-center.h5.text-secondary दलित वस्ती आराखडा प्रमाणे सोयी सुविधा पुरविणे.
                    .item
                      p.p-2.text-center.h5.text-secondary वृक्ष लागवड केलेली आहे  त्या सतर्भात करिता त्यांना प्रमाणपत्र मिळालेले आहे.
                    .item
                      p.p-2.text-center.h5.text-secondary निरनिराळ्या योजनेत सहभागी होणे करिता करिता त्यांना प्रमाणपत्र मिळालेले आहे .
                    .item
                      p.p-2.text-center.h5.text-secondary तंटामुक्त गाव करून करिता त्यांना प्रमाणपत्र मिळालेले आहे.
                    .item
                      p.p-2.text-center.h5.text-secondary गावकर्यांना साठी संगणकीकृत ऑनलाईन सेवा उपलब्ध करून दिलेल्या आहे.
                    .item
                      p.p-2.text-center.h5.text-secondary स्वच्छ गाव सुंदर गाव तयार करणे करिता त्यांना प्रमाणपत्र मिळालेले आहे
                    .item
                      p.p-2.text-center.h5.text-secondary गाव व ग्राम पंचायत स्मार्ट विलेज बनविणे करिता त्यांना प्रमाणपत्र मिळालेले आहे
        if(gallery.length !== 0)
          .col-12.mb-4
            .card
              .card-body
                h4.card-title.h4.text-center.font-weight-bold.text-primary
