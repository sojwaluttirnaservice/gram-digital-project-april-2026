                    .member
                      .member-img
                        - var link = "/gp/asstes/images/team/"
                        img.img-fluid(src=link+u.image, alt=u.name style="width:200px !important; height:200px !important")
                      .member-info
                        h4 #{u.name}
                        span #{u.p_name}  
                        span #{u.s_name}  
        // team ends
        // time and other details
