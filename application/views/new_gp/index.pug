extends ../user/include/index-page-master-layout.pug

block external_css 
    link(href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet")


block external_js

    script(src="https://unpkg.com/aos@2.3.1/dist/aos.js")

block internal_css
    style.
        @keyframes marquee {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }
        .animate-marquee {
            animation: marquee 14s linear infinite;
        }

        .my-scrollbar-thickness::-webkit-scrollbar {
            width: 5px; /* Adjust the width to make the scrollbar thinner */
        }

        .my-scrollbar-thickness::-webkit-scrollbar-thumb {
            background-color: rgba(0, 0, 0, 0.2); /* Adjust the thumb color */
            border-radius: 10px; /* Round the corners of the scrollbar thumb */
        }

        .my-scrollbar-thickness::-webkit-scrollbar-track {
            background-color: transparent; /* Make the track transparent or any color you like */
        }

        .qrcode img {
            width: 100% !important;
            height: 100% !important;
            //- width: 86px !important;
            //- height:86px !important;
        }

        .shimmer-bg {
            position: relative;
            overflow: hidden;
            background-color: #e5e7eb;
        }

        .shimmer-bg::after {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(
                90deg,
                rgba(243, 244, 246, 0) 0%,
                rgba(255, 255, 255, 1) 50%,
                rgba(243, 244, 246, 0) 100%
            );
            animation: shimmer-slide 1.8s ease-in-out infinite;
        }

        @keyframes shimmer-slide {
            0% {
                left: -100%;
            }
            100% {
                left: 100%;
            }
        }



