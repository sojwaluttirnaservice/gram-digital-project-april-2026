            // To work on
            document.addEventListener("DOMContentLoaded", function() {
                daisyUIModal.show('noticeModal');


                let validateInput = (name, value) => {
                    let isError = false;
                    if (value === "") {
                        errors[name] = "Please enter " + name;
                        isError = true;
                    } else {
                        let _text = "";
                        switch (name) {
                            case "username":
                                _text = testRegEx("user", value) ? "" : "Invalid User Full Name";
                                break;
                            case "mobile":
                                _text = testRegEx("mobile", Number(value))
                                    ? ""
                                    : "Invalid Mobile Number";
                                break;
                            case "email":
                                _text = testRegEx("email", value) ? "" : "Invalid Email";
                                break;
                            case "userid":
                                _text = testRegEx("username", value)
                                    ? ""
                                    : "Username Must Be without space";
                                break;
                            case "confirmpassword":
                                _text = forms.password === value ? "" : "Password is not matching";
                                break;
                        }
                        isError = _text === "" ? false : true;
                        errors[name] = _text;
                    }
                    setErrors({ ...errors });
                };

                let testRegEx = (type, string) => {
                    let expression = {
                        email: /^([a-zA-Z0-9\._]+)@([a-zA-Z0-9])+.([a-z]+)(.[a-z]+)$/g,
                        mobile: /^[6-9]\d{9}$/g,
                        username: /^([a-zA-z])+$/g,
                        user: /^([ A-Za-z])+$/g,
                        c_mobile: /^\+\d{2}[7-9]\d{9}$/g,
                        search: /([a-zA-Z0-9].*)/g,
                    };

                    const regex = new RegExp(expression[type]);
                    return regex.test(string);
                };

                function getCurrentDateInMarathi() {
                    const daysInMarathi = [
                        "रविवार", "सोमवार", "मंगळवार", "बुधवार", "गुरुवार", "शुक्रवार", "शनिवार"
                    ];

                    const monthsInMarathi = [
                        "जानेवारी", "फेब्रुवारी", "मार्च", "एप्रिल", "मे", "जून", 
                        "जुलै", "ऑगस्ट", "सप्टेंबर", "ऑक्टोबर", "नोव्हेंबर", "डिसेंबर"
                    ];

                    const devanagariDigits = ["०", "१", "२", "३", "४", "५", "६", "७", "८", "९"];

                    const today = new Date();

                    const day = daysInMarathi[today.getDay()]; // Get the current day in Marathi
                    const date = String(today.getDate()).padStart(2, '0').split('').map(num => devanagariDigits[num]).join(''); // Convert date to Devanagari
                    const month = monthsInMarathi[today.getMonth()]; // Get the current month in Marathi
                    const year = today.getFullYear().toString().split('').map(num => devanagariDigits[num]).join(''); // Convert year to Devanagari

                    return `${day}, ${date} ${month} ${year}`;
                }

                // Set the content of the paragraph
                //- document.getElementById('current-date-devnagari')?.textContent = getCurrentDateInMarathi();
            })


