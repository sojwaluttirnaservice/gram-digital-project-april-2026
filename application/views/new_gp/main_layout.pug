doctype html
html
    head
        meta(charset='utf-8')
        meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description' content='')
        meta(name='author' content='')
        title ग्राम ग्रामपंचायत #{gp.gp_name}
        // Bootstrap core CSS
        link(href='/gp/asstes/plugins/bootstrap/css/bootstrap.css' rel='stylesheet')
        link(rel='stylesheet' href='https://cdnjs.cloudflare.com/ajax/libs/ekko-lightbox/5.3.0/ekko-lightbox.css')
        link(href='/gp/asstes/plugins/fa-v4.7/css/font-awesome.min.css' rel='stylesheet')
        link(rel='stylesheet' href='/gp/asstes/plugins/gallery-master/dist/ssg.min.css')
        link(rel='stylesheet' href='/gp/asstes/plugins/owl-carousel/assets/owl.carousel.css')
        link(rel='stylesheet' href='/gp/asstes/plugins/owl-carousel/assets/owl.theme.default.css')
        link(rel='stylesheet' href='/gp/asstes/css/main.css')
        link(rel='stylesheet' href='/gp/asstes/css/style.css')



    body
        #myModal.modal(tabindex='-1' role='dialog')
            .modal-dialog.modal-lg(role='document')
                .modal-content
                    .modal-header
                        h5.modal-title गाव निवडा
                        button.close(type='button' data-dismiss='modal' aria-label='Close')
                            span(aria-hidden='true') ×
                    .modal-body
                        table.table.table-bordered
                            thead 
                                each value,index in sub_village
                                    tr
                                        th(width="5%") #{index+1}
                                        th 
                                            - var url =   value.gp_url + "/login";
                                            a(href=url) #{value.gp_name}
        #myModal1.modal(tabindex='-1' role='dialog')
            .modal-dialog.modal-lg(role='document')
                .modal-content
                    .modal-header
                        h5.modal-title नवीन अर्जा साठी गाव निवडा
                        button.close(type='button' data-dismiss='modal' aria-label='Close')
                            span(aria-hidden='true') ×
                    .modal-body
                        table.table.table-bordered
                            thead 
                                each value,index in sub_village
                                    tr
                                        th(width="5%") #{index+1}
                                        th
                                            - var url =   value.gp_url + "/new-application-form";
                                            a(href=url) #{value.gp_name}
        block content