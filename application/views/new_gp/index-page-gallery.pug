//- NEW VERSION OF THIS BELOW

//- #gp-images
    h4.information-heading(class='text-center text-lg md:text-3xl font-bold tracking-wider w-fit mx-auto px-8 pb-2 border-b-2 border-[#138f78]')
        .flex.gap-2.items-center
            i.fas.fa-broom.text-[#138f78]
            span #{t("homePage.cleanIdealGpSection.titleOne")}
            i.fas.fa-star.text-amber-400
            span #{t("homePage.cleanIdealGpSection.titleTwo")}


div.relative.my-carousel-container

    - let mdHeightInRem = 23.5
    - let lgHeightInRem = 32
    - let xlHeightInRem = 41
    //- SKELETON (takes layout space + shimmer)
    div#gp-carousel-skeleton(class=`w-full aspect-[16/9] md:h-[${mdHeightInRem}rem] lg:h-[${lgHeightInRem}rem] xl:h-[${xlHeightInRem}rem] shimmer-bg`)

    //- CAROUSEL (present but invisible)
    div#gp-carousel-content(class='relative opacity-0 pointer-events-none transition-opacity duration-500')

        .relative
            .relative.owl-carousel.gp-images-carousel.owl-theme.g-seva-slider
                - const firstThreeImages = gallery ? gallery.slice(0, Math.min(gallery.length, 30)) : [];

                each image in firstThreeImages
                    .item
                        .gp-image-container(class='border-y border-[#138f78]/60')
                            div(class=`relative overflow-hidden md:h-[${mdHeightInRem}rem] lg:h-[${lgHeightInRem}rem] xl:h-[${xlHeightInRem}rem] aspect-[16/9] md:aspect-auto group`)
                                - let galleryImagePath = '/gp/asstes/images/gallery/'

                                img(src=galleryImagePath + image.g_image_name class='gp-carousel-image w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]' loading='lazy' onerror="this.src='img/fallback/clean-village-fallback.webp'")

                                div(class='absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent')

                                div(class='absolute bottom-0 left-0 w-full px-6 pb-5 text-white')
                                    h6(class='text-base md:text-lg font-semibold tracking-wide text-center')= image.g_image_title || 'छायाचित्र'
                                    if image.g_image_desc
                                        div(class='mt-1 text-xs md:text-sm opacity-85 text-center leading-relaxed')= image.g_image_desc

        //- LEFT BUTTON
        button(type='button' class='absolute top-1/2 -translate-y-1/2 left-4 z-20 w-10 h-10 rounded-full bg-white/70 backdrop-blur flex items-center justify-center text-[#138f78] shadow-md hover:bg-[#138f78] hover:text-white transition-all duration-300' id='gp-slider-prev-btn')
            i.fa.fa-chevron-left

        //- RIGHT BUTTON
        button(type='button' class='absolute top-1/2 -translate-y-1/2 right-4 z-20 w-10 h-10 rounded-full bg-white/70 backdrop-blur flex items-center justify-center text-[#138f78] shadow-md hover:bg-[#138f78] hover:text-white transition-all duration-300' id='gp-slider-next-btn')
            i.fa.fa-chevron-right

