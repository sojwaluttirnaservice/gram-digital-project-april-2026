extends ../master-layout
block internal_css 
	link(rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/timepicker/1.3.5/jquery.timepicker.min.css")
	style.
		a{
			text-decoration: none;
		}
		td, th{
			vertical-align: middle !important;
			border: 1px solid gray !important;
		}

		label.error{
			color: red;
			font-size: 0.8rem;
		}

		#qr-code-list {
			display: grid;
			grid-template-columns: 1fr 1fr 1fr;
			gap: 2rem;
		}

block custom_js
	link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css")
	script(src="https://cdn.jsdelivr.net/npm/flatpickr")
	script(src="//cdnjs.cloudflare.com/ajax/libs/timepicker/1.3.5/jquery.timepicker.min.js" defer)

	script.
		$( function() {
			$( ".datepicker" ).datepicker({
				dateFormat: 'dd/mm/yy'
			});


			flatpickr('.timepicker', {
				enableTime: true,
				noCalendar: true,
				dateFormat: "H:i K",
				time_24hr: false
			})
		});

	style.
		#qr-code-list{
			display:grid;
		}

	link(href="https://cdn.datatables.net/2.1.3/css/dataTables.dataTables.min.css" rel="stylesheet" )

	script(src="https://cdn.datatables.net/2.1.3/js/dataTables.min.js")

	script(src='/asstest/coustom/js/handlers/master-panel-handlers/gharkul-yojana-handler.js')



block content
	.container.mt-5(style='margin-top: 5rem !important')
		form(id="gharkul-yojana-form")
			.d-flex.flex-column.justify-content-center.align-items-center(style="gap: 2rem;") 
				.col-4
					label Yojana Name 
					input.form-control(name="gy_name")

				.col-4
					.text-center
						button.btn.btn-primary(id="save-gharkul-yojana-btn") Save


		.mt-5
			table.table.table-striped#yojana-table
				thead 
					tr
						th(width="5%") No.
						th Yojana Name
						th(width='20%').text-center Action 

				tbody
					each _yojana, _index in gharkulYojanaList 
						tr
							td #{_index + 1}
							td 
								input.form-control.py-3.bg-transparent(value=_yojana.gy_name style='border:0; letter-spacing:0.8px; font-weight: 500;' data-originalValue=_yojana.gy_name id=`input-field-${_yojana.id}` readonly)
							td
								.d-flex.justify-content-center(style="gap:2rem;")
									button.btn.btn-secondary(class='edit-yojana-name-btn' data-yojanaId = _yojana.id) Edit
									button.btn.btn-success(class='update-yojana-name-btn' data-yojanaId = _yojana.id  style='display:none;') Update
									button.btn.btn-secondary(class='cancel-yojana-name-btn' data-yojanaId = _yojana.id style='display:none;' ) Cancel
									button.btn.btn-danger(class="delete-yojana-name-btn" data-yojanaId = _yojana.id ) Delete
