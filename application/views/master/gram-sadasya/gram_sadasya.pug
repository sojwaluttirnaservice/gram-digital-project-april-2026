doctype html
head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    meta(http-equiv='X-UA-Compatible' content='ie=edge')
    // common css
    link(rel='stylesheet' href='/asstest/plugins/bs4/css/bootstrap.css')
    link(rel='stylesheet' href='/asstest/plugins/font-awesome470/css/font-awesome.css')
    link(rel='stylesheet' href='/asstest/plugins/date/jquery-ui.css')
    link(rel='stylesheet' href='/asstest/coustom/css/main.css')
    link(rel='stylesheet' href='/asstest/plugins/select/css/select2.min.css')  
    link(href='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.css' rel='stylesheet')



    script(src='/asstest/plugins/jquery/jquery-3.3.1.min.js')
    script(src='/asstest/plugins/popper/popper.min.js')
    script(src='/asstest/plugins/bs4/js/bootstrap.min.js')
    script(src='/asstest/plugins/date/jquery-ui.js')
    script(src='/asstest/plugins/sweetalert/sweetalert.min.js')
    script(src='/asstest/plugins/notify/notify.js')
    script(src="/asstest/plugins/jquery_validation/jquery.validate.min.js")
    script(src="/asstest/plugins/jquery_validation/additional-methods.js")  
    //mask plugin jquery
    script(src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js") 


    //toggle
    script(src='/asstest/plugins/bootstrap4toggle/bootstrap4-toggle.min.js')
    // extras

    // common js setups
    script(src='/asstest/coustom/js/base.converter.js')
    script(src='/asstest/coustom/js/common.js')
    script(src='/asstest/coustom/js/handlers/master.sadasya.js')
    style.
        .error {
            color:red !important;
            font-style:italic !important;
            font-weight:700 !important;
        }
        .bg-warning{
            background-color:#f0d688 !important;
        }
        body{

            height:100vh;
        }

        .modal-dialog {
            width: 70% !important;
            margin-inline: auto;
            height: 90%;
            margin-top: 2%;
            padding: 0;
        }

        @media (max-width: 768px) {
            .modal-dialog {
                width: 90% !important;
            }
        }


body
    .modal.fade#marriageModel(tabindex='-1' role='dialog')
        .modal-dialog(tabindex='-1' role='document' class='modal-dialog-scrollable modal-lg')
            form#newFormMember(style='height: 100%;' class='modal-content')
                .modal-header(class='modal-header')
                    h5.modal-title
                    button(type='button' data-dismiss='modal' aria-label='Close' class='close')
                        span(aria-hidden='true') ×

                .modal-body(style='overflow-y:auto;' class='modal-body')
                    .row(class='row')
                        .col-12.col-md-7(class='col-12 col-md-7')
                            .form-group
                                label सदस्य नाव
                                input#memberName(type='text' placeholder='नाव' name='memberName' class='form-control')

                            .form-group
                                label सदस्य पद
                                select#memberType(name='memberType' class='form-control')

                            .form-group
                                label Section
                                select#memberTo(name='memberTo' class='form-control')

                            .form-group
                                button(type='button' id='add-other-section-btn' class='btn btn-primary btn-sm') Add Other section
                                button(type='button' id='cancel-add-other-section-btn' style='display:none;' class='btn btn-primary btn-sm') Cancel

                            .form-group#other-section-group(style='display:none;' class='form-group')
                                div(style='gap:1rem;' class='d-flex align-items-center')
                                    input(name='otherMemberTo' class='form-control')
                                    button(id='add-other-member-to-btn' class='btn btn-success') Add

                            .form-group
                                - let mainSNames = ["मुख्य सदस्य","उप सदस्य","कर्मचारी / लिपिक","गावातील प्रतिष्टीत नागरीक","गावातील मार्गदर्शक"]
                                button(type='button' id='edit-other-section-btn' class='btn btn-success btn-sm') Edit Other Section
                                button(type='button' id='cancel-edit-other-section-btn' style='display:none;' class='btn btn-primary btn-sm') Cancel Edit

                            .form-group#other-section-group-list(style='display:none;' class='form-group')

                            .form-group
                                label(for='sadasyaAadhar') सदस्य आधार न
                                input#sadasyaAadhar(name='sadasyaAadhar' maxlength='12' class='form-control')

                            .form-group
                                label(for='sadasyaMobile') सदस्य मो
                                input#sadasyaMobile(name='sadasyaMobile' maxlength='10' class='form-control')

                            .form-group
                                label.font-weight-bold(for="isNotificationAllowed") SMS सेंड करणे
                                select#isNotificationAllowed(name='isNotificationAllowed' class='form-control') निवडा
                                    option(value="YES") होय
                                    option(value="NO" selected) नाही


                        .col-12.col-md-5(class='col-12 col-md-5')
                            div(class='border p-3 text-center')
                                .form-group
                                    label सदस्य फोटो
                                    input#image_1(type='file' class='form-control')

                                .form-group
                                    img#image-1-preview(width='200' height='200' style='display:block;margin:0 auto;border:1px solid #ccc;object-fit:cover;')

                    .row.mt-3(class='row mt-3')
                        .col-12(class='col-12')
                            .form-group
                                label(class='form-label') सदस्याची माहिती
                                textarea#sadasyaInfo(rows='8' placeholder='येथे सदस्याची माहिती भरा.' name='sadasyaInfo' class='form-control')

                .modal-footer(class='modal-footer')
                    button#saveMember(type='button' class='btn btn-primary') जतन करा
                    button#updateMember(type='button' class='btn btn-success') अपडेट करा
                    button#resetFormBtn(type='reset' class='btn btn-info d-none') Reset
        
    
    .container-fluid

        if isMasterPanel
            .row
                .col-12 
                    .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
                        a.navbar-brand(href="/master") Master Panel
        else
            include ../../user/include/navs.pug



        .row 
            .col-12 
                div
                    p(class='mt-4 text-center' style='font-weight:bold;') ग्रामपंचायतीचा फोटो जोडा 
                form#gp-image-form(class='d-flex align-items-center justify-content-center' style='gap:1rem;')
                    input(name='gpImage' type='file')

                    button.btn.btn-primary.btn-sm(type='button' id='save-gp-image-btn') जोडा


            .col-12 
                div(style='width: 20rem; height: 14rem; margin-inline: auto; margin-top: 1rem; overflow:hidden;border:1px solid gray; padding: 1rem;')
                    img(src= '/uploads/images/gp/main/'+ gp.gp_image_name style='width: 100%; height: 100%;' onerror="this.src='/img/fallback/no-image-found.png'")

        .row.mt-5
            .col-12.mt-3
                h6.ml-5.text-center
                    button.galleryAddModel.float-right.btn.btn-primary.btn-sm.mr-2
                        span.fa.fa-user-plus
                        |  नवीन सदस्य जोडा 
            .col-10.offset-1.mt-3
                .row#sadasyaList(style='gap: 1rem; margin-bottom: 4rem')


    script.
            // - What's going to happen is that, in master.sadasya.js, I am going to create a variable 
            // - named 'member' containing those properties.
            // - Some parts of the script will execute after the WHOLE DOM is loaded, while other 
            // - parts will execute before the page loads (specifically the member variable creation).
            // - Since this block runs after that initial part is loaded, we are assigning the 
            // - values here. Then, the remaining logic will execute once the full DOM has loaded.

            //- sList is the sadasya list
            member.sList = !{sList}
            //- console.log(member.sList);

            member.sPost = !{sPost}

            //- this is for the section list i think
            member.sTo = !{sTo}
            console.log(member.sTo)


