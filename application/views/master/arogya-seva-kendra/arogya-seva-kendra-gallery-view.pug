extends ../master-layout
block custom_js 
	script(src='/asstest/coustom/js/handlers/master-panel-handlers/arogya-seva-kendra-gallery-upload-handler.js')
	
block custom_css 
	style.
		a{
			text-decoration: none;
		}

		.gallery-container {
			width: 100%;
			min-height: 100vh;
			
			padding: 50px 8%;
		}

		.gallery {
			width: 100%;
			display: grid;
			grid-template-columns: 1fr 1fr 1fr 1fr;
			gap: 1rem;
		}

		.gallery img {
			width: 100%;
			height: 100%;
			border: 5px solid #d6d1d1;
			box-shadow: 0 3px 5px rgba(0, 0, 0, 0.3);
			object-fit: cover;
			transition: all 200ms ease-in-out;
		}

		.gallery img:hover {
			transform: scale(1.03);
		}

		@media (max-width: 992px) {
			.gallery {
				grid-template-columns: 1fr 1fr 1fr;
			}
		}

		@media (max-width: 768px) {
			.gallery {
				grid-template-columns: 1fr 1fr;
			}
		}

		@media (max-width: 576px) {
			.gallery {
				grid-template-columns: 1fr;
			}
		}


block content
	.container.mt-5(style='margin-top: 5rem !important')

		h1.text-center #{arogyaSevaKendraDetails.arogya_seva_kendra_name}
		h4.text-center.text-success Gallery

		.text-end 
			button.btn.btn-primary(id='add-new-arogya-seva-kendra-gallery-image-btn') Add Image


	.gallery-container
		.gallery
			each photo in galleryPhotos
				.card 
					.card-body
						-let galleryImagePath = `/new-gp-page/main-page/files/arogya-seva-kendra-gallery/${photo.gallery_image_name}`
						a(href=galleryImagePath, data-lightbox="models", data-title="My caption")
							img(src=galleryImagePath, style='height: 14rem')
					.card-footer.text-center(style='border:none')
						button.btn.bg-danger.delete-arogya-seva-kendra-gallery-image-btn(style='font-size: 1rem' data-id=photo.id data-imageName=photo.gallery_image_name)
							i.fa.fa-trash.text-light &nbsp; Delete
					

		.modal.fade(tabindex="-1" aria-labelledby="" aria-hidden="true" id ='upload-institute-gallery-image-modal' )
					.modal-dialog(style='min-width:50% !important;')
						.modal-content.p-2
							.modal-header.bg-warning Upload Photo 
								h1.modal-title.fs-5() 
								button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
							.modal-body

								form#uploadArogyaSevaKendraGalleryPhotoForm(action="") 
									.card.mb-3

										.card-body
											.row.gy-3
												.col-12
													.form-group
														label(for="arogya-seva-kendra-gallery-photo") आरोग्य सेवा केंद्र फोटो
														input.form-control(type='file' id="arogya-seva-kendra-gallery-photo" name='arogya_seva_kendra_gallery_photo')

													img#arogya-seva-kendra-gallery-image-preview(style="max-width: 100%; max-height: 450px; display: none; margin-top: 10px;")
										div.d-flex.justify-content-center
											button#upload-arogya-seva-kendra-gallery-image-btn.mt-2.mb-2.btn.btn-primary(type='submit' data-id=arogyaSevaKendraDetails.id) जतन करा						   
