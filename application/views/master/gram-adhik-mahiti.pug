            else
                include ../user/include/navs.pug
            //- .row
                .col-12 
                    .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
                        a.navbar-brand(href="/master") Master Panel
            .row.mt-5.justify-content-center
                .col-12.col-md-10.mt-5
                    .row(style='gap: 0.2rem; row-gap: 1rem;').justify-content-center.justify-content-md-between.justify-content-lg-start
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiOne") 
                                i.fa.fa-users.fa-2x.text-success
                                |  &nbsp;गाव विषयी माहिती
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiTwo") 
                                i.fa.fa-home.fa-2x.text-primary(aria-hidden='true')
                                |  &nbsp;समित्या यादी
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiThree") 
                                i.fa.fa-home.fa-2x.text-primary(aria-hidden='true')
                                |  &nbsp;गावातील उद्योग माहिती
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiFour") 
                                i.fa.fa-home.fa-2x.text-primary(aria-hidden='true')
                                |  &nbsp;गावातील बातम्या
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiFive") 
                                i.fa.fa-home.fa-2x.text-primary(aria-hidden='true')
                                |  &nbsp;आरोग्य केंद्र माहिती
                        .col-5.col-md-3.col-lg-2.box.box--white.m-0
                            p.box__title(data-toggle="modal" data-target="#modalGramMahitiSix") 
                                i.fa.fa-home.fa-2x.text-primary(aria-hidden='true')
                                |  &nbsp;शासकीय योजना 

