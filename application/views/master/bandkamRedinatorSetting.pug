  style.
    .error {
      color:red !important;
      font-style:italic !important;
      font-weight:700 !important;
    }
    .bg-warning{
      background-color:#f0d688 !important;
    }
    body{
      
      height:100vh;
    }
    table, td, tr, th {
        border: 1px solid black;
    }

    th, td {
        padding: 5px;
    }
    @media (min-width: 576px) {
    .modal-dialog { max-width: none; }
      }
      .modal-dialog {
        width: 98%;
        height: 92%;
        padding: 0;
      }
body
    .container
      .row
        .col-12.mb-5 
          .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
              a.navbar-brand(href="/master") Master Panel
        .col-12.mt-5.d-flex.justify-content-between   
            h4 बांधकाम रेडीनटोर दर  सुधारणा 
            div.d-flex.flex-column.flex-sm-row(style='row-gap: 0.6rem;')
                a(class="btn btn-primary mr-4" href="https://easr.igrmaharashtra.gov.in/" target="_blank") बाजार मूल्य दर तक्ता 
                button(class="btn btn-success bandkamPrakarButton")  बांधकामाचे दर 
        .col-12.mt-5
            form#bandKamRedinatorForm
                .row
                    each el, i in bandKamDetails
                        .col-12.col-sm-6.mb-4.d-flex.flex-column
                            label(for="bandKamPrakarType") बांधकाम प्रकार 
                            input.form-control(type="text" name="bandKamPrakarType" value=el.bp_type disabled)                    
                        .col-6.col-sm-3.mb-4.d-flex.flex-column                    
                            label(for="redinekarRate") रेडीनेकर 
                            input.form-control(type="text" id=`redinekarRate${i+1}` data-id=el.id name="redinekarRate" value=el.bp_ready_nakar_rate)
                        .col-6.col-sm-3.mb-4.d-flex.flex-column   
                            label(for="taxRate") कराचा दर              
                            input.form-control(type="text" id=`taxRate${i+1}` data-id=el.id name="taxRate" value=el.bp_tax_rate)    
                .row 
                    .col-12.d-flex.justify-content-center.mb-5.mt-3
                        button(id="bandKamRedinatorFormSubmit" class="btn btn-primary") जतन करा 
    

    .modal#redinatorRateModal(tabindex='-1')  
        .modal-dialog
            .modal-content
                .modal-header
                    h5.modal-title बांधकामाचे दर 
                    button(type='button' data-bs-dismiss='modal' class="i fa fa-window-close redinatorRateModalCloseBtn" aria-label='Close')
                .modal-body
                    table 
                        thead 
                            tr  
                                th बांधकाम प्रकार
                                th रेडीनेकर
                                th कराचा दर
                        tbody.redinatorRateTbody
                .modal-footer
                    button.btn.btn-secondary(type='button' id="closeAddFormModalBtn" class="redinatorRateModalCloseBtn") Close


    script. 
        let bandKamDetails = !{JSON.stringify(bandKamDetails)}
