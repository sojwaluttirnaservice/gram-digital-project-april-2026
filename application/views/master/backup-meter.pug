body
    .container-fluid
        .row
          .col-12 
            .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
                a.navbar-brand(href="/master") Master Panel
        .row.mt-5.justify-content-center
          .col-12.mt-3
              h1.ml-5.text-center.mr-5 Meter Backup
          .col-12.col-sm-8.col-md-5.mt-3
            table.table.table-bordered
              thead 
                tr
                  th Next Month Range
                  th
                    input(class="form-control" value="०१ जुलै २०२१ ते ३१ मार्च २०२२" id="next_month_range")
                tr 
                  th backup घ्या 
                  th
                    input(class="form-control" value="chandresh@123" type="password" id="b" placeholder="backup password")
                tr
                  th(colspan="2")
                    center
                      button.btn.btn-outline-success.btn-sm#takeBackup Backup घ्या
        script.
          $(function(){
            takeBackup
              $('#takeBackup').on('click',function(){
                  if($('#b').val() === 'chandresh@123'){
                    $.ajax({
                      url:'/master/update-backup-nine',
                      type:'post',
                      data:{id:0}
                    }).done(function(data){
                      window.location.assign(`/master/backup-master?next_month_range=${$('#next_month_range').val()}}`)
                    }).fail(function(error){
                      console.log(error)
                      alert('server error')
                    })

                  }else{
                    alert('password is wrong.')
                  }
              })
          })
     
            
              
                          

                                
                            