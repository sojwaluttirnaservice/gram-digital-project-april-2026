body
  .container
    .row
      .col-12.mb-5 
        .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
          a.navbar-brand(href="/master") Master Panel
      .col-12.mt-3 
        h4.text-center पाणी कर सुधारणा 
      .col-12.mt-3
        form#bandKamRedinatorForm
          .row.d-flex.flex-column.align-items-center
            .col-12.col-sm-8.col-lg-3.mb-4.d-flex.flex-column
              label(for="generalWaterTax") सामान्य पाणी कर  
              input.form-control(type="text" name="generalWaterTax" id='generalWaterTax' value=`${paniKar != null ? paniKar.generalWaterTax : ''}` )                    
            .col-12.col-sm-8.col-lg-3.mb-4.d-flex.flex-column                    
              label(for="specialWaterTax") विशेष पाणी कर  
              input.form-control(type="text" name="specialWaterTax" id='specialWaterTax' value=`${paniKar != null ? paniKar.specialWaterTax : ''}`)
          .row 
            .col-12.d-flex.justify-content-center.mb-5.mt-3
              button(id="submitPaniKar" class="btn btn-primary") जतन करा 
