    script(src="https://cdn.lightwidget.com/widgets/lightwidget.js")

    script.
        document.addEventListener("DOMContentLoaded", function() {


            var data = !{userDataString};
            if(data){
                data.forEach(function(userData, index) {
                    generateQRCode(index, userData);
                });
            }
            function generateQRCode(id, userData) {
                //- let website = 'https://g-seva.com/pay';
                //- website = `${website}/!{zp.pg_registration_no}/${userData.id}?rTo=${encodeURIComponent(window.location.origin)}`;
                //- new QRCode(document.getElementById("qrcode" + id), website);
                const container = document.getElementById("qrcode" + id);

                // clear old QR (important for resize)
                container.innerHTML = "";

                let website = 'https://g-seva.com/pay';
                website = `${website}/!{zp.pg_registration_no}/${userData.id}?rTo=${encodeURIComponent(window.location.origin)}`;

                // get actual container width
                const size = container.offsetWidth || 80; // fallback for mobile

                new QRCode(container, {
                    text: website,
                    width: size,
                    height: size
                });
            }


            //- const allowedDomains = ['gpsangwabk.com', 'www.gpsangwabk.com'];
            //- if (!allowedDomains.includes(window.location.hostname)) {
            //-     document.getElementById('sangwa-section')?.remove();
            //- }
            AOS.init();

            $("#accordion-shasan-pdf").accordion({
                collapsible: true,
                "heightStyle": "auto" ,
                active: false,
                activate: function (event, ui) {
                    console.log(ui)
                        $(ui.newPanel).css('height', '200');
                        $(ui.newPanel).css('min-height', '200');
                        $(ui.newPanel).css('max-height', '600');
                    }
            });
            //- $('#myModal3').modal('show')
            $.ajax({
                url:"/site-seen",
                method:'post',
                data:{	
                    count:Number(#{gp.gp_site_count})+1
                }
                }).done(function(data){
                    console.log(data)
                }).fail(function(error){
                    alert('something went worng, try again')
                    console.log(error)
                })

            let $carousel = $('.owl-carousel.gp-images-carousel');

            $carousel.owlCarousel({
                loop: true,
                margin: 0,
                items: 1,

                nav: false,        // ❌ disable default arrows (we use custom buttons)
                dots: true,        // ✅ show dots
                autoplay: true,
                autoplayTimeout: 4500,
                autoplayHoverPause: true,
                smartSpeed: 800,   // smoother slide transition

                responsive: {
                    0: { items: 1 },
                    600: { items: 1 },
                    1000: { items: 1 }
                }
            });

            $('#gp-slider-prev-btn').on('click', function () {
                $carousel.trigger('prev.owl.carousel');
            });

            $('#gp-slider-next-btn').on('click', function () {
                $carousel.trigger('next.owl.carousel');
            });

            $('.owl-carousel.arogya-camp-photos').owlCarousel({
                items: 3.5,
