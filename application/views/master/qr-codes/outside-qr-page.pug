                            endpoint: "https://mpsc.gov.in/adv_notification/8",
                            title: {
                                mr: "महाराष्ट्र लोकसेवा आयोग",
                                hi: "महाराष्ट्र लोक सेवा आयोग",
                                en: "Maharashtra Public Service Commission"
                            },
                            desc: {
                                mr: "एम पी एस सी च्या विविध स्पर्धा परीक्षा व भरती प्रक्रियेसाठी ऑनलाईन अर्ज करण्यासाठी अधिकृत पोर्टल.",
