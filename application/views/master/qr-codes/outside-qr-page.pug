block content

    - let seeMore = {mr: 'आणखी बघा', hi: "और देखे", en: 'See More'}


    //-
    section
        #qr-code-container(class='py-8 bg-slate-100 border-t border-slate-300')
            -
                const qrButtons = [
                    { endpoint: "/village/nagrik-nondani-view", title: t("navbar.top.citizenRegistration"), icon: "fa-user-plus", desc: { mr: "नागरिक नोंदणी अर्ज भरा\nतुमच्या माहितीसाठी सुरक्षित", hi: "नागरिक पंजीकरण आवेदन करें\nआपकी जानकारी सुरक्षित रहेगी", en: "Apply for citizen registration\nKeep your information secure" } },
                    { endpoint: "/rti/info", title: t("navbar.bottom.rti"), icon: "fa-user-info", desc: { mr: "RTI अंतर्गत माहिती मागवण्यासाठी अर्ज भरा\nतुमची माहिती सुरक्षित राहील", hi: "RTI के अंतर्गत जानकारी प्राप्त करने के लिए आवेदन करें\nआपकी जानकारी सुरक्षित रहेगी", en: "Apply for information under RTI\nKeep your information secure" } },
                    { endpoint: "/new-application-form", title: t("navbar.top.citizenServiceApplication"), icon: "fa-file-circle-plus", desc: { mr: "नागरिक सेवा अर्ज सादर करा\nसर्व सुविधा मिळवण्यासाठी", hi: "नागरिक सेवा आवेदन जमा करें\nसभी सुविधाओं के लिए", en: "Submit citizen service application\nGet access to all services" } },
                    { endpoint: "/complaints/form", title: t("navbar.top.complaintRegistration"), icon: "fa-circle-exclamation", desc: { mr: "तक्रारी नोंदवा\nवेगवान उत्तर मिळवा", hi: "शिकायत दर्ज करें\nत्वरित प्रतिक्रिया प्राप्त करें", en: "Register your complaints\nReceive faster responses" } },
                    { endpoint: "/gp-applications/f8-ferfar/register", title: t("navbar.top.propertyMutationApplication"), icon: "fa-building", desc: { mr: "संपत्ती हस्तांतरण अर्ज भरा\nसोपी मार्गदर्शन मिळवा", hi: "संपत्ति परिवर्तन आवेदन करें\nसरल मार्गदर्शन प्राप्त करें", en: "Apply for property mutation\nGet simple guidance" } },
                    { endpoint: "/gp-applications/construction/form", title: t("navbar.top.constructionApplication"), icon: "fa-person-digging", desc: { mr: "बांधकाम परवानगी अर्ज करा\nसर्व नियम पाळा", hi: "निर्माण अनुमति आवेदन करें\nसभी नियमों का पालन करें", en: "Apply for construction permission\nFollow all rules" } },
                    { endpoint: "/gp-applications/job-card/form", title: t("navbar.top.jobCardApplication"), icon: "fa-id-card", desc: { mr: "जॉब कार्ड अर्ज भरा\nरोजगार संधी मिळवा", hi: "जॉब कार्ड आवेदन करें\nरोजगार के अवसर प्राप्त करें", en: "Apply for job card\nGet employment opportunities" } },
                    { endpoint: "/gp-applications/emp-demand/form", title: t("navbar.top.employmentGuaranteeApplication"), icon: "fa-briefcase", desc: { mr: "रोजगार हमी अर्ज करा\nअर्ज प्रक्रिया सोपी", hi: "रोजगार गारंटी आवेदन करें\nआवेदन प्रक्रिया सरल है", en: "Apply for employment guarantee\nEasy application process" } },
                    { endpoint: "https://play.google.com/store/apps/details?id=com.meri_panchayat", title: t("navbar.top.myPanchayat"), icon: "fa-landmark", desc: { mr: "माझी पंचायत अँप डाउनलोड करा\nसर्व माहिती एका ठिकाणी", hi: "माय पंचायत ऐप डाउनलोड करें\nसारी जानकारी एक जगह पर", en: "Download My Panchayat app\nAll info in one place" } },
                    { endpoint: "https://play.google.com/store/apps/details?id=com.gsnirnay.app&pli=1", title: t("navbar.top.panchayatDecisionApp"), icon: "fa-gavel", desc: { mr: "पंचायत निर्णय पहा\nसुलभ मार्गदर्शन मिळवा", hi: "पंचायत निर्णय देखें\nसहज मार्गदर्शन प्राप्त करें", en: "View panchayat decisions\nGet easy guidance" } },
                    { endpoint: "https://play.google.com/store/apps/details?id=com.nic.gramsamvaad", title: t("navbar.top.gramSamvad"), icon: "fa-comments", desc: { mr: "ग्रामीण संवाद अँप वापरा\nसंपूर्ण समुदायासाठी", hi: "ग्रामीण संवाद ऐप इस्तेमाल करें\nपूरा समुदाय जुड़ा रहे", en: "Use Gram Samvad app\nConnect the whole community" } },
                    { endpoint: "https://gr.maharashtra.gov.in/1125/Home", title: { mr: "शासन निर्णय", hi: "सरकारी निर्णय", en: "Government Resolutions" }[language], icon: "fa-gavel", desc: { mr: "सरकारी निर्णय पहा\nमहत्त्वाची माहिती मिळवा", hi: "सरकारी निर्णय देखें\nमहत्वपूर्ण जानकारी प्राप्त करें", en: "View government resolutions\nGet important information" } },
                    { endpoint: "/gp-applications/to-seva/form", title: "नागरिकांना सेवा सुविधा अर्ज", icon: "fa-file-lines", desc: { mr: "सेवा सुविधा अर्ज भरा\nसर्व सुविधा मिळवा", hi: "सेवा सुविधा आवेदन करें\nसभी सेवाएं प्राप्त करें", en: "Apply for citizen service facilities\nAccess all available services" } },

                    //- { endpoint: "/village/vaidyakiy-madat-kaksha-view", title: { original: t("navbar.bottom.medicalHelpDesk")}, desc: {
                    //-         mr: "वैद्यकीय मदत कक्षाशी संपर्क साधा\nतुमच्या आरोग्याच्या त्वरित मदतीसाठी",
                    //-         hi: "मेडिकल हेल्प डेस्क से संपर्क करें\nआपकी स्वास्थ्य के लिए त्वरित सहायता के लिए",
                    //-         en: "Contact the Medical Help Desk\nFor immediate assistance with your health needs"
                    //-     }
                    //- }
                    { endpoint: "/village/vaidyakiy-madat-kaksha-view", title: t("navbar.bottom.medicalHelpDesk"), icon: "fa-notes-medical", desc: { mr: "वैद्यकीय मदत कक्षाशी संपर्क साधा\nतुमच्या आरोग्याच्या त्वरित मदतीसाठी", hi: "मेडिकल हेल्प डेस्क से संपर्क करें\nआपकी स्वास्थ्य के लिए त्वरित सहायता के लिए", en: "Contact the Medical Help Desk\nFor immediate assistance with your health needs" } }
                ]



            .container

                //- Heading (same visual weight as emergency section)
                h4(class='text-center text-xl md:text-3xl font-bold tracking-wider w-fit mx-auto px-8 pb-2 border-b-2 mb-8')
                    i.fa-solid.fa-qrcode
                    span.ml-2 DOWNLOAD QR CODES


                div(class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-6')
                    each btn, _index in qrButtons
                        div(class='qr-card bg-white border p-4 rounded-lg shadow-sm hover:shadow-md transition-all flex flex-row')

                            // QR Code Container
                            div(class='w-24 flex-shrink-0')
                                div(id=`download-qr-${_index}` class='qr-box' data-endpoint=btn.endpoint )

                            // Text & Description
                            div(class='flex-grow px-3 flex flex-col justify-between')

                                // Title and Description
                                div
                                    a(href=btn.endpoint target='_blank' class='text-blue-700 font-bold hover:underline block text-lg') #{btn.title}
                                    p(class='text-gray-600 text-sm mt-1 mb-2 line-clamp-2') #{btn.desc[language]}

                                // Download Button
                                div(class='flex justify-end')
                                    button(type='button' class='download-qr-btn text-sm px-3 py-1 bg-emerald-500 text-white rounded hover:bg-emerald-600 flex items-center' data-target=`download-qr-${_index}`)
                                        i(class='fa-solid fa-download mr-1')
                                        | Download QR

    section

        div(class='py-8 bg-slate-100 border-t border-slate-300')
            .container

                //- Heading (same visual weight as before)
                h4(class='text-center text-xl md:text-3xl font-bold tracking-wider w-fit mx-auto px-8 pb-2 border-b-2 mb-8')
                    i.fa-solid.fa-qrcode
                    span.ml-2 DOWNLOAD SERVICE PORTALS

                -
                    const serviceLinks = [
                        {
                            endpoint: "https://aaplesarkar.mahaonline.gov.in/",
                            title: {
                                mr: "आरटीएस सेवांसाठी नागरिक लॉगिन",
                                hi: "आरटीएस सेवाओं के लिए नागरिक लॉगिन",
                                en: "Citizen Login for RTS Services"
                            },
                            desc: {
                                mr: "स्वतः चे नागरिक लॉगिन तयार करा आणि नागरी सेवा अधिकार कायदा महाराष्ट्र २०१५ च्या अंतर्गत सुचित सरकारी सेवेसाठी 'आपले सरकार' पोर्टलवर ऑनलाईन अर्ज करा.",
                                hi: "अपना नागरिक लॉगिन बनाएं और महाराष्ट्र लोक सेवा अधिकार अधिनियम 2015 के अंतर्गत अधिसूचित सरकारी सेवाओं के लिए 'आपले सरकार' पोर्टल पर ऑनलाइन आवेदन करें।",
                                en: "Create your citizen login and apply online for notified government services under the Maharashtra Right to Public Services Act, 2015 through the Aaple Sarkar portal."
                            }
                        },
                        {
                            endpoint: "https://rdd.maharashtra.gov.in/en/",
                            title: {
                                mr: "शासकीय विभाग",
                                hi: "सरकारी विभाग",
                                en: "Government Departments"
                            },
                            desc: {
                                mr: "महाऑनलाईन पोर्टलचा वापर करणाऱ्या शासकीय विभागांनी सर्व्हिस डिलिव्हरीसाठी येथे लॉगिन करा.",
                                hi: "महाऑनलाइन पोर्टल का उपयोग करने वाले सरकारी विभाग सेवा वितरण के लिए यहां लॉगिन करें।",
                                en: "Government departments using the MahaOnline portal can log in here for service delivery and application management."
                            }
                        },
                        {
                            endpoint: "https://aaplesarkar.mahaonline.gov.in/",
                            title: {
                                mr: "आपले सरकार सेवा केंद्र / सेतू केंद्र",
