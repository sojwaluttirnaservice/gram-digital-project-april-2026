                            endpoint: "https://mahammb.maharashtra.gov.in/",
                            title: {
                                mr: "महाराष्ट्र सागरी मंडळ",
                                hi: "महाराष्ट्र समुद्री मंडल",
                                en: "Maharashtra Maritime Board"
                            },
                            desc: {
                                mr: "महाराष्ट्र सागरी मंडळाच्या फेरी सेवांसाठी ऑनलाईन तिकीट बुकिंग करण्यासाठी अधिकृत पोर्टल.",
                                hi: "महाराष्ट्र सागरी मंडल की फेरी सेवाओं के लिए ऑनलाइन टिकट बुकिंग हेतु आधिकारिक पोर्टल।",
                                en: "Official portal for online ferry ticket booking services operated by the Maharashtra Maritime Board."
                            }
                        },
                        {
                            endpoint: "https://aaplesarkar.mahaonline.gov.in/",
                            title: {
                                mr: "प्रमाणित प्रमाणपत्र सत्यापित करा",
                                hi: "प्रमाणित प्रमाणपत्र सत्यापित करें",
                                en: "Verify Issued Certificates"
                            },
                            desc: {
                                mr: "आपले सरकार पोर्टलवरून जारी करण्यात आलेल्या प्रमाणपत्रांची ऑनलाईन सत्यता तपासण्यासाठी सुविधा.",
                                hi: "आपले सरकार पोर्टल के माध्यम से जारी प्रमाणपत्रों की ऑनलाइन सत्यापन सुविधा।",
                                en: "Facility to verify the authenticity of certificates issued through the Aaple Sarkar portal."
                            }
                        },
                        {
                            endpoint: "https://aaplesarkar.mahaonline.gov.in/",
                            title: {
                                mr: "आपला अर्ज ट्रॅक करा",
                                hi: "अपने आवेदन को ट्रैक करें",
                                en: "Track Your Application"
                            },
                            desc: {
                                mr: "आपले सरकार पोर्टलवर सादर केलेल्या अर्जाची सद्यस्थिती ऑनलाईन ट्रॅक करा.",
                                hi: "आपले सरकार पोर्टल पर जमा किए गए आवेदन की वर्तमान स्थिति ऑनलाइन ट्रैक करें।",
                                en: "Track the current status of applications submitted through the Aaple Sarkar portal."
                            }
                        },
                    ];



                //- Grid of QR Cards
                div(class='grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-4 gap-y-6')
                    each link, _index in serviceLinks
                        div(class='qr-card bg-white border p-4 rounded-lg shadow-sm hover:shadow-md transition-all flex flex-row')

                            // QR Code Container
                            div(class='w-24 flex-shrink-0')
                                div(id=`service-qr-${_index}` class='qr-box' data-endpoint=link.endpoint )

                            // Text & Description
                            div(class='flex-grow px-3 flex flex-col justify-between')
