body  

    //- if we dont send the key isMasterPanel from backend, then it might be master panel view, if sent check if its true, if not then go in else
    if (typeof isMasterPanel == 'undefined' || isMasterPanel)
        .row
            .col-12 
                .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
                    a.navbar-brand(href="/master") Master Panel
    else
        include ../user/include/navs.pug
