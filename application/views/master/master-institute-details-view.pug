body


	- let isMasterView = (typeof isMasterPanel == 'undefined' || isMasterPanel) 

	if isMasterView
		.nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
			a.navbar-brand(href="/master") Master Panel
	else
		include ../user/include/navs.pug

	.container
		.row(style='margin-top: 6rem;')
			.col-12
				.text-end
					button.btn.btn-success(id='add-institute-staff-btn' type='button' data-id=instituteDetails.id data-instituteImage=instituteDetails.institute_image)
						i.fa.fa-plus &nbsp; Add Staff
			.col-12 
				h2.fw-semibold.mt-2.mb-5.text-center.text-uppercase #{instituteDetails.institute_name} Staff Members
				div.text-end.mb-3
					a.btn.btn-primary.float-right.me-4(href='javascript:history.back()') Go Back
			//- .col-12
			//- 	- let path = `/new-gp-page/main-page/files/education-institute-files/${instituteDetails.institute_image}`
			//- 	img.d-block.mx-auto.w-75(src=path class='img-fluid' style='height: 22rem; overflow: hidden')

			.col-12

				//- h4.my-4.text-center.fw-bold Staff Members 

				if instituteStaff.length > 0
					.row.mb-5.gx-3.gy-3.mt-1.justify-content-center.justify-content-md-start
						each staffMember in instituteStaff 
							.col-11.col-sm-6.col-md-4.col-lg-3
								.card
									- let path = `/new-gp-page/main-page/files/education-institute-files/${staffMember.staff_photo}`
									img.card-img-top(src=path, alt=`${staffMember.staff_name}` style='height:8rem')
									.card-body
										h5.card-title.text-center #{staffMember.staff_name}
										div.text-center(style='font-size: 0.8rem') (#{staffMember.staff_designation})
									.card-footer 
										.d-flex.justify-content-center 
											button.btn.text-success(class='edit-institute-staff-btn' type='button' data-id=staffMember.id)
												i.fa.fa-edit
											button.btn.text-danger(class='delete-institute-staff-btn' type='button' data-id=staffMember.id data-staffPhoto=staffMember.staff_photo)
												i.fa.fa-trash

		.modal.fade(tabindex="-1" aria-labelledby="" aria-hidden="true" id ='upload-education-institute-details-modal' )
			.modal-dialog(style='min-width:50% !important;')
				.modal-content.p-2
					.modal-header.bg-warning माहिती भरा 
						h1.modal-title.fs-5() 
						button.btn-close(type="button" data-bs-dismiss="modal" aria-label="Close")
					.modal-body

						form#upload-education-institute-details
							.row.gy-3
								.col-12
									label(for="staff-name") Staff name
									input.form-control(type='text' id="staff-name")


								.col-12 
									label(for="staff-designation") Designation
									input.form-control(type='text' id="staff-designation")

								.col-12
									label(for="staff-photo") Staff photo
									input.form-control(type='file' id="staff-photo")

								.col-12
									label(for="staff-mobile-no") Mobile No 
									input.form-control(type='text' id="staff-mobile-no" maxlength='10')

								//- div
								//- 	label(for="institute-photo") Designation
								//- 	select.form-control#institute-type
								//- 		option(value='-1') -- Type --
								//- 		option(value='1') Principal 
								//- 		option(value='2')  
								//- 		option(value='3') कॉलेज
								.col-12.text-center
									button.btn.btn-primary.mt-3(type='button' id="upload-staff-details" ) जतन करा					   
