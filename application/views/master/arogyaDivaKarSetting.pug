body
    .container
      .row
        .col-12.mb-5 
          .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
              a.navbar-brand(href="/master") Master Panel
        .col-12.mt-5
          h4 आरोग्य आणि दिवाबत्ती कर सुधारणा 
        .col-12
          form#arogyaDivaKarSettingForm   
            each el, i in akdDetails
              .row.mb-3.justify-content-between(style='row-gap: 1rem;')
                .col-6.col-md-2
                  label(for="adkMin") चौ फूट (पासून)
                  input(type="text" class='form-control' value=el.adk_min disabled) 
                .col-6.col-md-2 
                  label(for="adkMax") चौ फूट (ते)
                  input(type='text' class='form-control' value=el.adk_max disabled)
                .col-4.col-md-1 
                  label(for='adkArogya') आरोग्य 
                  input(type='text' id=`adkArogya${i+1}` name='adkArogya' class='form-control required' value=el.adk_arogya)
                .col-4.col-md-1 
                  label(for='adkDiva') दिवाबत्ती 
                  input(type='text' id=`adkDiva${i+1}` name='adkDiva' class='form-control' value=el.adk_diva)

                .col-4.col-md-1
                  label(for='cleaningTax') स्वच्छता 
                  input(type='text' id=`cleaningTax${i+1}` name='cleaningTax' class='form-control required' value=el.cleaning_tax)

                .col-4.col-md-1 
                  label(for='treeTax') वृक्ष
                  input(type='text' id=`treeTax${i+1}` name='treeTax' class='form-control required' value=el.tree_tax)

                .col-4.col-md-1 
                  label(for='fireblegateTax') अग्नी 
                  input(type='text' id=`fireblegateTax${i+1}` name='fireblegateTax' class='form-control required' value=el.firebligate_tax)

                .col-4.col-md-1 
                  label(for='educationTax') शिक्षण 
                  input(type='text' id=`educationTax${i+1}` name='educationTax' class='form-control required' value=el.education_tax)

            .col-12.mt-5.d-flex.justify-content-center
              button.btn.btn-primary#submitAdkForm जतन करा 

            