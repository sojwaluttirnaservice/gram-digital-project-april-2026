body
  .container-fluid
    .row
      .col-12 
        .nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.fixed-top
          a.navbar-brand(href="/master") Master Panel
    .row.mt-5.justify-content-center
      .col-12.mt-3
        h1.ml-5.text-center.mr-5 9 Backup  
      .col-12.col-sm-8.col-md-4.mt-4
        table.table.table-bordered
          thead 
            tr
              th नवीन सुरु वर्ष
              th
                input(class="form-control" value=gp_working_from+1 readonly id="s_name")
            tr
              th नवीन समाप्ती वर्ष
              th 
                input(class="form-control" value=gp_working_to+1 readonly id="e_name")
            tr 
              th backup घ्या 
              th
                input(class="form-control" type="password" id="b" placeholder="backup password")
            tr
              th(colspan="2")
                center
                  button.btn.btn-outline-success.btn-sm#takeBackup Backup घ्या
    script.
      $(function(){
        takeBackup
          $('#takeBackup').on('click',function(){
            if($('#b').val() === 'chandresh@123'){
              $.ajax({
                url:'/master/update-backup-nine',
                type:'post',
                data:{id:0}
              }).done(function(data){
                window.location.assign(`/master/backup-nine?s_name=${$('#s_name').val()}&e_name=${$('#e_name').val()}`)
              }).fail(function(error){
                console.log(error)
                alert('server error')
              })

            }else{
              alert('password is wrong.')
            }
          })
      })






